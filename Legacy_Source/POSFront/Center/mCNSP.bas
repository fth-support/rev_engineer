Public Function SP_NETbCheckPort() As Boolean
'--------------------------------------------------------------------------
'Call:
'Cmt: Check NETS port '*Eaw 56-06-17
'--------------------------------------------------------------------------
Dim tSql As String
Dim orsTemp As ADODB.Recordset

On Error GoTo ErrHandler
    bVB_CNNETPos = False
    tSql = "SELECT FTTmnMsr,FTTmnMsrPort"
    tSql = tSql & vbCrLf & "FROM TCNMTerminalMtn"
    tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        If SP_FEDtChkString(orsTemp, "FTTmnMsr") = "1" Then
            bVB_CNNETPos = True
            nVB_NETPort = SP_VALcText2Double(SP_FEDtChkString(orsTemp, "FTTmnMsrPort")) - 1
        Else
            bVB_CNNETPos = False
        End If
    Else
        bVB_CNNETPos = False
    End If
    SP_NETbCheckPort = bVB_CNNETPos
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandler:
    SP_NETbCheckPort = False
End Function

Public Function SP_RNDnAmount(ByVal pcAmount As Double) As Double
'-----------------------------------------------------------
'   Parameter :
'   Cmt :
'   File Refer :*BG 56-07-10 แก้ให้ส่งค่ากลับเป็น Double
'   Developer : PATCHARIN
'   Date Create : 23/05/2013 :  14:12:34
'-----------------------------------------------------------
    Dim aRnd2Point() As String
    On Error GoTo ErrHandle
        If InStr(CStr(pcAmount), ".", vbBinaryCompare) = 0 Then
            aRnd2Point() = Split(pcAmount, ".")
            SP_RNDnAmount = CDbl(aRnd2Point(0))
        Else
            SP_RNDnAmount = pcAmount
        End If
        Exit Function
ErrHandle:
        SP_RNDnAmount = pcAmount
End Function

Public Sub SP_PRNxUpdLogo(ByVal ptImage As String, ByVal ptRjfCode As String)
'-------------------------------------------------------------------------------------------------------------------------
'   Call:
'   Cmt:    '*Ao 2013/03/06
'-------------------------------------------------------------------------------------------------------------------------
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim oStream As ADODB.Stream

On Error GoTo ErrHandler
    If ptImage <> "" Then
        
        If Not orsTemp Is Nothing Then
            If orsTemp.State = adStateOpen Then orsTemp.Close
        End If
        Set orsTemp = New ADODB.Recordset
        tSql = "SELECT * FROM TCNMReceiptJN"
        tSql = tSql & vbCrLf & "WHERE FTRjfCode = '" & ptRjfCode & "'"
        orsTemp.Open tSql, oDB.ocnOffLine, adOpenKeyset, adLockOptimistic

'        Do While Not orsTemp.EOF
'            orsTemp.Fields("FORjfLogo").Value = oStream.Read
'            orsTemp.Update
'            orsTemp.MoveNext
'        Loop
        Set oStream = New ADODB.Stream
        oStream.Type = adTypeBinary
        oStream.Open
        oStream.LoadFromFile ptImage
        orsTemp.Fields("FORjfLogo").Value = oStream.Read
        orsTemp.Update
            
        oStream.Close
        Set oStream = Nothing
    End If
    Call SP_DATxRsNothing(orsTemp)
Exit Sub
ErrHandler:
    
End Sub

Public Sub SP_PRNxGetLogo(ByVal ptTmnNum As String, ByVal ptImage As String)
'-------------------------------------------------------------------------------------------------------------------------
'   Call:
'   Cmt:    '*Ao 2013/03/06
'-------------------------------------------------------------------------------------------------------------------------
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim bChk As Boolean
Dim nEff As Long
Dim tRjfCode As String, tLogo As String, tSlpHead As String, tSlpTrail As String, tSlpDisp As String, tRemark As String

On Error GoTo ErrHandler

    If Not (oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)) Then   'OFFLINE
        Exit Sub
    End If
    
    tSql = "SELECT TCNMReceiptJN.* FROM TCNMReceiptJN"
    tSql = tSql & vbCrLf & "INNER JOIN TCNMTerminalMtn"
    tSql = tSql & vbCrLf & "ON TCNMReceiptJN.FTRjfCode = TCNMTerminalMtn.FTRjfCode"
    tSql = tSql & vbCrLf & "WHERE TCNMTerminalMtn.FTTmnNum = '" & ptTmnNum & "'"
    Call SP_SQLbExecute(tSql, orsTemp)
    If (orsTemp.BOF And orsTemp.EOF) Then
        bChk = False
        tRjfCode = ""
    Else
        bChk = True
        tRjfCode = SP_FEDtChkString(orsTemp, "FTRjfCode")
    End If
    
    If bChk Then
        Call SP_PRNxUpdLogo(ptImage, tRjfCode)
    Else
        If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
            tSql = "SELECT FTRjfCode FROM dbo.TCNMTerminalMtn"
            tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & ptTmnNum & "'"
            Call SP_SQLbExecute(tSql, orsTemp)
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                tRjfCode = SP_FEDtChkString(orsTemp, "FTRjfCode")
                tSql = "SELECT * FROM TCNMReceiptJN"
                tSql = tSql & vbCrLf & "WHERE FTRjfCode = '" & tRjfCode & "'"
                Call SP_SQLbExecute(tSql, orsTemp, , , , oDB.ocnOnLine, True, True)
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    tRjfCode = SP_FEDtChkString(orsTemp, "FTRjfCode")
                    tLogo = SP_FEDtChkString(orsTemp, "FTRjfLogo")
                    tSlpHead = SP_FEDtChkString(orsTemp, "FTRjfSlpHead")
                    tSlpTrail = SP_FEDtChkString(orsTemp, "FTRjfSlpTrail")
                    tSlpDisp = SP_FEDtChkString(orsTemp, "FTRjfSlpDisp")
                    tRemark = "INSERT"
                    tSql = "INSERT INTO TCNMReceiptJN(FTRjfCode,FTRjfLogo,FTRjfSlpHead,FTRjfSlpTrail,FTRjfSlpDisp,FTRemark," & tCS_CNLastFedIns
                    tSql = tSql & vbCrLf & "VALUES ('" & tRjfCode & "','" & tLogo & "','" & tSlpHead & "'"
                    tSql = tSql & vbCrLf & ",'" & tSlpTrail & "','" & tSlpDisp & "','" & tRemark & "'"
                    tSql = tSql & vbCrLf & "," & UT_tLastInsSql & ")"
                    Call SP_SQLbExecute(tSql, , , nEff)
                    If nEff > 0 Then
                        Call SP_PRNxUpdLogo(ptImage, tRjfCode)
                    End If
                End If
            End If
        End If
    End If
    
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandler:

End Sub

Public Function SP_PRNtSalesManID(ByVal ptSalesManID As String) As String
'-------------------------------------------------------------------------------------------------------------------------
'   Call:
'   Cmt:    '*Ao 2013/03/06
'-------------------------------------------------------------------------------------------------------------------------
Dim tSalesManID As String

On Error GoTo ErrHandler

    Select Case Len(ptSalesManID)
        Case 1 To 5
            tSalesManID = ptSalesManID
        Case 6 To 10
            tSalesManID = Left(ptSalesManID, 5) & "/" & Right(ptSalesManID, Len(ptSalesManID) - 5)
        Case 11 To 15
            tSalesManID = Left(ptSalesManID, 5) & "/" & Mid(ptSalesManID, 6, 5) & "/" & Right(ptSalesManID, Len(ptSalesManID) - 10)
        Case 16 To 20
            tSalesManID = Left(ptSalesManID, 5) & "/" & Mid(ptSalesManID, 6, 5) & "/" & Mid(ptSalesManID, 11, 5) & "/" & Right(ptSalesManID, Len(ptSalesManID) - 15)
        Case Else
            tSalesManID = ptSalesManID
    End Select
    
    SP_PRNtSalesManID = tSalesManID
    Exit Function
ErrHandler:
    SP_PRNtSalesManID = ptSalesManID
End Function

