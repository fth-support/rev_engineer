                Case UCase("FTShdOptAlw"): tSqlV = tSqlV & "'" & tOptAlw & "',"
                Case UCase("FTEmpOverideCode"):  tSqlV = tSqlV & "'" & IIf(tVB_CNUserAlwC = tVB_CNUserCode Or tVB_CNUserAlwC = "", "", tVB_CNUserAlwC) & "',"
