        tSql = "STP_CNxGETDeptBrdAlwORNotAlwCrd @ptTdmCode = '',@ptCrdType = '',@ptType = ''"
        If bOnOffCur Then Call SP_SQLvExecute(tSql, , .ocnOnLine) 'Online
        Call SP_SQLvExecute(tSql, , .ocnOffLine)  'OffLine
        tSql = "STP_CNxGETSKUCodeAlwORNotAlwMall @ptCrdType = '',@ptType = ''"
        If bOnOffCur Then Call SP_SQLvExecute(tSql, , .ocnOnLine) 'Online
        Call SP_SQLvExecute(tSql, , .ocnOffLine)  'OffLine
        tSql = "STP_CNxGETDeptBrdAlwORNotAlwMall @ptCrdType = '',@ptType = ''"
        If bOnOffCur Then Call SP_SQLvExecute(tSql, , .ocnOnLine) 'Online
        Call SP_SQLvExecute(tSql, , .ocnOffLine)  'OffLine
        tSql = "STP_CNxGetMaxQtyPromoTimePre @ptTransDate='" & tUT_SaleDate & "',@ptSKUCode='" & "" & "'"
        If bOnOffCur Then Call SP_SQLvExecute(tSql, , .ocnOnLine) 'Online
        Call SP_SQLvExecute(tSql, , .ocnOffLine)  'OffLine
        tSql = "STP_CNxGetMaxQtyPromoPre @ptTransDate='" & tUT_SaleDate & "',@ptSKUCode='" & "" & "'"
        If bOnOffCur Then Call SP_SQLvExecute(tSql, , .ocnOnLine) 'Online
        Call SP_SQLvExecute(tSql, , .ocnOffLine)  'OffLine
    End With
    Exit Sub
ErrHandle:
    
End Sub


Public Sub SP_PRCbVerifyPointSKU(ByVal ptMcdCode As String, ByVal porsTemp As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, ByRef porsTarget2 As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double)
'--------------------------------------------------------
'Ret:
'Cmt: *KT 52-02-24 Allow/Not Allow SKU.Code
'porsTarget : สำหรับนำไปใช้สำหรับข้อมูลตั้งต้นของการคิด SP_PRCbVerifyPointDpt
'porsTarget2 : สำหรับนำไปใช้สำหรับข้อมูลตั้งต้นของการคิด SP_PRCbVerifyPointMall
'-------------------------------------------------------
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
    Dim tSKUCode As String
    Dim orsTemp As ADODB.Recordset
    Dim orsSource As ADODB.Recordset
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nI As Long
    Dim cTemp As Double
On Error GoTo ErrHandle

    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    Set orsSource = porsTemp.Clone
    Set porsTarget = New ADODB.Recordset
    Set porsTarget2 = New ADODB.Recordset
    For nI = 1 To orsSource.Fields.Count
        Call porsTarget.Fields.Append(orsSource.Fields(nI - 1).Name, orsSource.Fields(nI - 1).Type, orsSource.Fields(nI - 1).DefinedSize)
        Call porsTarget2.Fields.Append(orsSource.Fields(nI - 1).Name, orsSource.Fields(nI - 1).Type, orsSource.Fields(nI - 1).DefinedSize)
    Next nI
    porsTarget.CursorType = adOpenStatic
    porsTarget2.CursorType = adOpenStatic
    porsTarget.Open
    porsTarget2.Open
    
    ReDim aW_PointSKU(0) As POINTSKU
    aW_PointSKU(0).tSKUCode = ""
    aW_PointSKU(0).cPoint = 0
    aW_PointSKU(0).cRank = 0
    aW_PointSKU(0).cAmt = 0
    aW_PointSKU(0).cMin = 0
    aW_PointSKU(0).cMax = 0
    
    Do While Not orsSource.EOF
        tSKUCode = Trim(SP_FEDtChkString(orsSource, "FTSKUCode"))
        cSaleAmt = SP_FEDvChkNumeric(orsSource, "FCSdtSaleAmt")
        If SP_FEDtChkString(orsSource, "FTSkuStaMallEmpCard") = "Y" Then
            cBlue = cSaleAmt
            cYellow = 0
        Else
            cBlue = 0
            cYellow = cSaleAmt
        End If
        
         tSql = "SELECT FTMcsAlw ,FCMcsAmtPoint ,FCMcsAmtRank ,FCMcsAmtMin,FCMcsAmtMax"
         tSql = tSql & vbCrLf & ",FDMcsStartDate,FDMcsEndDate"
         tSql = tSql & vbCrLf & " FROM TCNMMallCardSKU"
         tSql = tSql & vbCrLf & " WHERE FTSkuCode = '" & tSKUCode & "'"
         tSql = tSql & vbCrLf & " AND FTMcdCode = '" & ptMcdCode & "'"
         tSql = tSql & vbCrLf & " AND FTMcsAlwPoint = '1'"
         tSql = tSql & vbCrLf & " ORDER BY  FTMcsAlw  DESC"
         Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
         If Not (orsTemp.BOF Or orsTemp.EOF) Then
                orsTemp.Filter = "FTMcsAlw = '1'" 'SKU Not Allow
                If Not (orsTemp.BOF Or orsTemp.EOF) Then
                    If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDMcsStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDMcsEndDate"), "YYYY/MM/DD") Then
                        'none ไม่เก็บเข้า porsTarget และ porsTarget2
                    Else
                        'เก็บเข้า porsTarget
                        porsTarget.AddNew
                        For nI = 1 To orsSource.Fields.Count
                            Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                                Case "T"
                                    porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                                Case "C"
                                    porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                Case "N"
                                    porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                Case "D"
                                    If IsNull(orsSource.Fields(nI - 1).Value) Then
                                        porsTarget.Fields(nI - 1).Value = "Null"
                                    Else
                                       porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                                    End If
                            End Select
                        Next nI
                    End If
                Else
                     bPass = False
                     orsTemp.Filter = adFilterNone
                     orsTemp.Filter = "FTMcsAlw = '0'" 'SKU  Allow
                     If Not (orsTemp.BOF Or orsTemp.EOF) Then
                        'เข้าเงื่อนไขการได้ Allow SKU
                        If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDMcsStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDMcsEndDate"), "YYYY/MM/DD") Then
                                'ไม่เก็บเข้า porsTarget เพราะได้แต้มใน Allow SKU ไม่ให้ Allow Dept.Code/Brand.Code
                                bPass = True
                                For nI = 0 To UBound(aW_PointSKU)
                                    If aW_PointSKU(nI).tSKUCode = tSKUCode Then
                                        aW_PointSKU(nI).cAmt = aW_PointSKU(nI).cAmt + cBlue + cYellow
                                        bPass = False
                                        Exit For
                                    End If
                                Next nI
                                If bPass Then
                                    nI = UBound(aW_PointSKU)
                                    aW_PointSKU(nI).tSKUCode = tSKUCode
                                    aW_PointSKU(nI).cPoint = SP_FEDvChkNumeric(orsTemp, "FCMcsAmtPoint")
                                    aW_PointSKU(nI).cRank = SP_FEDvChkNumeric(orsTemp, "FCMcsAmtRank")
                                    aW_PointSKU(nI).cAmt = cBlue + cYellow
                                    aW_PointSKU(nI).cMin = SP_FEDvChkNumeric(orsTemp, "FCMcsAmtMin")
                                    aW_PointSKU(nI).cMax = SP_FEDvChkNumeric(orsTemp, "FCMcsAmtMax")
                                End If
                                If bPass Then ReDim Preserve aW_PointSKU(UBound(aW_PointSKU) + 1) As POINTSKU
                        Else
                                'เก็บเข้า porsTarget เพื่อนำไปทำที่ Allow Dept.Code/Brand.Code ต่อไปเพราะในส่วน Allow SKU ไม่ผ่านเงื่อนไข ExpireDate
                                porsTarget.AddNew
                                For nI = 1 To orsSource.Fields.Count
                                    Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                                        Case "T"
                                            porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                                        Case "C"
                                            porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                        Case "N"
                                            porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                        Case "D"
                                            If IsNull(orsSource.Fields(nI - 1).Value) Then
                                                porsTarget.Fields(nI - 1).Value = "Null"
                                            Else
                                               porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                                            End If
                                    End Select
                                Next nI
                        End If
                     End If
                    'เก็บเข้า porsTarget2 สำหรับใช้กับ Genneral ไม่จำเป็นต้องตรวจสอบเงื่อนไขวันที่ ExpireDate ของ Allow SKU นั้น
                    porsTarget2.AddNew
                    For nI = 1 To orsSource.Fields.Count
                        Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                            Case "T"
                                porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                            Case "C"
                                porsTarget2.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                            Case "N"
                                porsTarget2.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                            Case "D"
                                If IsNull(orsSource.Fields(nI - 1).Value) Then
                                    porsTarget2.Fields(nI - 1).Value = "Null"
                                Else
                                   porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                                End If
                            End Select
                    Next nI
                End If
          Else
                'เก็บเข้า porsTarget พื่อนำไปทำที่ Allow Dept.Code/Brand.Code ต่อไปเพราะในส่วน Allow SKU ไม่มี SKU Code นี้
                porsTarget.AddNew
                For nI = 1 To orsSource.Fields.Count
                    Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                        Case "T"
                            porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                        Case "C"
                            porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "N"
                            porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "D"
                            If IsNull(orsSource.Fields(nI - 1).Value) Then
                                porsTarget.Fields(nI - 1).Value = "Null"
                            Else
                               porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                            End If
                    End Select
                Next nI
                
                'เก็บเข้า porsTarget2 สำหรับใช้กับ Genneral เพราะในส่วน Allow SKU ไม่มี SKU Code นี้ แต่ยังมีโอกาศที่จะเข้าส่วนของ Allow Dept.Code/Brand.Code อยู่
                porsTarget2.AddNew
                For nI = 1 To orsSource.Fields.Count
                    Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                        Case "T"
                            porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                        Case "C"
                            porsTarget2.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "N"
                            porsTarget2.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "D"
                            If IsNull(orsSource.Fields(nI - 1).Value) Then
                                porsTarget2.Fields(nI - 1).Value = "Null"
                            Else
                               porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                            End If
                        End Select
                Next nI
          End If
           orsSource.MoveNext
      Loop
      'ขั้นตอนการคำนวนแต้มส่วนของ Allow SKU
      If UBound(aW_PointSKU) = 0 Then
        nMax = 1
     Else
        nMax = UBound(aW_PointSKU)
     End If
     For nI = 0 To nMax - 1
        If aW_PointSKU(nI).tSKUCode <> "" And aW_PointSKU(nI).cRank > 0 Then
            If aW_PointSKU(nI).cAmt > aW_PointSKU(nI).cMax Then
                cTemp = pcPoint + (Int(aW_PointSKU(nI).cMax / aW_PointSKU(nI).cRank) * aW_PointSKU(nI).cPoint)
                pcPoint = pcPoint + cTemp
                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointSKU(nI).cMax
            Else
                cTemp = (Int(aW_PointSKU(nI).cAmt / aW_PointSKU(nI).cRank) * aW_PointSKU(nI).cPoint)
                pcPoint = pcPoint + cTemp
                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointSKU(nI).cAmt
            End If
        End If
     Next nI
     If Not (porsTarget.BOF And porsTarget.EOF) Then porsTarget.MoveFirst
     If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Exit Sub
ErrHandle:

     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
End Sub


Public Sub SP_PRCbVerifyPointDpt(ByVal ptMcdCode As String, ByVal porsTemp As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, ByRef porsTarget2 As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double)
'--------------------------------------------------------
'Ret:
'Cmt: *KT 52-02-24 Allow/Not Allow Dpt.Code OR Brand.Code
'porsTarget2 : สำหรับนำไปใช้สำหรับข้อมูลตั้งต้นของการคิด SP_PRCbVerifyPointMall โดยที่ SKU Code ไหนเข้าเงื่อนไขมีการกำหนด Dpt.Code / Brand.Code ในส่วนของ Allow Dpt.Code / Brand.Code จะทำการ Delete Record ออกจาก
'porsTarget2
'-------------------------------------------------------
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
'    Dim tSKUCode As String
    Dim tDptCode As String
    Dim tBrdCode As String
    Dim cSumSaleAmt As Double
    Dim orsTemp As ADODB.Recordset
    Dim orsSource As ADODB.Recordset
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nI As Long
    Dim tReg As String
    Dim tPro As String
    Dim tDept As String
    Dim tBrand As String
    
On Error GoTo ErrHandle
    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
    Set orsSource = porsTemp.Clone
    ReDim aW_PointDpt(0) As POINTDPT
    aW_PointDpt(0).tDptCode = ""
    aW_PointDpt(0).cPoint = 0
    aW_PointDpt(0).cRank = 0
    aW_PointDpt(0).cAmt = 0
    aW_PointDpt(0).cMin = 0
    aW_PointDpt(0).cMax = 0
    
    Do While Not orsSource.EOF
        'tSKUCode = SP_FEDtChkString(orsSource, "FTSKUCode")
        tDptCode = Trim(SP_FEDtChkString(orsSource, "FTSkuDepCode"))
        tBrdCode = Trim(SP_FEDtChkString(orsSource, "FTSkuBrdCode"))
        
        cSaleAmt = SP_FEDvChkNumeric(orsSource, "FCSdtSaleAmt")
        If SP_FEDtChkString(orsSource, "FTSkuStaMallEmpCard") = "Y" Then
            cBlue = cSaleAmt
            cYellow = 0
        Else
            cBlue = 0
            cYellow = cSaleAmt
        End If
        
        cSumSaleAmt = 0
        porsTemp.Filter = "FTSkuDepCode = '" & tDptCode & "'"
        If Not (porsTemp.BOF Or porsTemp.EOF) Then
            Do While Not porsTemp.EOF
                cSumSaleAmt = cSumSaleAmt + SP_FEDvChkNumeric(porsTemp, "FCSdtSaleAmt")
                porsTemp.MoveNext
            Loop
        End If
        porsTemp.Filter = adFilterNone
        'ทำการค้นหาข้อมูลของ Dept.Code/Brd.Code ของ SKU Code นี้ว่ามีในตาราง TCNMMallCardDep หรือไม่
         tSql = "SELECT FTMpcAlw ,FCMpcAmtPoint ,FCMpcAmtRank,FCMpcAmtMin,FCMpcAmtMax,FTMpcReg,FTMpcPro  "
         tSql = tSql & vbCrLf & ",FDMpcStartDate,FDMpcEndDate,FTMpcCode,FTMpcBrdCode"
         tSql = tSql & vbCrLf & "FROM TCNMMallCardDep"
         tSql = tSql & vbCrLf & "WHERE ((FTMpcCode = '" & tDptCode & "' AND FTMpcBrdCode ='" & tBrdCode & "') OR (FTMpcCode = '" & tDptCode & "' AND FTMpcBrdCode ='' AND ISNULL(FTMpcCode,'') <> '') OR (FTMpcCode = '' AND FTMpcBrdCode ='" & tBrdCode & "' AND ISNULL(FTMpcBrdCode,'')<>'') OR (FTMpcCode = '" & tDptCode & "' AND FTMpcBrdCode = '' AND ISNULL(FTMpcCode,'') <> '' AND '" & tBrdCode & "' <> '') OR (ISNULL(FTMpcBrdCode,'') = '" & tBrdCode & "' AND  ISNULL(FTMpcBrdCode,'') <> ''))"
         tSql = tSql & vbCrLf & " AND FTMcdCode = '" & ptMcdCode & "'"
         tSql = tSql & vbCrLf & " AND FTMpcAlwPoint = '1'"
         tSql = tSql & vbCrLf & " ORDER BY  FTMpcAlw DESC"
         Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
         If Not (orsTemp.BOF Or orsTemp.EOF) Then
                    orsTemp.Filter = "FTMpcAlw = '1'" 'Dept Code/Brand Code Not Allow
                    If Not (orsTemp.BOF Or orsTemp.EOF) Then
                        'มีข้อมูล Dept Code/Brand Code ที่เป็นแบบ Not Allow
                        If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDMpcStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDMpcEndDate"), "YYYY/MM/DD") Then
                             'เข้าเงื่อนไข ExpireDate
                             If cSumSaleAmt >= SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMin") And cSumSaleAmt <= SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMax") Then
                                'เข้าเงื่อนไขของการตรวจสอบ Max , Min
                                tReg = SP_FEDtChkString(orsTemp, "FTMpcReg")
                                tPro = SP_FEDtChkString(orsTemp, "FTMpcPro")
                                tDept = SP_FEDtChkString(orsTemp, "FTMpcCode")
                                tBrand = SP_FEDtChkString(orsTemp, "FTMpcBrdCode")
                                bPass = True
                                For nI = 0 To UBound(aW_PointDpt)
                                    If aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand) Then
                                        If tReg = "Y" And tPro = "Y" Then
                                            aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + 0
                                        ElseIf tReg = "Y" And tPro = "N" Then
                                            aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cYellow '***ต้องให้ราคาป้ายเหลือง เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเงิน ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายเหลือง
                                        ElseIf tReg = "N" And tPro = "Y" Then
                                            aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cBlue '***ต้องให้ราคาป้ายน้ำเงิน เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเหลือง ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายน้ำเงิน
                                        End If
                                        bPass = False
                                        Exit For
                                    End If
                                Next nI
                                If bPass Then
                                    nI = UBound(aW_PointDpt)
                                    aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand)
                                    aW_PointDpt(nI).cPoint = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtPoint")
                                    aW_PointDpt(nI).cRank = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtRank")
                                    If tReg = "Y" And tPro = "Y" Then
                                        aW_PointDpt(nI).cAmt = 0
                                    ElseIf tReg = "Y" And tPro = "N" Then
                                        aW_PointDpt(nI).cAmt = cYellow '***ต้องให้ราคาป้ายเหลือง เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเงิน ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายเหลือง
                                    ElseIf tReg = "N" And tPro = "Y" Then
                                        aW_PointDpt(nI).cAmt = cBlue '***ต้องให้ราคาป้ายน้ำเงิน เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเหลือง ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายน้ำเงิน
                                    End If
                                    aW_PointDpt(nI).cMin = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMin")
                                    aW_PointDpt(nI).cMax = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMax")
                                End If
                                If bPass Then ReDim Preserve aW_PointDpt(UBound(aW_PointDpt) + 1) As POINTDPT
                            End If
                        End If
                        'ทำการลบ Record ที่นำไปคิดของ General(Tier) ของ Mall Card
                        If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
                        Do While Not porsTarget2.EOF
                            If SP_FEDvChkNumeric(porsTarget2, "FNSdtSeqNo") = SP_FEDvChkNumeric(orsSource, "FNSdtSeqNo") Then
                                porsTarget2.Delete
                                Exit Do
                            End If
                            porsTarget2.MoveNext
                        Loop
                    Else
                        orsTemp.Filter = adFilterNone
                        orsTemp.Filter = "FTMpcAlw = '0'" 'Dept Code/Brand Code  Allow
                        If Not (orsTemp.BOF Or orsTemp.EOF) Then
                            If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDMpcStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDMpcEndDate"), "YYYY/MM/DD") Then
                                 If cSumSaleAmt >= SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMin") And cSumSaleAmt <= SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMax") Then
                                        tReg = SP_FEDtChkString(orsTemp, "FTMpcReg")
                                        tPro = SP_FEDtChkString(orsTemp, "FTMpcPro")
                                        bPass = True
                                        For nI = 0 To UBound(aW_PointDpt)
                                            If aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand) Then
                                                If tReg = "Y" And tPro = "Y" Then
                                                    aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cBlue + cYellow
                                                ElseIf tReg = "Y" And tPro = "N" Then
                                                    aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cBlue
                                                ElseIf tReg = "N" And tPro = "Y" Then
                                                    aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cYellow
                                                End If
                                                bPass = False
                                                Exit For
                                            End If
                                        Next nI
                                        If bPass Then
                                            nI = UBound(aW_PointDpt)
                                            aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand)
                                            aW_PointDpt(nI).cPoint = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtPoint")
                                            aW_PointDpt(nI).cRank = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtRank")
                                            If tReg = "Y" And tPro = "Y" Then
                                                aW_PointDpt(nI).cAmt = cBlue + cYellow
                                            ElseIf tReg = "Y" And tPro = "N" Then
                                                aW_PointDpt(nI).cAmt = cBlue
                                            ElseIf tReg = "N" And tPro = "Y" Then
                                                aW_PointDpt(nI).cAmt = cYellow
                                            End If
                                            aW_PointDpt(nI).cMin = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMin")
                                            aW_PointDpt(nI).cMax = SP_FEDvChkNumeric(orsTemp, "FCMpcAmtMax")
                                        End If
                                        If bPass Then ReDim Preserve aW_PointDpt(UBound(aW_PointDpt) + 1) As POINTDPT
                                    End If
                            End If
                        End If
                        'จะไม่ทำการ Add Recordset กรณีที่ Dept Code/Brand Code  Allow เพราะมีการกรอกระดับ SKU Code มาก่อนหน้านี้แล้ว
                    End If
          Else
'                'กรณีที่พบว่า Dept.Code / Brd.Code นั้นไม่มีอยู่ในส่วนของ Allow  Dept.Code / Brd.Code  ให้ทำการลบ Record ออกจาก Recordset
'                'ที่จะนำไปคิดส่วนของ Generate Mall Card
'                If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
'                Do While Not porsTarget2.EOF
'                    If SP_FEDvChkNumeric(porsTarget2, "FNSdtSeqNo") = SP_FEDvChkNumeric(orsSource, "FNSdtSeqNo") Then
'                        porsTarget2.Delete
'                        Exit Do
'                    End If
'                    porsTarget2.MoveNext
'                Loop

                'none
                'กรณีที่พบว่า Dept.Code / Brd.Code นั้นไม่มีอยู่ในส่วนของ Allow  Dept.Code / Brd.Code  สามารถนำไปคิดส่วนของ General (Tier)

          End If
          orsSource.MoveNext
      Loop

      If UBound(aW_PointDpt) = 0 Then
        nMax = 1
     Else
        nMax = UBound(aW_PointDpt)
     End If
     For nI = 0 To nMax - 1
        If aW_PointDpt(nI).tDptCode <> "" And aW_PointDpt(nI).cRank > 0 Then
            If aW_PointDpt(nI).cAmt > aW_PointDpt(nI).cMax Then
                pcPoint = pcPoint + (Int(aW_PointDpt(nI).cMax / aW_PointDpt(nI).cRank) * aW_PointDpt(nI).cPoint)
                pcPointAmt = pcPointAmt + aW_PointSKU(nI).cMax
            Else
                pcPoint = pcPoint + (Int(aW_PointDpt(nI).cAmt / aW_PointDpt(nI).cRank) * aW_PointDpt(nI).cPoint)
                pcPointAmt = pcPointAmt + aW_PointSKU(nI).cAmt
            End If
        End If
     Next nI
     'If Not (porsTarget.BOF And porsTarget.EOF) Then porsTarget.MoveFirst
     If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Exit Sub
ErrHandle:
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
End Sub

Public Sub SP_PRCbVerifyPointMall(ByVal porsMall As ADODB.Recordset, ByVal porsTemp As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double, ByVal pcSubReg As Double, ByVal pcSubPro As Double, ByVal pcSubTotal As Double)
'--------------------------------------------------------
'Ret:
'Cmt: *KT 52-02-24 Allow/Not Allow General Mall Card
'-------------------------------------------------------
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
    Dim tBlue As String
    Dim cSumSaleAmt As Double
    Dim orsTemp As ADODB.Recordset
    Dim orsSource As ADODB.Recordset
    Dim orsTier As ADODB.Recordset
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nI As Long
    Dim tReg As String
    Dim tPro As String
    Dim cTemp As Double
    Dim tTierType As String
    Dim cMinTier As Double
    Dim cMaxTier As Double
    Dim cSubTotalAll As Double
    Dim bCal As Boolean
    Dim bTier As Boolean
    Dim bSubAllTier As Boolean
On Error GoTo ErrHandle
    cSubTotalAll = pcSubReg + pcSubPro
    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    Set orsSource = porsTemp.Clone
    ReDim aW_PointMall(0) As POINTDPT
    aW_PointMall(0).tDptCode = ""
    aW_PointMall(0).cPoint = 0
    aW_PointMall(0).cRank = 0
    aW_PointMall(0).cAmt = 0
    aW_PointMall(0).cMin = 0
    aW_PointMall(0).cMax = 0
    
    tSql = "SELECT *"
    tSql = tSql & vbCrLf & "FROM TCNMMallCardTier"
    tSql = tSql & vbCrLf & "WHERE FTMcdCode = '" & SP_FEDtChkString(porsMall, "FTMcdCode") & "'"
    tSql = tSql & vbCrLf & "AND FCMtrAmt > 0"
    tSql = tSql & vbCrLf & "ORDER BY FTMtrSeq DESC"
    If SP_SQLvExecute(tSql, orsTier, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
        bTier = False
    Else
        If orsTier.BOF And orsTier.EOF Then
            bTier = False
        Else
            bTier = True
        End If
    End If
    tTierType = SP_FEDtChkString(porsMall, "FTMcdStaTier") '0 : Tier แบบ Time 1 : Tier แบบ Amount
    cMinTier = SP_FEDvChkNumeric(porsMall, "FCMcdAmtMinPoint")
    cMaxTier = SP_FEDvChkNumeric(porsMall, "FCMcdAmtMaxPoint")
    bSubAllTier = IIf(SP_FEDtChkString(porsMall, "FTMcdStaSubAllPoint") = "Y", True, False)
    If bSubAllTier Then
'        If cSubTotalAll >= cMinTier And cSubTotalAll <= cMaxTier Then
        If cSubTotalAll >= cMinTier Then            '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
            bCal = True
        Else
            bCal = False
        End If
    Else
'        If pcSubTotal >= cMinTier And pcSubTotal <= cMaxTier Then
        If pcSubTotal >= cMinTier Then          '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
            bCal = True
        Else
            bCal = False
        End If
    End If
    
    If bCal Then
        tReg = SP_FEDtChkString(porsMall, "FTMcdRegPoint")
        tPro = SP_FEDtChkString(porsMall, "FTMcdPromoPoint")
        bPass = True
        Do While Not orsSource.EOF
                cSaleAmt = SP_FEDvChkNumeric(orsSource, "FCSdtSaleAmt")
                If SP_FEDtChkString(orsSource, "FTSkuStaMallEmpCard") = "Y" Then
                    cBlue = cSaleAmt
                    cYellow = 0
                Else
                    cBlue = 0
                    cYellow = cSaleAmt
                End If
                If bPass Then
                    aW_PointMall(0).tDptCode = "MALL"
                    aW_PointMall(0).cPoint = SP_FEDvChkNumeric(porsMall, "FCMcdAmtPoint")
                    aW_PointMall(0).cRank = SP_FEDvChkNumeric(porsMall, "FCMcdAmtRank")
                    If tReg = "Y" And tPro = "Y" Then
                        aW_PointMall(0).cAmt = cYellow + cBlue
                    ElseIf tReg = "Y" And tPro = "N" Then
                        aW_PointMall(0).cAmt = cBlue
                    ElseIf tReg = "N" And tPro = "Y" Then
                        aW_PointMall(0).cAmt = cYellow
                    End If
                    aW_PointMall(0).cMin = SP_FEDvChkNumeric(porsMall, "FCMcdAmtMinPoint")
                    aW_PointMall(0).cMax = SP_FEDvChkNumeric(porsMall, "FCMcdAmtMaxPoint")
                    bPass = False
                Else
                    If tReg = "Y" And tPro = "Y" Then
                        aW_PointMall(0).cAmt = aW_PointMall(0).cAmt + cBlue + cYellow
                    ElseIf tReg = "Y" And tPro = "N" Then
                        aW_PointMall(0).cAmt = aW_PointMall(0).cAmt + cBlue
                    ElseIf tReg = "N" And tPro = "Y" Then
                        aW_PointMall(0).cAmt = aW_PointMall(0).cAmt + cYellow
                    End If
                End If
                orsSource.MoveNext
          Loop
    
          If UBound(aW_PointMall) = 0 Then
            nMax = 1
         Else
            nMax = UBound(aW_PointMall)
         End If
        If tTierType = "Y" Then 'Y : Tier แบบ Amount     N : Tier แบบ Time
            For nI = 0 To nMax - 1
                    If Not bTier Then
                         If aW_PointMall(nI).cAmt > aW_PointMall(nI).cMax Then
                                cTemp = (Int(aW_PointMall(nI).cMax / aW_PointMall(nI).cRank) * aW_PointMall(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointMall(nI).cAmt
                        Else
                                cTemp = (Int(aW_PointMall(nI).cAmt / aW_PointMall(nI).cRank) * aW_PointMall(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointMall(nI).cAmt
                        End If
                    Else
                        cTemp = SP_PRCcTierAmountPointMall(orsTier, aW_PointMall(nI).cAmt, cMinTier, cMaxTier, True)
                        pcPoint = pcPoint + cTemp
                        If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointMall(nI).cAmt
                    End If
            Next nI
        Else
            For nI = 0 To nMax - 1
                     If Not bTier Then
                        If aW_PointMall(nI).cAmt > aW_PointMall(nI).cMax Then
                                cTemp = (Int(aW_PointMall(nI).cMax / aW_PointMall(nI).cRank) * aW_PointMall(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointMall(nI).cAmt
                        Else
                                cTemp = (Int(aW_PointMall(nI).cAmt / aW_PointMall(nI).cRank) * aW_PointMall(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointMall(nI).cAmt
                        End If
                    Else
                        cTemp = SP_PRCcTierTimePointMall(orsTier, aW_PointMall(nI).cAmt, aW_PointMall(nI).cRank, aW_PointMall(nI).cPoint, cMinTier, cMaxTier)
                        pcPoint = pcPoint + cTemp
                        If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointMall(nI).cAmt
                    End If
            Next nI
        End If
    End If
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Call SP_DATxRsNothing(orsTier)
     Exit Sub
ErrHandle:
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Call SP_DATxRsNothing(orsTier)
End Sub

Public Sub SP_PRCbVerifyPointCrdBySKU(ByVal ptCrdCode As String, ByVal ptTenderCode As String, ByVal porsTemp As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, ByRef porsTarget2 As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double)
'--------------------------------------------------------
'Ret: porsTarget,porsTarget2,pcPoint,pcPointAmt
'Cmt: Allow/Not Allow SKU.Code
'porsTarget : สำหรับนำไปใช้สำหรับข้อมูลตั้งต้นของการคิด SP_PRCbVerifyPointCrdByDpt
'porsTarget2 : สำหรับนำไปใช้สำหรับข้อมูลตั้งต้นของการคิด SP_PRCbVerifyPointCrd
'pcPoint : จำนวนแต้มที่คิดได้จากเงื่อนไข Allow/Not Allow SKU.Code
'pcPointAmt : จำนวนเงินที่คิดแต้มได้จากเงื่อนไข Allow/Not Allow SKU.Code
'-------------------------------------------------------
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
    Dim tSKUCode As String
    Dim orsTemp As ADODB.Recordset
    Dim orsSource As ADODB.Recordset
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nI As Long
    Dim cTemp As Double


On Error GoTo ErrHandle
    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    Set orsSource = porsTemp.Clone
    Set porsTarget = New ADODB.Recordset
    Set porsTarget2 = New ADODB.Recordset
    For nI = 1 To orsSource.Fields.Count
        Call porsTarget.Fields.Append(orsSource.Fields(nI - 1).Name, orsSource.Fields(nI - 1).Type, orsSource.Fields(nI - 1).DefinedSize)
        Call porsTarget2.Fields.Append(orsSource.Fields(nI - 1).Name, orsSource.Fields(nI - 1).Type, orsSource.Fields(nI - 1).DefinedSize)
    Next nI
    porsTarget.CursorType = adOpenStatic
    porsTarget2.CursorType = adOpenStatic
    porsTarget.Open
    porsTarget2.Open
    
    ReDim aW_PointSKU(0) As POINTSKU
    aW_PointSKU(0).tSKUCode = ""
    aW_PointSKU(0).cPoint = 0
    aW_PointSKU(0).cRank = 0
    aW_PointSKU(0).cAmt = 0
    aW_PointSKU(0).cMin = 0
    aW_PointSKU(0).cMax = 0
    
    Do While Not orsSource.EOF
        tSKUCode = Trim(SP_FEDtChkString(orsSource, "FTSKUCode"))
        cSaleAmt = SP_FEDvChkNumeric(orsSource, "FCSdtNet") ' SP_FEDvChkNumeric(orsSource, "FCSdtSaleAmt")
        If SP_FEDtChkString(orsSource, "FTSkuStaMallEmpCard") = "Y" Then
            cBlue = cSaleAmt
            cYellow = 0
        Else
            cBlue = 0
            cYellow = cSaleAmt
        End If
         
        tSql = "SELECT  FTCpsAlw,FDCpsStartDate, FDCpsEndDate, FCCpsAmtMin, FCCpsAmtMax"
        tSql = tSql & vbCrLf & ",FCCpsAmtRank , FCCpsAmtPoint"
        tSql = tSql & vbCrLf & "FROM TCNMCreditCardSKU"
        tSql = tSql & vbCrLf & " WHERE FTCpsSKU = '" & tSKUCode & "'"
        tSql = tSql & vbCrLf & " AND FTTdmCode = '" & ptTenderCode & "'"
        tSql = tSql & vbCrLf & " AND FTCdcCreditType = '" & ptCrdCode & "'"
        tSql = tSql & vbCrLf & " AND FTCpsAlwPoint = '1'"
        tSql = tSql & vbCrLf & " ORDER BY  FTCpsAlw  DESC"
          
         Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
         If Not (orsTemp.BOF Or orsTemp.EOF) Then
                orsTemp.Filter = "FTCpsAlw = '1'" 'SKU Not Allow
                If Not (orsTemp.BOF Or orsTemp.EOF) Then
                    If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDCpsStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDCpsEndDate"), "YYYY/MM/DD") Then
                        'none ไม่เก็บเข้า porsTarget และ porsTarget2
                    Else
                        'เก็บเข้า porsTarget
                        porsTarget.AddNew
                        For nI = 1 To orsSource.Fields.Count
                            Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                                Case "T"
                                    porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                                Case "C"
                                    porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                Case "N"
                                    porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                Case "D"
                                    If IsNull(orsSource.Fields(nI - 1).Value) Then
                                        porsTarget.Fields(nI - 1).Value = "Null"
                                    Else
                                       porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                                    End If
                            End Select
                        Next nI
                    End If
                Else
                     bPass = False
                     orsTemp.Filter = adFilterNone
                     orsTemp.Filter = "FTCpsAlw = '0'" 'SKU  Allow
                     If Not (orsTemp.BOF Or orsTemp.EOF) Then
                        'เข้าเงื่อนไขการได้ Allow SKU
                        If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDCpsStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDCpsEndDate"), "YYYY/MM/DD") Then
                                'ไม่เก็บเข้า porsTarget เพราะได้แต้มใน Allow SKU ไม่ให้ Allow Dept.Code/Brand.Code
                                bPass = True
                                For nI = 0 To UBound(aW_PointSKU)
                                    If aW_PointSKU(nI).tSKUCode = tSKUCode Then
                                        aW_PointSKU(nI).cAmt = aW_PointSKU(nI).cAmt + cBlue + cYellow
                                        bPass = False
                                        Exit For
                                    End If
                                Next nI
                                If bPass Then
                                    nI = UBound(aW_PointSKU)
                                    aW_PointSKU(nI).tSKUCode = tSKUCode
                                    aW_PointSKU(nI).cPoint = SP_FEDvChkNumeric(orsTemp, "FCCpsAmtPoint")
                                    aW_PointSKU(nI).cRank = SP_FEDvChkNumeric(orsTemp, "FCCpsAmtRank")
                                    aW_PointSKU(nI).cAmt = cBlue + cYellow
                                    aW_PointSKU(nI).cMin = SP_FEDvChkNumeric(orsTemp, "FCCpsAmtMin")
                                    aW_PointSKU(nI).cMax = SP_FEDvChkNumeric(orsTemp, "FCCpsAmtMax")
                                End If
                                If bPass Then ReDim Preserve aW_PointSKU(UBound(aW_PointSKU) + 1) As POINTSKU
                        Else
                                'เก็บเข้า porsTarget เพื่อนำไปทำที่ Allow Dept.Code/Brand.Code ต่อไปเพราะในส่วน Allow SKU ไม่ผ่านเงื่อนไข ExpireDate
                                porsTarget.AddNew
                                For nI = 1 To orsSource.Fields.Count
                                    Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                                        Case "T"
                                            porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                                        Case "C"
                                            porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                        Case "N"
                                            porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                                        Case "D"
                                            If IsNull(orsSource.Fields(nI - 1).Value) Then
                                                porsTarget.Fields(nI - 1).Value = "Null"
                                            Else
                                               porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                                            End If
                                    End Select
                                Next nI
                        End If
                     End If
                    'เก็บเข้า porsTarget2 สำหรับใช้กับ Genneral ไม่จำเป็นต้องตรวจสอบเงื่อนไขวันที่ ExpireDate ของ Allow SKU นั้น
                    porsTarget2.AddNew
                    For nI = 1 To orsSource.Fields.Count
                        Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                            Case "T"
                                porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                            Case "C"
                                porsTarget2.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                            Case "N"
                                porsTarget2.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                            Case "D"
                                If IsNull(orsSource.Fields(nI - 1).Value) Then
                                    porsTarget2.Fields(nI - 1).Value = "Null"
                                Else
                                   porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                                End If
                            End Select
                    Next nI
                End If
          Else
                'เก็บเข้า porsTarget พื่อนำไปทำที่ Allow Dept.Code/Brand.Code ต่อไปเพราะในส่วน Allow SKU ไม่มี SKU Code นี้
                porsTarget.AddNew
                For nI = 1 To orsSource.Fields.Count
                    Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                        Case "T"
                            porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                        Case "C"
                            porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "N"
                            porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "D"
                            If IsNull(orsSource.Fields(nI - 1).Value) Then
                                porsTarget.Fields(nI - 1).Value = "Null"
                            Else
                               porsTarget.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                            End If
                    End Select
                Next nI
                
                'เก็บเข้า porsTarget2 สำหรับใช้กับ Genneral เพราะในส่วน Allow SKU ไม่มี SKU Code นี้ แต่ยังมีโอกาศที่จะเข้าส่วนของ Allow Dept.Code/Brand.Code อยู่
                porsTarget2.AddNew
                For nI = 1 To orsSource.Fields.Count
                    Select Case UCase(Mid(orsSource.Fields(nI - 1).Name, 2, 1))
                        Case "T"
                            porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value & vbNullString
                        Case "C"
                            porsTarget2.Fields(nI - 1).Value = SP_VALcText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "N"
                            porsTarget2.Fields(nI - 1).Value = SP_VALnText2Double(orsSource.Fields(nI - 1).Value & vbNullString)
                        Case "D"
                            If IsNull(orsSource.Fields(nI - 1).Value) Then
                                porsTarget2.Fields(nI - 1).Value = "Null"
                            Else
                               porsTarget2.Fields(nI - 1).Value = orsSource.Fields(nI - 1).Value
                            End If
                        End Select
                Next nI
          End If
           orsSource.MoveNext
      Loop
      'ขั้นตอนการคำนวนแต้มส่วนของ Allow SKU
      If UBound(aW_PointSKU) = 0 Then
        nMax = 1
     Else
        nMax = UBound(aW_PointSKU)
     End If
     For nI = 0 To nMax - 1
        If aW_PointSKU(nI).tSKUCode <> "" And aW_PointSKU(nI).cRank > 0 Then
            If aW_PointSKU(nI).cAmt > aW_PointSKU(nI).cMax Then
                cTemp = pcPoint + (Int(aW_PointSKU(nI).cMax / aW_PointSKU(nI).cRank) * aW_PointSKU(nI).cPoint)
                pcPoint = pcPoint + cTemp
                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointSKU(nI).cMax
            Else
                cTemp = (Int(aW_PointSKU(nI).cAmt / aW_PointSKU(nI).cRank) * aW_PointSKU(nI).cPoint)
                pcPoint = pcPoint + cTemp
                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointSKU(nI).cAmt
            End If
        End If
     Next nI
     If Not (porsTarget.BOF And porsTarget.EOF) Then porsTarget.MoveFirst
     If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Exit Sub
ErrHandle:

     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
End Sub

Public Sub SP_PRCbVerifyPointCrdByDpt(ByVal ptCrdCode As String, ByVal ptTenderCode As String, ByVal porsTemp As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, ByRef porsTarget2 As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double)
'--------------------------------------------------------
'Ret: porsTarget ,porsTarget2 ,pcPoint ,pcPointAmt
'Cmt: Allow/Not Allow Dpt.Code OR Brand.Code
'porsTarget : none
'porsTarget2 : สำหรับนำไปใช้สำหรับข้อมูลตั้งต้นของการคิด SP_PRCbVerifyPointCrd โดยที่ SKU Code ไหนเข้าเงื่อนไขมีการกำหนด Dpt.Code / Brand.Code ในส่วนของ Allow Dpt.Code / Brand.Code จะทำการ Delete Record ออกจาก
'pcPoint : จำนวนแต้มที่คิดได้จากเงื่อนไข Allow/Not Allow Dpt.Code OR Brand.Code
'pcPointAmt : จำนวนเงินที่คิดแต้มได้จากเงื่อนไข Allow/Not Allow Dpt.Code OR Brand.Code
'-------------------------------------------------------
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
    Dim tDptCode As String
    Dim tBrdCode As String
    Dim cSumSaleAmt As Double
    Dim orsTemp As ADODB.Recordset
    Dim orsSource As ADODB.Recordset
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nI As Long
    Dim tReg As String
    Dim tPro As String
    Dim tDept As String
    Dim tBrand As String

On Error GoTo ErrHandle
    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
    Set orsSource = porsTemp.Clone
    ReDim aW_PointDpt(0) As POINTDPT
    aW_PointDpt(0).tDptCode = ""
    aW_PointDpt(0).cPoint = 0
    aW_PointDpt(0).cRank = 0
    aW_PointDpt(0).cAmt = 0
    aW_PointDpt(0).cMin = 0
    aW_PointDpt(0).cMax = 0
    
    Do While Not orsSource.EOF
        tDptCode = Trim(SP_FEDtChkString(orsSource, "FTSkuDepCode"))
        tBrdCode = Trim(SP_FEDtChkString(orsSource, "FTSkuBrdCode"))
        
        cSaleAmt = SP_FEDvChkNumeric(orsSource, "FCSdtNet")  'SP_FEDvChkNumeric(orsSource, "FCSdtSaleAmt")
        If SP_FEDtChkString(orsSource, "FTSkuStaMallEmpCard") = "Y" Then
            cBlue = cSaleAmt
            cYellow = 0
        Else
            cBlue = 0
            cYellow = cSaleAmt
        End If
        
        cSumSaleAmt = 0
        porsTemp.Filter = "FTSkuDepCode = '" & tDptCode & "'"
        If Not (porsTemp.BOF Or porsTemp.EOF) Then
            Do While Not porsTemp.EOF
                cSumSaleAmt = cSumSaleAmt + SP_FEDvChkNumeric(porsTemp, "FCSdtSaleAmt")
                porsTemp.MoveNext
            Loop
        End If
        porsTemp.Filter = adFilterNone
        'ทำการค้นหาข้อมูลของ Dept.Code/Brd.Code ของ SKU Code นี้ว่ามีในตาราง TCNMCreditCardDep หรือไม่
         tSql = "SELECT FTCpcAlw ,FCCpcAmtPoint ,FCCpcAmtRank,FCCpcAmtMin,FCCpcAmtMax,FTCpcReg,FTCpcPro  "
         tSql = tSql & vbCrLf & ",FDCpcStartDate,FDCpcEndDate,FTCpcCode,FTCpcBrdCode"
         tSql = tSql & vbCrLf & "FROM TCNMCreditCardDep"
         tSql = tSql & vbCrLf & "WHERE ((FTCpcCode = '" & tDptCode & "' AND FTCpcBrdCode ='" & tBrdCode & "') OR (FTCpcCode = '" & tDptCode & "' AND FTCpcBrdCode ='' AND ISNULL(FTCpcCode,'') <> '') OR (FTCpcCode = '' AND FTCpcBrdCode ='" & tBrdCode & "' AND ISNULL(FTCpcBrdCode,'')<>'') OR (FTCpcCode = '" & tDptCode & "' AND FTCpcBrdCode = '' AND ISNULL(FTCpcCode,'') <> '' AND '" & tBrdCode & "' <> '') OR (ISNULL(FTCpcBrdCode,'') = '" & tBrdCode & "' AND  ISNULL(FTCpcBrdCode,'') <> ''))"
         tSql = tSql & vbCrLf & " AND FTCdcCreditType = '" & ptCrdCode & "'"
         tSql = tSql & vbCrLf & " AND FTTdmCode = '" & ptTenderCode & "'"
         tSql = tSql & vbCrLf & " AND FTCpcAlwPoint = '1'"
         tSql = tSql & vbCrLf & " ORDER BY  FTCpcAlw DESC"
         
         Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
         If Not (orsTemp.BOF Or orsTemp.EOF) Then
                    orsTemp.Filter = "FTCpcAlw = '1'" 'Dept Code/Brand Code Not Allow
                    If Not (orsTemp.BOF Or orsTemp.EOF) Then
                        'มีข้อมูล Dept Code/Brand Code ที่เป็นแบบ Not Allow
                        If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDCpcStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDCpcEndDate"), "YYYY/MM/DD") Then
                             'เข้าเงื่อนไข ExpireDate
                             If cSumSaleAmt >= SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMin") And cSumSaleAmt <= SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMax") Then
                                'เข้าเงื่อนไขของการตรวจสอบ Max , Min
                                tReg = SP_FEDtChkString(orsTemp, "FTCpcReg")
                                tPro = SP_FEDtChkString(orsTemp, "FTCpcPro")
                                tDept = SP_FEDtChkString(orsTemp, "FTCpcCode")
                                tBrand = SP_FEDtChkString(orsTemp, "FTCpcBrdCode")
                                bPass = True
                                For nI = 0 To UBound(aW_PointDpt)
                                    If aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand) Then
                                        If tReg = "Y" And tPro = "Y" Then
                                            aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + 0
                                        ElseIf tReg = "Y" And tPro = "N" Then
                                            aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cYellow '***ต้องให้ราคาป้ายเหลือง เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเงิน ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายเหลือง
                                        ElseIf tReg = "N" And tPro = "Y" Then
                                            aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cBlue '***ต้องให้ราคาป้ายน้ำเงิน เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเหลือง ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายน้ำเงิน
                                        End If
                                        bPass = False
                                        Exit For
                                    End If
                                Next nI
                                If bPass Then
                                    nI = UBound(aW_PointDpt)
                                    aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand)
                                    aW_PointDpt(nI).cPoint = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtPoint")
                                    aW_PointDpt(nI).cRank = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtRank")
                                    If tReg = "Y" And tPro = "Y" Then
                                        aW_PointDpt(nI).cAmt = 0
                                    ElseIf tReg = "Y" And tPro = "N" Then
                                        aW_PointDpt(nI).cAmt = cYellow '***ต้องให้ราคาป้ายเหลือง เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเงิน ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายเหลือง
                                    ElseIf tReg = "N" And tPro = "Y" Then
                                        aW_PointDpt(nI).cAmt = cBlue '***ต้องให้ราคาป้ายน้ำเงิน เพราะเงื่อนไขระบุว่าไม่ให้แต้มที่ Dept Code/Brand Code ในช่วง ExpireDate นี้ Max Min นี้และเฉพาะ ป้ายน้ำเหลือง ดังนั้นจะมีผลให้ได้แต้มส่งกันข้ามทันทีที่ รายการ SKU Code เป็นป้ายน้ำเงิน
                                    End If
                                    aW_PointDpt(nI).cMin = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMin")
                                    aW_PointDpt(nI).cMax = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMax")
                                End If
                                If bPass Then ReDim Preserve aW_PointDpt(UBound(aW_PointDpt) + 1) As POINTDPT
                            End If
                        End If
                        'ทำการลบ Record ที่นำไปคิดของ General(Tier) ของ Mall Card
                        If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
                        Do While Not porsTarget2.EOF
                            If SP_FEDvChkNumeric(porsTarget2, "FNSdtSeqNo") = SP_FEDvChkNumeric(orsSource, "FNSdtSeqNo") Then
                                porsTarget2.Delete
                                Exit Do
                            End If
                            porsTarget2.MoveNext
                        Loop
                    Else
                        orsTemp.Filter = adFilterNone
                        orsTemp.Filter = "FTCpcAlw = '0'" 'Dept Code/Brand Code  Allow
                        If Not (orsTemp.BOF Or orsTemp.EOF) Then
                            If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsTemp, "FDCpcStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsTemp, "FDCpcEndDate"), "YYYY/MM/DD") Then
                                 If cSumSaleAmt >= SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMin") And cSumSaleAmt <= SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMax") Then
                                        tReg = SP_FEDtChkString(orsTemp, "FTCpcReg")
                                        tPro = SP_FEDtChkString(orsTemp, "FTCpcPro")
                                        tDept = SP_FEDtChkString(orsTemp, "FTCpcCode")
                                        tBrand = SP_FEDtChkString(orsTemp, "FTCpcBrdCode")
                                        bPass = True
                                        For nI = 0 To UBound(aW_PointDpt)
                                            If aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand) Then
                                                If tReg = "Y" And tPro = "Y" Then
                                                    aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cBlue + cYellow
                                                ElseIf tReg = "Y" And tPro = "N" Then
                                                    aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cBlue
                                                ElseIf tReg = "N" And tPro = "Y" Then
                                                    aW_PointDpt(nI).cAmt = aW_PointDpt(nI).cAmt + cYellow
                                                End If
                                                bPass = False
                                                Exit For
                                            End If
                                        Next nI
                                        If bPass Then
                                            nI = UBound(aW_PointDpt)
                                            aW_PointDpt(nI).tDptCode = IIf(tDept = "", "-", tDept) & IIf(tBrand = "", "-", tBrand)
                                            aW_PointDpt(nI).cPoint = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtPoint")
                                            aW_PointDpt(nI).cRank = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtRank")
                                            If tReg = "Y" And tPro = "Y" Then
                                                aW_PointDpt(nI).cAmt = cBlue + cYellow
                                            ElseIf tReg = "Y" And tPro = "N" Then
                                                aW_PointDpt(nI).cAmt = cBlue
                                            ElseIf tReg = "N" And tPro = "Y" Then
                                                aW_PointDpt(nI).cAmt = cYellow
                                            End If
                                            aW_PointDpt(nI).cMin = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMin")
                                            aW_PointDpt(nI).cMax = SP_FEDvChkNumeric(orsTemp, "FCCpcAmtMax")
                                        End If
                                        If bPass Then ReDim Preserve aW_PointDpt(UBound(aW_PointDpt) + 1) As POINTDPT
                                    End If
                            End If
                        End If
                        'จะไม่ทำการ Add Recordset กรณีที่ Dept Code/Brand Code  Allow เพราะมีการกรอกระดับ SKU Code มาก่อนหน้านี้แล้ว
                    End If
          Else
                    'none
          End If
          orsSource.MoveNext
      Loop

      If UBound(aW_PointDpt) = 0 Then
        nMax = 1
     Else
        nMax = UBound(aW_PointDpt)
     End If
     For nI = 0 To nMax - 1
        If aW_PointDpt(nI).tDptCode <> "" And aW_PointDpt(nI).cRank > 0 Then
            If aW_PointDpt(nI).cAmt > aW_PointDpt(nI).cMax Then
                pcPoint = pcPoint + (Int(aW_PointDpt(nI).cMax / aW_PointDpt(nI).cRank) * aW_PointDpt(nI).cPoint)
                pcPointAmt = pcPointAmt + aW_PointSKU(nI).cMax
            Else
                pcPoint = pcPoint + (Int(aW_PointDpt(nI).cAmt / aW_PointDpt(nI).cRank) * aW_PointDpt(nI).cPoint)
                pcPointAmt = pcPointAmt + aW_PointSKU(nI).cAmt
            End If
        End If
     Next nI
     If Not (porsTarget2.BOF And porsTarget2.EOF) Then porsTarget2.MoveFirst
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Exit Sub
ErrHandle:
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
End Sub

Public Sub SP_PRCbVerifyPointCrd(ByVal porsCrd As ADODB.Recordset, ByVal porsTemp As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double, ByVal pcSubReg As Double, ByVal pcSubPro As Double, ByVal pcSubTotal As Double)
'--------------------------------------------------------
'Ret:
'Cmt: Allow/Not Allow General Credit Card
'-------------------------------------------------------
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
    Dim tBlue As String
    Dim cSumSaleAmt As Double
    Dim orsTemp As ADODB.Recordset
    Dim orsSource As ADODB.Recordset
    Dim orsTier As ADODB.Recordset
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nI As Long
    Dim tReg As String
    Dim tPro As String
    Dim cTemp As Double
    Dim tTierType As String
    Dim cMinTier As Double
    Dim cMaxTier As Double
    Dim cSubTotalAll As Double
    Dim bCal As Boolean
    Dim bTier As Boolean
    Dim bSubAllTier As Boolean
On Error GoTo ErrHandle
    cSubTotalAll = pcSubReg + pcSubPro
    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    Set orsSource = porsTemp.Clone
    ReDim aW_PointCrd(0) As POINTDPT
    aW_PointCrd(0).tDptCode = ""
    aW_PointCrd(0).cPoint = 0
    aW_PointCrd(0).cRank = 0
    aW_PointCrd(0).cAmt = 0
    aW_PointCrd(0).cMin = 0
    aW_PointCrd(0).cMax = 0
    
    tSql = "SELECT * "
    tSql = tSql & vbCrLf & "FROM TCNMCreditCardTierPoint"
    tSql = tSql & vbCrLf & "WHERE FTCdcCreditType = '" & SP_FEDtChkString(porsCrd, "FTCdcCreditType") & "'"
    tSql = tSql & vbCrLf & "AND FTTdmCode = '" & SP_FEDtChkString(porsCrd, "FTTdmCode") & "'"
    tSql = tSql & vbCrLf & "AND FCCtpAmt > 0"
    tSql = tSql & vbCrLf & "ORDER BY FTCtpSeq DESC"
    If SP_SQLvExecute(tSql, orsTier, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
        bTier = False
    Else
        If orsTier.BOF And orsTier.EOF Then
            bTier = False
        Else
            bTier = True
        End If
    End If
    tTierType = SP_FEDtChkString(porsCrd, "FTCdcStaTierPoint") '0 : Tier แบบ Time 1 : Tier แบบ Amount
    cMinTier = SP_FEDvChkNumeric(porsCrd, "FCCdcAmtMinPoint")
    cMaxTier = SP_FEDvChkNumeric(porsCrd, "FCCdcAmtMaxPoint")
    bSubAllTier = IIf(SP_FEDtChkString(porsCrd, "FTCdcStaSubAllPoint") = "Y", True, False)
    If bSubAllTier Then
'        If cSubTotalAll >= cMinTier And cSubTotalAll <= cMaxTier Then
        If cSubTotalAll >= cMinTier Then         '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
            bCal = True
        Else
            bCal = False
        End If
    Else
'        If pcSubTotal >= cMinTier And pcSubTotal <= cMaxTier Then
        If pcSubTotal >= cMinTier Then          '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
            bCal = True
        Else
            bCal = False
        End If
    End If
    
    If bCal Then
        tReg = SP_FEDtChkString(porsCrd, "FTCdcRegPoint")
        tPro = SP_FEDtChkString(porsCrd, "FTCdcPromoPoint")
        bPass = True
        Do While Not orsSource.EOF
                cSaleAmt = SP_FEDvChkNumeric(orsSource, "FCSdtNet") 'SP_FEDvChkNumeric(orsSource, "FCSdtSaleAmt")
                If SP_FEDtChkString(orsSource, "FTSkuStaMallEmpCard") = "Y" Then
                    cBlue = cSaleAmt
                    cYellow = 0
                Else
                    cBlue = 0
                    cYellow = cSaleAmt
                End If
                If bPass Then
                    aW_PointCrd(0).tDptCode = "MALL"
                    aW_PointCrd(0).cPoint = SP_FEDvChkNumeric(porsCrd, "FCCdcAmtPoint")
                    aW_PointCrd(0).cRank = SP_FEDvChkNumeric(porsCrd, "FCCdcAmtRank")
                    If tReg = "Y" And tPro = "Y" Then
                        aW_PointCrd(0).cAmt = cYellow + cBlue
                    ElseIf tReg = "Y" And tPro = "N" Then
                        aW_PointCrd(0).cAmt = cBlue
                    ElseIf tReg = "N" And tPro = "Y" Then
                        aW_PointCrd(0).cAmt = cYellow
                    End If
                    aW_PointCrd(0).cMin = SP_FEDvChkNumeric(porsCrd, "FCCdcAmtMinPoint")
                    aW_PointCrd(0).cMax = SP_FEDvChkNumeric(porsCrd, "FCCdcAmtMaxPoint")
                    bPass = False
                Else
                    If tReg = "Y" And tPro = "Y" Then
                        aW_PointCrd(0).cAmt = aW_PointCrd(0).cAmt + cBlue + cYellow
                    ElseIf tReg = "Y" And tPro = "N" Then
                        aW_PointCrd(0).cAmt = aW_PointCrd(0).cAmt + cBlue
                    ElseIf tReg = "N" And tPro = "Y" Then
                        aW_PointCrd(0).cAmt = aW_PointCrd(0).cAmt + cYellow
                    End If
                End If
                orsSource.MoveNext
          Loop
    
          If UBound(aW_PointCrd) = 0 Then
            nMax = 1
         Else
            nMax = UBound(aW_PointCrd)
         End If
        If tTierType = "Y" Then 'Y : Tier แบบ Amount     N : Tier แบบ Time
            For nI = 0 To nMax - 1
                    If Not bTier Then
                         If aW_PointCrd(nI).cAmt > aW_PointCrd(nI).cMax Then
                                cTemp = (Int(aW_PointCrd(nI).cMax / aW_PointCrd(nI).cRank) * aW_PointCrd(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointCrd(nI).cAmt
                        Else
                                cTemp = (Int(aW_PointCrd(nI).cAmt / aW_PointCrd(nI).cRank) * aW_PointCrd(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointCrd(nI).cAmt
                        End If
                    Else
                        cTemp = SP_PRCcTierAmountPointCrd(orsTier, aW_PointCrd(nI).cAmt, cMinTier, cMaxTier, True)
                        pcPoint = pcPoint + cTemp
                        If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointCrd(nI).cAmt
                    End If
            Next nI
        Else
            For nI = 0 To nMax - 1
                     If Not bTier Then
                        If aW_PointCrd(nI).cAmt > aW_PointCrd(nI).cMax Then
                                cTemp = (Int(aW_PointCrd(nI).cMax / aW_PointCrd(nI).cRank) * aW_PointCrd(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointCrd(nI).cAmt
                        Else
                                cTemp = (Int(aW_PointCrd(nI).cAmt / aW_PointCrd(nI).cRank) * aW_PointCrd(nI).cPoint)
                                pcPoint = pcPoint + cTemp
                                If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointCrd(nI).cAmt
                        End If
                    Else
                        cTemp = SP_PRCcTierTimePointCrd(orsTier, aW_PointCrd(nI).cAmt, aW_PointCrd(nI).cRank, aW_PointCrd(nI).cPoint, cMinTier, cMaxTier)
                        pcPoint = pcPoint + cTemp
                        If cTemp > 0 Then pcPointAmt = pcPointAmt + aW_PointCrd(nI).cAmt
                    End If
            Next nI
        End If
    End If
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Call SP_DATxRsNothing(orsTier)
     Exit Sub
ErrHandle:
     Call SP_DATxRsNothing(orsTemp)
     Call SP_DATxRsNothing(orsSource)
     Call SP_DATxRsNothing(orsTier)
End Sub


Public Sub SP_PRCbVerifyPointSec(ByVal porsTemp As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, ByRef pcPoint As Double, ByRef pcPointAmt As Double, ByVal pcSubReg As Double, ByVal pcSubPro As Double, ByVal pcSubTotal As Double, ByVal pbMissRec As Boolean)
'--------------------------------------------------------
'Ret:
'Cmt: *KT 52-02-24 section กำหนดเป็น SKU Code หรือ Dep.Code ทั้ง Allow หรือ Not Allow
'*KT 52-03-30 PH1.8-ML-SF-018
'-------------------------------------------------------
    Dim orsMas As ADODB.Recordset
    Dim orsSec As ADODB.Recordset
    Dim orsNotAlw As ADODB.Recordset
    Dim orsAlw As ADODB.Recordset
    Dim orsTier As ADODB.Recordset
    
    Dim tSql$
    Dim cBlue As Double
    Dim cYellow As Double
    Dim cSaleAmt As Double
    Dim tBlue As String
    Dim bPass As Boolean
    Dim nMax As Long
    Dim nMax2 As Long
    Dim nI As Long
    Dim nJ As Long
    Dim tDptCode As String
    Dim tBrdCode As String
    Dim tSKUCode As String
    Dim tReg As String
    Dim tPro As String
    Dim cTemp As Double
    Dim tFilter As String
    Dim tFilterDep As String
    Dim tFilterBrd  As String
    Dim bHaveAlw As Boolean
    Dim bHaveNotAlw As Boolean
    
    Dim bCalGeneral  As Boolean
    Dim bCalTier As Boolean
    Dim tTmpSkuCode As String
    Dim tTmpDptCode As String
    Dim tTmpBrdCode As String
    Dim cGenPoint As Double
    Dim cTierPoint As Double
    Dim cGenPointAmt As Double
    Dim cTierPointAmt As Double
    Dim cMaxGen  As Double
    Dim cMinGen As Double
    Dim bSubAllGen As Boolean
    Dim cMaxTier  As Double
    Dim cMinTier  As Double
    Dim bSubAllTier  As Boolean
    Dim bCal As Boolean
    Dim tTierType As String
    Dim cSubTotalAll  As Long

    Dim tMsmSeq As String
    Dim nSeqNo As Long
    Dim bFoundSeq As Boolean
    Dim bTier As Boolean
    Dim bAdd As Boolean
    Dim tStaCoopTier As String
    
    Dim bChkAllowPointGeneral As Boolean     'Mee 55-02-14 เพิ่มการตรวจสอบก่อนให้แต้มตาม Tier ว่า SKU นั้นได้อนุญาตให้ได้แต้มแบบ General แล้วหรือไม่
    Dim tChkBrdCode As String      'Mee 55-02-14 เพิ่มเงื่อนไขเช็คการให้แต้มแบบ Additional Point
    
On Error GoTo ErrHandle

'    cSubTotalAll = pcSubReg + pcSubPro
    cSubTotalAll = pcSubReg                                 '*Ao 2013/03/05  TK
    
    cVB_TotalSecsionTierAmt = 0 'กรณีที่ Secsion มีการ set ว่าให้ส่วนของ Tier ใช้ Tier ร่วมกับ Tier ของ Coopearte นั้น ให้ทำการเก็บค่าไว้ในตัวแปร Global แล้วไป+ เพิ่มที่ส่วนการคำนวนแต้มของ Tier Cooperate
    If Not (porsTemp.BOF And porsTemp.EOF) Then porsTemp.MoveFirst
    Set porsTarget = New ADODB.Recordset
    For nI = 1 To porsTemp.Fields.Count
        Call porsTarget.Fields.Append(porsTemp.Fields(nI - 1).Name, porsTemp.Fields(nI - 1).Type, porsTemp.Fields(nI - 1).DefinedSize)
    Next nI
    porsTarget.CursorType = adOpenStatic
    porsTarget.Open

    ReDim aW_PointSKUSeq(0) As Long
    
    cGenPoint = 0
    cGenPointAmt = 0
    cTierPoint = 0
    cTierPointAmt = 0
    
    ReDim aW_PointSec(0) As POINTDPT
    aW_PointSec(0).tDptCode = ""
    aW_PointSec(0).tBrdCode = ""
    aW_PointSec(0).cPoint = 0
    aW_PointSec(0).cRank = 0
    aW_PointSec(0).cAmt = 0
    aW_PointSec(0).cMin = 0
    aW_PointSec(0).cMax = 0
    aW_PointSec(0).tCode = ""
    aW_PointSec(0).tTier = ""
    aW_PointSec(0).tUseTierCoo = ""
    aW_PointSec(0).tAdd = ""
    aW_PointSec(0).tAlw = ""
    aW_PointSec(0).tEvnID = ""
    
    ReDim aW_PointSKU(0) As POINTSKU
    aW_PointSKU(0).tSKUCode = ""
    aW_PointSKU(0).cPoint = 0
    aW_PointSKU(0).cRank = 0
    aW_PointSKU(0).cAmt = 0
    aW_PointSKU(0).cMin = 0
    aW_PointSKU(0).cMax = 0
    aW_PointSKU(0).tCode = ""
    aW_PointSKU(0).tTier = ""
    aW_PointSKU(0).tUseTierCoo = ""
    aW_PointSKU(0).tAdd = ""
    aW_PointSKU(0).tAlw = ""
    aW_PointSKU(0).tEvnID = ""
    
    ReDim aW_PointDpt(0) As POINTDPT
    aW_PointDpt(0).tDptCode = ""
    aW_PointDpt(0).cPoint = 0
    aW_PointDpt(0).cRank = 0
    aW_PointDpt(0).cAmt = 0
    aW_PointDpt(0).cMin = 0
    aW_PointDpt(0).cMax = 0
    aW_PointDpt(0).tCode = ""
    aW_PointDpt(0).tTier = ""
    aW_PointDpt(0).tUseTierCoo = ""
    aW_PointDpt(0).tAdd = ""
    aW_PointDpt(0).tAlw = ""
    aW_PointDpt(0).tEvnID = ""
    
    ReDim aW_PointSec2(0) As POINTDPT
    aW_PointSec2(0).tDptCode = ""
    aW_PointSec2(0).tBrdCode = ""
    aW_PointSec2(0).cPoint = 0
    aW_PointSec2(0).cRank = 0
    aW_PointSec2(0).cAmt = 0
    aW_PointSec2(0).cMin = 0
    aW_PointSec2(0).cMax = 0
    aW_PointSec2(0).tCode = ""
    aW_PointSec2(0).tTier = ""
    aW_PointSec2(0).tUseTierCoo = ""
    aW_PointSec2(0).tAdd = ""
    aW_PointSec2(0).tAlw = ""
    aW_PointSec2(0).tEvnID = ""
    
    ReDim aW_PointSKU2(0) As POINTSKU
    aW_PointSKU2(0).tSKUCode = ""
    aW_PointSKU2(0).cPoint = 0
    aW_PointSKU2(0).cRank = 0
    aW_PointSKU2(0).cAmt = 0
    aW_PointSKU2(0).cMin = 0
    aW_PointSKU2(0).cMax = 0
    aW_PointSKU2(0).tCode = ""
    aW_PointSKU2(0).tTier = ""
    aW_PointSKU2(0).tUseTierCoo = ""
    aW_PointSKU2(0).tAdd = ""
    aW_PointSKU2(0).tAlw = ""
    aW_PointSKU2(0).tEvnID = ""

    ReDim aW_PointDpt2(0) As POINTDPT
    aW_PointDpt2(0).tDptCode = ""
    aW_PointDpt2(0).cPoint = 0
    aW_PointDpt2(0).cRank = 0
    aW_PointDpt2(0).cAmt = 0
    aW_PointDpt2(0).cMin = 0
    aW_PointDpt2(0).cMax = 0
    aW_PointDpt2(0).tCode = ""
    aW_PointDpt2(0).tTier = ""
    aW_PointDpt2(0).tUseTierCoo = ""
    aW_PointDpt2(0).tAdd = ""
    aW_PointDpt2(0).tAlw = ""
    aW_PointDpt2(0).tEvnID = ""
    
    tSql = "SELECT  TA.FTMsmSeq,TA.FTSkuCode,TA.FTSpsDepCode,TA.FTSpsBrdCode"
    tSql = tSql & vbCrLf & " FROM   TCNMMemberSectMtn TM INNER JOIN"
    tSql = tSql & vbCrLf & " TCNMMemberSectAlw TA ON TM.FTMsmSeq = TA.FTMsmSeq"
    tSql = tSql & vbCrLf & " WHERE  TA.FTSpsAlwTier = '1'"
'    tSql = tSql & vbCrLf & " AND TA.FTSpsAlwGen = '1'"    'Mee 55-02-10 แก้ไข Grid Allow SKU/Dept สลับกับ Grid Not Allow SKU/Dept
    tSql = tSql & vbCrLf & " AND TA.FTSpsAlwGen = '0'"
    tSql = tSql & vbCrLf & " AND (TM.FTMsmStaSection = 'Y'  OR TM.FTMsmStaAlw = 'Y')"
    tSql = tSql & vbCrLf & " ORDER BY TA.FTMsmSeq"
    Call SP_SQLvExecute(tSql, orsMas, oDB.ocnOnLine, , , , , True, True) 'read master
    Do While Not porsTemp.EOF
        nSeqNo = SP_FEDvChkNumeric(porsTemp, "FNSdtSeqNo")
        tSKUCode = Trim(SP_FEDtChkString(porsTemp, "FTSkuCode"))
        tDptCode = Trim(SP_FEDtChkString(porsTemp, "FTSkuDepCode"))
        tBrdCode = Trim(SP_FEDtChkString(porsTemp, "FTSkuBrdCode"))
        tChkBrdCode = tBrdCode      'Mee 55-02-14 เพิ่มเงื่อนไขเช็คการให้แต้มแบบ Additional Point
        tMsmSeq = ""
        'ขั้นตอนการหาว่า SKU นั้นควรอยู่ที่ Section ไหน
        'โดยเรียงลำดับความสำคัญดังนี้
        'SKU Allow >> Dept.Code  Only >> Brand.Code Only >> Dept.Code + Brand.Code >> Dept.Code >> Brand.Code
        If Not (orsMas.BOF And orsMas.EOF) Then
               ' SKU Allow
                If Not (orsMas.BOF And orsMas.EOF) Then orsMas.MoveFirst
               Do While Not orsMas.EOF
                    If Trim(SP_FEDtChkString(orsMas, "FTSkuCode")) = tSKUCode And tSKUCode <> "" Then
                        tMsmSeq = SP_FEDtChkString(orsMas, "FTMsmSeq")
                        Exit Do
                    End If
                    orsMas.MoveNext
               Loop
                'Dept.Code Only
               If Not (orsMas.BOF And orsMas.EOF) Then orsMas.MoveFirst
                Do While Not orsMas.EOF And tMsmSeq = ""
                    If Trim(SP_FEDtChkString(orsMas, "FTSpsDepCode")) = tDptCode And Trim(SP_FEDtChkString(orsMas, "FTSpsBrdCode")) = "" And tDptCode <> "" Then
                        tMsmSeq = SP_FEDtChkString(orsMas, "FTMsmSeq")
                        Exit Do
                    End If
                    orsMas.MoveNext
               Loop
               'Brand.Code Only
                If Not (orsMas.BOF And orsMas.EOF) Then orsMas.MoveFirst
                Do While Not orsMas.EOF And tMsmSeq = ""
                    If Trim(SP_FEDtChkString(orsMas, "FTSpsDepCode")) = "" And Trim(SP_FEDtChkString(orsMas, "FTSpsBrdCode")) = tBrdCode And tBrdCode <> "" Then
                        tMsmSeq = SP_FEDtChkString(orsMas, "FTMsmSeq")
                        Exit Do
                    End If
                    orsMas.MoveNext
               Loop
               'Dept.Code + Brand.Cod
              If Not (orsMas.BOF And orsMas.EOF) Then orsMas.MoveFirst
                Do While Not orsMas.EOF And tMsmSeq = ""
                    If Trim(SP_FEDtChkString(orsMas, "FTSpsDepCode")) = tDptCode And Trim(SP_FEDtChkString(orsMas, "FTSpsBrdCode")) = tBrdCode And tDptCode <> "" And tBrdCode <> "" Then
                        tMsmSeq = SP_FEDtChkString(orsMas, "FTMsmSeq")
                        Exit Do
                    End If
                    orsMas.MoveNext
               Loop
               'Dept.Code
                If Not (orsMas.BOF And orsMas.EOF) Then orsMas.MoveFirst
                Do While Not orsMas.EOF And tMsmSeq = ""
                    If Trim(SP_FEDtChkString(orsMas, "FTSpsDepCode")) = tDptCode And tDptCode <> "" Then
                        tMsmSeq = SP_FEDtChkString(orsMas, "FTMsmSeq")
                        Exit Do
                    End If
                    orsMas.MoveNext
               Loop
               'Brand.Code
                If Not (orsMas.BOF And orsMas.EOF) Then orsMas.MoveFirst
                Do While Not orsMas.EOF And tMsmSeq = ""
                    If Trim(SP_FEDtChkString(orsMas, "FTSpsBrdCode")) = tBrdCode And tBrdCode <> "" Then
                         tMsmSeq = SP_FEDtChkString(orsMas, "FTMsmSeq")
                        Exit Do
                    End If
                    orsMas.MoveNext
               Loop
        End If
        Call SP_DATxRsClose(orsSec)
        'ขั้นตอนการดึงข้อมูลของ Section นั้น
        tSql = "SELECT * "
        tSql = tSql & vbCrLf & " FROM TCNMMemberSectMtn"
        tSql = tSql & vbCrLf & " WHERE FTMsmSeq = '" & tMsmSeq & "'"
        Call SP_SQLvExecute(tSql, orsSec, oDB.ocnOnLine, , , , , True, True) 'read master
        'มีข้อมูล Section
        If Not (orsSec.BOF And orsSec.EOF) And tMsmSeq <> "" Then
                tStaCoopTier = SP_FEDtChkString(orsSec, "FTMsmStaCoopTier")
                'General
                '##############################################################################################
                'Secsion Allow(ทั้ง General/Tier)
                tSql = "SELECT * "
                tSql = tSql & vbCrLf & " FROM TCNMMemberSectAlw"
                tSql = tSql & vbCrLf & " WHERE FTMsmSeq ='" & tMsmSeq & "'"
                tSql = tSql & vbCrLf & " AND FTSpsAlwTier = '1'"
'                tSql = tSql & vbCrLf & " AND FTSpsAlwGen = '1'"     'Mee 55-02-10 แก้ไข Grid Allow SKU/Dept สลับกับ Grid Not Allow SKU/Dept
                tSql = tSql & vbCrLf & " AND FTSpsAlwGen = '0'"
                tSql = tSql & vbCrLf & " ORDER BY FTSpsSeq"
                Call SP_SQLvExecute(tSql, orsAlw, oDB.ocnOnLine, , , , , True, True) 'read master
                If Not (orsAlw.BOF And orsAlw.EOF) Then
                    bHaveAlw = True
                Else
                    bHaveAlw = False
                End If
                'ส่วนของการเก็บ SeqNo ของ Item ที่ได้ Section
                '-------------------------------------------------------------------------------------------
                bFoundSeq = False
                For nI = 0 To UBound(aW_PointSKUSeq)
                    If nSeqNo = aW_PointSKUSeq(nI) Then
                        bFoundSeq = True
                        Exit For
                    End If
                Next nI
                If Not bFoundSeq Then
                    aW_PointSKUSeq(UBound(aW_PointSKUSeq)) = nSeqNo
                    ReDim Preserve aW_PointSKUSeq(UBound(aW_PointSKUSeq) + 1) As Long
                End If
                '-------------------------------------------------------------------------------------------
                'Secsion Not Allow(General)
                tSql = "SELECT * "
                tSql = tSql & vbCrLf & " FROM TCNMMemberSectAlw"
                tSql = tSql & vbCrLf & " WHERE '" & Format(SP_GETdChkDatePoint, "YYYY/MM/DD") & "' BETWEEN FDSpsStartDate AND FDSpsEndDate"
                tSql = tSql & vbCrLf & " AND FTMsmSeq ='" & tMsmSeq & "'"
                tSql = tSql & vbCrLf & " AND FTSpsAlwTier = '1'"
'                tSql = tSql & vbCrLf & " AND FTSpsAlwGen = '0'"     'Mee 55-02-10 แก้ไข Grid Allow SKU/Dept สลับกับ Grid Not Allow SKU/Dept
                tSql = tSql & vbCrLf & " AND FTSpsAlwGen = '1'"
                Call SP_SQLvExecute(tSql, orsNotAlw, oDB.ocnOnLine, , , , , True, True) 'read master
                If Not (orsNotAlw.BOF And orsNotAlw.EOF) Then
                    bHaveNotAlw = True
                Else
                    bHaveNotAlw = False
                End If
                'Genneral ที่ Tik Active
                If SP_FEDtChkString(orsSec, "FTMsmStaSection") = "Y" Then
                    cMaxGen = SP_FEDvChkNumeric(orsSec, "FCMsmAmtMax")
                    cMinGen = SP_FEDvChkNumeric(orsSec, "FCMsmAmtMin")
                    bSubAllGen = IIf(SP_FEDtChkString(orsSec, "FTMsmStaSubAll") = "Y", True, False)
                    If bSubAllGen Then
'                        If cSubTotalAll >= cMinGen And cSubTotalAll <= cMaxGen Then
                        If cSubTotalAll >= cMinGen Then         '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
                            bCal = True
                        Else
                            bCal = False
                        End If
                    Else
'                        If pcSubTotal >= cMinGen And pcSubTotal <= cMaxGen Then
                        If pcSubTotal >= cMinGen Then           '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
                            bCal = True
                        Else
                            bCal = False
                        End If
                    End If
                    If Format(SP_GETdChkDatePoint, "YYYY/MM/DD") >= Format(SP_FEDdChkDate(orsSec, "FDMsmStartDate"), "YYYY/MM/DD") And Format(SP_GETdChkDatePoint, "YYYY/MM/DD") <= Format(SP_FEDdChkDate(orsSec, "FDMsmEndDate"), "YYYY/MM/DD") And bCal Then
                        If bHaveNotAlw Then
                             bCalGeneral = True
                             If Not (orsNotAlw.BOF And orsNotAlw.EOF) Then orsNotAlw.MoveFirst
                             Do While Not orsNotAlw.EOF
                                 tTmpSkuCode = Trim(SP_FEDtChkString(orsNotAlw, "FTSkuCode"))
                                 tTmpDptCode = Trim(SP_FEDtChkString(orsNotAlw, "FTSpsDepCode"))
                                 tTmpBrdCode = Trim(SP_FEDtChkString(orsNotAlw, "FTSpsBrdCode"))
'                                If (tDptCode = tTmpDptCode And tBrdCode = tTmpBrdCode) Or (tDptCode = tTmpDptCode And tTmpBrdCode = "" And tTmpDptCode <> "") Or (tTmpDptCode = "" And tBrdCode = tTmpBrdCode And tTmpBrdCode <> "") Or (tDptCode = tTmpDptCode And tBrdCode <> "" And tTmpDptCode <> "") Or (tTmpDptCode <> "" And tTmpBrdCode = tBrdCode And tTmpBrdCode <> "") Or (tSKUCode = tTmpSkuCode) Then
                                If (tDptCode = tTmpDptCode And tBrdCode = tTmpBrdCode) Or (tDptCode = tTmpDptCode And tTmpBrdCode = "" And tTmpDptCode <> "") Or (tTmpDptCode = "" And tBrdCode = tTmpBrdCode And tTmpBrdCode <> "") Or (tDptCode = tTmpDptCode And tBrdCode <> "" And tTmpDptCode <> "" And tBrdCode = tTmpBrdCode) Or (tTmpDptCode <> "" And tTmpBrdCode = tBrdCode And tTmpBrdCode <> "") Or (tSKUCode = tTmpSkuCode) Then     'Mee 55-02-10 แก้ไข Grid Allow SKU/Dept สลับกับ Grid Not Allow SKU/Dept
                                    bCalGeneral = False
                                    bChkAllowPointGeneral = False      'Mee 55-02-14 เพิ่มการตรวจสอบก่อนให้แต้มตาม Tier ว่า SKU นั้นได้อนุญาตให้ได้แต้มแบบ General แล้วหรือไม่
                                    Exit Do
                                End If
                                orsNotAlw.MoveNext
                             Loop
                        Else
                            bCalGeneral = True
                            bChkAllowPointGeneral = True      'Mee 55-02-14 เพิ่มการตรวจสอบก่อนให้แต้มตาม Tier ว่า SKU นั้นได้อนุญาตให้ได้แต้มแบบ General แล้วหรือไม่
                        End If
                        If bCalGeneral Then
                            cSaleAmt = SP_FEDvChkNumeric(porsTemp, "FCSdtSaleAmt")
                            '*KT 54-08-03 V.4.0.1 Req.2 Phase4.0(Member Point) Member Point Based on Tender ทำการคำนวณการ Prorate ยอดสุทธิของสินค้าหลังหักส่วนลดกับยอด Tender รวมที่อนุญาตให้ Point
                            'cVB_CNTenderAmtAlwPoint มีการรวมเศษที่ปัดขึ้นปัดลงแล้ว ส่วน cSubTotalAll เป็นยอดที่ยังไม่รวมเศษที่ปัดขึ้นปัดลง
                            '*KT 54-11-21 V.4.0.5 เปลี่ยน cSubTotalAll เป็น pcSubTotal
                            If cVB_CNTenderAmtAlwPoint > pcSubTotal Then
                                'cSaleAmt = SP_FMTcCurPoint((cSaleAmt * pcSubTotal) / pcSubTotal, True, False)
                                cSaleAmt = SP_FMTcCurPoint(cSaleAmt, True, False)
                            Else
                                cSaleAmt = SP_FMTcCurPoint((cSaleAmt * cVB_CNTenderAmtAlwPoint) / pcSubTotal, True, False)
                            End If
