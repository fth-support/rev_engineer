Public Function SP_DATbRsOpen(ByRef poRs As ADODB.Recordset, ByVal pnCurLoc As Long, ByVal ptSrc$, pocnAll As ADODB.Connection, ByVal piCurType%, ByVal piLocked%, ByVal pnCmnd As Long) As Boolean
'----------------------------------------------------------
'   Call:   pnCurLoc is cursorlocation
'               ptSrc is source to be opened
'               poCnAll is connection
'               piCurType is type of cursor
'               piLocked is type of Db locked
'               pnCmnd is type of command
'   Ret:    true if open ok
'----------------------------------------------------------
On Error GoTo ErrHandler
    
    SP_DATbRsOpen = False
    
    Set poRs = New ADODB.Recordset
    poRs.CursorLocation = pnCurLoc
    poRs.Open ptSrc, pocnAll, piCurType, piLocked, pnCmnd
    
    If poRs.State = adStateOpen Then
        SP_DATbRsOpen = True
    Else
        SP_DATbRsOpen = False
    End If
    
    Exit Function
ErrHandler:
    SP_DATbRsOpen = False
End Function

Public Function SP_GETtWinPath() As String
'-----------------------------------------------------------
'   Parameter :
'   Cmt :  GET Windows Path
'   Ex. output
'       GetTheWindowsDirectory = E:\Windows
'       GetTheWindowsDirectory = C:\Windows
'       GetTheWindowsDirectory = C:\WinNT
'   File Refer :
'   Developer : BUNG
'   Date Create : 16/10/2013 :  13:32:48
'-----------------------------------------------------------
    Dim tWindowsDir As String
    Dim nWindowsDirLength As Integer
    On Error GoTo ErrHandle
        SP_GETtWinPath = ""
        tWindowsDir = Space(250)
        nWindowsDirLength = GetWindowsDirectory(tWindowsDir, 250)
        tWindowsDir = Left(tWindowsDir, nWindowsDirLength)
        SP_GETtWinPath = tWindowsDir
    Exit Function
ErrHandle:
    SP_GETtWinPath = "C:\WINDOWS"
End Function

