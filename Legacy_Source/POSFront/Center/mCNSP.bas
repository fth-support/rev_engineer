Public Function SP_DATtGetUserLocaleInfo(ByVal pnLocaleID As Long, ByVal pnLCType As Long) As String
'----------------------------------------------------------
'   Call:   pnLocaleID as LOCALE ID,
'               pnLCType as type of constant
'   Ret:   Locale  info
'----------------------------------------------------------
   Dim tReturn As String
   Dim nR As Long

  'call the function passing the Locale type
  'variable to retrieve the required size of
  'the string buffer needed
   nR = GetLocaleInfo(pnLocaleID, pnLCType, tReturn, Len(tReturn))
    
  'if successful (r > 0)
   If nR Then
    
     'pad the buffer with spaces
      tReturn = Space$(nR)
       
     'and call again passing the buffer
      nR = GetLocaleInfo(pnLocaleID, pnLCType, tReturn, Len(tReturn))
     
     'if successful (r > 0)
      If nR Then
      
        'r holds the size of the string
        'including the terminating null
         SP_DATtGetUserLocaleInfo = Left$(tReturn, nR - 1)
      
      End If
   
   End If
    
End Function

Public Function SP_ENMnCaldProc(pnDateFormatString As Long) As Long
'----------------------------------------------------------
'   Call:   pnDateFormatString as Formatt  of  date  string
'   Cmt:   AddItem  into  ComboBox
'----------------------------------------------------------
  'application-defined callback function for EnumCalendarInfo
   oThisCombo.AddItem SP_DATtStrFromPointer(pnDateFormatString)
   
  'return 1 to continue enumeration
   SP_ENMnCaldProc = 1
   
End Function

Private Function SP_DATtStrFromPointer(pnString As Long) As String
'----------------------------------------------------------
'   Call:   pnDateFormatString as Formatt  of  date  string
'   Ret:   Date  string
'----------------------------------------------------------
   Dim nPos As Long
   Dim tBuffer As String
   
  'pad a string to hold the data
   tBuffer = Space$(128)
   
  'copy the string pointed to by the return value
   CopyMemory ByVal tBuffer, pnString, ByVal Len(tBuffer)
   
  'remove the trailing null and trim
   nPos = InStr(tBuffer, Chr$(0))
   
   If nPos Then
      SP_DATtStrFromPointer = Left$(tBuffer, nPos - 1)
   End If

End Function

