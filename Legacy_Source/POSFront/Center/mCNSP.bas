Public Function SP_FMTcCurPointForeign(ByRef pcValue As Variant, Optional ByVal pbNoComma As Boolean = True, Optional ByVal pbToShow As Boolean = True) As Variant
'----------------------------------------------------------
'   Call:   pcValue as double value
'   Cmt:   return format of number
'----------------------------------------------------------
    Dim nDecAmt As Integer
    
    nDecAmt = IIf(pbToShow, 2, 2)
    If pbNoComma Then
        SP_FMTcCurPointForeign = Format(pcValue, "########0." & String(nDecAmt, "0"))
