    '                        aVB_CNSKUPointByTime(nJ).nSeqNo = nSeq
    '                        aVB_CNSKUPointByTime(nJ).cPoint = cPointAvg
    '                        aVB_CNSKUPointByTime(nJ).tType = "1"
    '                        ReDim Preserve aVB_CNSKUPointByTime(UBound(aVB_CNSKUPointByTime) + 1) As SKUPointByTime
                            porsTemp.MoveNext
                        Loop
                    End If
                    porsTemp.Filter = adFilterNone
                    pcPoint = pcPoint + cPointSec
                    '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                    If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type1SKUPoint, cPointSec, cSKUAmtSec, aW_SKUAmtBySec(nI).tSKU, tEventsID, tVB_MemPointID, tSKU) Then
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type1SKUPoint & ",SKU Code = " & tSKU & ",Point =" & cPointAvg, tVB_MemPointID)
                    End If
                End If
            Next nI
        End If

        'By Cooperate
        If cSKUAmtCoo > 0 Then
            cPointSumAvg = 0
            pcPointAmt = pcPointAmt + cSKUAmtCoo
            For nI = 0 To UBound(aW_SKUPintByCoo) - 1
                ' ตรวจสอบ Min สาเหตุที่ไม่ตรวจสอบตั้งแต่ขั้นแรก เนื่องมีความเป็นไปได้ที่มีการ Scan ขายสินค้าเดียวกันมากกว่า 1 รายการ จึงต้องตรวจสอบในขั้นนี้
                If Val(Format(SP_FMTcCurPoint(aW_SKUPintByCoo(nI).cAmt, True, False))) >= Val(Format(SP_FMTcCurPoint(aW_SKUPintByCoo(nI).cMin, True, False))) Then
                    If aW_SKUPintByCoo(nI).cRank > 0 Then
                        cPointCoo = (aW_SKUPintByCoo(nI).cAmt \ IIf(aW_SKUPintByCoo(nI).cRank = 0, 1, aW_SKUPintByCoo(nI).cRank)) * aW_SKUPintByCoo(nI).nTime
                    Else
                        cPointCoo = 0
                    End If
                    porsTemp.MoveFirst
                    porsTemp.Filter = "FTSKUCode='" & aW_SKUPintByCoo(nI).tSKU & "'"
                    porsTemp.Sort = "FNSdtSeqNo ASC"
                    If Not (porsTemp.BOF And porsTemp.EOF) Then
                        porsTemp.MoveLast
                        nLSeqNo = SP_FEDvChkNumeric(porsTemp, "FNSdtSeqNo")
                        porsTemp.MoveFirst
                        Do While Not porsTemp.EOF
                            nSeq = SP_FEDtChkString(porsTemp, "FNSdtSeqNo")
                            cSaleAmt = SP_FEDvChkNumeric(porsTemp, "FCSdtSaleAmt")
                            tSKU = SP_FEDtChkString(porsTemp, "FTSKUCode")
                            tEventsID = SP_FEDtChkString(porsTemp, "FTSdtEventMemPoint")
                            cPointAvg = SP_FMTcCurPoint(cPointCoo * (cSaleAmt / aW_SKUPintByCoo(nI).cAmt), True, False)
                            cPointSumAvg = cPointSumAvg + cPointAvg
                            If nSeq = nLSeqNo Then
                                If cPointSumAvg <> cPointCoo Then
                                    cPointAvg = cPointAvg + (cPointCoo - cPointSumAvg)
                                End If
                            End If
'*KT 54-11-23 V.4.0.5 ML-PH4-R3-009 Allow Cooperate Flag in Upload file always "Y" ทำการยกเลิกการใช้งาน FTSdtAlwCoRateFlag
'--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
'                            tSql = "UPDATE " & tVB_CNTblDT
'                            tSql = tSql & vbCrLf & "SET "
'                            tSql = tSql & vbCrLf & "FTSdtAlwCoRateFlag = 'Y'"
'                            tSql = tSql & vbCrLf & ",FCSdtMemberPoint = " & cPointAvg
'                            tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
'                            tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
'                            tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
'                            tSql = tSql & vbCrLf & " AND FNSdtSeqNo = " & nSeq
'                            If SP_SQLvExecute(tSql, , , , , nEff) = 0 Then
'
'                            End If
'--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
    '                        nJ = UBound(aVB_CNSKUPointByTime)
    '                        aVB_CNSKUPointByTime(nJ).tSKU = SP_FEDtChkString(porsTemp, "FTSkuCode")
    '                        aVB_CNSKUPointByTime(nJ).nSeqNo = nSeq
    '                        aVB_CNSKUPointByTime(nJ).cPoint = cPointAvg
    '                        aVB_CNSKUPointByTime(nJ).tType = "0"
                            porsTemp.MoveNext
                        Loop
                    End If
                    porsTemp.Filter = adFilterNone
                    pcPoint = pcPoint + cPointCoo
                    '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                    If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type1SKUPoint, cPointCoo, aW_SKUPintByCoo(nI).cAmt, aW_SKUPintByCoo(nI).tSKU, tEventsID, tVB_MemPointID, tSKU) Then
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type1SKUPoint & ",SKU Code = " & tSKU & ",Point =" & cPointAvg, tVB_MemPointID)
                    End If
                End If
            Next nI
        End If
    End If
    Exit Sub
ErrHandle:

End Sub

Public Function SP_PRCcTierAmountPointCrd(ByVal porsTier As ADODB.Recordset, ByVal pcAmount As Double, ByVal pcMinTier As Double, ByVal pcMaxTier As Double, Optional ByVal pbChk As Boolean = True) As Double
'------------------------------------------------------
'Call:
'Cmt: คิดจำนวนแต้มที่ได้ลำดับขั้นของ Tier แบบ Amount

'Min 3000  Max 9999999.99
'ลำดับ             Amount         Point
'1                   3000               20
'2                   5000               50
'3                   12000             125
'4                   50000             275

'Ex1..
'Amount ที่นำมาคิดแต้ม  17000
'รอบที่ 1 ได้ลำดับที่ 3 ที่ 12000 = 125 แต้ม เหลือจำนวนที่นไปคิดแต้มต่อได้ 17000-12000 = 5000
'รอบที่ 2 ได้ลำดับที่ 2 ที่ 5000   = 50  แต้ม ไม่เหลือจำนวนที่นำไปคิด
'ดังนั้นจะได้แต้มทั้งหมด = 175 แต้ม

'Ex2..
'Amount ที่นำมาคิดแต้ม  18000
'รอบที่ 1 ได้ลำดับที่ 3 ที่ 12000 = 125 แต้ม เหลือจำนวนที่นไปคิดแต้มต่อได้ 18000-12000 = 6000
'รอบที่ 2 ได้ลำดับที่ 2 ที่ 5000   = 50  แต้ม เหลือจำนวนที่นไปคิดแต้มต่อได้ 6000-5000 = 1000
'1000 ที่เหลือไม่สามารถนำไปคิดแต้มได้เพราะน้อยกว่าค่า Min(3000)
'ดังนั้นจะได้แต้มทั้งหมด = 175 แต้ม

'Ex3..
'Amount ที่นำมาคิดแต้ม  10000000.00
'10000000.00 ไม่สามารถนำไปคิดแต้มได้เพราะมากกว่าค่า Max(9999999.99)
'ดังนั้นจะได้แต้มทั้งหมด = 0  แต้ม
'------------------------------------------------------
    Dim cAmtRang As Double
    Dim cPoint As Double
    Dim cTemp As Double
    Dim nFac As Long
On Error GoTo ErrHandle
    porsTier.MoveFirst
    pcAmount = SP_RNDnAmount(pcAmount)  '*BG 56-05-23 CommSheet TK-ISS3000-195-ST 00 00 01
    Do While Not porsTier.EOF
        cAmtRang = SP_FEDvChkNumeric(porsTier, "FCCtpAmt")
        cPoint = SP_FEDvChkNumeric(porsTier, "FNCtpPoint")
        If pbChk Then
'            If pcAmount >= cAmtRang And pcAmount >= pcMinTier And pcAmount <= pcMaxTier Then
            If pcAmount >= cAmtRang And pcAmount >= pcMinTier Then          '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
                If pcAmount > pcMaxTier Then pcAmount = pcMaxTier           '*Ao 2011/01/21
                If cAmtRang > 0 Then
                    nFac = pcAmount \ cAmtRang
                    If nFac = 0 Then nFac = 1
                Else
                    nFac = 1
                End If
                pcAmount = pcAmount - (cAmtRang * nFac)
                If pcAmount > 0 Then
                    SP_PRCcTierAmountPointCrd = (cPoint * nFac) + SP_PRCcTierAmountPointCrd(porsTier, pcAmount, pcMinTier, pcMaxTier, False)
                Else
                    SP_PRCcTierAmountPointCrd = (cPoint * nFac)
                End If
                Exit Function
            End If
        Else
            If pcAmount >= cAmtRang Then
                If cAmtRang > 0 Then
                    nFac = pcAmount \ cAmtRang
                    If nFac = 0 Then nFac = 1
                Else
                    nFac = 1
                End If
                pcAmount = pcAmount - (cAmtRang * nFac)
                If pcAmount > 0 Then
                    SP_PRCcTierAmountPointCrd = (cPoint * nFac) + SP_PRCcTierAmountPointCrd(porsTier, pcAmount, pcMinTier, pcMaxTier, False)
                Else
                    SP_PRCcTierAmountPointCrd = (cPoint * nFac)
                End If
                Exit Function
            End If
        End If
        porsTier.MoveNext
    Loop
    Exit Function
ErrHandle:
    
End Function

Public Function SP_PRCcTierTimePointCrd(ByVal porsTier As ADODB.Recordset, ByVal pcAmount As Double, ByVal pcRang As Double, ByVal pcPoint As Double, ByVal pcMinTier As Double, ByVal pcMaxTier As Double) As Double
'------------------------------------------------------
'Call:
'Cmt: คิดจำนวนแต้มที่ได้ลำดับขั้นของ Tier แบบ Time

'General
'Amount  25 = 1 แต้ม
'25 = X                   1 =  Y

'Min 3000  Max 9999999.99
'ลำดับ             Amount         Time
'1                   3000               1
'2                   5000               2
'3                   12000             3
'4                   50000             4

'Ex1..
'Amount ที่นำมาคิดแต้ม  17000
'ได้ลำดับที่ 3 ที่ 12000 = ((17000\X) * Y) * Time   = ((17000\25)*1) * 3  = 2040 แต้ม
'ดังนั้นจะได้แต้มทั้งหมด = 2040  แต้ม

'Ex2..
'Amount ที่นำมาคิดแต้ม  18000
'ได้ลำดับที่ 3 ที่ 12000 =((18000\X) * Y) * Time   = ((18000\25)*1) * 3  = 2160 แต้ม
'ดังนั้นจะได้แต้มทั้งหมด = 2160  แต้ม

'Ex3..
'Amount ที่นำมาคิดแต้ม  10000000.00
'10000000.00 ไม่สามารถนำไปคิดแต้มได้เพราะมากกว่าค่า Max(9999999.99)
'ดังนั้นจะได้แต้มทั้งหมด = 0  แต้ม
'*** หมายเหตุ: การคิดของ Time ไม่เหมือนกับแบบ Amount คือ จะไปคิดแค่ขั้นเดียว

'------------------------------------------------------
    Dim cAmtRang As Double
    Dim cFac As Double
    Dim cTemp As Double
On Error GoTo ErrHandle
    porsTier.MoveFirst
    pcAmount = SP_RNDnAmount(pcAmount)  '*BG 56-05-23 CommSheet TK-ISS3000-195-ST 00 00 01
    Do While Not porsTier.EOF
        cAmtRang = SP_FEDvChkNumeric(porsTier, "FCCtpAmt")
        cFac = SP_FEDvChkNumeric(porsTier, "FCCtpTime")
'        If pcAmount >= cAmtRang And pcAmount >= pcMinTier And pcAmount <= pcMaxTier Then
        If pcAmount >= cAmtRang And pcAmount >= pcMinTier Then          '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
            If pcAmount > pcMaxTier Then pcAmount = pcMaxTier
            cTemp = Int(pcAmount / pcRang) * pcPoint
            SP_PRCcTierTimePointCrd = (cTemp * cFac)
            Exit Function
        End If
        porsTier.MoveNext
    Loop
    Exit Function
ErrHandle:
    
End Function


