Public Function SP_GetRndNSaveHD(ByVal pcTotal As Double, ByVal pbUpdTotal As Boolean) As Double
'---------------------------------------------------------------------
'   Call:
'   Cmt:    calculate % for Customer or cust group
'--------------------------------------------------------------------
    Dim tRight$, tSql$, tTotal$
    Dim cDif As Double
    Dim nDec As Double
    Dim nDot%, nI%

    SP_GetRndNSaveHD = 0
    tTotal = SP_FMTcCurPoint(pcTotal, , False)

    'if diff of total not exactly number
    nDot = InStr(tTotal, ".")
    tRight = Mid(tTotal, nDot, Len(tTotal) - nDot + 1)    'จากทศนิยมไป n ตำแหน่ง

    Select Case CDbl(tRight)
        Case 0, 0.25, 0.5, 0.75
            cDif = 0       'or do nothing

        Case Else
            If bVB_CNAlwRnd Then                       'system roucDiff or not
                cDif = UT_nRoundDiff(tRight)
            Else
                cDif = 0
            End If
    End Select
    SP_GetRndNSaveHD = cDif

    'update first Total(before + cDif) and Round Dif into TSHDXXX
    tSql = "UPDATE " & tVB_CNTblHD
    tSql = tSql & " SET FCShdRnd=" & SP_FMTcCurPoint(cDif, , False) & ","
    If pbUpdTotal Then tSql = tSql & "FCShdTotal =" & SP_FMTcCurPoint(pcTotal, , False)
    tSql = tSql & "," & UT_tLastUpdSql
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    'Call DB_ExecuteSQL(tSql)
    Call SP_SQLvExecute(tSql)
End Function

Public Function SP_FMTcUpRound(ByRef pcValue As Variant, Optional ByVal pbToShow As Boolean = True) As Variant
'*Gon 50-02-21,22,23-----------------------------
'   Call:   pcValue as double value
'   Cmt:   return format of number
'----------------------------------------------------------
    Dim nDecAmt As Integer
    Dim cTemp As Double, cTemp2 As Double
        
    nDecAmt = IIf(pbToShow, nVB_CNDecAmtForShw, nVB_CNDecAmtForSav)
    
    cTemp = pcValue * 10 ^ nDecAmt
    If cTemp = Int(cTemp) Then
        cTemp2 = Int(cTemp) / 10 ^ nDecAmt
    Else
        cTemp2 = Int(cTemp + 1) / 10 ^ nDecAmt
    End If
    SP_FMTcUpRound = Format(cTemp2, "########0." & String(nDecAmt, "0"))
    
End Function


