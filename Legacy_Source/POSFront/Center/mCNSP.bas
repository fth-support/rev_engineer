Public Function SP_DATbConnect(ByRef pocnConnect As ADODB.Connection, ByVal ptDBMS As eEN_DBMS, ByVal ptFile$, ByVal ptPwd$, ByVal ptSrc$, Optional ByVal ptPvd$) As Boolean
'----------------------------------------------------------
'   Call:  ptDBMS is database selection
'              ptFile was selected  from Common Dialog(Open)
'              ptPwd is a database password
'              ptSrc is server data source (for SQL)
'              ptPvd is optional of whole string provider
'   Ret:   true, if database was successfully opened
'----------------------------------------------------------
    Dim tFile$, tCon$
    
On Error GoTo ErrHandler
    SP_DATbConnect = False
    
    tFile = Trim(ptFile)
    If tFile = "" Then Exit Function
    
    Select Case ptDBMS
        Case nEN_Dbs1ACS       'access
            If Not SP_FLEbManFile(tFile, nEN_Fle1Exist) Then Exit Function       'not found, exit
            Set pocnConnect = New ADODB.Connection
            If ptPvd = "" Then
                tCon = "Provider=Microsoft.Jet.OLEDB.4.0;"
                tCon = tCon + "Data Source=" + tFile & ";Jet OLEDB:Database Password=" & ptPwd
            Else
                tCon = ptPvd
            End If
            pocnConnect.CursorLocation = adUseClient
            pocnConnect.ConnectionTimeout = 90      '1.5 นาที
            pocnConnect.CommandTimeout = 45
            pocnConnect.Open tCon
            
        Case nEN_Dbs2SQL       'sql
            If Trim(ptSrc) = "" Then Exit Function          'no server
            Set pocnConnect = New ADODB.Connection
            If ptPvd = "" Then
                If tVB_CNDbLoginType = "WINAUTHEN" Then
                    tCon = "Provider=SQLOLEDB.1;Integrated Security=SSPI;Persist Security Info=False;Initial Catalog=" & ptFile & ";Data Source=" & ptSrc
                Else
                    If UCase(tVB_CNDbSQLAuthUsrC) = "ADASOFT" Then
                        tCon = "Provider=SQLOLEDB.1;Password=" & ptPwd & ";Persist Security Info=True;User ID=AdaSoft;Initial Catalog=" & ptFile & ";Data Source=" & ptSrc
                    Else
                        tCon = "Provider=SQLOLEDB.1;Password=" & tVB_CNDbSQLAuthUsrP & ";Persist Security Info=True;User ID=" & tVB_CNDbSQLAuthUsrC & ";Initial Catalog=" & ptFile & ";Data Source=" & ptSrc
                    End If
                End If
        Else
                tCon = ptPvd
            End If
            pocnConnect.CursorLocation = adUseClient
            pocnConnect.ConnectionTimeout = 90     '1.5 นาที
            pocnConnect.CommandTimeout = 45
            pocnConnect.Open tCon
    
    End Select
    
    If pocnConnect.State = adStateOpen Then
        SP_DATbConnect = True
     End If
    
    Exit Function
ErrHandler:
'    SP_DATbConnect = False
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

Public Sub SP_GETxGridCaptionAndKey(ByVal pogdValue As VSFlexGrid, ptKey As String, ptForm As String, Optional ByVal pbUseTag As Boolean = False)
'----------------------------------------------------------------------------
'*Gon 50-07-14
'   Call :  pogdValue -> Grid ,ptKey -> Key in INI File , ptForm -> Form Sector In INI
'   Cmt : For All -> set grid header And ColKey
'----------------------------------------------------------------------------
    Dim tLang1 As String, tLang2 As String
    Dim tTemp As String, tGrpFed As String, tGrpWid As String
    Dim aLang1() As String
    Dim aLang2() As String
    Dim aFed() As String, aWid() As String
    Dim nI As Integer
    
    If Not pbUseTag Then
        tTemp = SP_INItGetLang(ptForm, ptKey, True)
    Else
        tTemp = pogdValue.Tag
    End If
    
    tLang1 = cUT.UT_STRtToken(tTemp, ";", nEN_FedLang1, True)
    tLang2 = cUT.UT_STRtToken(tTemp, ";", nEN_FedLang2, True)
    tGrpFed = cUT.UT_STRtToken(tTemp, ";", nEN_ColFed, True)
    tGrpWid = cUT.UT_STRtToken(tTemp, ";", nEN_ColWidth, True)
    aLang1 = Split(tLang1, ",")
    aLang2 = Split(tLang2, ",")
    aFed = Split(tGrpFed, ",")
    aWid = Split(tGrpWid, ",")
    
    nI = 0
    For nI = 0 To UBound(aLang1)
        With pogdValue
            .ColKey(nI) = Trim(aFed(nI))
            .ColWidth(nI) = Trim(aWid(nI))
            .TextMatrix(0, nI) = IIf(nVB_CNCutLang = 1, aLang1(nI), aLang2(nI))
            .FixedAlignment(nI) = flexAlignCenterCenter
        End With
    Next nI
End Sub

