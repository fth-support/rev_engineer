Public Function SP_CHKbPeriodPreDay() As Boolean
'----------------------------------------------------------
'   Ret: True : อยู่ในช่วงที่ PreviewDay ได้ False : ไม่อยู่ในช่วงที่ PreviewDay
'   Cmt: ตรวจสอบช่วงวันที่ที่สามารถทำรายการ Preview Day ได้
'----------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    SP_CHKbPeriodPreDay = False
    tSql = "SELECT FTPdnCode,FDPdnStartDate,FDPdnEndDate"
    tSql = tSql & vbCrLf & "FROM TCNMPreDayMtn"
    tSql = tSql & vbCrLf & "WHERE '" & Format(SP_GETdChkDatePreDay, "YYYY/MM/DD") & "' BETWEEN FDPdnStartDate AND FDPdnEndDate"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            SP_CHKbPeriodPreDay = True
        Else
            SP_CHKbPeriodPreDay = False
        End If
    Else
        SP_CHKbPeriodPreDay = False
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_CHKbPeriodPreDay = False
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Function SP_PRCbChkStaSKUNotAlw(ByVal ptSKUCode As String, ptDeptCode As String, ByVal ptBrdCode As String) As Boolean
'----------------------------------------------------------
'   Ret: True : True : Not Allow Preview Day Fale : Allow Preview Day
'   Cmt:  แยกการทำงานตามการ Register
'----------------------------------------------------------
On Error GoTo ErrHandle
    SP_PRCbChkStaSKUNotAlw = False
    Select Case nVB_RegPreType
        Case 1 'Credit Card
            SP_PRCbChkStaSKUNotAlw = SP_PRCbChkCrdStaSKUNotAlw(ptSKUCode, ptDeptCode, ptBrdCode)
        Case 2 'Member Card
             SP_PRCbChkStaSKUNotAlw = SP_PRCbChkMallStaSKUNotAlw(ptSKUCode, ptDeptCode, ptBrdCode)
        Case 3 'Non Card
            SP_PRCbChkStaSKUNotAlw = SP_PRCbChkMallStaSKUNotAlw(ptSKUCode, ptDeptCode, ptBrdCode)
    End Select
    Exit Function
ErrHandle:
    SP_PRCbChkStaSKUNotAlw = False
End Function

Public Function SP_PRCbChkCrdStaSKUNotAlw(ByVal ptSKUCode As String, ptDeptCode As String, ByVal ptBrdCode As String) As Boolean
'----------------------------------------------------------
'   Ret: True : True : Not Allow Preview Day Fale : Allow Preview Day
'   Cmt: ตรวจสอบว่าสินค้าได้รับอนุญาติให้ใช้ตาราง Preview Day ได้
'----------------------------------------------------------
    Dim tSql As String
    Dim bExit As Boolean
    Dim bFound As Boolean
On Error GoTo ErrHandle
    SP_PRCbChkCrdStaSKUNotAlw = False 'Default ว่าอนุญาต Preview Day
    'Step 1 : ตรวจสอบว่าประเภทบัตรที่ Register มามีการอนุญาต Allow Dept and SKU หรือไม่ ?
    If aW_CardPreDay(1).tStaDeptCode = "Y" Then
         'ระดับ SKU
         '----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        If aW_CardPreDay(1).tStaDataSKU = "Y" Then
            'Allow SKU   Y : มีข้อมูล  N : ไม่มีข้อมูล
            bFound = False
            If aW_CardPreDay(1).tStaDataSKUAlw = "Y" Then
                'กรอง SKU
                orsVB_CNSKUCrd.Filter = "FTCpsAlw = '0' AND FTCpsSKU = '" & ptSKUCode & "'"
                If orsVB_CNSKUCrd.BOF And orsVB_CNSKUCrd.EOF Then
                    'กรองไม่พบ ptSKUCode
                    bExit = True
                    bFound = False
                Else
                    'กรองพบ ptSKUCode
                    bExit = False
                    bFound = True
                End If
                orsVB_CNSKUCrd.Filter = adFilterNone
                If bExit Then
                    SP_PRCbChkCrdStaSKUNotAlw = True
                    Exit Function
                End If
            End If
            
            'Not Allow SKU Y : มีข้อมูล  N : ไม่มีข้อมูล
            If aW_CardPreDay(1).tStaDataSKUNotAlw = "Y" Then
                'กรอง SKU
                orsVB_CNSKUCrd.Filter = "FTCpsAlw = '1' AND FTCpsSKU = '" & ptSKUCode & "'"
                If orsVB_CNSKUCrd.BOF And orsVB_CNSKUCrd.EOF Then
                    'กรองไม่พบ ptSKUCode
                    bExit = False
                Else
                    'กรองพบ ptSKUCode
                    bExit = True
                End If
                orsVB_CNSKUCrd.Filter = adFilterNone
                If bExit Then
                    SP_PRCbChkCrdStaSKUNotAlw = True
                    Exit Function
                Else
                    'ถ้าพบว่าใน Allow SKU และไม่พบใน Not Allow SKU ก็ไม่ต้องตรวจสอบใน Dept/Brd แล้ว
                    If bFound Then
                        SP_PRCbChkCrdStaSKUNotAlw = False
                        Exit Function
                    End If
                End If
            Else
                'ถ้าพบว่าใน Allow SKU และไม่พบใน Not Allow SKU ก็ไม่ต้องตรวจสอบใน Dept/Brd แล้ว
                If bFound Then
                    SP_PRCbChkCrdStaSKUNotAlw = False
                    Exit Function
                End If
            End If
            
        End If 'ระดับ SKU
        '-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        
        'ระดับ Dept/Brd
        '-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        If aW_CardPreDay(1).tStaDataDept = "Y" Then
            'Allow Dept/Brd   Y : มีข้อมูล  N : ไม่มีข้อมูล
            If aW_CardPreDay(1).tStaDataDeptAlw = "Y" Then
                'กรอง Dept/Brd
                bExit = False 'Default กรองพบ ptDeptCode,ptBrdCode
                If ptDeptCode <> "" And ptBrdCode <> "" Then
                    orsVB_CNDeptCrd.Filter = adFilterNone
                    orsVB_CNDeptCrd.Filter = "FTCpcAlw = '0' AND (FTCpcCode = '" & ptDeptCode & "' AND FTCpcBrdCode = '" & ptBrdCode & "')"
                    If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                        orsVB_CNDeptCrd.Filter = adFilterNone
                        orsVB_CNDeptCrd.Filter = "FTCpcAlw = '0' AND (FTCpcCode = '" & ptDeptCode & "' AND FTCpcBrdCode = '')"
                        If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                            orsVB_CNDeptCrd.Filter = adFilterNone
                            orsVB_CNDeptCrd.Filter = "FTCpcAlw = '0' AND (FTCpcCode = '" & ptDeptCode & "' AND FTCpcBrdCode = NULL)"
                            If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                orsVB_CNDeptCrd.Filter = adFilterNone
                                orsVB_CNDeptCrd.Filter = "FTCpcAlw = '0' AND (FTCpcCode = '' AND FTCpcBrdCode = '" & ptBrdCode & "')"
                                If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                    orsVB_CNDeptCrd.Filter = adFilterNone
                                    orsVB_CNDeptCrd.Filter = "FTCpcAlw = '0' AND (FTCpcCode = NULL  AND FTCpcBrdCode = '" & ptBrdCode & "' AND FTCpcBrdCode <> '')"
                                    If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                        'กรองไม่พบ ptDeptCode,ptBrdCode
                                        bExit = True
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If 'กรอง Dept/Brd
                orsVB_CNSKUCrd.Filter = adFilterNone
                If bExit Then
                    SP_PRCbChkCrdStaSKUNotAlw = True
                    Exit Function
                End If
            End If 'Allow Dept/Brd   Y : มีข้อมูล  N : ไม่มีข้อมูล
            
            'Not Allow Dept/Brd   Y : มีข้อมูล  N : ไม่มีข้อมูล
            If aW_CardPreDay(1).tStaDataDeptNotAlw = "Y" Then
                'กรอง Dept/Brd
                bExit = True 'Default กรองพบ ptDeptCode,ptBrdCode
                If ptDeptCode <> "" And ptBrdCode <> "" Then
                    orsVB_CNDeptCrd.Filter = adFilterNone
                    orsVB_CNDeptCrd.Filter = "FTCpcAlw = '1' AND (FTCpcCode = '" & ptDeptCode & "' AND FTCpcBrdCode = '" & ptBrdCode & "')"
                    If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                        orsVB_CNDeptCrd.Filter = adFilterNone
                        orsVB_CNDeptCrd.Filter = "FTCpcAlw = '1' AND (FTCpcCode = '" & ptDeptCode & "' AND FTCpcBrdCode = '')"
                        If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                orsVB_CNDeptCrd.Filter = adFilterNone
                                orsVB_CNDeptCrd.Filter = "FTCpcAlw = '1' AND (FTCpcCode = '" & ptDeptCode & "' AND FTCpcBrdCode = NULL)"
                                If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                    orsVB_CNDeptCrd.Filter = adFilterNone
                                    orsVB_CNDeptCrd.Filter = "FTCpcAlw = '1' AND (FTCpcCode = '' AND FTCpcBrdCode = '" & ptBrdCode & "')"
                                    If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                        orsVB_CNDeptCrd.Filter = adFilterNone
                                        orsVB_CNDeptCrd.Filter = "FTCpcAlw = '1' AND (FTCpcCode = NULL  AND FTCpcBrdCode = '" & ptBrdCode & "' AND FTCpcBrdCode <> '')"
                                        If orsVB_CNDeptCrd.BOF And orsVB_CNDeptCrd.EOF Then
                                            'กรองไม่พบ ptDeptCode,ptBrdCode
                                            bExit = False
                                        End If
                                    End If
                                End If
                        End If
                    End If
                End If 'กรอง Dept/Brd
                orsVB_CNDeptCrd.Filter = adFilterNone
                If bExit Then
                    SP_PRCbChkCrdStaSKUNotAlw = True
                    Exit Function
                End If
            End If 'Not Allow Dept/Brd   Y : มีข้อมูล  N : ไม่มีข้อมูล
            
        End If 'ระดับ Dept/Brd
        '-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
    End If 'Step 1
    Exit Function
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    SP_PRCbChkCrdStaSKUNotAlw = False
End Function

