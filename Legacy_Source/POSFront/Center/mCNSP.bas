Public Function SP_EDCtDecrypt(ByVal ptData As String) As String
    Dim oFSO As New FileSystemObject
    Dim tFileBatch As String
    Dim tFileText As String
    Dim tFileName As String
    Dim tDecryptData As String
    Dim nFreeFile As Long
    Dim nLine%
    On Error GoTo ErrorHandles
        Screen.MousePointer = vbHourglass
        nLine = 1
        tFileText = Left(App.Path, InStrRev(App.Path, "\") - 1) + "\POS\encdec\" & "Decrypt.txt"
        If Not SP_FLEbManFile(tFileText, nEN_Fle1Exist) Then
                tFileText = oFSO.GetParentFolderName(oFSO.GetParentFolderName(App.Path))
                tFileText = tFileText & "\POS\encdec\" & "Decrypt.txt"
                If Not SP_FLEbManFile(tFileText, nEN_Fle1Exist) Then
                     tFileText = Left(App.Path, InStrRev(App.Path, "\") - 1) & "\POS\encdec\" & "Decrypt.txt"
                End If
        End If
        nLine = 2
        Call SP_CRTxText(tFileText)
        nLine = 3
        tFileBatch = Left(App.Path, InStrRev(App.Path, "\") - 1) + "\POS\encdec\" & "Decrypt.bat"
        If Not SP_FLEbManFile(tFileBatch, nEN_Fle1Exist) Then
                tFileBatch = oFSO.GetParentFolderName(oFSO.GetParentFolderName(App.Path))
                tFileBatch = tFileBatch & "\POS\encdec\" & "Decrypt.bat"
                If Not SP_FLEbManFile(tFileBatch, nEN_Fle1Exist) Then
                     tFileBatch = Left(App.Path, InStrRev(App.Path, "\") - 1) & "\POS\encdec\" & "Decrypt.bat"
                End If
        End If
        nLine = 4
        'Call SP_FILxWriteDataBatch(tFileBatch, "gTAjLBBtYd1K03zzhSNn+uqsofhcoaYUwNnFh2QjHX4=", False)
        Call SP_FILxWriteDataBatch(tFileBatch, Trim(ptData), False)
        nLine = 5
        '-------------------Start Run Java------------------------------------
        Call SP_RUNxShellBatch(tFileBatch)
        nLine = 6
        '-------------------End Run Java------------------------------------
        
        '-------------------Start Read File------------------------------------
        tDecryptData = SP_REDtFileToString(tFileText)
        nLine = 7
        '-------------------End Read File------------------------------------
        Screen.MousePointer = vbDefault
        SP_EDCtDecrypt = tDecryptData
Exit Function
ErrorHandles:
    Call SP_CRTxLogMallCardEvent("Credit", "SP_EDCtDecrypt", "nLine=", nLine)
    'Call SP_CRTxLogMallCardEvent("Credit", "SP_EDCtDecrypt", "nLine=" & nLine)   '*Thirapong 64-12-10    Log monitor CommSheet TTK-ISS3000-794 TK-ISSUE - Error 5 from EDC Response
    SP_EDCtDecrypt = ""
End Function

Public Sub SP_RUNxShellBatch(ByVal ptPath As String)
