Public Function SP_CHKtCheckCrdCardMEM() As String
'--------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao  2013/02/02
'--------------------------------------------------------------------
Dim tSql As String, tCardNo As String
Dim nEff As Long
Dim orsTemp As ADODB.Recordset, orsTempEx As ADODB.Recordset
    
On Error GoTo ErrHandle
    tSql = SP_GETtStrSql("20130202_1348")
    If tSql = "" Then Exit Function
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine, nEff) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                tCardNo = SP_FEDtChkString(orsTemp, "FTSrcCardNo")
                tSql = SP_GETtStrSql("20130202_1209", tCardNo)
                If tSql = "" Then
                    tCardNo = ""
                    Exit Do
                End If
                If SP_SQLvExecute(tSql, orsTempEx, oDB.ocnOnLine, nEff) = 0 Then
                    If Not (orsTempEx.BOF And orsTempEx.EOF) Then
                        Exit Do
                    Else
                        tCardNo = ""
                    End If
                End If
                orsTemp.MoveNext
            Loop
        End If
    End If
        
    SP_CHKtCheckCrdCardMEM = tCardNo
    Exit Function
ErrHandle:
    SP_CHKtCheckCrdCardMEM = ""
End Function

Public Function SP_GETtStrSql(ByVal ptCase As String, Optional ByVal ptString As String)
'--------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao  2013/02/02
'--------------------------------------------------------------------
Dim tSql As String
Dim tTmp As String

On Error GoTo ErrHandle
    Select Case UCase(ptCase)
        Case UCase("20130202_1209")
                tTmp = ptString
                tSql = "SELECT TOP 1 * FROM"
                tSql = tSql & vbCrLf & "TCNMMallCardMtn MM INNER JOIN"
                tSql = tSql & vbCrLf & "TCNMMallCardRange MR ON MM.FTMcdCode = MR.FTMcdCode"
                tSql = tSql & vbCrLf & "WHERE LEFT(" & tTmp & ",MM.FNMcdDigitChk) BETWEEN LEFT(MR.FTMcrRangeFrom,MM.FNMcdDigitChk)"
                tSql = tSql & vbCrLf & "AND LEFT(MR.FTMcrRangeTo,MM.FNMcdDigitChk)"
                tSql = tSql & vbCrLf & "AND LEN(" & tTmp & ") = MM.FNMcdDigits"
                tSql = tSql & vbCrLf & "AND ISNULL(MM.FTCdcStaNonCard,'N') <> 'Y'"
                tSql = tSql & vbCrLf & "AND (ISNULL(FTMcdAlwPoint,'N') = 'Y' OR ISNULL(FTMcdAlwPointAll,'N') = 'Y')"
                tSql = tSql & vbCrLf & "ORDER BY MM.FNMcdDigitChk DESC"
            Case UCase("20130202_1348")
                tSql = "SELECT * FROM " & tVB_CNTblRC
                tSql = tSql & vbCrLf & "WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & "AND FTShdTransNo='" & tVB_Running & "'"
                tSql = tSql & vbCrLf & "AND FDShdTransDate ='" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & "AND FTShdTransType='" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & "AND FTTdmCode IN ('T002','T003')"
    End Select
    
    If tSql = "" Then
        Call SP_MSGxShowError("55", "ERROR CASE " & ptCase)
    End If
    SP_GETtStrSql = tSql
    Exit Function
ErrHandle:
    SP_GETtStrSql = ""
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function


Public Function SP_GETnMemLPoint(ByRef pcLPoint As Double, ByRef ptCstName As String)
