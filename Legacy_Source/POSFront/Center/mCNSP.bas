Public Function SP_AUTtGenCode(ByVal ptTblName$) As String
'----------------------------------------------------------
'   Call:
'   Cmt:     For All -> option การสร้างเลขที่ Runing
'                 ***KT ยังไม่สมบูรณ์
'                 *KT 52-10-21 SP_AUTtGenCode(ByVal ptTblName$) As String
'----------------------------------------------------------
    Dim orsTemp As New ADODB.Recordset
    Dim orsLast  As New ADODB.Recordset
    Dim tSql$, tLeftCode$, tNextCode$, tMaxNum$, tYear$, tMonth$, tDay$, tCYMDSep$, tErr$
    Dim nLenLeft As Long, nLenRight As Long, nLenFTCode As Long, i As Long
    Dim tMaxDoc$
    Dim tDocNoINI$
    Dim tDocNoISal$
    Dim tDocNoLast$
    Dim nErr As Long
On Error GoTo ErrHandle
    SP_AUTtGenCode = vbNullString

    'get format
    tYear = Right(Format(Year(Date), "0000"), SP_VALcText2Double(tVB_AUTYear) * 2)       'หารูปแบบการใช้ปี
    tMonth = Right(Format(Month(Date), "00"), SP_VALcText2Double(tVB_AUTMonth) * 2)       'หารูปแบบการใช้เดือน
    tDay = Right(Format(Day(Date), "00"), SP_VALcText2Double(tVB_AUTDay) * 2)       'หารูปแบบการใช้วัน

    tCYMDSep = IIf(Len(tVB_AUTChar & tVB_AUTChkBch & tYear & tMonth & tDay) = 0, "", tVB_AUTChar & tVB_AUTChkBch & tYear & tMonth & tDay & "-")       'รูปแบบทางซ้ายของ running number ตาม format ที่ใช้งาน
    nLenFTCode = Len(tCYMDSep & tVB_AUTNum)      'ความยาวทั้งหมดของ format ที่ใช้งาน
    nLenRight = Len(tVB_AUTNum)
    Select Case tVB_AUTStaResetBill
        Case "0" 'ต่อเนื่อง
            nLenLeft = Len(tVB_AUTChar & tVB_AUTChkBch)      'ความยาวของอักขระนำหน้าที่ใช้เป็นรูปแบบ     (เฉพาะตัวอักษร)
            tLeftCode = tVB_AUTChar & tVB_AUTChkBch     'ค้นหารายการเฉพาะที่มีอักขระนำหน้าเหมือนกับอักขระที่ใช้เป็นรูปแบบ
        Case "1"  'ตามปี
            nLenLeft = Len(tVB_AUTChar & tVB_AUTChkBch & tYear)      'ความยาวของอักขระนำหน้าที่ใช้เป็นรูปแบบ     (เฉพาะตัวอักษร + ปี)
            tLeftCode = tVB_AUTChar & tVB_AUTChkBch & tYear       'ค้นหารายการเฉพาะที่มีอักขระนำหน้า+ปี เหมือนกับอักขระที่ใช้เป็นรูปแบบ
    End Select
    '--------------------------------------
    '*KT 54-09-15 V.4.0.1 ML-PRV-068 ป้องกันกรณี tVB_AUTFedCode  = Blank
    If Trim(tVB_AUTFedCode) = "" Then
        Select Case UCase(ptTblName)
            Case UCase("TPSTSalHD")
                tVB_AUTFedCode = "FTShdTransNo"
            Case UCase("TPSHD" & tVB_CNTerminalNum)
                 tVB_AUTFedCode = "FTShdTransNo"
        End Select
         Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Module:mCNSP Function:SP_AUTtGenCode " & "tVB_AUTFedCode  = Blank")
    End If
    
    tSql = "SELECT MAX(" & tVB_AUTFedCode & ")  As MaxValue "        'เอารหัสเอกสารตัวที่มากที่สุด ตามเงื่อนไข
    tSql = tSql & vbCrLf & " FROM " & ptTblName         'จาก ตาราง ที่กำหนด
    tSql = tSql & vbCrLf & " WHERE Len(" & tVB_AUTFedCode & ") = " & nLenFTCode       'เฉพาะรายการที่ความยาวรหัสเท่ากันกับรูปแบบที่ใช้งาน
    tSql = tSql & vbCrLf & " AND Left(" & tVB_AUTFedCode & "," & nLenLeft & ")='" & tLeftCode & "'"  'ที่อักขระของข้อมูลทางซ้ายเท่ากับหรือเหมือนกับอักขระที่ Format ใช้
    tSql = tSql & vbCrLf & " AND (IsNumeric(Right(" & tVB_AUTFedCode & "," & nLenRight & "))=1)"      'จำนวนหลักของ running number เท่ากับจำนวนหลักของ running number ของรูปแบบ Format
    tSql = tSql & vbCrLf & " AND (FTShdStaDoc = '1')"
    If UCase(ptTblName) = UCase("TPSTSalHD") Then tSql = tSql & vbCrLf & " AND  FTTmnNum ='" & tVB_CNTerminalNum & "'"
    tErr = SP_SQLvExecute(tSql, orsTemp)        'if error return error description
    If tErr <> 0 Then
        Call SP_MSGnShowing(tErr, tCS_CNMsgErr, True, "Sql Execute")
        '*KT 54-09-15 V.4.0.1 ML-PRV-068 ถ้า SELECT(MAX) ไม่ได้ให้ Exit Program
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & tErr & " ErrorDesc:" & " Module:mCNSP Events:SP_AUTtGenCode[EndProgram]")
        Call SP_APPxEndProgram
        Exit Function
    End If
    If Not orsTemp Is Nothing Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            tDocNoISal = SP_FEDtChkString(orsTemp, "MaxValue")
        Else
            tDocNoISal = ""
        End If
    Else
        tDocNoISal = ""
    End If
    
    'แก้ไขให้อ่านค่าจาก adaini
    tSql = "SELECT FTCfgValue "
    tSql = tSql & vbCrLf & " FROM TConfigTerminal"
    tSql = tSql & vbCrLf & " WHERE   FTTmnCode = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & " AND  FTCfgCode ='LRunning'"
    tErr = SP_SQLvExecute(tSql, orsLast, ocnCfg)
'    If tErr <> 0 Then
'        Call SP_MSGnShowing(tErr, tCS_CNMsgErr, True, "Sql Execute")
'        Exit Function
'    End If
'    tDocNoINI = SP_FEDtChkString(orsLast, "FTCfgValue")
'    tDocNoLast = tDocNoINI
    If tErr <> 0 Then
         Call SP_MSGnShowing("Running ticket error", tCS_CNMsgErr)
        '*KT 54-09-15 V.4.0.1 ML-PRV-068 ถ้า SELECT TConfigTerminal ไม่ได้ให้ Exit Program
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & tErr & " ErrorDesc:" & " Module:mCNSP Events:SP_AUTtGenCode[EndProgram][2]")
        Call SP_APPxEndProgram
        Exit Function
    End If
    If Not orsLast Is Nothing Then
        If Not (orsLast.BOF And orsLast.EOF) Then
             tDocNoINI = SP_FEDtChkString(orsLast, "FTCfgValue")
        Else
            tDocNoINI = ""
        End If
    Else
        tDocNoINI = ""
    End If
    tDocNoLast = tDocNoINI
     
    '*KT 51-07-25 Comsheet ML- SF- 418
    'Transaction No. Is Wrong When Change Terminal No.
    '----------------------------------------------------------------------------------------------------------------------------------
    If tDocNoINI = "" Then
        tSql = "SELECT  FTTmnLSaleNo AS FTCfgValue"
        tSql = tSql & vbCrLf & " FROM TCNMTerminalMtn"
        tSql = tSql & vbCrLf & " WHERE   FTTmnNum = '" & tVB_CNTerminalNum & "'"
        tErr = SP_SQLvExecute(tSql, orsLast)
'        If tErr <> 0 Then
'            Call SP_MSGnShowing(tErr, tCS_CNMsgErr, True, "Sql Execute")
'            Exit Function
'        End If
'        tDocNoINI = SP_FEDtChkString(orsLast, "FTCfgValue")
        If tErr <> 0 Then
             Call SP_MSGnShowing("Running ticket error", tCS_CNMsgErr)
            '*KT 54-09-15 V.4.0.1 ML-PRV-068 ถ้า SELECT TCNMTerminalMtn ไม่ได้ให้ Exit Program
            Call SP_CRTxWriteLogTerminated("ErrorNumber:" & tErr & " ErrorDesc:" & " Module:mCNSP Events:SP_AUTtGenCode[EndProgram][3]")
            Call SP_APPxEndProgram
            Exit Function
        End If
        If Not orsLast Is Nothing Then
            If Not (orsLast.BOF And orsLast.EOF) Then
                  tDocNoINI = SP_FEDtChkString(orsLast, "FTCfgValue")
            Else
                tDocNoINI = ""
            End If
        Else
            tDocNoINI = ""
        End If
    End If
    '--------------------------------------------------------------------------------------------------------------------------------
    
    If Val(Format(tDocNoISal)) > Val(Format(tDocNoINI)) Then
        tMaxDoc = tDocNoISal
    Else
        tMaxDoc = tDocNoINI
    End If

    If orsTemp.BOF And orsTemp.EOF Then
        SP_AUTtGenCode = tCYMDSep & cUT.UT_STRtFillChar("1", Len(tVB_AUTNum))     'ยังไม่เคยใช้ตามรูปแบบปัจจุบัน ก็เริ่มเป็น เช่น IC-00001
    Else
        '*BG 57-04-19
'        For i = 1 To Len(tVB_AUTNum)     'หาค่ามากสุดที่รับได้ของrunning number ของformat ที่ใช้ ไว้ตรวจสอบว่า Format ที่กำหนด overflow หรือยัง
'            tMaxNum = tMaxNum & "9"
'        Next i
        If bVB_CNRunning And tVB_CNRunning = "2" Then
            'Get MaxRunning
            tMaxNum = "0"
            For i = 1 To Len(tVB_AUTNum) - 1
                tMaxNum = tMaxNum & "9"
            Next i
        Else
            For i = 1 To Len(tVB_AUTNum)
                tMaxNum = tMaxNum & "9"
            Next i
        End If
'        MsgBox tMaxNum & " : " & tMaxDoc '*BG 57-04-22 Test Running
        '***********************************
        tNextCode = Right(tMaxDoc, nLenRight)     'ตัดเอาเฉพาะ running number
        
'        If tMaxNum = tNextCode Then
        If tMaxNum <= tNextCode Then
            'Call SP_MSGnShowing("tms_CN005120", tCS_CNMsgInfo)       'ถ้าถึงค่ามากสุดต้องเปลี่ยนรูปแบบใช้งาน
            'Exit Function
            '*KT 51-12-09  กรรีที่ Run Trans No แล้วจนครบ 99999 จะกลับไปเริ่มใหม่
        '            If SP_VALnText2Double(tDocNoLast) > SP_VALnText2Double(0) And tDocNoLast = tMaxNum Then
            If SP_VALnText2Double(tDocNoLast) > SP_VALnText2Double(0) And tDocNoLast >= tMaxNum Then
                tNextCode = vbNullString
            Else
               tNextCode = tDocNoLast
            End If
        End If

        If tNextCode = vbNullString Then
            tNextCode = "1"     'ใหม่ --> set running number ให้เป็น 1
        Else
            tNextCode = CCur(tNextCode) + 1     'ต่อ -->  สร้างเลขที่เอกสารใหม่ โดยบวกเพิ่ม
        End If
        SP_AUTtGenCode = tCYMDSep & cUT.UT_STRtFillChar(tNextCode, "0", Len(tVB_AUTNum) - Len(tNextCode))        'เข้ารูปแบบรหัสตามการใช้งาน
    End If
    
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsLast)
    Exit Function
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxLogPrg("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "mCNSP" & " Control:mCNSP" & " Events:SP_AUTtGenCode")
End Function


Public Function SP_DEFxGetFmtSystem(ByVal ptTable As String, ByVal ptField As String, Optional ByVal ptDocType As String = 0) As Boolean
'----------------------------------------------------------
'   Call:   ptTable is table to save document,ptField is DocNo Field of table,ptDocType(optional) is Type of document
'   Cmt: For All -> option การสร้างรหัสอัตโนมัติ ต้องการ 2 function
'             W_AUTxGetFmtSystem เรียกใน
'               -   Form_Load::     ex. Call W_AUTxGetFmtSystem
'            W_DEFtGenCode  เรียกใน
'               - ocmGenAuto_Click   ::    ex. otbForm(0).Text = W_DEFtGenCode("TACTPoHD", "FT" & tW_StdHD & "DocNo",1)
'            *KT 54-09-14 V.4.0.1 ML-PRV-068 เปลี่ยนเป็น Function มีการ Return ค่า True,False กรณี Reture False ให้เก็บ Log ลง ExitPrgyyyymmdd.Log
'              เพิ่ม WITH(NOLOCK) สำหรับกรณีที่ตาราง TSysAuto ถูก Lock อยู่
'    Ret:  True : Get data ,False : Not get data ,Default = False
'----------------------------------------------------------
    Dim orsTemp As ADODB.Recordset
    Dim tSql As String, tYear As String, tMonth As String, tDay As String
    Dim bChkBch As Boolean
    Dim nErr As Long
On Error GoTo ErrHandle
   SP_DEFxGetFmtSystem = False
    tSql = "SELECT *"
    tSql = tSql & " From TSysAuto WITH(NOLOCK)"
    tSql = tSql & " WHERE ((FTSatTblName='" & ptTable & "') "
    tSql = tSql & " AND (FTSatFedCode='" & ptField & "')) "
   If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
        If orsTemp Is Nothing Then  '*KT 54-03-25 ป้องกันโปรแกรมหลุด
             Call SP_DATxRsNothing(orsTemp)
             Call SP_MSGnShowing("tms_CN006004", tCS_CNMsgErr)
             Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nVB_CNErrNo & " ErrorDesc:" & " Module:mCNSP Function:SP_DEFxGetFmtSystem " & "Is Nothing ")
             SP_DEFxGetFmtSystem = False
             Exit Function
        Else
             If orsTemp.BOF And orsTemp.EOF Then
                 Call SP_DATxRsNothing(orsTemp)
                 Call SP_MSGnShowing("tms_CN006004", tCS_CNMsgErr)
                 Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nVB_CNErrNo & " ErrorDesc:" & " Module:mCNSP Function:SP_DEFxGetFmtSystem " & "No data")
                 SP_DEFxGetFmtSystem = False
                 Exit Function
             Else
                 tVB_AUTTblName = ptTable     'ตารางการใช้งาน
                 tVB_AUTFedCode = ptField     'Field รหัสเอกสาร
                 tVB_AUTFedType = ptDocType          'ประเภทของเอกสาร เฉพาะตารางที่มีการใช้งานมากกว่า 1 รูปแบบ  เช่น รหัสเอกสารสินค้า ,รหัสเอกสารบริการ
                 tVB_AUTFedTypeName = SP_FEDtChkString(orsTemp, "FTSatDocTypeName")       'ชื่อ Field ประเภทของเอกสาร เฉพาะตารางที่มีการใช้งานมากกว่า 1 รูปแบบ  เช่น รหัสเอกสารสินค้า ,รหัสเอกสารบริการ
                 nVB_AUTFedSize = SP_FEDvChkNumeric(orsTemp, "FNSatFedSize")      'ขนาดของ Field รหัสเอกสาร
                 tVB_AUTStaCallNew = SP_FEDtChkString(orsTemp, "FTSatStaCallNew")     'สถานะการเรียกปุ่ม add new ถายหลังการบันทึก
                 tVB_AUTStaResetBill = SP_FEDtChkString(orsTemp, "FTSatStaResetBill")     'สถานะการกำหนดการเปลี่ยนเลขที่ เอกสาร 0 ต่อเนื่อง  1 เปลี่ยนรอบปี
                 bChkBch = IIf(SP_FEDtChkString(orsTemp, "FTSatStaChkBch") = "1", True, False)    'Gen Code Auto
                 
                 If Abs(SP_VALcText2Double(SP_FEDtChkString(orsTemp, "FTSatStaChkBch"), 0)) = 1 Then
                     tVB_AUTChkBch = Format(Right(tVB_CNBchCode, 5), "00000")
                 Else
                     tVB_AUTChkBch = ""
                 End If
                 
                 If SP_FEDtChkString(orsTemp, "FTSatStaDefUsage") = "1" Then         'ใช้ค่า Default
                     tVB_AUTChar = SP_FEDtChkString(orsTemp, "FTSatDefChar")          'อักขระนำ
                     tVB_AUTYear = SP_FEDtChkString(orsTemp, "FTSatDefYear")
                     tVB_AUTMonth = SP_FEDtChkString(orsTemp, "FTSatDefMonth")
                     tVB_AUTDay = SP_FEDtChkString(orsTemp, "FTSatDefDay")
                     tVB_AUTNum = SP_FEDtChkString(orsTemp, "FTSatDefNum")
                     tVB_AUTCodeFormat = SP_FEDtChkString(orsTemp, "FTSatDefFmtAll")
                 Else    '   ตามผู้ใช้กำหนด
                     tVB_AUTChar = SP_FEDtChkString(orsTemp, "FTSatUsrFmtChar")          'อักขระนำ
                     tVB_AUTYear = SP_FEDtChkString(orsTemp, "FTSatUsrFmtYear")
                     tVB_AUTMonth = SP_FEDtChkString(orsTemp, "FTSatUsrFmtMonth")
                     tVB_AUTDay = SP_FEDtChkString(orsTemp, "FTSatUsrFmtDay")
                     tVB_AUTNum = SP_FEDtChkString(orsTemp, "FTSatUsrFmtNum")
                     tVB_AUTCodeFormat = SP_FEDtChkString(orsTemp, "FTSatUsrFmtAll")
                 End If
             End If
         End If
    Else
        Call SP_DATxRsNothing(orsTemp)
        Call SP_MSGnShowing("tms_CN006004", tCS_CNMsgErr)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nVB_CNErrNo & " ErrorDesc:" & " Module:mCNSP Function:SP_DEFxGetFmtSystem " & tVB_CNErrDescript)
        SP_DEFxGetFmtSystem = False
        Exit Function
    End If
    Call SP_DATxRsNothing(orsTemp)
    SP_DEFxGetFmtSystem = True
    Exit Function
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & " Module:mCNSP Function:SP_DEFxGetFmtSystem[ErrHandle] " & Err.Description)
    'MsgBox Err.Number & "/" & Err.Description
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Sub SP_GETxTransMode()
'------------------------------------------------------
'Call
'Cmt: *KT 50-12-21 เป็นการเก็บประเภทของ Transaction ทั้งหมดที่มีอยุ่ที่ Front ไว้ใน Array
'------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle             '*KT 54-03-25 ป้องกันโปรแกรมหลุด

    ReDim aVB_TransMode(0)
    
    tSql = "SELECT FTSttTranCode,FTSttDesc,FTSttABB,FTSttPrintType"
    tSql = tSql & " FROM TSysTransType"
    tSql = tSql & " ORDER BY FTSttTranCode"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not orsTemp Is Nothing Then  '*KT 54-03-25 ป้องกันโปรแกรมหลุด
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Do While Not orsTemp.EOF
                aVB_TransMode(UBound(aVB_TransMode)).ID = SP_FEDtChkString(orsTemp, "FTSttTranCode")
                aVB_TransMode(UBound(aVB_TransMode)).Name = SP_FEDtChkString(orsTemp, "FTSttDesc")
                aVB_TransMode(UBound(aVB_TransMode)).NameABB = SP_FEDtChkString(orsTemp, "FTSttABB")
                aVB_TransMode(UBound(aVB_TransMode)).PrintType = SP_FEDtChkString(orsTemp, "FTSttPrintType")
                ReDim Preserve aVB_TransMode(UBound(aVB_TransMode) + 1)
                orsTemp.MoveNext
            Loop
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Sub SP_GETxMainMnuAll()
'------------------------------------------------------
'Call
