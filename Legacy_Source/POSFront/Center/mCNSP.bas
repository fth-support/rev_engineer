Public Sub SP_GRDxNewRecAfterEdit(ByVal pogdForm As VSFlexGrid, ByVal pnMaxRow As Long, ByVal ptSeqKey As String)
'----------------------------------------------------------------------------
' Cmt: resize row of grid
'
'----------------------------------------------------------------------------
    'Dim i%, nSeq%      '*Tee 46-12- 02
    Dim i As Long
    Dim nSeq As Long
    Dim nFNSeqNo As Long
    Dim nRowData As Long
    With pogdForm
        nRowData = .Aggregate(flexSTCount, .FixedRows, .ColIndex("KeyEdit"), .rows - 1, .ColIndex("KeyEdit"))
        If .rows < nRowData + pnMaxRow Then
           .rows = .rows + 1
        Else
           If .rows > nRowData + pnMaxRow Then .rows = .rows - 1
       End If
      
      '  .Redraw = False
        For nSeq = .FixedRows To nRowData
            If .IsSubtotal(nSeq) And .TextMatrix(nSeq, .ColIndex("KeyEdit")) <> "4" Then
                .IsCollapsed(nSeq) = flexOutlineExpanded
            End If
        Next nSeq
        nSeq = 0
      
        For i = .FixedRows To nRowData + (.FixedRows - 1)
            If .RowHidden(i) = False Then
                nSeq = nSeq + 1
                nFNSeqNo = .ValueMatrix(i, .ColIndex(ptSeqKey))
                If (nFNSeqNo <> nSeq) And (nFNSeqNo <> 0) And (.TextMatrix(i, .ColIndex("KeyEdit")) = "1") Then
                    .TextMatrix(i, .ColIndex("KeyEdit")) = "2"
                End If
                .TextMatrix(i, .ColIndex(ptSeqKey)) = nSeq
           End If
        Next i
        
        For nSeq = .FixedRows To nRowData
            If .IsSubtotal(nSeq) Then
                .IsCollapsed(nSeq) = flexOutlineCollapsed
            End If
        Next nSeq
        .Redraw = True
    End With
End Sub


Public Sub SP_RECAddClick(ByVal pwForm As Form)
'----------------------------------------------------------
'   Call:   pwForm any Form object
'   Cmt:   clear field to blank, text(index=0) set to enabled and unlock
'----------------------------------------------------------
    Dim oControl As Object
     
    For Each oControl In pwForm
        'text box
        If TypeOf oControl Is TextBox Then
            If oControl.Tag <> vbNullString Then
                oControl.Text = ""
            End If
        End If
        
        'clear label tag 4
        If TypeOf oControl Is Label Then
            If oControl.Tag = "4" Then
                oControl.Caption = ""
            End If
        End If
        
        'option button
        If TypeOf oControl Is OptionButton Then
            If oControl.Index = 0 Then
                oControl.Value = True
            End If
        End If
        
        'check box
        If TypeOf oControl Is CheckBox Then
            If cUT.UT_STRtToken(oControl.Tag, ";", 4) <> "" Then oControl.Value = False
        End If
        
        'date time picker
        If TypeOf oControl Is DTPicker Then
            oControl.Value = Date
        End If
        
        'combo box
        If TypeOf oControl Is ComboBox Then
            If oControl.ListCount <> 0 Then
                oControl.ListIndex = 0
            End If
        End If
        
        'list box
        If TypeOf oControl Is ListBox Then
            If oControl.ListCount <> 0 Then
                oControl.ListIndex = 0
            End If
        End If
    Next
End Sub


Public Sub SP_FRMxSetPosition(ByVal poBtnClick As Object, ByVal poParent As Object, ByVal pwShw As Form, Optional ByVal pnGrdRow As Long = -1, Optional ByVal pnGrdCol As Long = -1)
'----------------------------------------------------------------------------
'   Call :poBtnClick is object ที่ใช้เป็นปุ่มเีรยกฟอร์ม
'            poParent is object ที่ poBtnClick วางอยู่ เช่น อาจเป็น Form,Frame,Tab,Picture box
'            pwShw is form to show modal
'   Cmt: set poition to form  modal when call from other form
'----------------------------------------------------------------------------
  Dim apiCurXY As POINTAPI
  Dim nCurX As Long, nCurY As Long
  
    'find position
    If pnGrdRow < 0 And pnGrdCol < 0 Then   'ปุ่มทั่วไป
        apiCurXY.X = poBtnClick.Left \ Screen.TwipsPerPixelX
        apiCurXY.Y = (poBtnClick.Top + poBtnClick.Height) \ Screen.TwipsPerPixelY
    Else  'vsflexgrid
        apiCurXY.X = poBtnClick.ColPos(pnGrdCol) \ Screen.TwipsPerPixelX
        apiCurXY.Y = (poBtnClick.RowPos(pnGrdRow) + poBtnClick.RowHeight(pnGrdRow)) \ Screen.TwipsPerPixelY
    End If
    Call ClientToScreen(poParent.hwnd, apiCurXY)
    
    nCurX = apiCurXY.X * Screen.TwipsPerPixelX      'ซ้าย /ขวา
    nCurY = apiCurXY.Y * Screen.TwipsPerPixelY      'บน / ล่าง
    
    nVB_CNBrwPosGrdRow = pnGrdRow
    nVB_CNBrwPosGrdCol = pnGrdCol
    nVB_CNBrwPosCurX = nCurX
    nVB_CNBrwPosCurY = nCurY
    nVB_CNBrwPosBtnW = poBtnClick.Width
    nVB_CNBrwPosBtnH = poBtnClick.Height
    If TypeOf poParent Is VSFlexGrid Then
        nVB_CNBrwPosParentCellW = poParent.CellWidth
        nVB_CNBrwPosParentCellH = poParent.CellHeight
    End If
End Sub


Public Sub SP_BRWSetPdtHead(ByVal piCodeOrBar%)
'----------------------------------------------------------
'   Call:  piCodeOrBar as 1:Code first, 2:Bar first
'   Cmt:   select header and field of Product
'               separated by ขึ้นต้นด้วยรหัส/บาร์โค้ด @ ไทย/อังกฤษ @ ใช้ค่า default หรือไม่
'----------------------------------------------------------
    If piCodeOrBar = 1 Then                       'brower start with code
        If bVB_CNShwThai Then                     'thai
            If tVB_CNBrwPdtField = "" Then      'not defined,  from default mCS
                tVB_CNBrwHead = tCS_CNHBThaPdtCode
                tVB_CNBrwField = tCS_CNHBFldPdtCode
            Else
                tVB_CNBrwHead = tCS_CNHBFixThaPdtCode & tVB_CNBrwPdtHeadTha         'from system mUT
                tVB_CNBrwField = tCS_CNHBFixFldPdtCode & tVB_CNBrwPdtField
            End If
        Else                                                          'eng
            If tVB_CNBrwPdtField = "" Then       'not defined,  from default mCS
                tVB_CNBrwHead = tCS_CNHBEngPdtCode
                tVB_CNBrwField = tCS_CNHBFldPdtCode
            Else
                tVB_CNBrwHead = tCS_CNHBFixEngPdtCode & tVB_CNBrwPdtHeadEng         'from system mUT
                tVB_CNBrwField = tCS_CNHBFixFldPdtCode & tVB_CNBrwPdtField
            End If
        End If
    Else                                                               'brower start with bar
        If bVB_CNShwThai Then                      'thai
            If tVB_CNBrwPdtField = "" Then       'not defined,  from default mCS
                tVB_CNBrwHead = tCS_CNHBThaPdtBar
                tVB_CNBrwField = tCS_CNHBFldPdtBar
            Else
                tVB_CNBrwHead = tCS_CNHBFixThaPdtBar & tVB_CNBrwPdtHeadTha         'from system mUT
                tVB_CNBrwField = tCS_CNHBFixFldPdtBar & tVB_CNBrwPdtField
            End If
        Else                                                         'eng
            If tVB_CNBrwPdtField = "" Then      'not defined,  from default mCS
                tVB_CNBrwHead = tCS_CNHBEngPdtBar
                tVB_CNBrwField = tCS_CNHBFldPdtBar
            Else
                tVB_CNBrwHead = tCS_CNHBFixEngPdtBar & tVB_CNBrwPdtHeadEng         'from system
                tVB_CNBrwField = tCS_CNHBFixFldPdtBar & tVB_CNBrwPdtField
            End If
        End If
    End If
End Sub

