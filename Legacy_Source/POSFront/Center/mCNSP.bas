Public Function SP_GETcSumDepositAmt(ByVal ptTerminalNo$, ByVal ptTransNo$, ByVal ptTransType$, ByVal pdTransDate As Date) As Double
'--------------------------------------------------------------
'Ret: ส่งยอดรวมการวางมัดจำ
'Cmt: หายอดรวมของใบมัดจำที่เป็นแม่และมีใบมัดจำลูกที่พ่วงด้วยกัน
'*KT 51-11-09 Deposit/Add Deposit
'*KT 51-11-11
'PH 2.0.0
'-------------------------------------------------------------
    Dim tWhe$
    tWhe = "  WHERE ((FTTmnNum='" & ptTerminalNo & "'"
    tWhe = tWhe & "  AND FTShdTransNo='" & ptTransNo & "'"
    tWhe = tWhe & "  AND FTShdTransType='" & ptTransType & "'"
    tWhe = tWhe & "  AND FDShdTransDate ='" & SP_DTEtStrSTD(pdTransDate) & "')"
    tWhe = tWhe & "  OR "
    tWhe = tWhe & "   (FTShdDepRefTmnNum='" & ptTerminalNo & "'"
    tWhe = tWhe & "  AND FTShdDepReTransNo='" & ptTransNo & "'"
    tWhe = tWhe & "  AND FDShdDepReTransDate='" & SP_DTEtStrSTD(pdTransDate) & "'))"
    tWhe = tWhe & "  AND FTShdTransType IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "','" & Format(tEN_TrnDepositCancel, "00") & "','" & Format(tEN_TrnAddDepositCancel, "00") & "')"

'*KT 51-09-19 ML-SF- 556 Previous Payments is wrong On Redeem Transaction
'   SP_GETcSumDepositAmt = SP_VALcText2Double(SP_SQLtFunction("SUM", "(CASE WHEN  ISNULL(FTShdStaCancel,'N') <>'Y' THEN (ISNULL(FCShdDepositAmt,0) + ISNULL(FCShdRnd,0))  ELSE (-1) * (ISNULL(FCShdDepositAmt,0) +  ISNULL(FCShdRnd,0))  END)", "TPSTDepositHD", tWhe, oDB.ocnOnLine)) 'PH 2.0.0 อ่านข้อมูลจากฐานข้อมูล Server เท่านั้น
   SP_GETcSumDepositAmt = SP_VALcText2Double(SP_SQLtFunction("SUM", "(CASE WHEN  ISNULL(FTShdStaCancel,'N') <>'Y' THEN (ISNULL(FCShdDepositAmt,0))  ELSE (-1) * (ISNULL(FCShdDepositAmt,0))  END)", "TPSTDepositHD", tWhe, oDB.ocnOnLine)) '*Eaw 56-07-24 ไม่บวก Rounding เข้าเพราะตอนนี้ถ้ามี Rouding ถูกบวกเข้าเป็นยอด DepositAmt แล้ว CommSheet TK-ISS3000-287 TR-FAPL-067.xls
End Function

Public Sub SP_GETxSumDepositAmt(ByVal ptTerminalNo$, ByVal ptTransNo$, ByVal ptTransType$, ByVal pdTransDate As Date, ByRef pcDpsAmt As Double, ByRef pcDpsVat As Double)
'--------------------------------------------------------------
'Ret: ค่ามัดจำรวมก่อน Redeem,ค่า Vat ของมัดจำรวมก่อน Redeem
'Cmt: *KT 51-09-22 ให้รายงานออก
'*KT 51-11-11
'PH 2.0.0
'-------------------------------------------------------------
    Dim tWhe$
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim nErr As Long
On Error GoTo ErrHandle
'    tSql = "SELECT SUM(CASE WHEN  ISNULL(FTShdStaCancel,'N') <>'Y' THEN ISNULL(FCShdDepositAmt,0 ) + ISNULL(FCShdRnd,0) ELSE (-1) * (ISNULL(FCShdDepositAmt,0) + ISNULL(FCShdRnd,0) ) END) AS FCDepositAmt"
'    tSql = tSql & vbCrLf & ",SUM(CASE WHEN  ISNULL(FTShdStaCancel,'N') <>'Y' THEN ISNULL(FCShdDepositVat,0) + ISNULL(FCShdRnd,0)  ELSE (-1) * (ISNULL(FCShdDepositVat,0) + ISNULL(FCShdRnd,0) ) END) AS FCDepositVat"
    '*Eaw 56-07-24 ไม่บวก Rounding เข้าเพราะตอนนี้ถ้ามี Rouding ถูกบวกเข้าเป็นยอด DepositAmt แล้ว CommSheet TK-ISS3000-287 TR-FAPL-067.xls
    tSql = "SELECT SUM(CASE WHEN  ISNULL(FTShdStaCancel,'N') <>'Y' THEN ISNULL(FCShdDepositAmt,0 ) ELSE (-1) * (ISNULL(FCShdDepositAmt,0) ) END) AS FCDepositAmt"
    tSql = tSql & vbCrLf & ",SUM(CASE WHEN  ISNULL(FTShdStaCancel,'N') <>'Y' THEN ISNULL(FCShdDepositVat,0)   ELSE (-1) * (ISNULL(FCShdDepositVat,0) ) END) AS FCDepositVat"
    tSql = tSql & vbCrLf & "FROM TPSTDepositHD"
    tSql = tSql & vbCrLf & "  WHERE ((FTTmnNum='" & ptTerminalNo & "'"
    tSql = tSql & vbCrLf & "  AND FTShdTransNo='" & ptTransNo & "'"
    tSql = tSql & vbCrLf & "  AND FTShdTransType='" & ptTransType & "'"
    tSql = tSql & vbCrLf & "  AND FDShdTransDate ='" & SP_DTEtStrSTD(pdTransDate) & "')"
    tSql = tSql & vbCrLf & "  OR "
    tSql = tSql & vbCrLf & "   (FTShdDepRefTmnNum='" & ptTerminalNo & "'"
    tSql = tSql & vbCrLf & "  AND FTShdDepReTransNo='" & ptTransNo & "'"
    tSql = tSql & vbCrLf & "  AND FDShdDepReTransDate='" & SP_DTEtStrSTD(pdTransDate) & "'))"
    tSql = tSql & vbCrLf & "  AND FTShdTransType IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "','" & Format(tEN_TrnDepositCancel, "00") & "','" & Format(tEN_TrnAddDepositCancel, "00") & "')"

    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) <> 0 Then 'PH 2.0.0 อ่านข้อมูลจากฐานข้อมูล Server เท่านั้น
        pcDpsAmt = 0
        pcDpsVat = 0
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If
    If Not (orsTemp.BOF Or orsTemp.EOF) Then
        pcDpsAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCDepositAmt"), True, False)
        pcDpsVat = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCDepositVat"), True, False)
    Else
        pcDpsAmt = 0
        pcDpsVat = 0
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    pcDpsAmt = 0
    pcDpsVat = 0
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Function SP_GETbOPenStore() As Boolean
'--------------------------------------------------------------
'Ret: Status ของการ open/close store True : Open  False : Close
'Cmt: ตรวจสอบสถานะว่า Store ทำทำการ Open Store หรือไม่
'-------------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    SP_GETbOPenStore = False
    tSql = "SELECT FTTmsOpnStore"
    tSql = tSql & " FROM TSysTerminalSta"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not orsTemp Is Nothing Then '*KT 54-03-25 ป้องกันโปรแกรมหลุดให้ตรวจสอบ recordset  ว่า Nothing หรือไม่ก่อนใช้งาน
        If Not (orsTemp.BOF Or orsTemp.EOF) Then
            SP_GETbOPenStore = IIf(SP_FEDtChkString(orsTemp, "FTTmsOpnStore") = "Y", True, False)
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Function SP_USRbMnuAccept(ByVal pnRight As eEN_UsrAutho, ByVal ptMenuName$, Optional ByVal pbShwSplash As Boolean = True) As Boolean
'----------------------------------------------------------
'   Call :  pnRight is eEN_UsrAutho(user right)
'               optional ptMenuName is name of menu
'   Cmt :  True if accept level of user
'               *KT 52-10-21 On Error GoTo ErrHandle
'----------------------------------------------------------
    Dim orsTemp As ADODB.Recordset
    Dim tSql$, bRet As Boolean
On Error GoTo ErrHandle
    SP_USRbMnuAccept = False
    bVB_CNUserOveride = False

    If tCS_CNPwdNoUsr = tVB_CNUserCode And tVB_CNPwdAdaUsrP = tVB_CNUserPwd Then
        SP_USRbMnuAccept = True        'ok pass โดยขออนุญาต
        Exit Function
    End If
    'เช็คก่อน 1 รอบ
     If SP_USRtMnuGetAutho(pnRight, ptMenuName) = "0" Then        '0:ไม่ผ่าน, 1:ผ่าน
            Do
                wCNAllow.tW_ID = ptMenuName
                bVB_ChkMode = False                '*Ao 2013/10/15   V4.0.80
                wCNAllow.Show vbModal        'ฟอร์มเป็นแค่ตัว return รหัสผู้อนุมัติ, กับชื่ออย่างเดียว เผื่อไปใช้งานอื่น
                If tVB_CNUserAlwC <> "" Then
                    SP_USRbMnuAccept = True        'ok pass โดยขออนุญาต
                    bVB_CNUserOveride = True
                    Exit Function
                Else
                    SP_USRbMnuAccept = False        'ok pass โดยขออนุญาต
                    Exit Function
                End If
            Loop
    Else
        tVB_CNUserAlwC = tVB_CNUserCode
        tVB_CNUserAlwN = tVB_CNUserName
        SP_USRbMnuAccept = True        'ok pass โดยผู้ใช้ปัจจุบัน
    End If
    Exit Function
ErrHandle:
    SP_USRbMnuAccept = False
End Function

