                                Else
                                     Set poRs = oDB.ocnOnLine.Execute(ptSql, pnEffect)
                                End If
                            End If
                            pnErr = 0
                            SP_SQLbExecute = True
                            Exit Function
                        End If
                End Select
            End If
            If pbSwithOnline Then
                If pbWaitRep Then
                    tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
                        nCountRound = nCountRound + 1
                        SleepEx 1000, 0
                        tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Loop
                End If
                '*KT 54-03-24 ป้องกันการเกิดโปรแกรมหลุด
                If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute[Offline][1]")
                        If SP_SQLnPrcTimeOutOff(ptSql, poRs, oDB.ocnOffLine, pnEffect) <> 0 Then
                            'If oDB.ocnOffLine.State = adStateOpen Then oDB.ocnOffLine.Close '*KT 54-04-11 V.3.0.56 ทำการ New  oDB.ocnOffLine ใหม่ก่อน Open
                            If Not oDB.ocnOffLine Is Nothing Then Set oDB.ocnOffLine = Nothing
                            If oDB.SQLbConnectDB(oDB.ocnOffLine, Offline) Then
                                Set ocnAll = oDB.ocnOffLine
                                Set oDB.ActiveConnection = ocnAll
                                If IsMissing(poRs) Then
                                    oDB.ocnOffLine.Execute ptSql, pnEffect
                                Else
                                    'Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                                    '*KT 54-03-25
                                    If pbClone Then
                                        'Set orsTemp = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                                        'Call SP_RSTbClone2OfflineEx2(orsTemp, poRs)
                                         Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
    '                                     If poRs Is Nothing Then Set poRs = New ADODB.Recordset
    '                                    If poRs.State = adStateOpen Then poRs.Close
    '                                     poRs.Open ptSql, oDB.ocnOffLine, adOpenStatic, adLockOptimistic
                                        
