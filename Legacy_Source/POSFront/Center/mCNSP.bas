On Error GoTo Err_Handler

    SP_DATbCrtTrigger = False
'    oRe.bW_ReQueryMode = True
    
    If tVB_CNTerminalNum = "" Then
        Call SP_MSGnShowing("tms_CN005119", nCS_Information)
        Exit Function
    End If
    
    tSql = "IF OBJECT_ID ('TRG_Tmp2Sale" & tVB_CNTerminalNum & "', 'TR') IS NOT NULL"
    tSql = tSql & vbCrLf & "DROP TRIGGER TRG_Tmp2Sale" & tVB_CNTerminalNum
    'If pbOnline And oDB.ocnOffLine.ConnectionString <> ocnAll.ConnectionString Then 'PH 2.0.0 OLD
    If pbOnline And oDB.SQLbAvailableServer(oDB.OnServerName, oDB.OnComIP) Then
        If SP_SQLvExecute(tSql, , oDB.ocnOnLine) <> 0 Then
            Call SP_MSGnShowing("tms_CN005190", nCS_Information)
            Exit Function
        End If
    End If
    
    If pbOffline Then
        If SP_SQLvExecute(tSql, , ocnAll) <> 0 Then '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
            Call SP_MSGnShowing("tms_CN005191", nCS_Information)
            Exit Function
        End If
    End If
    '*KT 52-01-14 แก้ไขใน Trigger ให้ Active เมื่อ field FTShdStaDoc มีการ Update
    tSql = "CREATE TRIGGER TRG_Tmp2Sale" & tVB_CNTerminalNum
    tSql = tSql & vbCrLf & "ON TPSHD" & tVB_CNTerminalNum
    tSql = tSql & vbCrLf & "AFTER Update"
    tSql = tSql & vbCrLf & "AS"
    tSql = tSql & vbCrLf & "IF UPDATE(FTShdStaDoc)"
    tSql = tSql & vbCrLf & "BEGIN"
    tSql = tSql & vbCrLf & "BEGIN TRY"
    tSql = tSql & vbCrLf & "EXEC STP_PRCxTmp2Sale 'TPSHD" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "END TRY"
    tSql = tSql & vbCrLf & "BEGIN CATCH"
    tSql = tSql & vbCrLf & "EXEC STP_CRTnLogTemp2Sale '" & tVB_CNTerminalNum & "','" & "Trigger" & "','" & SP_DTEtStrSTD(Date) & "',0"
    tSql = tSql & vbCrLf & "END CATCH"
    tSql = tSql & vbCrLf & "END"
    
'    If pbOnline And oDB.ocnOffLine.ConnectionString <> ocnAll.ConnectionString Then  'PH 2.0.0 OLD
    If pbOnline And oDB.SQLbAvailableServer(oDB.OnServerName, oDB.OnComIP) Then
        If SP_SQLvExecute(tSql, , oDB.ocnOnLine) <> 0 Then
            Call SP_MSGnShowing("tms_CN005119", nCS_Information)
            Exit Function
        End If
    End If
    
    If pbOffline Then
        If SP_SQLvExecute(tSql, , ocnAll) <> 0 Then '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
            Call SP_MSGnShowing("tms_CN005189", nCS_Information)
            Exit Function
        End If
    End If
    
    If pbOffline Then
        tSql = "STP_IMPxEnableTrigger @tTable = '" & "TRG_Tmp2Sale" & tVB_CNTerminalNum & "',@tTrigger = '" & "TPSHD" & tVB_CNTerminalNum & "'"
        If SP_SQLvExecute(tSql, , ocnAll) <> 0 Then '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
            MsgBox "ENABLE TRIGGER is failed.", vbCritical
            Exit Function
        End If
    End If
    
    SP_DATbCrtTrigger = True
'    oRe.bW_ReQueryMode = False
    Exit Function
Err_Handler:
    SP_DATbCrtTrigger = False
'    oRe.bW_ReQueryMode = False
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

