Public Sub SP_TBKxMov2Folder()
    Dim oFSO As New FileSystemObject
    Dim oFolder As Folder
    Dim oFile As File
    Dim tKeepFolder As String
    Dim tFolderNow As String
    Dim tKeepFolderOld As String
On Error GoTo Err_Handler
    
    Set oFolder = oFSO.GetFolder(tVB_CNPthBnkTr)
    For Each oFile In oFolder.Files
        If InStr(1, tKeepFolder, Left(oFile.Name, 25)) = 0 And UCase(oFile.Type) = "DAT FILE" Then   'Date(10)+_+LogCode(14)
            If Mid(Left(oFile.Name, 20), 5, 1) = "-" And Mid(Left(oFile.Name, 20), 8, 1) = "-" And Mid(Left(oFile.Name, 20), 16, Len(Format(tVB_CNTerminalNum, "00000"))) = Format(tVB_CNTerminalNum, "00000") Then
                tKeepFolder = IIf(tKeepFolder = "", "", tKeepFolder & ",") & Left(oFile.Name, 25)
            End If
        End If
    Next
    
    tKeepFolderOld = tKeepFolder
    tFolderNow = cUT.UT_STRtToken(tKeepFolder, ",", 1, False)
    Do While tFolderNow <> ""
        If Not SP_FLDbManFolder(tVB_CNPthBnkTr & "\" & tFolderNow, nEN_Fld1Exist) Then
            Call SP_FLDbManFolder(tVB_CNPthBnkTr & "\" & tFolderNow, nEN_Fld3Create)
        End If
        tFolderNow = cUT.UT_STRtToken(tKeepFolder, ",", 1, False)
    Loop
    If tKeepFolderOld <> "" Then
        For Each oFile In oFolder.Files
            tFolderNow = Left(oFile.Name, 25)
            If InStr(1, tKeepFolderOld, tFolderNow) > 0 Then
                If Not SP_FLEbExist(tVB_CNPthBnkTr & "\" & tFolderNow & "\" & oFile.Name, False) Then
                    oFile.Attributes = Normal
                    'Call oFile.Move(tVB_CNPthBnkTr & "\" & tFolderNow & "\" & oFile.Name) '*KT 52-01-08 น่าจะได้คำสั่ง Copy แล้วค่อย Delete
                    Call oFile.Copy(tVB_CNPthBnkTr & "\" & tFolderNow & "\" & oFile.Name)
                    Call oFile.Delete
                Else
                    If Not SP_FLEbExist(tVB_CNPthBnkTr & "\" & "Z_BAK_" & oFile.Name, False) Then '*KT 52-01-08 ไม่มีแล้ว File ที่ขึ้นว่า  "Z_BAK_" & oFile.Name
                         oFile.Attributes = Normal
                        'Call oFile.Move(tVB_CNPthBnkTr & "\" & "Z_BAK_" & oFile.Name) '*KT 52-01-08 ไม่มีแล้ว File ที่ขึ้นว่า  "Z_BAK_" & oFile.Name
                        Call oFile.Copy(tVB_CNPthBnkTr & "\" & "Z_BAK_" & oFile.Name)
                        Call oFile.Delete
                    End If
                End If
            End If
        Next
    End If
    
    Set oFSO = Nothing
    Set oFolder = Nothing
    Set oFile = Nothing
    Exit Sub
Err_Handler:
    Set oFSO = Nothing
    Set oFolder = Nothing
    Set oFile = Nothing
    Call SP_CRTxLogFile("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Events:SP_TBKxMov2Folder" & " Type:Process move DAT to folder") '*KT 52-12-21 ทำการเก้บ Log การเกิด Error ที่เกี่ยวข้องการการทำ Dat File และ EJ
End Sub

