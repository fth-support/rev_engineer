Public Sub SP_CHKInsHDRecovery(ByVal ptVB_CNTblHD As String, ByVal ptTmnNum As String, ByVal ptShdTransNo As String, ByVal ptShdTransDate As String, ByVal ptShdTransType As String)
    '--------------------------------------------------------------------
    '   Call:
    '   Cmt: '*Bump 57-08-16 comsheet 204_MissingEJ
    '--------------------------------------------------------------------
    '*Bump 57-07-04
    ' 1.วัตถุประสงค์ การเพิ่ม function นี้ เพื่อให้ Recovery ข้อมูลใน TPSHDXXXXX , XXXXX คือ หมายเลขเครื่อง POS
    '   เนื่องจากพบปัญหาว่า ตอนจอบบิล ข้อมูลใน TPSHDXXXXX ไม่มี ทำให้ ข้อมูลไม่สมบูรณ์ และทำให้ เลขที่บิลกระโดด
    '
    ' 2.
    ' 3.
    ' 4.
    Dim tSql As String
    Dim nEff As Long
    Dim orsTmp As New ADODB.Recordset
    On Error GoTo ErrHandle
    '1. ตรวจสอบก่อนว่า Transaction Type อะไรบ้างที่จะให้ Recovery HD
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnSale, tEN_TrnReturn, tEN_TrnDeposit, tEN_TrnTaxExceptSale, tEN_TrnDutyFreeSale, tEN_TrnOtherReceive, tEN_TrnOtherDisbursement
            'Normal Transaction
        Case tEN_TrnSaleTaxInc, tEN_TrnReturnTaxInc
            'Re Entry Sale Include Tax
        Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax
            'Re Entry Sale Manual Tax
        Case Else
            'ไม่ต้องทำ INSERT ใหม่
            Exit Sub
    End Select
    
    '2. เช็คข้อมูลก่อน ถ้าไม่มีจึง INSERT ใหม่
    
    tSql = "SELECT TOP 1 FTShdTransNo,FTShdCshOrCrd  FROM dbo." & ptVB_CNTblHD
    tSql = tSql & vbCrLf & " WITH(NOLOCK) WHERE FTTmnNum = '" & ptTmnNum & "' AND FTShdTransNo = '" & ptShdTransNo & "' AND FDShdTransDate = '" & ptShdTransDate & "' AND FTShdTransType = '" & ptShdTransType & "'"
    '*การเช็คให้เช็คใน Local Database เสมอ เนื่องจาก Architecture ของ ISS3000 จะ Write ลง Local Database ก่อนแล้วจึง ServiceTransfer.exe หยิบไปที่ Server Database
    Set orsTmp = oDB.ocnOffLine.Execute(tSql)
    If Not (orsTmp.EOF And orsTmp.BOF) Then
        'มีข้อมูลแล้ว ไม่ต้อง INSERT ใหม่
        tVB_MallCardIDRef = SP_FEDtChkString(orsTmp, "FTShdCshOrCrd") '*Tao 60-04-27 อ่านค่า Manual Member ID
        Call SP_DATxRsNothing(orsTmp)
        Exit Sub
    End If

    '3. อ่าน SQL INSERT Statement ที่เก็บได้จาก SP_INSxTransHD cal SP_CHKKeepInsHD ตอนเริ่มบิล
    tSql = "SELECT TOP 1 FTSQL  FROM dbo.TInsSQL  "
    tSql = tSql & vbCrLf & " WITH(NOLOCK) WHERE FTTmnNum = '" & ptTmnNum & "' AND FTShdTransNo = '" & ptShdTransNo & "' AND  FDShdTransDate = '" & ptShdTransDate & "' AND FTShdTransType = '" & ptShdTransType & "'"
    Set orsTmp = oDB.ocnOffLine.Execute(tSql)
    tSql = ""
    If (orsTmp.EOF And orsTmp.BOF) Then
        'ถ้าไม่มีข้อมูล ไม่ต้อง INSERT
        Call SP_DATxRsNothing(orsTmp)
        Exit Sub
    End If
    orsTmp.MoveFirst
    tSql = orsTmp.Fields("FTSQL")
    If tSql <> "" Then
        If SP_SQLvExecute(tSql, , , , , nEff) = 0 Then
            If nEff < 1 Then 'แสดงว่า INSERT ไม่สำเร็จ ให้เก็บ Log ไว้ตรวจสอบ
                Call SP_CRTxWriteLogTerminated("Date:" & Date & " Time:" & Time$ & " Recovery:" & ptVB_CNTblHD & "Failed:" & tSql)
            End If
        End If
    End If
    Call SP_DATxRsNothing(orsTmp)
ErrHandle:
    Call SP_DATxRsNothing(orsTmp)
End Sub
