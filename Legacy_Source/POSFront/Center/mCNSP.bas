Public Function SP_SHWbSlipPrinter() As Boolean
'*Bump 56-11-11 Workshop Slip Printer เอาไว้เช็ค กรณีมีการเปิดปิด Printer ใหม่
'* Copy มาจาก wCNMsgErrSlip.SlpInsertion()
'* เอาไว้เช็คว่า Print Type ที่เป็น 2 จะต้องถาม Casehier ว่า "Do you want print slip ?"  ถ้า Slip Printer มีกระดาษเสียบอยู่
'******************************************************************************************************************
'SP_SHWbSlipPrinter  =True คือ ให้ถาม Do you want print slip ?
'SP_SHWbSlipPrinter  =False คือ ไม่ต้องถาม Do you want print slip ?  และให้พิมพ์ออก Thermal Printer เลย
'******************************************************************************************************************
Dim nMSG As Long
Dim nSlpPrintable As Long
Dim tMsg As String
Dim bEndInsert  As Boolean
Dim nLevel As Long

On Error GoTo ErrHandle
    'SP_SHWSlipPrinter = True
    'Insert sheet
    nSlpPrintable = 1
    bEndInsert = False
    SP_SHWbSlipPrinter = True
    With oOposSlip
         nLevel = .nCheckHealth(OPOS_CH_INTERNAL) 'Slip Printer is turned off.  printer ถูกปิดอยู่ จะตรวจสอบกระดาษไม่ได้ จึงให้ Return False เพื่อให้พิมพ์ออก Thermal Printer ได้เลย
        If nLevel = OPOS_E_ILLEGAL Then
            SP_SHWbSlipPrinter = False
            Exit Function
        Else
        
            If Not .oPrinterDeviceEnabled Then
                nVB_MaxCharSlip = 40
                .ClosePrint
                .OpenPrint tVB_CashSlipPrinter, nVB_MaxCharSlip, nVB_CashCodePage 'Open Printer OPOS
                .SlpLineChars = nVB_MaxCharSlip
            End If
        End If
          'Check a sheet/Error check
'          MsgBox ("ResultCode=" & .ResultCode & ",ResultCodeExtended" & .ResultCodeExtended)

            If (.ResultCode <> OPOS_SUCCESS) Then
                
                Select Case .ResultCode
                    Case OPOS_E_TIMEOUT
                        tMsg = "Please Insert slip."    '112&
                        '* ให้พิมพ์ออกที่ Thermal Printer
                        'MsgBox ("1.OPOS_E_TIMEOUT=Fasle")
                        SP_SHWbSlipPrinter = False   '* Slip Printer มีกระดาษ   กรณี   Power Off/Powe On.ต้องถาม Do you want print slip ?
                        Exit Function
                    Case OPOS_E_ILLEGAL '106&
                            SP_SHWbSlipPrinter = False    '***V.B101 ปิด Printer จะเข้า Case นี้
                            Exit Function
                   Case Else
                End Select
            Else
                    SP_SHWbSlipPrinter = False   '* Slip Printer Powe On.ต้องถาม Do you want print slip ?
                    Exit Function
            End If
   End With
   
ErrHandle:
    SP_SHWbSlipPrinter = False
End Function

Public Sub SP_MOVxEJToOnlineRE(ByVal ptDateEJ As String)
'-----------------------------------------------------------------
'Call:
'Cmt: ทำการ ย้าย File EJ ที่เกิดใน ณ ขณะที่เป็น Offline เมื่อเป็น Offline ให้ย้ายไปที่ Path Online ทันที่
'-----------------------------------------------------------------
    Dim tPth$
    Dim tPthEJ$
    Dim oFSO As New FileSystemObject
    Dim oFldInbox As Folder
    Dim oFile As File
    Dim objFile As File
    Dim tTemp As String
    Dim bCopy As Boolean
On Error GoTo ErrHandle
'    tPth = oFSO.GetParentFolderName(App.Path) & "\POSEJ\" & Format(CDate(tUT_SaleDate), "yyMMdd")
    tPth = oFSO.GetParentFolderName(App.Path) & "\POSEJ\" & ptDateEJ
'    MsgBox "tPth = " & tPth
'    tPthEJ = tVB_CNOnDbSrcEJ & "\" & Format(CDate(tUT_SaleDate), "yyMMdd")
    tPthEJ = tVB_CNOnDbSrcEJ & "\" & ptDateEJ
'    MsgBox "tPthEJ = " & tPthEJ
    '*KT 54-09-20 V.4.0.1 ป้องกันกรณีที่ Path EJ Local กับ Server ที่เดียวกัน
    If UCase(tPth) <> UCase(tPthEJ) Then
        'C:\Program Files\ISS3000\POSEJ  กับ
        '\\Ada54a\ISS3000\POSEJ
        If UCase("\\" & cUT.UT_SYStGetComName) = UCase(Mid(tPthEJ, 1, 2 + Len(cUT.UT_SYStGetComName))) Then
            tTemp = Replace(UCase(tPthEJ), UCase("\\" & cUT.UT_SYStGetComName), "")
            If UCase(Right(tPth, Len(tTemp))) = UCase(Right(tPthEJ, Len(tTemp))) Then
                bCopy = False
            Else
                bCopy = True
            End If
        Else
            bCopy = True
        End If
    Else
        bCopy = False
    End If
'    MsgBox "bCopy = " & bCopy
    If bCopy Then
        If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then                        'เช็ค ON LINE หรือไม่        '*Ao 2011/03/19   CommSheet ML-PRV-046- POS Front  Terminate  Reboot and Not responding.xls
'            MsgBox "ON LINE"
            If SP_FLDbManFolder(tPthEJ, nEN_Fld3Create) Then
                If SP_FLDbManFolder(tPth, nEN_Fld3Create) Then
                    Set oFldInbox = oFSO.GetFolder(tPth)
                    For Each oFile In oFldInbox.Files
                        If UCase(Right(oFile.Path, 3)) = ".EJ" Then
                            If oFSO.FileExists(tPthEJ & "\" & oFile.Name) Then
                                Set objFile = oFSO.GetFile(tPthEJ & "\" & oFile.Name)
                                objFile.Attributes = Normal
                            End If
                            oFile.Attributes = Normal
                            Call SP_FLEbManFile(tPthEJ & "\" & oFile.Name, nEN_Fld2Delete)
                             'oFSO.MoveFile oFile.Path, tPthEJ & "\" '*KT 52-01-09 เปลี่ยนเป็นการ Copy File แล้วค่อย Delete ที่หลัง
                            oFSO.CopyFile oFile.Path, tPthEJ & "\"
                            If SP_FLEbManFile(tPthEJ & "\" & oFile.Name, nEN_Fle1Exist) Then
                                Call SP_CRTxLogFile("Send completed:" & oFile.Name)                             '*Ao 2014/03/04 CommSheet TK-ISS3000-468
                                oFSO.DeleteFile oFile.Path
                            Else
                                Call SP_CRTxLogFile("Send not completed:" & oFile.Name)                     '*Ao 2014/03/04 CommSheet TK-ISS3000-468
                            End If
                        End If
                    Next
                Else
                    Call SP_CRTxLogFile("Can not create:" & tPth)                     '*Ao 2014/03/04 CommSheet TK-ISS3000-468
                End If
            Else
                Call SP_CRTxLogFile("Can not create:" & tPthEJ)                     '*Ao 2014/03/04 CommSheet TK-ISS3000-468
            End If
        Else
'            MsgBox "OFF LINE"
            'OFF LINE ไม่ต้องทำการ MOVE EJ
            Call SP_CRTxLogFile("OFF LINE")
        End If
    End If

    Set oFSO = Nothing
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxLogFile("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Events:SP_MOVxEJToOnline" & " Type:Process move EJ to Server") '*KT 52-12-21 ทำการเก้บ Log การเกิด Error ที่เกี่ยวข้องการการทำ Dat File และ EJ
End Sub
Public Function SP_CHKtChangeCardID(ByVal ptCardID As String, ptRcvCode As String) As String
'   Bump 57-07-07 copy มาจาก cTransaction.W_CHKtChangeCardID
'__________________________________________________________________
'   Call:
'   Cmt:    '*Ao 09-08-01 ChangeCardID "12345678XXXX1234"
'                กรณีเกิด Error ให้ Function Return ค่า ptCardID กลับไปให้ *KT 52-09-26
'                PH2-ML-SF-127 เมื่อชำระด้วย Installment Creditจะไม่พิมพ์ หมายเลขบัตรเครดิตรบน Receipt / EJ (ให้พิมพ์แบบเดียวกับบัตรเครดิต)
'__________________________________________________________________
Dim tFirst As String, tLast As String
Const nFirst = 8
Const nLast = 13
'Const tTmp = "XXXX"
'Const tTmp = "XXXX XXXX XXXX "   '*Eaw 56-02-19 เปลี่ยนรูปแบบการพิมพ์หมายเลขบัตรเป็น XXXX XXXX XXXX 1234
Dim tTmp As String
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim tStaValue As String
Dim tStaAlw As String
Dim nI As Integer
Dim tCard As String
Dim nCount As Integer
On Error GoTo Err_Handler
    Select Case UCase(ptRcvCode)
        Case "T002", "T003", "T017", "0" '*Eaw เคส 0 คือกรณีพิมพ์ Emp Card+Member Card
            If (Trim(ptCardID) = "") Then
                SP_CHKtChangeCardID = ptCardID
                Exit Function
            End If

            If bVB_ChkMarkX Then
                Select Case Trim(tVB_OptionMarkX)
                    Case "1"
                        tTmp = ""                                                                   '*Ao 2013/08/26
                        If Len(ptCardID) > 8 Then
                            For nI = 1 To Len(ptCardID) - 8
                                tTmp = tTmp & "X"
                            Next nI
                            tFirst = Left(ptCardID, 4)
                            tLast = Right(ptCardID, 4)
                            tCard = tFirst & tTmp & tLast
                            tTmp = ""
                            For nI = 1 To Len(tCard)
                                Select Case nI
                                    Case 5, 9, 13, 17, 21, 25
                                        tTmp = tTmp & " "
                                End Select
                                tTmp = tTmp & Mid(tCard, nI, 1)
                            Next nI
                        Else
                            If Len(ptCardID) < 5 Then
                                tTmp = ptCardID
                            Else
                                For nI = 1 To Len(ptCardID) - 4
                                    tTmp = tTmp & "X"
                                Next nI
                                tLast = Right(ptCardID, 4)
                                tCard = tTmp & tLast
                                tTmp = ""
                                For nI = 1 To Len(tCard)
                                    Select Case nI
                                        Case 5, 9, 13
                                            tTmp = tTmp & " "
                                    End Select
                                    tTmp = tTmp & Mid(tCard, nI, 1)
                                Next nI
                            End If
                        End If
                        SP_CHKtChangeCardID = tTmp
                        Exit Function
                    Case "2"
                        tTmp = "XXXX XXXX XXXX "
                        '*Eaw 56-05-15 CommSheet TK-ISS3000-159-IT2 00.00.03.xls
                        Select Case Len(ptCardID)
                            Case 1
                                tLast = "000" & ptCardID
                                SP_CHKtChangeCardID = tTmp & tLast
                            Case 2
                                tLast = "00" & ptCardID
                                SP_CHKtChangeCardID = tTmp & tLast
                            Case 3
                                tLast = "0" & ptCardID
                                SP_CHKtChangeCardID = tTmp & tLast
                            Case 4
                                tLast = ptCardID
                                SP_CHKtChangeCardID = tTmp & tLast
                            Case Else
                                tLast = Mid(ptCardID, Len(ptCardID) - 3)
                                SP_CHKtChangeCardID = tTmp & tLast
                         End Select
                         '--------------------------------------------------------------
                         Exit Function
                End Select
            Else
                SP_CHKtChangeCardID = ptCardID
                Exit Function
            End If
    End Select
Err_Handler:
    SP_CHKtChangeCardID = ptCardID
End Function
Public Sub SP_EDCxSplitResponseExtend(ByVal ptType As String, ByVal ptRet$)
'------------------------------------------------------------
    '*Bump 57-05-12 Phase2 เก็บไว้ตรวจสอบปัญหา
    '* PRJ10001TK-PH2-External Spec-Goods Return-00.02.06 FSBT.docx
    '* Page.8
    '* TK-ISS3000-463 TK-ISS3000-FAPL-182   EDC error message and response code
'------------------------------------------------------------
'   Cmt : split response to array
'   Create by : *Korn 55-10-12 Edit เพิ่ม procedure ใหม่
'รูดไม่ผ่าน
        'แคชเชียร ์กด end ที่เครื่องเลย ยังไม่ได้รูด    EDC คืนค่า=> R20004120000000001003902TA5706000001
        'แคชเชียร ์รูดบัตรไปครึ่งทาง แล้วกด end     EDC คืนค่า=> R20004120000000001003902XX5706000001
        'แคชเชียร์ ไม่กดอะไร รอจนเครื่อง end          EDC คืนค่า=> R20004120000000001003902TA5706000001
        'แคชเชียร์ รูดบัตรผิดประเภท, บัตรอื่น            EDC คืนค่า=> R20004120000000001003902IC5706000001
    
        'aTag[0,0]=>R200-
        'aTag [0,1] - [1,1] => 04 - 000000000100
        'aTag [0,2] - [1,2] => 39 - TA
        'aTag [0,3] - [1,3] => 57 - 1

'รูดผ่าน
        'Response:    R2000216XXXXXXXXXXXX93200412000000000100071010151522551404XXXX2201M3712DEMODEMODEMO3806DEMO5139020041081234567842151681680000000005203DBS5410MASTERCARD5501M5601D57060000016206000047640600000296101100000004
        'aTag[0,0]=>R200-                                           1.6.2 ประเภท Command & Response R200:Sale, R201:Pre-Auth, R203:Refund, R902:Echo ...
        'aTag[0/1,1]=>02-XXXXXXXXXXXX9320    *หมายเลขบัตร (ได้ค่า XXXX XXXX XXXX NNNN ตลอด)
        'aTag[0/1,2]=>04-000000000100                 ยอดเงิน 1.00
        'aTag[0/1,3]=>07-1015152255                     เดือนวันเวลา MMDDHHmmss ส่วนปีหามาเพิ่มเอง เป็นปีปัจจุบัน
        'aTag[0/1,4]=>14-XXXX                                  *Expired YYMM (ได้ค่า XXXX ตลอด)
        'aTag[0/1,5]=>22-M                                         1.6.11 ประเภทการรูด E:คีย์เอง, M:แถบแม่เหล็ก, C:ชิป, ...
        'aTag[0/1,6]=>37-DEMODEMODEMO     หมายเลขอ้างอิง
        'aTag[0/1,7]=>38-DEMO51                           *Approved Code
        'aTag[0/1,8]=>39-00                                        1.6.3 Response Code, 00: ไม่ต้องทำอะไร ...
        'aTag[0/1,9]=>41-12345678                           หมายเลขเครื่อง EDC
        'aTag[0/1,10]=>42-168168000000000        หมายเลขร้านค้าที่จดกับ EDC
        'aTag[0/1,11]=>52-DBS                                  Bank ของ EDC
        'aTag[0/1,12]=>54-MASTERCARD            *ชื่อประเภทบัตร VISA, MASTERCARD, AMEX
        'aTag[0/1,13]=>55-M                                        *1.6.6 ตัวย่อประเภทบัตร V:VISA, M:MASTER, E:EZ-LINK, P:PIN DEBIT ...
        'aTag[0/1,14]=>56-D                                        1.6.7 ประเภทของ Bank(Host) D:Normal, A:American Express, N:Diners ...
        'aTag[0/1,15]=>57-000001                             1.6.6 หมายเลขคำสั่ง เลข 6 หลักเริ่มที่ 000001 ...
        'aTag[0/1,16]=>62-000047                             หมายเลข Invoice
        'aTag[0/1,17]=>64-000002                             หมายเลข Batch
        'aTag[0/1,18]=>96-1100000004                    หมายเลขอ้างอิงในการพิมพ์
        
        '*Tao 62-07-19                                                                                                                                                                         '-LMS-' '--- Amount ---' '--- Redeem --'
        'aTag[0/1,99]=>63-Transaction Info            Additional transaction information (Redeem Tender) (63 60 000023 000000010000 000000001000 000000000000 000100 000000006000)
        'aTag[0/1,99]=>98-Card Holder Name      Card Holder's Name (98 26 WONG SOONG TECK)
        
'____________________________________________________________________________________
    Dim tTemp$, tCut$, nLen%, n%, tMsg$
    Dim aTag() As String
    Dim tTmp As String
    Dim tExpired As String
    Dim tCardNo As String
    
    '*Tao 62-07-19 Redeem Tender
    Dim tHolderName As String
    Dim cAmount As Double
    Dim cRedeem As Double
    Dim cBalance As Double
    
    On Error GoTo ErrorHandles
    
    tTemp = ptRet
    If Trim(tTemp) = "" Then Exit Sub
    
'    tVB_EDCDetail = ptRet
    'ตัดรอบแรกก่อน 4 ตัว(fixed)
    ReDim Preserve aTag(1, n)
    tCut = Left(tTemp, 4)
    aTag(0, n) = tCut
    tTemp = Right(tTemp, Len(tTemp) - 4)    'ตัด temp ออก
    
    'เริ่มวนตัดที่เหลือ
    Do While tTemp <> ""
        n = n + 1
        
        'ปรับ size array
        ReDim Preserve aTag(1, n)

        'เก็บค่า tag ลง aTag(0, n)
        tCut = Left(tTemp, 2)   'tag code 2 ตัว(fixed)
        tTemp = Right(tTemp, Len(tTemp) - 2)    'ตัด temp ออก
        aTag(0, n) = tCut
        
        'เก็บค่า value ลง aTag(1, n)
        tCut = Left(tTemp, 2)   'tag length 2 ตัว(fixed)
        tTemp = Right(tTemp, Len(tTemp) - 2)   'ตัด temp ออก
        nLen = Int(tCut)        'ความยาวของ value
        tCut = Left(tTemp, nLen)    'tag value nLen ตัว
        tTemp = Right(tTemp, Len(tTemp) - nLen)   'ตัด temp ออก
        aTag(1, n) = tCut
    Loop
'    tTagDetail = "02" & SP_EDCxCheckTag(aTag, n, "02")
'    tTagDetail = tTagDetail & ",14" & SP_EDCxCheckTag(aTag, n, "14")
'    tTagDetail = tTagDetail & ",38" & SP_EDCxCheckTag(aTag, n, "38")
'    tTagDetail = tTagDetail & ",56" & SP_EDCxCheckTag(aTag, n, "56")
'    tTagDetail = tTagDetail & ",54" & SP_EDCxCheckTag(aTag, n, "54")
'    tTagDetail = tTagDetail & ",55" & SP_EDCxCheckTag(aTag, n, "55")
'    If Len(Trim(tTagDetail)) > 255 Then
'        tVB_EDCDetail = Left(tTagDetail, 255)
'    Else
'        tVB_EDCDetail = tTagDetail
'    End If

    '*Bump 57-04-22 Workshop    CommSheet TK-ISS3000-463-FAPL-182.xls   OPTION-1
    '*Date: DD/MM/YYY Time: hh:mm:ss Card No:    XXXX56789012XXXX 12/14  ApprovalCode:   100 Status: Approved
    '-----------------------------------------------------------------------------------------------
    '*Bump 57-05-12 Phase2 เก็บไว้ตรวจสอบปัญหา
    '* PRJ10001TK-PH2-External Spec-Goods Return-00.02.06 FSBT.docx
    '* Page.8
    '* TK-ISS3000-463 TK-ISS3000-FAPL-182   EDC error message and response code
    tMsg = SP_GETtMsgErrEDC(SP_EDCxCheckTag(aTag, n, "39"))
    
    tExpired = SP_EDCxCheckTag(aTag, n, "14") 'YYMM
    'orbMonth.Text = Right(tExpired, 2)
    'orbYear.Text = Left(tExpired, 2)
    'Bump 57-07-07 เพิ่มการ Mark
    Select Case UCase(ptType)
        Case UCase("E")
            tCardNo = SP_CHKtChangeCardID(SP_EDCxCheckTag(aTag, n, "02"), "0")
        Case Else
            tCardNo = SP_CHKtChangeCardID(SP_EDCxCheckTag(aTag, n, "02"), "T002")
    End Select
        
    'tTmp = "Date:" & Date & " Time:" & Time$ & " Credit No.:" & SP_EDCxCheckTag(aTag, n, "02") & " Expired date(MM/YY):" & Right(tExpired, 2) & "/" & Left(tExpired, 2) & " Approval  Code:" & SP_EDCxCheckTag(aTag, n, "38") & "  Status:" & tMsg & " Response Code:" & SP_EDCxCheckTag(aTag, n, "39")
    Select Case UCase(ptType)
        Case UCase("EE")    '*เอา Credit card ไปรูดที่ Staff discount
            tTmp = "Date:" & Date & " Time:" & Time$ & " Credit No.:" & SP_PRCtStrMarkX(tCardNo) & " Expired date(MM/YY):" & Right(tExpired, 2) & "/" & Left(tExpired, 2) & " Approval  Code:" & SP_EDCxCheckTag(aTag, n, "38") & "  Status: WrongTypecard" & " Response Code:" & SP_EDCxCheckTag(aTag, n, "39") & "(This card is Invalid for Staff Discount.)"
        Case UCase("CE")    '*เอาบัตร  Staff discount  ไปรูดที่  Credit
            tTmp = "Date:" & Date & " Time:" & Time$ & " Credit No.:" & SP_PRCtStrMarkX(tCardNo) & " Expired date(MM/YY):" & Right(tExpired, 2) & "/" & Left(tExpired, 2) & " Approval  Code:" & SP_EDCxCheckTag(aTag, n, "38") & "  Status: WrongTypecard" & " Response Code:" & SP_EDCxCheckTag(aTag, n, "39") & "(This card is Invalid for Credit Payment.)"
        Case Else
            tTmp = "Date:" & Date & " Time:" & Time$ & " Credit No.:" & SP_PRCtStrMarkX(tCardNo) & " Expired date(MM/YY):" & Right(tExpired, 2) & "/" & Left(tExpired, 2) & " Approval  Code:" & SP_EDCxCheckTag(aTag, n, "38") & "  Status:" & tMsg & " Response Code:" & SP_EDCxCheckTag(aTag, n, "39")
    End Select
    Call SP_CRTxLogMallCardExtend(tTmp)
    
    '*Tao 62-07-19 Redeem Tender
    tHolderName = SP_EDCxCheckTag(aTag, n, "98") 'Name of Card Holder/Payee
    'nAmount = (SP_VALcText2Double(SP_EDCxCheckTag(aTag, n, "04")) / 100) 'Transaction Amount
    tTmp = SP_EDCxCheckTag(aTag, n, "63") 'Transaction Info
    If tTmp <> "" Then
        cAmount = SP_VALcText2Double(Mid(tTmp, 7, 12)) / 100 'Sale Amount
        cRedeem = SP_VALcText2Double(Mid(tTmp, 19, 12)) / 100 'Redeem Amount
        cBalance = cAmount - cRedeem
        tTmp = "Date:" & Date & " Time:" & Time$ & " Card Holder:" & tHolderName & " Sale Amount:" & SP_FMTcCurPoint(cAmount, False, False) & " Redeem Amount:" & SP_FMTcCurPoint(cRedeem, False, False) & " Balance Amount:" & SP_FMTcCurPoint(cBalance, False, False)
    Else
        tTmp = "Date:" & Date & " Time:" & Time$ & " Card Holder:" & tHolderName
    End If
    Call SP_CRTxLogMallCardExtend(tTmp)
    '=============================
    
    Select Case UCase(ptType)
        Case UCase("E")
            '   สำหรับ Staff discount ให้เก็บ Log ของ tPurchaseLimit ด้วย
                'Tag : 63 และ 40 ตัว  = 2800000001309500000001309400000000000000
                '28 ตัดทิ้ง    และ ตัดทิ้ง 12 ตัว และเอา 12 ตัว =  000000013094
                '
                'cTransaction.W_PRNbTicketPeople()
                '
                Dim tPurchaseLimit As String
                tPurchaseLimit = ""
                tTmp = ""
                tTmp = SP_EDCxCheckTag(aTag, n, "63")
                tTmp = Right(tTmp, Len(tTmp) - 2)
                tTmp = Mid(tTmp, 13, 12)
                tTmp = Format(tTmp, "#,##0")
                tPurchaseLimit = "Staff Purchase Limit: " & tTmp
                Call SP_CRTxLogMallCardExtend(tPurchaseLimit)
    Case Else
        'No action สำหรับบัตรเครดิต คือ ไม่ต้อง Log  tPurchaseLimit
    End Select

ErrorHandles:
End Sub

Public Function SP_GETtMsgErrEDC(ByVal ptResCode As String) As String
'----------------------------------------------------------
' Call
' Cmt :
'----------------------------------------------------------
Dim tMsg As String

On Error GoTo ErrHandle
    Select Case UCase(ptResCode)
        Case "00": tMsg = "APPROVED" '*Bump 57-07-07
        Case "01": tMsg = "REFER TO CARD ISSUER."
        Case "02": tMsg = "REFER TO CARD ISSUER’S SPECIAL CONDITION."
        Case "03": tMsg = "ERROR CALL HELP SN."
        Case "05": tMsg = "DO NOT HONOUR."
        Case "12": tMsg = "INVALID TRANSACTION (HELP TR)."
        Case "13": tMsg = "INVALID AMOUNT (HELP AM)."
        Case "14": tMsg = "INVALID CARD NUMBER (HELP RE)."
        Case "19": tMsg = "RE-ENTER TRANSACTION."
        Case "25": tMsg = "UNABLE TO LOCATE RECORD ON FILE (HELP NT)."
        Case "30": tMsg = "FORMAT ERROR (HELP FE)."
        Case "31": tMsg = "BANK NOT SUPPORTED BY SWITCH (HELP NS)."
        Case "41": tMsg = "LOST CARD."
        Case "43": tMsg = "STOLEN CARD PICK UP."
        Case "51": tMsg = "TRANSACTION DECLINED."
        Case "54": tMsg = "EXPIRED CARD."
        Case "55": tMsg = "INCORRECT PIN."
        Case "58": tMsg = "TRANSACTION NOT PERMITTED IN TERMINAL."
        Case "76": tMsg = "INVALID PRODUCT CODES (HELP DC)."
        Case "77": tMsg = "RECONCILE ERROR."
        Case "78": tMsg = "TRACE# NOT FOUND."
        Case "89": tMsg = "BAD TERMINAL ID."
        Case "91": tMsg = "ISSUER/SWITCH INOPERATIVE."
        Case "94": tMsg = "DUPLICATE TRANSMISSION."
        Case "96": tMsg = "SYSTEM MALFUNCTION."
        Case "SE": tMsg = "TERMINAL FULL."
        Case "PE": tMsg = "PIN ENTRY ERROR."
        Case "IC": tMsg = "INVALID CARD."
        Case "EC": tMsg = "CARD IS EXPIRED."
        Case "CE": tMsg = "CONNECTION ERROR."
        Case "RE": tMsg = "RECORD NOT FOUND."
        Case "HE": tMsg = "WRONG HOST NUMBER PROVIDED."
        Case "LE": tMsg = "LINE ERROR."
        Case "VB": tMsg = "TRANSACTION ALREADY VOIDED."
        Case "FE": tMsg = "FILE EMPTY / NO TRANSACTION TO VOID."
        Case "WC": tMsg = "CARD NUMBER DOES NOT MATCH."
        'Case "TA": tMsg = "TRANSACTION ABORTED BY USER."
        Case "TA": tMsg = "TIMEOUT ERROR/TRANSACTION ABORTED BY USER"   '*Bump 56-12-03  CommSheet TK-ISS3000-441-FAPL-165.xlsx
            'กรณีที่  ไม่รูดบัตรที่ EDC ปล่อยให้ หมดเวลา ค่าที่  MagIC3DBSECR.dll จะส่ง Response Code มาที่ POS คือ TA  (Tag ID 39)
            'เช่น R20004120000000050023902TA5706000111
        Case "AE": tMsg = "AMOUNT DID NOT MATCH."
        Case "XX": tMsg = "TERMINAL NOT PROPERLY SETUP"
        Case "DL": tMsg = "LOGON NOT LOGON."
        Case "BT": tMsg = "BAD TLV COMMAND FORMAT."
        Case "IS": tMsg = "TRANSACTION NOT FOUND, INQUIRY SUCCESSFUL."
        Case "CD": tMsg = "CARD DECLINED TRANSACTION."
        Case "LH": tMsg = "LOYALTY HOST IS TEMPORARY OFFLINE."
        Case "IN": tMsg = "INVALID CARD (EZLINK CARD IS REFUNDED or BLACKLISTED)."
        Case "CO": tMsg = "CARD NOT READ PROPERLY."
        Case "TL": tMsg = "TOP UP LIMIT EXCEEDED."
        Case "PL": tMsg = "PAYMENT LIMIT EXCEEDED."
        'Case "Y3": tMsg = "TRANSACTION FAILED."
'        Case "Y3": tMsg = "UNKNOWN RESPONSE CODE" '*Bump 57-07-07
        Case "Y3": tMsg = "UNKNOWN RESPONSE CODE FROM EDC." '*Bump 58-05-02
        Case Else
            tMsg = "UNKNOWN RESPONSE CODE FROM EDC./TRANSACTION FAILED."
End Select
    SP_GETtMsgErrEDC = tMsg
Exit Function
ErrHandle:
    SP_GETtMsgErrEDC = "UNKNOWN RESPONSE CODE FROM EDC./TRANSACTION FAILED."
End Function

Public Function SP_MSGtNoSendData() As String
'----------------------------------------------------------------------
'Cmt:  ทำการแสดงข้อความเตือนพร้อมเก็บ Lot ข้อมุลที่ยังไม่มีการส่งขึ้น Server
'----------------------------------------------------------------------
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim tMsg As String
Dim nCount As Long
 
On Error GoTo ErrHandle
    tMsg = ""
    tSql = "SELECT FTTmnNum,FTShdTransNo,FDShdTransDate, FTShdTransType"
    tSql = tSql & vbCrLf & "FROM TPSTSalHD WITH(NOLOCK)"
    tSql = tSql & vbCrLf & "WHERE ISNULL(FTStaSentOnOff,'0') <> '1'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate <= '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " ORDER BY FTShdTransNo ASC"
    If SP_SQLvExecute(tSql, orsTemp) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            nCount = orsTemp.RecordCount
            If nCount > 0 Then
'                '*Tao 61-11-20 ของเดิม
'                tMsg = "DO NOT SEND DATA " & nCount & " TRANSACTION " & " BEGIN " & SP_FEDtChkString(orsTemp, "FTShdTransNo")
'                If nCount > 1 Then
'                    orsTemp.MoveLast
'                    tMsg = tMsg & " TO " & SP_FEDtChkString(orsTemp, "FTShdTransNo")
'                Else
'                    tMsg = tMsg & " TO " & SP_FEDtChkString(orsTemp, "FTShdTransNo")
'                End If
                
                '*Tao 61-11-20 TK-ISS3000-712 TK ISSUE - TK Request - Modify exit terminal for resend transaction
                tMsg = nCount & " trx " & "(" & SP_FEDtChkString(orsTemp, "FTShdTransNo")
                If nCount > 1 Then
                    orsTemp.MoveLast
                    tMsg = tMsg & " - " & SP_FEDtChkString(orsTemp, "FTShdTransNo") & ")"
                Else
                    tMsg = tMsg & ")"
                End If
                tMsg = tMsg & " has not been sent."
            End If
        End If
    End If
'    If tMsg <> "" Then
'        MsgBox tMsg, vbCritical
'        Call SP_CRTxLogPrg("ErrorNumber:0" & " ErrorDesc:" & tMsg & " Form:" & "mCNSP" & " Step:Audit results send data to Server" & " Events:SP_MSGtNoSendData")
'    End If
    Call SP_DATxRsNothing(orsTemp)
    SP_MSGtNoSendData = tMsg
    Exit Function
ErrHandle:
    SP_MSGtNoSendData = ""
End Function

Public Function SP_PRCtCheckEJ() As String
'----------------------------------------------------------
' Call
' Cmt : *Ao 2013/10/18
'----------------------------------------------------------
Dim tPth As String, tTmp As String
Dim oFSO As New FileSystemObject
Dim oFldInbox As Folder
Dim oFile As File
Dim nCount As Integer

On Error GoTo ErrHandle
    nCount = 0
    tTmp = ""
    tPth = oFSO.GetParentFolderName(App.Path) & "\POSEJ\" & Format(CDate(tUT_SaleDate), "yyMMdd")
    Set oFldInbox = oFSO.GetFolder(tPth)
    For Each oFile In oFldInbox.Files
        If UCase(Right(oFile.Path, 3)) = ".EJ" Then
            nCount = nCount + 1
        End If
    Next
    If nCount > 0 Then
        tTmp = "DO NOT SEND FILE EJ " & nCount & " FILE"
'        MsgBox tTmp, vbCritical
    End If
    Set oFSO = Nothing
    SP_PRCtCheckEJ = tTmp
    Exit Function
ErrHandle:
    Set oFSO = Nothing
    SP_PRCtCheckEJ = ""
End Function

Public Sub SP_PRCxCheckEJ()
'----------------------------------------------------------
' Call
' Cmt : *Ao 2013/10/18
'----------------------------------------------------------
Dim tPth As String, tTmp As String
Dim oFSO As New FileSystemObject
Dim oFldInbox As Folder
Dim oFile As File
Dim nCount As Integer
 
On Error GoTo ErrHandle
    nCount = 0
    tPth = oFSO.GetParentFolderName(App.Path) & "\POSEJ\" & Format(CDate(tUT_SaleDate), "yyMMdd")
    Set oFldInbox = oFSO.GetFolder(tPth)
    For Each oFile In oFldInbox.Files
        If UCase(Right(oFile.Path, 3)) = ".EJ" Then
            nCount = nCount + 1
        End If
    Next
    If nCount > 0 Then
        tTmp = "DO NOT SEND FILE EJ " & nCount & " FILE"
        MsgBox tTmp, vbCritical
    End If
    Set oFSO = Nothing
    Exit Sub
ErrHandle:
    Set oFSO = Nothing
End Sub

Public Sub SP_PRCxVirtualTerminalRepOnToOff()
'----------------------------------------------------------
' Call
' Cmt : *Eaw 56-09-30  สำหรับการ Copy ข้อมูล Terminal Maintennance ของ VirtualPos จาก Server มายัง Local
'----------------------------------------------------------
    Dim orsTemp As ADODB.Recordset
    Dim i%, tSql$, tTmp$
    Dim tSqlH$, tSqlT$
    Dim tSqlF$, tSqlV$
    
On Error GoTo ErrHandle

    tSql = "SELECT * FROM TCNMTerminalMtn  WHERE FTTmnStaVM = 'Y'" '*Eaw 56-10-14 เปลี่ยนจาก '1'-->'Y'
    Set orsTemp = oDB.ocnOnLine.Execute(tSql)
'    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) <> 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then 'พบใน Server
            Do While Not orsTemp.EOF
                tSqlF = ""
                tSqlV = ""
                tSqlH = "INSERT INTO TCNMTerminalMtn" & " ("
                tSqlT = " VALUES ("
                For i = 0 To orsTemp.Fields.Count - 1
                    tSqlF = tSqlF & orsTemp.Fields(i).Name & ","
                    Select Case Mid(orsTemp.Fields(i).Name, 2, 1)
                        Case "T"
                            If IsNull(orsTemp.Fields(i)) Then
                                tSqlV = tSqlV & "Null" & ","
                            Else
                                If Len(Trim(orsTemp.Fields(i))) = 0 Then
                                    tSqlV = tSqlV & "Null" & ","
                                Else
                                    tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(orsTemp, orsTemp.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                                End If
                            End If
                        Case "D"
                            If IsNull(orsTemp.Fields(i).Value) Then
                                tSqlV = tSqlV & "Null" & ","
                            Else
                                tSqlV = tSqlV & "'" & UT_tStringDate(orsTemp.Fields(i).Value) & "',"                         'มี เขาเดี่ยว
                            End If
                        Case "N"
                           tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(orsTemp, orsTemp.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                        Case "C"
                            tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(orsTemp, orsTemp.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                    End Select
                    If i = orsTemp.Fields.Count - 1 Then
                        tSqlF = Left(tSqlF, Len(tSqlF) - 1)
                        tSqlV = Left(tSqlV, Len(tSqlV) - 1)
                    End If
                Next i
                tSql = tSqlH & tSqlF & ")" & tSqlT & tSqlV & ")"
                Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
                orsTemp.MoveNext
            Loop
        Else
                'ไม่มีข้อมูลทั้ง Server
        End If
'    End If

    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Sub

