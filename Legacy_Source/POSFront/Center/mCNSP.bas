' Call
' Cmt :   Create File
'----------------------------------------------------------
    Dim oFSO  As New FileSystemObject
    Dim nLof As Long
    Dim tFileName$
    Dim tFld$
    Dim oFile As File
    
On Error GoTo ErrHandler
    tFileName = ptPath
    
