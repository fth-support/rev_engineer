                aVB_TenderMnu(UBound(aVB_TenderMnu)).DescReturn = SP_FEDtChkString(orsTemp, "FTTdmDescReturn")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).SmnID = SP_FEDtChkString(orsTemp, "FTSmnID")
'                aVB_TenderMnu(UBound(aVB_TenderMnu)).Show = SP_FEDvChkNumeric(orsTemp, "FNSmnVisible")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).Show = IIf(SP_FEDtChkString(orsTemp, "FNSmnVisible") = "1", True, False)  '*Eaw 56-05-16 CommSheet TK-ISS3000-180-ST 00 00 01.xls
                aVB_TenderMnu(UBound(aVB_TenderMnu)).Use = IIf(SP_FEDtChkString(orsTemp, "FTSmnUsage") = "1", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).Autho = SP_FEDvChkNumeric(orsTemp, "FNSmnAutho")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaSale = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaSale")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaChange = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaChange")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaReturn = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaReturn")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaMallCard = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaMallCard")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).Menu = SP_FEDtChkString(orsTemp, "FTSpmNameUser") '*KT 53-10-15 Commsheet หมายเลข PH3-ML-SF-131
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaPoint = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaPoint")) = "Y", True, False) '*KT 54-08-03 V.4.0.1 Req.2 Phase4.0(Member Point) Member Point Based on Tender
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaEmpDisc = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaEmpDisc")) = "Y", True, False)       '*Ao 2012/07/30 PRJ10001TK-External Specification Takashimaya Gift Voucher-00.01.00.doc
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaBPSale = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaBPSale")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaBPReturn = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaBPReturn")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaExpDate = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaExpDate")) = "Y", True, False)
                aVB_TenderMnu(UBound(aVB_TenderMnu)).StaReEntry = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTdmStaReEntry")) = "Y", True, False)
                ReDim Preserve aVB_TenderMnu(UBound(aVB_TenderMnu) + 1)
                orsTemp.MoveNext
            Loop
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Sub SP_GETxNameAbb()
'------------------------------------------------------
'Call
'Cmt:  Get data tender type to array for payment
'------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle             '*KT 54-03-25 ป้องกันโปรแกรมหลุด

    ReDim aVB_NameAbb(0)
    
    tSql = "SELECT FTSpmGrp,FNSpmSeq,FTSpmID,FTSpmOrder,FTSpmName,FTSpmNameUser,FTDefLangPri,FTDefLangSec,"
    tSql = tSql & vbCrLf & "FTUsrLangPri,FTUsrLangSec"
    tSql = tSql & vbCrLf & "FROM  TSysPosMenu "
    tSql = tSql & vbCrLf & "WHERE  FTSpmGrp = 'Print Trans'"
    tSql = tSql & vbCrLf & "ORDER BY FNSpmSeq"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not orsTemp Is Nothing Then  '*KT 54-03-25 ป้องกันโปรแกรมหลุด
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Do While Not orsTemp.EOF
                aVB_NameAbb(UBound(aVB_NameAbb)).ID = SP_FEDtChkString(orsTemp, "FNSpmSeq")
                aVB_NameAbb(UBound(aVB_NameAbb)).Name = SP_FEDtChkString(orsTemp, "FTSpmName")
                aVB_NameAbb(UBound(aVB_NameAbb)).NameUsr = SP_FEDtChkString(orsTemp, "FTSpmNameUser")
                aVB_NameAbb(UBound(aVB_NameAbb)).DefLangPri = SP_FEDtChkString(orsTemp, "FTDefLangPri")
                aVB_NameAbb(UBound(aVB_NameAbb)).DefLangSec = SP_FEDtChkString(orsTemp, "FTDefLangSec")
                aVB_NameAbb(UBound(aVB_NameAbb)).UsrLangPri = SP_FEDtChkString(orsTemp, "FTUsrLangPri")
                aVB_NameAbb(UBound(aVB_NameAbb)).UsrLangSec = SP_FEDtChkString(orsTemp, "FTUsrLangSec")
                aVB_NameAbb(UBound(aVB_NameAbb)).SmnID = SP_FEDtChkString(orsTemp, "FTSpmID")
                ReDim Preserve aVB_NameAbb(UBound(aVB_NameAbb) + 1)
                orsTemp.MoveNext
            Loop
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Sub SP_INSxTransHD(ByVal ptTblHD$, Optional ByVal pbSal As Boolean = False, Optional ByRef pbIns As Boolean = False) '***KT 51-11-28 V 1.0.1 Default ให้ pbSal = False
'--------------------------------------------------------
'Call:
'Cmt: *KT 50-12-24 เป็นการ Insert ข้อมูล HD
'          *KT 52-10-21เพิ่ม Parameter pbIns เก็บค่าการ Insert  True :  Insert สำเร็จ             False :  Insert ไม่สำเร็จ
'--------------------------------------------------------
    Dim tSql$
    Dim tSqlF$
    Dim tSqlV$
    Dim tF$
    Dim tStr$
    Dim nEffect As Long
    Dim tOptAlw$
    Dim tTblDT As String
    Dim tTblCD As String
    Dim tTblRC As String
    Dim nEff As Long
    Dim nStep As Long
    Dim orsTemp As ADODB.Recordset
    Dim tTerminal As String, tRepMsg As String
On Error GoTo ErrHandle
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "mCNSP" & " Events:SP_INSxTransHD[1]")
    nStep = 0
    
    If pbSal Then
        tTblDT = "TPSTSalDT"
        tTblCD = "TPSTSalCD"
        tTblRC = "TPSTSalRC"
    Else
        tTblDT = tVB_CNTblDT
        tTblCD = tVB_CNTblCD
        tTblRC = tVB_CNTblRC
    End If
    '*BG 56-09-23
    tTerminal = ""
    If bVB_ReEntryMode Then
        tTerminal = tVB_CNVirTerminalNum
    Else
        tTerminal = tVB_CNPhysicalTerminalNum
    End If
    '****
    tOptAlw = Format(tVB_SelConfigDate & IIf(bVB_CNAlwPrnLPoint, "1", "0") & IIf(bVB_CNAlwPrnToDayPoint, "1", "0") & IIf(bVB_CNAlwPrnBarTicket, "1", "0") & IIf(bVB_CNAlwPrnSKUName, tVB_CNPrnSKUName, "0"), "00000")
    
    tRepMsg = GetSetting("AdaPosMall", "POSFront", "RepMsg")
    
    'Mode Trainning
   tVB_TransactionSub = tVB_Transaction
   If bVB_TrainingMode Then
        tVB_Transaction = Format(tEN_TrnTraining, "00")
   End If
   
    'insert HD (start)
    tVB_Running = SP_AUTtGenCode(ptTblHD)
    
    If tVB_EJDate = "" Then
        tVB_EJDate = tUT_SaleDate               '*Ao 2014/02/03   เก็บ Operation Date
    End If
    
    tSql = "DELETE " & ptTblHD & " WITH(ROWLOCK) "
    tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
    tSql = tSql & "  AND FTShdStaDoc = '2'"
    Call SP_SQLbExecute(tSql, , , nEffect)
    If nEffect > 0 Then
        tSql = "DELETE " & tTblDT & " WITH(ROWLOCK) "
        tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql)
        '*KT 55-08-28 Takashimaya CV
        tSql = "SELECT FTSrcCardNo FROM " & tTblRC & " WITH(NOLOCK) "
        tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
        tSql = tSql & "  AND FTTdmCode ='T018'"
        If SP_SQLvExecute(tSql, orsTemp) <> 0 Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                Do While Not orsTemp.EOF
                    tSql = "UPDATE  TPSTCV  WITH(ROWLOCK) "
                    tSql = tSql & vbCrLf & "  SET FTCVStatusCode = '2'"
                    tSql = tSql & vbCrLf & " , FTSendUp = '0'"
                    tSql = tSql & vbCrLf & " , FTSendDown= '0'"
                    tSql = tSql & vbCrLf & "," & UT_tLastUpdSql
                    tSql = tSql & vbCrLf & "  WHERE  FTCVNum='" & SP_FEDtChkString(orsTemp, "FTSrcCardNo") & "'"
                    tSql = tSql & vbCrLf & "  AND  FTCVStatusCode='1'"
                    Call SP_SQLvExecute(tSql, , oDB.ocnOnLine)
                    orsTemp.MoveNext
                Loop
            End If
        End If
        
        tSql = "DELETE " & tTblRC & " WITH(ROWLOCK) "
        tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql)
        tSql = "DELETE " & tTblCD & " WITH(ROWLOCK) "
        tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql)
        '*KT 54-08-23 V.4.0.1
        tSql = "DELETE TPSTSalePoint WITH(ROWLOCK) "
        tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql)
         '*KT 54-10-06 V.4.0.1Req.6 Phase4.0(Member Point) Promotion Coupon ขอทำการแก้ไขตาม  DCR_5410001
        tSql = "DELETE  TPSTSalPmtCpn WITH(ROWLOCK) "
