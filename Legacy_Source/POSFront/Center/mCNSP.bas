Public Function SP_STRtReplaceChar(ByVal ptString As String, ByVal pvChr As Variant, Optional ptRplWith$ = "") As String
'-------------------------------------
'   Call:   ptString is string that want to check pvChr
'
'   Ret : string without pvChr
'--------------------------------------
    Dim nChrPos As Integer
    Dim tText As String
    Dim tSource As String
    Dim tStrNew As String
    Dim tStartStr As String
    
    SP_STRtReplaceChar = vbNullString
    tSource = ptString
    'tStrNew = Replace(tSource, pvChr, ptRplWith)
    nChrPos = InStr(1, tSource, pvChr, vbTextCompare)
    If nChrPos = 0 Then
        tStrNew = tSource
    Else
        tStartStr = 1
        Do While nChrPos > 0
            tStrNew = tStrNew & Mid(tSource, tStartStr, nChrPos - tStartStr)
            tStartStr = nChrPos + Len(pvChr)
            nChrPos = InStr(tStartStr, tSource, pvChr, vbTextCompare)
        Loop
        tStrNew = tStrNew & Mid(tSource, tStartStr, Len(tSource))
    End If
    SP_STRtReplaceChar = tStrNew
End Function
'***

