                            tEventsID = SP_FEDtChkString(porsTemp, "FTSdtEventMemPoint")
                            cPointAvg = SP_FMTcCurPoint(cPointSec * (cSaleAmt / aW_SKUAmtBySec(nI).cAmt), True, False)
                            cPointSumAvg = cPointSumAvg + cPointAvg
                            If nSeq = nLSeqNo Then
                                If cPointSumAvg <> cPointSec Then
                                    cPointAvg = cPointAvg + (cPointSec - cPointSumAvg)
                                End If
                            End If
'*KT 54-11-23 V.4.0.5 ML-PH4-R3-009 Allow Cooperate Flag in Upload file always "Y" ทำการยกเลิกการใช้งาน FTSdtAlwCoRateFlag
