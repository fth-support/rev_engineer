'--------------------------------------------------------------------
    Dim tSql$
    Dim orsTmp As ADODB.Recordset
    Dim nI As Long
     Dim oPicLogo   As IPictureDisp
On Error GoTo ErrHandle
    bVB_SetImageLogoCpn = False
    tSql = "SELECT  FTPcnID,FTPcnLogo,FOPcnLogo" & vbCrLf
    tSql = tSql & "FROM TCNMPmtCpnJN"
    'Set orsTmp = ocnAll.Execute(tSql)
