Public Function SP_FLEtCipherHash(ByRef ptFileStr$) As String
'---------------------------------------------------------------------------------
'   Cmt:
'
'---------------------------------------------------------------------------------
    Dim nCount As Long, nRet As Long
    Dim tFileHD$
    
    For nCount = 1 To Len(ptFileStr$)
        nRet = nRet + Asc(Mid$(ptFileStr$, nCount, 1))
        nRet = (nRet * 1717 + 1717) Mod 1048576
    Next nCount
    
    For nCount = 1 To 7
        nRet = (nRet * 997 + 997) Mod 1048576
    Next nCount
    
    tFileHD$ = Right$("0000" & Hex$(nRet), 4)
    For nCount = 1 To Len(ptFileStr$)
        nRet = nRet + Asc(Mid$(ptFileStr$, nCount, 1))
        nRet = (nRet * 997 + 997) Mod 1048576
    Next nCount
    
    For nCount = 1 To 7
        nRet = (nRet * 1717 + 1717) Mod 1048576
    Next nCount
    
    SP_FLEtCipherHash$ = tFileHD$ & Right$("0000" & Hex$(nRet), 4)
End Function

Public Sub SP_FLExCipher(ByRef ptFileStr$, Optional ByVal pnRet, Optional ByVal pvFstValue, Optional ByVal pvSndValue)
'---------------------------------------------------------------------------------
'   Cmt:
'
'---------------------------------------------------------------------------------
Static nRValue As Long
Static nMValue As Long
Static nNValue As Long
Const nBigNum As Long = 32768
Dim nCount As Long, nCValue As Long, nDValue As Long

If IsMissing(pnRet) = False Then nRValue = pnRet
If IsMissing(pvFstValue) Then
    If nMValue = 0 Then nMValue = 69
Else
    nMValue = (pvFstValue * 4 + 1) Mod nBigNum
End If
If IsMissing(pvSndValue) Then
    If nNValue = 0 Then nNValue = 47
Else
    nNValue = (pvSndValue * 2 + 1) Mod nBigNum
End If

For nCount = 1 To Len(ptFileStr$)
    nCValue = Asc(Mid$(ptFileStr$, nCount, 1))
    Select Case nCValue
        Case 48 To 57
            nDValue = nCValue - 48
        Case 63 To 90
            nDValue = nCValue - 53
        Case 97 To 122
            nDValue = nCValue - 59
        Case Else
            nDValue = -1
    End Select
    
    If nDValue >= 0 Then
        nRValue = (nRValue * nMValue + nNValue) Mod nBigNum
        nDValue = (nRValue And 63) Xor nDValue
        Select Case nDValue
            Case 0 To 9
                nCValue = nDValue + 48
            Case 10 To 37
                nCValue = nDValue + 53
            Case 38 To 63
                nCValue = nDValue + 59
        End Select
        Mid$(ptFileStr$, nCount, 1) = Chr$(nCValue)
    End If
Next nCount
End Sub

Public Sub SP_FLExEnCipher(ByVal ptFile$, ByVal ptPwd$)
'----------------------------------------------------------------
'   Cmt:
'
'----------------------------------------------------------------
Dim tFileStr$, tFileHD$

    Open ptFile For Binary As #1
        tFileStr$ = Space$(LOF(1))
        Get #1, , tFileStr$
        tFileHD$ = "[Secret]" & SP_FLEtCipherHash$(ptPwd$) & vbCrLf
        Call SP_FLExCipherProcess(tFileStr$, ptPwd$)
        Put #1, 1, tFileHD$
        Put #1, , tFileStr$
    Close #1
End Sub

Public Sub SP_FLExDeCipher(ByVal ptFile$, ByVal ptPwd$)
'----------------------------------------------------------------
'   Cmt:
'
'----------------------------------------------------------------
Dim tFileStr$, tFileHD$

    Open ptFile For Binary As #1
        tFileHD$ = Space$(18)
        tFileStr$ = Space$(LOF(1) - 18)
        Get #1, , tFileHD$
        Get #1, , tFileStr$
    Close #1
    Call SP_FLExCipherProcess(tFileStr$, ptPwd$)
    'Stop
    Kill ptFile
    Open ptFile For Binary As #1
        Put #1, , tFileStr$
    Close #1
End Sub

Public Sub SP_FLExCipherProcess(ByRef ptFileStr$, ByVal ptPwd$)
'----------------------------------------------------------------
'   Cmt:
'
'----------------------------------------------------------------
    Dim nRet, vFstValue, vSndValue
    Dim i
    For i = 1 To Len(ptPwd$)
    nRet = nRet + Asc(Mid$(ptPwd$, i, 1))
    nRet = (nRet * 367 + 331) Mod &HFFF
    vFstValue = ((vFstValue + nRet) * 743 + 599) Mod &HFFF
    vSndValue = ((vSndValue + vFstValue) * 563 + 787) Mod &HFFF
    Next i
    Call SP_FLExCipher(ptFileStr$, nRet, vFstValue, vSndValue)
End Sub

