Public Sub SP_CHKxTransferLogWallet()
'*Tao 60-08-31 ย้าย Log WalletPay ไป OnLine
Dim tSql  As String
Dim tSqlF As String, tSqlV As String, tFedName As String
Dim nCol As Integer
Dim nRet As Long
Dim orsTmpOFF As ADODB.Recordset
Dim dDate As Date
Dim tTime As String
Dim tTmn As String
Dim tRefdoc As String

On Error GoTo ErrHandle
    If Not (oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)) Then Exit Sub 'ต้องติดต่อ OnLine ได้
    If tVB_CNOnDbSrc & ";" & tVB_CNOnDbCurFile = tVB_CNOffDbSrc & ";" & tVB_CNOffDbCurFile Then Exit Sub 'ถ้าเป็น Table เดียวกัน ไม่ต้อง Transfer
    tSql = "SELECT * FROM TPSTLogWallet WITH (NOLOCK) ORDER BY FDDateIns, FTTimeIns"
    Call SP_SQLvExecute(tSql, orsTmpOFF, oDB.ocnOffLine)
    
    If Not (orsTmpOFF.BOF And orsTmpOFF.EOF) Then
        orsTmpOFF.MoveFirst
        Do While Not orsTmpOFF.EOF
            dDate = SP_FEDdChkDate(orsTmpOFF, "FDDateIns")
            tTime = SP_FEDtChkString(orsTmpOFF, "FTTimeIns")
            tTmn = SP_FEDtChkString(orsTmpOFF, "FTTmnNum")
            tRefdoc = SP_FEDtChkString(orsTmpOFF, "FTRefDoc")
            DoEvents
                tSqlF = ""
                tSqlV = ""
                For nCol = 0 To orsTmpOFF.Fields.Count - 1
                    tFedName = orsTmpOFF.Fields(nCol).Name
                    tSqlF = tSqlF & tFedName & ","
                    Select Case Mid(tFedName, 2, 1)
                        Case "T"
                            tSqlV = tSqlV & "'" & SP_STRtSiggleCode(SP_FEDtChkString(orsTmpOFF, tFedName)) & "',"
                        Case "N", "C"
                            tSqlV = tSqlV & SP_FEDvChkNumeric(orsTmpOFF, tFedName) & ","
                        Case "D"
                            If IsNull(orsTmpOFF.Fields(tFedName)) Then
                                tSqlV = tSqlV & "NULL" & ","
                            Else
                                tSqlV = tSqlV & SP_DTEtStrSTD(SP_FEDdChkDate(orsTmpOFF, tFedName), True) & ","
                            End If
                    End Select
                Next nCol
                
                tSqlF = Left(tSqlF, Len(tSqlF) - 1)
                tSqlV = Left(tSqlV, Len(tSqlV) - 1)
                
                tSql = "INSERT INTO TPSTLogWallet" & "(" & tSqlF & ")"
                tSql = tSql & vbCrLf & "VALUES(" & tSqlV & ")"
                
                If SP_SQLvExecute(tSql, , oDB.ocnOnLine, False, , nRet) <> 0 Then GoTo ErrHandle
                tSql = "DELETE FROM TPSTLogWallet WITH (ROWLOCK)"
                tSql = tSql & vbCrLf & "WHERE FDDateIns = " & SP_DTEtStrSTD(dDate, True)
                tSql = tSql & vbCrLf & "AND FTTimeIns = '" & tTime & "'"
                tSql = tSql & vbCrLf & "AND FTTmnNum = '" & tTmn & "'"
                tSql = tSql & vbCrLf & "AND FTRefDoc = '" & tRefdoc & "'"
                Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
            
            orsTmpOFF.MoveNext
        Loop
    End If
    Call SP_DATxRsNothing(orsTmpOFF)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTmpOFF)
End Sub

Public Sub SP_GETxWalletType()
'*Tao 60-08-31 เป็นการเก็บประเภทของ Wallet Type ไว้ใน Array
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle

    ReDim aVB_WalletType(0)
    tSql = "SELECT FTTdmCode,FTTdmType,FTTdmDescSale,FTTdmDescReturn"
    tSql = tSql & " ,FTTdmStaSale,FTTdmStaReturn,FTTdmStaPoint,FTTdmStaMallCard"
    tSql = tSql & " ,FTTdmStaReEntry,FTTdmStaExpDate,FTTdmStaBPReturn,FTTdmStaEmpDisc"
    tSql = tSql & " FROM TCNMTenderMtn WITH (NOLOCK)"
    tSql = tSql & " WHERE FTTdmCode IN ('T019','T020','T021','T022')"
    tSql = tSql & " ORDER BY FTTdmCode"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not orsTemp Is Nothing Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Do While Not orsTemp.EOF
                aVB_WalletType(UBound(aVB_WalletType)).TenderCode = SP_FEDtChkString(orsTemp, "FTTdmCode")
                aVB_WalletType(UBound(aVB_WalletType)).TenderType = SP_FEDtChkString(orsTemp, "FTTdmType")
                aVB_WalletType(UBound(aVB_WalletType)).TenderSale = SP_FEDtChkString(orsTemp, "FTTdmDescSale")
                aVB_WalletType(UBound(aVB_WalletType)).TenderReturn = SP_FEDtChkString(orsTemp, "FTTdmDescReturn")
                aVB_WalletType(UBound(aVB_WalletType)).StaSale = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaSale") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaReturn = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaReturn") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaPoint = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaPoint") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaMallCard = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaMallCard") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaReEntry = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaReEntry") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaExpDate = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaExpDate") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaBPReturn = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaBPReturn") = "Y", True, False)
                aVB_WalletType(UBound(aVB_WalletType)).StaEmpDisc = IIf(SP_FEDtChkString(orsTemp, "FTTdmStaEmpDisc") = "Y", True, False)
                ReDim Preserve aVB_WalletType(UBound(aVB_WalletType) + 1)
                orsTemp.MoveNext
            Loop
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    
    '*Tao 60-09-01 ขยาย FTRemark ใน TPSRCxxxxx
    tSql = "IF NOT EXISTS(SELECT CHARACTER_MAXIMUM_LENGTH FROM information_schema.columns WHERE table_name='TPSRC" & tVB_CNTerminalNum & "' AND COLUMN_NAME='FTSrcRmk' AND DATA_TYPE='varchar' AND CHARACTER_MAXIMUM_LENGTH=-1)"
    tSql = tSql & vbNewLine & "BEGIN"
    tSql = tSql & vbNewLine & "ALTER TABLE [dbo].[TPSRC" & tVB_CNTerminalNum & "] ALTER COLUMN [FTSrcRmk] VARCHAR(MAX) NULL"
    tSql = tSql & vbNewLine & "END"
    Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Function SP_PRCbChkClosing(ByVal ptTransType As String, ByVal ptLogCode As String) As Boolean
    '*Bmp 60-12-20 ตรวจสอบว่า มีการ ออก Closing Report แล้วหรือยังไม่ออก
    '* ถ้ามี Closing แล้ว ให้ Return    True
    '* ถ้ายังไม่มี Closing ให้ Return    False
    '* Transaction Type ที่ตรวจสอบ
    
    '09 = Print Closing Report                      จากรายการขายปกติ
    
    '42 = Closing Report(Tax Include)     จากรายการ Re-Entry       ทำเป็น parameter (ptTransType) ไว้แต่ยังไม่ตรวจสอบ
    '47 = Closing Report(Manual Tax)    จากรายการ Re-Entry      ทำเป็น parameter(ptTransType) ไว้แต่ยังไม่ตรวจสอบ
    
    ' ป้องกันปัญหา CommSheet TTK-ISS3000-665 TK Issue - Close Report generated twice.xlsx
    Dim tSql$
    Dim nCnt1 As Long
    Dim nCnt2 As Long
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle

    nCnt1 = 0
    nCnt2 = 0
    
    SP_PRCbChkClosing = False
    '1.ตรวจสอบใน  TPSTSALHD
    tSql = "SELECT COUNT(FTShdTransNo) AS FNCnt"
    tSql = tSql & " FROM TPSTSALHD WITH(NOLOCK)"
    tSql = tSql & " WHERE   FTShdTransType = '" & ptTransType & "'"
    tSql = tSql & " AND FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & "  AND     FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & "  AND     FTShdStaDoc = '1'"
    tSql = tSql & "  AND     FTLogCode = '" & ptLogCode & "'" '--tVB_Transaction,tUT_LoginCode
    tSql = tSql & "  GROUP BY FTTmnNum "
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine) = 0 Then
        If Not orsTemp Is Nothing Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                nCnt1 = SP_FEDvChkNumeric(orsTemp, "FNCnt")
            End If
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    
    '2.ตรวจสอบใน  tVB_CNTblHD
    tSql = "SELECT COUNT(FTShdTransNo) AS FNCnt "
    tSql = tSql & " FROM " & tVB_CNTblHD & " WITH(NOLOCK)"
    tSql = tSql & " WHERE   FTShdTransType = '" & ptTransType & "'"
    tSql = tSql & " AND FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & "  AND     FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & "  AND     FTShdStaDoc = '1'"
    tSql = tSql & "  AND     FTLogCode = '" & ptLogCode & "'" '--tVB_Transaction,tUT_LoginCode
    tSql = tSql & "  GROUP BY FTTmnNum "
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine) = 0 Then
        If Not orsTemp Is Nothing Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                nCnt2 = SP_FEDvChkNumeric(orsTemp, "FNCnt")
              End If
        End If
    End If

    If (nCnt1 > 0) Or (nCnt2 > 0) Then
        '* ถ้ามี Closing แล้ว ให้ Return True
        SP_PRCbChkClosing = True
    Else
        SP_PRCbChkClosing = False
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_PRCbChkClosing = False
End Function
Public Function SP_PRCbTokenMemSrv(ByVal ptFuncName As String, ByVal ptCardNo As String, ByRef ptRefCardNoToken As String) As Boolean
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim nErr  As Long
    Dim tdbCardNo As String
On Error GoTo ErrHandle
    '*Bmp 61-04-04
    '*Bmp 61-04-10
   '** หา token บน Member ก่อน เพื่อไม่ต้อง token ใหม่
    
    'bVB_AbleToken  '==== Store Para บอกว่า ไม่ต้อง Token ให้ส่งเลขเดิมกลับไป
    If (Not bVB_AlwToken) Or (Len(ptCardNo) < nVB_ChkDigitToken) Then '*Tao 61-10-05 ตรวจสอบจำนวนหลัก ก่อน Token
        ptRefCardNoToken = ptCardNo
        SP_PRCbTokenMemSrv = True
        Exit Function
    End If
    ''************************
    
    '*Tao 61-05-17 ปิดไว้
'    If Not SP_CHKbWebservice() Then
'        SP_PRCbTokenMemSrv = False
'        Exit Function
'    End If
    
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then '*Tao 61-05-17 ถ้า OnLine ค่อยหาจาก Member Server
        '*Tao 61-05-22 ของเดิม
'        tSql = "SELECT TOP 1 FTToken FROM [TPSTTokenLst] WITH(NOLOCK)"
'        tSql = tSql & " WHERE FTValue = '" & ptCardNo & "'"
        
        '*Tao 61-05-22 หาข้อมูลที่ Value ไม่เท่ากับ Token
        tSql = "SELECT TOP 1 FTToken FROM TPSTTokenLst WITH(NOLOCK)"
        tSql = tSql & vbNewLine & "WHERE (ISNULL(FTValue,'')<>'' OR ISNULL(FTToken,'')<>'') AND (FTValue<>FTToken)"
        tSql = tSql & vbNewLine & "AND (FTValue='" & ptCardNo & "')"
        tSql = tSql & vbNewLine & "ORDER BY FDDateIns DESC"
        
        nErr = SP_SQLvExecute(tSql, orsTemp, ocnMember, False, , , True)
        tdbCardNo = ""
        If nErr = 0 Then
            If Not (orsTemp.BOF Or orsTemp.EOF) Then
                tdbCardNo = SP_FEDtChkString(orsTemp, "FTToken")
            End If
            Call SP_DATxRsNothing(orsTemp)
        End If
        ptRefCardNoToken = tdbCardNo
        If tdbCardNo <> "" Then
            SP_PRCbTokenMemSrv = True
        Else
            SP_PRCbTokenMemSrv = False
        End If
    End If
    Exit Function
ErrHandle:
    SP_PRCbTokenMemSrv = False
End Function
