Public Function SP_CHKnDDPMallCard(ByVal pnDTSeqNo As Integer, ByVal pnDiscType As Integer, ByVal ptTransNo As String, ByVal ptTmnNum As String, ByVal pdTranDate As Date) As Integer
'--------------------------------------------------
'Ret    0:Not Allow
'           1:Allow
'           2:Thebest
'--------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim tDctNo$
On Error GoTo Err_Handler
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
        tDctNo = ""
        tSql = "SELECT CD.FNDctNo"
        tSql = tSql & vbCrLf & " FROM " & tVB_CNTblCD & " CD "
        tSql = tSql & vbCrLf & " WHERE  CD.FTShdTransNo = '" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND CD.FTTmnNum = '" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND CD.FDShdTransDate = '" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND CD.FNSdtSeqNo = " & pnDTSeqNo
        tSql = tSql & vbCrLf & " GROUP BY CD.FNDctNo"
        If SP_SQLvExecute(tSql, orsTemp) = 0 Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                Do While Not orsTemp.EOF
                    tDctNo = tDctNo & SP_FEDtChkString(orsTemp, "FNDctNo")
                    orsTemp.MoveNext
                    If Not orsTemp.EOF Then tDctNo = tDctNo & ","
                Loop
            End If
            If tDctNo <> "" Then
                tSql = "SELECT PO.FNDdpNo1,PO.FNDdpNo2 ,PO.FTDdpStaPolicy"
                tSql = tSql & vbCrLf & " FROM TCNMDoubleDiscPolicy PO "
                tSql = tSql & vbCrLf & "  WHERE PO.FNDdpNo1 = " & pnDiscType
                tSql = tSql & vbCrLf & "  AND PO.FNDdpNo2 = " & nEN_Disc11MallCrd
                tSql = tSql & vbCrLf & "  AND PO.FNDdpNo1 IN (" & tDctNo & ")"
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                            orsTemp.Filter = "FTDdpStaPolicy = 'N'"
                            If Not (orsTemp.BOF And orsTemp.EOF) Then
                                SP_CHKnDDPMallCard = 0 'มีตัวที่เป็น N ไม่ให้ผ่าน
                            Else
                                orsTemp.Filter = "FTDdpStaPolicy = 'B'"
                                If Not (orsTemp.BOF And orsTemp.EOF) Then 'มีตัวที่เป็น B
                                    Do While Not orsTemp.EOF
                                        orsTemp.MoveNext
                                    Loop
                                    SP_CHKnDDPMallCard = 2
                                Else
                                    SP_CHKnDDPMallCard = 1
                                End If
                            End If
                    Else
                        SP_CHKnDDPMallCard = 1
                    End If
                Else
                    SP_CHKnDDPMallCard = 0
                End If
            Else
                SP_CHKnDDPMallCard = 1
            End If
        Else
            SP_CHKnDDPMallCard = 0
        End If
    Else
        tSql = "SELECT PO.FNDdpNo1,PO.FNDdpNo2 ,PO.FTDdpStaPolicy"
        tSql = tSql & vbCrLf & " FROM TCNMDoubleDiscPolicy PO LEFT JOIN " & tVB_CNTblCD & " CD ON PO.FNDdpNo1 = CD.FNDctNo"
        tSql = tSql & vbCrLf & " WHERE PO.FNDdpNo1 = " & pnDiscType
        tSql = tSql & vbCrLf & " AND PO.FNDdpNo2 = " & nEN_Disc11MallCrd
        tSql = tSql & vbCrLf & " AND CD.FTShdTransNo = '" & ptTransNo & "'"
        tSql = tSql & vbCrLf & " AND CD.FTTmnNum = '" & ptTmnNum & "'"
        tSql = tSql & vbCrLf & " AND CD.FDShdTransDate = '" & SP_DTEtStrSTD(pdTranDate) & "'"
        tSql = tSql & vbCrLf & " AND CD.FNSdtSeqNo = " & pnDTSeqNo
        tSql = tSql & vbCrLf & " ORDER BY CD.FNScdSeqNo "
        If SP_SQLbExecute(tSql, orsTemp) Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                orsTemp.Filter = "FTDdpStaPolicy = 'N'"
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    SP_CHKnDDPMallCard = 0 'มีตัวที่เป็น N ไม่ให้ผ่าน
                Else
                    orsTemp.Filter = "FTDdpStaPolicy = 'B'"
                    If Not (orsTemp.BOF And orsTemp.EOF) Then 'มีตัวที่เป็น B
                        Do While Not orsTemp.EOF
                            orsTemp.MoveNext
                        Loop
                        SP_CHKnDDPMallCard = 2
                    Else
                        SP_CHKnDDPMallCard = 1
                    End If
                End If
            Else
                SP_CHKnDDPMallCard = 1 'ยังไม่มีส่วนลดอื่น ให้ผ่าน
            End If
        Else
            SP_CHKnDDPMallCard = 0 'Error ไม่ผ่าน
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
Err_Handler:
    SP_CHKnDDPMallCard = 0
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Function

