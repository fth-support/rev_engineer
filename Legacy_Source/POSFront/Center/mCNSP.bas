                    For nI = 0 To nMax - 1
                       If aW_PointDpt(nI).tDptCode <> "" And aW_PointDpt(nI).cRank > 0 Then
                            If tTierType = "Y" Then 'แบบ Amount Tier
                                If Not (orsTier.BOF And orsTier.EOF) Then
                                    cTemp = SP_PRCcTierAmountPoint(orsTier, aW_PointDpt(nI).cAmt, cMinTier, cMaxTier, True)
                                    cTierPoint = cTierPoint + cTemp
                                    If cTemp > 0 Then cTierPointAmt = cTierPointAmt + aW_PointDpt(nI).cAmt
                                End If
                            Else 'แบบ Time Tier
                                cTemp = SP_PRCcTierTimePoint(orsTier, aW_PointDpt(nI).cAmt, aW_PointDpt(nI).cRank, aW_PointDpt(nI).cPoint, cMinTier, cMaxTier)
                                cTierPoint = cTierPoint + cTemp
                                If cTemp > 0 Then cTierPointAmt = cTierPointAmt + aW_PointDpt(nI).cAmt
                            End If
                       End If
                    Next nI
                Else 'TCNTMemCoopRang
                    cTierPoint = 0
                    cTierPointAmt = 0
                End If
            Else 'FDMcmStartDatePoint,FDMcmEndDatePoint,bCal
                cTierPoint = 0
                cTierPointAmt = 0
            End If
        Else 'FTMcmStaPointACT = 'Y'
            cTierPoint = 0
            cTierPointAmt = 0
        End If
        porsCoo.Filter = adFilterNone
       ' ##########################################################################################################################
       'ตรวจสอบค่า Flag Addition Point ของ Tier ว่า Active หรือไม่
       'Tik: เอาค่า Point จาก Tier มา + เพิ่มจาก General
       'ไม่ Tik :เอาค่า Point จาก Tier มาแทนที่
       If SP_FEDtChkString(porsCoo, "FTMcmStaPoint") = "Y" Then
            pcPoint = pcPoint + cGenPoint + cTierPoint
            pcPointAmt = pcPointAmt + cGenPointAmt + cTierPointAmt
            '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
            If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type2CooPoint, cGenPoint, cGenPointAmt, "", tEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type2CooPoint & ",Cooperate ID = Cooperate Point" & ",Point =" & cGenPoint, tVB_MemPointID)
            End If
            '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
            If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type3CooAddPoint, cTierPoint, cTierPointAmt, "", tEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type3CooAddPoint & ",Cooperate ID = Cooperate Point" & ",Point =" & cTierPoint, tVB_MemPointID)
            End If
        Else
            If SP_FEDtChkString(porsCoo, "FTMcmStaPointACT") = "N" Then
                pcPoint = pcPoint + cGenPoint
                pcPointAmt = pcPointAmt + cGenPointAmt
                '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type2CooPoint, cGenPoint, cGenPointAmt, "", tEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type2CooPoint & ",Cooperate ID = Cooperate Point" & ",Point =" & cGenPoint, tVB_MemPointID)
                End If
            Else
                pcPoint = pcPoint + cTierPoint
                pcPointAmt = pcPointAmt + cTierPointAmt
                '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type3CooAddPoint, cTierPoint, cTierPointAmt, "", tEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type3CooAddPoint & ",Cooperate ID = Cooperate Point" & ",Point =" & cTierPoint, tVB_MemPointID)
                End If
            End If
        End If
    Else
        Do While Not porsTemp.EOF
            porsTarget.AddNew
            For nI = 1 To porsTemp.Fields.Count
                Select Case UCase(Mid(porsTemp.Fields(nI - 1).Name, 2, 1))
                    Case "T"
                        porsTarget.Fields(nI - 1).Value = porsTemp.Fields(nI - 1).Value & vbNullString
                    Case "C"
                        porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(porsTemp.Fields(nI - 1).Value & vbNullString)
                    Case "N"
                        porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(porsTemp.Fields(nI - 1).Value & vbNullString)
                    Case "D"
                        If IsNull(porsTemp.Fields(nI - 1).Value) Then
                            porsTarget.Fields(nI - 1).Value = "Null"
                        Else
                           porsTarget.Fields(nI - 1).Value = porsTemp.Fields(nI - 1).Value
                        End If
                End Select
            Next nI
            porsTemp.MoveNext
        Loop
    End If

    If Not (porsTarget.BOF And porsTarget.EOF) Then porsTarget.MoveFirst
    'Call SP_DATxRsNothing(orsCoo)
    Call SP_DATxRsNothing(orsNotAlw)
    Call SP_DATxRsNothing(orsTier)
    Exit Sub
ErrHandle:
    MsgBox Err.Description
    'Call SP_DATxRsNothing(orsCoo)
    Call SP_DATxRsNothing(orsNotAlw)
    Call SP_DATxRsNothing(orsTier)
End Sub

Public Function SP_PRCcTierTimePointSec(ByVal porsTier As ADODB.Recordset, ByVal pcAmount As Double, ByVal pcRang As Double, ByVal pcPoint As Double, ByVal pcMinTier As Double, ByVal cMaxTier As Double) As Double
'------------------------------------------------------
'Call:
'Cmt: คิดจำนวนแต้มที่ได้ลำดับขั้นของ Tier แบบ Time

'General
'Amount  25 = 1 แต้ม
'25 = X                   1 =  Y

'Min 3000  Max 9999999.99
'ลำดับ             Amount         Time
'1                   3000               1
'2                   5000               2
'3                   12000             3
'4                   50000             4

'Ex1..
'Amount ที่นำมาคิดแต้ม  17000
'ได้ลำดับที่ 3 ที่ 12000 = ((17000\X) * Y) * Time   = ((17000\25)*1) * 3  = 2040 แต้ม
'ดังนั้นจะได้แต้มทั้งหมด = 2040  แต้ม

'Ex2..
'Amount ที่นำมาคิดแต้ม  18000
'ได้ลำดับที่ 3 ที่ 12000 =((18000\X) * Y) * Time   = ((18000\25)*1) * 3  = 2160 แต้ม
'ดังนั้นจะได้แต้มทั้งหมด = 2160  แต้ม

'Ex3..
'Amount ที่นำมาคิดแต้ม  10000000.00
'10000000.00 ไม่สามารถนำไปคิดแต้มได้เพราะมากกว่าค่า Max(9999999.99)
'ดังนั้นจะได้แต้มทั้งหมด = 0  แต้ม
'*** หมายเหตุ: การคิดของ Time ไม่เหมือนกับแบบ Amount คือ จะไปคิดแค่ขั้นเดียว
'------------------------------------------------------

'------------------------------------------------------
    Dim cAmtRang As Double
    Dim cFac As Double
    Dim cTemp As Double
On Error GoTo ErrHandle
    porsTier.MoveFirst
    Do While Not porsTier.EOF
        cAmtRang = SP_FEDvChkNumeric(porsTier, "FCMsrAmt")
        cFac = SP_FEDvChkNumeric(porsTier, "FCMsrTime")
'        If pcAmount >= cAmtRang And pcAmount >= pcMinTier And pcAmount <= cMaxTier Then
        If pcAmount >= cAmtRang And pcAmount >= pcMinTier Then
            If pcAmount > cMaxTier Then pcAmount = cMaxTier
'            cTemp = CLng(cAmtRang \ pcRang) * pcPoint
'            pcAmount = pcAmount - cAmtRang
'            If pcAmount > 0 Then
'                SP_PRCcTierTimePointSec = (cTemp * cFac) + SP_PRCcTierTimePointSec(porsTier, pcAmount, pcRang, pcPoint, pcMinTier, cMaxTier)
'            Else
'                SP_PRCcTierTimePointSec = (cTemp * cFac)
'            End If
            cTemp = Int(pcAmount / pcRang) * pcPoint
            SP_PRCcTierTimePointSec = (cTemp * cFac)
            Exit Function
        End If
        porsTier.MoveNext
    Loop
    Exit Function
ErrHandle:
    
End Function


Public Function SP_PRCcTierAmountPointSec(ByVal porsTier As ADODB.Recordset, ByVal pcAmount As Double, ByVal pcMinTier As Double, ByVal cMaxTier As Double, Optional ByVal pbChk As Boolean = True) As Double
'------------------------------------------------------
'Call:
'Cmt: คิดจำนวนแต้มที่ได้ลำดับขั้นของ Tier แบบ Amount

'Min 3000  Max 9999999.99
'ลำดับ             Amount         Point
'1                   3000               20
'2                   5000               50
'3                   12000             125
'4                   50000             275

'Ex1..
'Amount ที่นำมาคิดแต้ม  17000
'รอบที่ 1 ได้ลำดับที่ 3 ที่ 12000 = 125 แต้ม เหลือจำนวนที่นไปคิดแต้มต่อได้ 17000-12000 = 5000
'รอบที่ 2 ได้ลำดับที่ 2 ที่ 5000   = 50  แต้ม ไม่เหลือจำนวนที่นำไปคิด
'ดังนั้นจะได้แต้มทั้งหมด = 175 แต้ม

'Ex2..
'Amount ที่นำมาคิดแต้ม  18000
'รอบที่ 1 ได้ลำดับที่ 3 ที่ 12000 = 125 แต้ม เหลือจำนวนที่นไปคิดแต้มต่อได้ 18000-12000 = 6000
'รอบที่ 2 ได้ลำดับที่ 2 ที่ 5000   = 50  แต้ม เหลือจำนวนที่นไปคิดแต้มต่อได้ 6000-5000 = 1000
'1000 ที่เหลือไม่สามารถนำไปคิดแต้มได้เพราะน้อยกว่าค่า Min(3000)
'ดังนั้นจะได้แต้มทั้งหมด = 175 แต้ม

'Ex3..
'Amount ที่นำมาคิดแต้ม  10000000.00
'10000000.00 ไม่สามารถนำไปคิดแต้มได้เพราะมากกว่าค่า Max(9999999.99)
'ดังนั้นจะได้แต้มทั้งหมด = 0  แต้ม
'------------------------------------------------------
    Dim cAmtRang As Double
    Dim cPoint As Double
    Dim cTemp As Double
    Dim cChkMaxMin As Double
    Dim nFac As Long
On Error GoTo ErrHandle
    porsTier.MoveFirst
    Do While Not porsTier.EOF
        cAmtRang = SP_FEDvChkNumeric(porsTier, "FCMsrAmt")
        cPoint = SP_FEDvChkNumeric(porsTier, "FNMsrPoint")
        If pbChk Then
'            If pcAmount >= cAmtRang And pcAmount >= pcMinTier And pcAmount <= cMaxTier Then
            If pcAmount >= cAmtRang And pcAmount >= pcMinTier Then                  '*Ao 2011/01/21 CommSheet ML-UAT-PRV-028-If Amount excess Max amount, Point wont be calculated.xls
                If pcAmount > cMaxTier Then pcAmount = cMaxTier                 '*Ao 2011/01/21
                If cAmtRang > 0 Then
                    nFac = pcAmount \ cAmtRang
                    If nFac = 0 Then nFac = 1
                Else
                    nFac = 1
                End If
                pcAmount = pcAmount - (cAmtRang * nFac)
                If pcAmount > 0 Then
                    SP_PRCcTierAmountPointSec = (cPoint * nFac) + SP_PRCcTierAmountPointSec(porsTier, pcAmount, pcMinTier, cMaxTier, False)
                Else
                    SP_PRCcTierAmountPointSec = (cPoint * nFac)
                End If
                Exit Function
            End If
        Else
            If pcAmount >= cAmtRang Then
                If cAmtRang > 0 Then
                    nFac = pcAmount \ cAmtRang
                    If nFac = 0 Then nFac = 1
                Else
                    nFac = 1
                End If
                pcAmount = pcAmount - (cAmtRang * nFac)
                If pcAmount > 0 Then
                    SP_PRCcTierAmountPointSec = (cPoint * nFac) + SP_PRCcTierAmountPointSec(porsTier, pcAmount, pcMinTier, cMaxTier, False)
                Else
                    SP_PRCcTierAmountPointSec = (cPoint * nFac)
                End If
                Exit Function
            End If
        End If
        porsTier.MoveNext
    Loop
    Exit Function
ErrHandle:
    
End Function

