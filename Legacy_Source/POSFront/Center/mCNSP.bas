Public Function SP_PRCxSkuItemType(ByVal ptFTSkuCode As String, ByVal ptTblDT As String, Optional ByVal pbUseServer As Boolean = False, Optional ByVal ptWhere As String) As String
'*Tao 60-04-05 หา SkuItemType
Dim tSql  As String
Dim orsTemp As ADODB.Recordset
Dim tSkuItemType As String

On Error GoTo ErrorHandle

'*KT 67-12-12 TTK-ISS3000-885,TTK-ISS3000-886
'            tSql = "SELECT FTSkuItemType FROM " & ptTblDT & " DT WITH(NOLOCK)"
'            tSql = tSql & vbCrLf & "INNER JOIN TCNMSKU WITH(NOLOCK) ON DT.FTSkuCode = TCNMSKU.FTSkuCode"
'            If ptWhere = "" Then
'                tSql = tSql & vbCrLf & "WHERE DT.FTTmnNum='" & tVB_CNTerminalNum & "' AND DT.FTShdTransNo='" & tVB_Running & "' AND DT.FDShdTransDate='" & tUT_SaleDate & "' AND DT.FTSkuCode='" & ptFTSkuCode & "'"
'            Else
'                tSql = tSql & vbCrLf & "WHERE " & ptWhere & " AND DT.FTSkuCode='" & ptFTSkuCode & "' AND ISNULL(DT.FTSdtCancelFlag,'0')='0'"
'            End If
'            Call SP_SQLvExecute(tSql, orsTemp, IIf(pbUseServer, oDB.ocnOnLine, oDB.ocnOffLine), , , , , IIf(pbUseServer, True, False))
 
          '*KT 67-12-12 TTK-ISS3000-885,TTK-ISS3000-886
           '1. First to use read flag  FTSdtStaPdt position digit is 22 case FTSdtStaPdt length >=22 digit
           '2. ถ้าข้อที่ 1 ไม่มีข้อมุล/ หรือ FTSdtStaPdt < 22 digit ให้ไปดึงโดยการ join masster SKU ด้วย Query เดิม

            tSql = "SELECT SUBSTRING(DT.FTSdtStaPdt,22,1) AS FTSkuItemType ,FTSdtStaPdt FROM " & ptTblDT & " DT WITH(NOLOCK)"
            If ptWhere = "" Then
                tSql = tSql & vbCrLf & "WHERE DT.FTTmnNum='" & tVB_CNTerminalNum & "' AND DT.FTShdTransNo='" & tVB_Running & "' AND DT.FDShdTransDate='" & tUT_SaleDate & "' AND DT.FTSkuCode='" & ptFTSkuCode & "'"
            Else
                tSql = tSql & vbCrLf & "WHERE " & ptWhere & " AND DT.FTSkuCode='" & ptFTSkuCode & "' AND ISNULL(DT.FTSdtCancelFlag,'0')='0'"
            End If

            Call SP_SQLvExecute(tSql, orsTemp, IIf(pbUseServer, oDB.ocnOnLine, oDB.ocnOffLine), , , , , IIf(pbUseServer, True, False))
            
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                If Len(SP_FEDtChkString(orsTemp, "FTSdtStaPdt")) < 22 Then
                    SP_PRCxSkuItemType = ""
                Else
                    tSkuItemType = SP_FEDtChkString(orsTemp, "FTSkuItemType")
                    SP_PRCxSkuItemType = IIf(tSkuItemType = "2", "", " " & tSkuItemType)
                    Call SP_DATxRsNothing(orsTemp)
                    Exit Function
                End If
            Else
                SP_PRCxSkuItemType = ""
            End If
            
            If SP_PRCxSkuItemType = "" Then
                Call SP_DATxRsClose(orsTemp)
                tSql = "SELECT FTSkuItemType FROM " & ptTblDT & " DT WITH(NOLOCK)"
                tSql = tSql & vbCrLf & "INNER JOIN TCNMSKU WITH(NOLOCK) ON DT.FTSkuCode = TCNMSKU.FTSkuCode"
                If ptWhere = "" Then
                    tSql = tSql & vbCrLf & "WHERE DT.FTTmnNum='" & tVB_CNTerminalNum & "' AND DT.FTShdTransNo='" & tVB_Running & "' AND DT.FDShdTransDate='" & tUT_SaleDate & "' AND DT.FTSkuCode='" & ptFTSkuCode & "'"
                Else
                    tSql = tSql & vbCrLf & "WHERE " & ptWhere & " AND DT.FTSkuCode='" & ptFTSkuCode & "' AND ISNULL(DT.FTSdtCancelFlag,'0')='0'"
                End If
                Call SP_SQLvExecute(tSql, orsTemp, IIf(pbUseServer, oDB.ocnOnLine, oDB.ocnOffLine), , , , , IIf(pbUseServer, True, False))
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    tSkuItemType = SP_FEDtChkString(orsTemp, "FTSkuItemType")
                    SP_PRCxSkuItemType = IIf(tSkuItemType = "2", "", " " & tSkuItemType)
                Else
                     SP_PRCxSkuItemType = ""
                End If
            End If
            Call SP_DATxRsNothing(orsTemp)
            
    Exit Function
ErrorHandle:
    Call SP_DATxRsNothing(orsTemp)
End Function

Private Function SP_PRCbChkLowBP(ByVal ptBpTdmCode As String, ByVal ptBpCardType As String, ByVal pcSrcAmt As Double, ByVal ptBpType As String, Optional ByRef pnLowBPPoint As Long = 0) As Boolean
'*Tao 60-04-05 เช็คว่าใช้ Low BP หรือไม่
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim cLowBPAmt As Double
Dim nLowBPPoint As Long
Dim tTenderGroup As String
Dim nI As Integer
On Error GoTo ErrHandle
    
    If ptBpType = "1" Then
        tSql = "SELECT * FROM TCNMTenderMember"
        tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE FTTdmCode = '" & ptBpTdmCode & "'"
        If ptBpTdmCode = "T002" Then tSql = tSql & vbCrLf & "AND FTCdcCreditType = '" & ptBpCardType & "'" '*Tao 60-04-25 ถ้าเป็น Credit Card ต้อง Where ด้วย CardType ด้วย
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                tTenderGroup = SP_FEDtChkString(orsTemp, "FTMbgGroup")
                For nI = 0 To UBound(aMBGroup)
                    If UCase(aMBGroup(nI).FTMbgGroup) = UCase(tTenderGroup) Then
                        If ptBpTdmCode = "T002" Then '*Tao 60-05-18 ถ้าเป็น Credit Card ต้อง Where ด้วย CardType ด้วย
                            If UCase(aMBGroup(nI).FTMcdCardType) = UCase(ptBpCardType) Then
                                ptBpCardType = aMBGroup(nI).FTMcdCode
                                ptBpTdmCode = "0000"
                                Exit Do
                            End If
                        Else
                            ptBpCardType = aMBGroup(nI).FTMcdCode
                            ptBpTdmCode = "0000"
                            Exit Do
                        End If
                    End If
                Next nI
                orsTemp.MoveNext
            Loop
        End If
    End If
    
    tSql = "SELECT ISNULL(FTLowBPSta,'') AS FTLowBPSta,FCLowBPAmt,FNLowBP FROM TCNMPointCard WITH(NOLOCK)"
    tSql = tSql & vbCrLf & "WHERE FTBpTdmCode='" & ptBpTdmCode & "'"
    tSql = tSql & vbCrLf & "AND FTBpCardType='" & ptBpCardType & "'"
    tSql = tSql & vbCrLf & "AND FTBpType='" & ptBpType & "'"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True)       'ON LINE
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        If SP_FEDtChkString(orsTemp, "FTLowBPSta") = "1" Then
            SP_PRCbChkLowBP = True
            cLowBPAmt = SP_FEDvChkNumeric(orsTemp, "FCLowBPAmt")
            nLowBPPoint = SP_FEDvChkNumeric(orsTemp, "FNLowBP")
            If cLowBPAmt > 0 Then
                pnLowBPPoint = (Fix(pcSrcAmt / cLowBPAmt)) * nLowBPPoint
            ElseIf cLowBPAmt = 0 Then
                pnLowBPPoint = nLowBPPoint
            End If
        Else
             SP_PRCbChkLowBP = False
        End If
    Else
        SP_PRCbChkLowBP = False
    End If
    Call SP_DATxRsNothing(orsTemp)
Exit Function
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Function

