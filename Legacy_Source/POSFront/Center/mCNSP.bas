   tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
   Call SP_SQLvExecute(tSql)
   '*Ao 09-12-17 ไม่มี Table PTPSxxxxx
   '*KT 51-04-18 พี่ไก่ให้เพิ่มเมื่อมีการเริ่มต้น Ticket ใหม่ทุกครั้ง
'     tSql = "IF EXISTS(SELECT Name FROM Sys.Sysobjects WHERE Name = '" & "TPTPS" & tVB_CNTerminalNum & "')"
'     tSql = tSql & vbCrLf & "TRUNCATE  TABLE TPTPS" & tVB_CNTerminalNum
'     Call SP_SQLvExecute(tSql)
     
      tVB_CNWheBill = "FTShdTransNo = '" & tVB_Running & "' AND  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FDShdTransDate = '" & tUT_SaleDate & "'"
      
    '*KT 51-11-18 ให้ Flag bVB_CNTrnOnlineSuccess กับ Transaction ที่ทำเฉพาะ Online เป็น False
    '-----------------------------------------------------------------------------------
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnIPV, tEN_TrnIPVDutyFreeSale, tEN_TrnIPVRedeem, tEN_TrnIPVReturn, tEN_TrnIPVTaxExceptSale, tEN_TrnIPVVIPService
            bVB_CNTrnOnlineSuccess = False
        Case tEN_TrnIPVOtherReceive, tEN_TrnIPVOtherDisbursement
            bVB_CNTrnOnlineSuccess = False
        Case tEN_TrnDeposit, tEN_TrnRedeem, tEN_TrnAddDeposit, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
            bVB_CNTrnOnlineSuccess = False
        Case tEN_TrnVoucher, tEN_TrnCancelVoucher
            bVB_CNTrnOnlineSuccess = False
        Case Else
            bVB_CNTrnOnlineSuccess = True
   End Select
   '------------------------------------------------------------------------------
   Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "mCNSP" & " Events:SP_INSxTransHD[2]")
   Exit Sub
ErrHandle:
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "mCNSP" & " Events:SP_INSxTransHD[3]")
    If nStep = 0 Then pbIns = False
End Sub

Public Function SP_GETdSaleDate() As Date
'------------------------------------------------------
'Ret: ค่าวันที่ Operation Date(Sale Date) ของ System
'Cmt: *KT 50-12-25 Get Operation Date On Database
'-----------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle             '*KT 54-03-25 ป้องกันโปรแกรมหลุด

    tSql = "SELECT FDCdtDate "
    tSql = tSql & " FROM TSysChgDateTime"
    'PH 2.0.0
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
        'Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master '*Tao 61-06-26 ของเดิม
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, False) 'read master '*Tao 61-06-26 ไม่ต้องรอ Rep
    Else
        Call SP_SQLvExecute(tSql, orsTemp)
    End If
    If Not orsTemp Is Nothing Then
        If Not (orsTemp.BOF Or orsTemp.EOF) Then
            SP_GETdSaleDate = SP_FEDdChkDate(orsTemp, "FDCdtDate")
        Else
            SP_GETdSaleDate = Date
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_GETdSaleDate = Date
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Function SP_GETdSaleDateEx() As Date
'------------------------------------------------------
'Ret: ค่าวันที่ Operation Date(Sale Date) ของ System
'Cmt: *KT 52-09-27 Get Operation Date On Database
'-----------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    tSql = "SELECT FDCdtDate "
    tSql = tSql & " FROM TSysChgDateTime"
    'PH 2.0.0
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
        If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) = 0 Then 'read master
            If Not (orsTemp.BOF Or orsTemp.EOF) Then
                SP_GETdSaleDateEx = SP_FEDdChkDate(orsTemp, "FDCdtDate")
            Else
                SP_GETdSaleDateEx = SP_GETdCurrentDate(True)
            End If
        Else
            SP_GETdSaleDateEx = SP_GETdCurrentDate(True)
        End If
    Else
        SP_GETdSaleDateEx = SP_GETdCurrentDate(True)
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_GETdSaleDateEx = SP_GETdCurrentDate(True)
    Call SP_DATxRsNothing(orsTemp)
End Function

