Public Sub SP_PRCxReMemberPointOth(Optional ByRef pnRound As Long = 2)
'------------------------------------------------------
'Call:
'Cmt: *KT 52-03-03 Member Point ทำการคำนวณแต้มใหม่หลังมีการเปลี่ยนแปลงส่วนลดลง(Special Gift Voucher,Special Coupon)
'          *KT 52-10-27 PH2-ML-SF-132 Extra Point ของ Card ถ้าไม่ Allow  [ADD] จะไม่คำนวน Extra Point ให้ (บัตรนั้นไม่ได้ Allow Dept/SKU)
'          *KT 54-09-13 V.4.0.1 Req3 Phase4.0 (Member Point) Member Point on Other Receive
'------------------------------------------------------
    Dim tSql$
    Dim cLastPoint As Double
    Dim tMemberName As String
    Dim orsMall As ADODB.Recordset
    Dim orsTemp As ADODB.Recordset
    Dim orsTemp2 As ADODB.Recordset
    Dim orsTemp3 As ADODB.Recordset
'    Dim orsTemp4 As ADODB.Recordset
    Dim orsCoo As ADODB.Recordset
'    Dim orsTender As ADODB.Recordset
'    Dim orsCrd As ADODB.Recordset
'    Dim orsProRate As ADODB.Recordset
    
    Dim cPoint As Double
    Dim cPointAmt As Double
    Dim bPass As Boolean
    Dim tPointSpecial As String
    Dim tPointAdd As String
    Dim cPointSku As Double
    Dim cPointAmtSku As Double
    Dim cPointDpt As Double
    Dim cPointAmtDpt  As Double
    Dim cPointGen As Double
    Dim cPointAmtGen As Double
    Dim bMissRec As Boolean
    Dim cSubTotal As Double
    Dim tMallCardKey As String
    Dim tCrdCardKey As String
    Dim cCrdAmt As Double
    Dim tTenderCode As String
    Dim nEff As Long
    Dim tCardNo As String
    Dim nPointCrd As Long
    Dim bPass2 As Boolean
    Dim cSecTemp As Double
    Dim cCooTemp As Double
    Dim cSKUTemp As Double
    Dim cTenderAmtAlw As Double
    Dim bReMemberPoint As Boolean
    
On Error GoTo ErrHandle
   '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
    If pnRound = 0 Then
        Call SP_DATxRsNothing(orsTemp)
        Call SP_DATxRsNothing(orsTemp2)
        Call SP_DATxRsNothing(orsTemp3)
        Call SP_DATxRsNothing(orsCoo)
        Call SP_DATxRsNothing(orsMall)
        bReMemberPoint = False
        Exit Sub
    End If
    pnRound = pnRound - 1
    bReMemberPoint = True
    
    bPass2 = False
    '*KT 52-07-27 ป้องกันกรณีที่ tVB_MemPointID = "" แต่ว่าในฐานข้อมุลมีการเก็บค่าไว้แล้ว
    If Trim(tVB_MemPointID) = "" Then
        tSql = "SELECT FTCstCardCode FROM " & tVB_CNTblHD
        tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
        tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
             tVB_MemPointID = SP_FEDtChkString(orsTemp, "FTCstCardCode")
        End If
        Call SP_DATxRsClose(orsTemp)
    End If
    
    Select Case Val(Format(tVB_TransactionSub))
        Case tEN_TrnDeposit
            cSubTotal = (cVB_Total - cVB_TotalDiscAft)
        Case Else
            cSubTotal = cVB_NetSale
    End Select
    
    If tVB_MemPointID <> "" Then
        tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & tVB_MemPointID & "'"
        Call SP_SQLvExecute(tSql, orsMall, oDB.ocnOnLine, , , , , True, True) 'read master
        If Not (orsMall.BOF And orsMall.EOF) Then
            tVB_StaMemPointAlw = SP_FEDtChkString(orsMall, "FTMcdAlwPointAll")
            tPointSpecial = SP_FEDtChkString(orsMall, "FTMcdAlwPoint")
            tPointAdd = SP_FEDtChkString(orsMall, "FTMcdStaAddSku") 'Test 19
            tMallCardKey = SP_FEDtChkString(orsMall, "FTMcdCode") '
            tVB_MemEvnCode = SP_FEDtChkString(orsMall, "FTEvnCode") '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
            '*KT 52-02-24 member point process คำนวณ point
            '---------------------------------------------------------------------------------------------
            'All
            cPoint = 0
            cPointAmt = 0
            'Mall Card
            cPointSku = 0
            cPointAmtSku = 0
            cPointDpt = 0
            cPointAmtDpt = 0
            cPointGen = 0
            cPointAmtGen = 0

            If tVB_StaMemPointAlw = "Y" Then
                tSql = "SELECT *  FROM " & tVB_CNTblDT
                tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
                tSql = tSql & vbCrLf & "  AND SUBSTRING(ISNULL(FTSdtStaPdt,''),21,1) = '1'" '*KT 55-08-15 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
                'Call SP_SQLvExecute(tSql, orsTemp)
                If orsTemp Is Nothing Then
                    Set orsTemp = New ADODB.Recordset
                End If
                If orsTemp.State = adStateOpen Then orsTemp.Close
                orsTemp.Open tSql, ocnAll, adOpenKeyset, adLockPessimistic
            ElseIf SP_FEDtChkString(orsMall, "FTMcdAlwPoint") = "Y" Then
                tSql = "SELECT *  FROM " & tVB_CNTblDT
                tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
                tSql = tSql & vbCrLf & "  AND SUBSTRING(ISNULL(FTSdtStaPdt,''),21,1) = '1'" '*KT 55-08-15 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
                'Call SP_SQLvExecute(tSql, orsTemp)
                If orsTemp Is Nothing Then
                    Set orsTemp = New ADODB.Recordset
                End If
                If orsTemp.State = adStateOpen Then orsTemp.Close
                orsTemp.Open tSql, ocnAll, adOpenKeyset, adLockPessimistic
            End If
            
            'Allow Member Point from Mall Card Maintenance
            If tVB_StaMemPointAlw = "Y" Then
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[1]", "Section/Cooperate/SKU", tVB_MemPointID)
                
                'ใช้สำหรับการเก็บข้อมูลนำไปคิดแต้มตาม SKU CODE ทั้ง Amount/Time
                ReDim aW_PointSKUTime(0) As POINTSEQ
                aW_PointSKUTime(0).nSeqNo = 0
                aW_PointSKUTime(0).cPoint = 0
                aW_PointSKUTime(0).cRank = 0
                aW_PointSKUTime(0).cAmt = 0
                aW_PointSKUTime(0).cMin = 0
                aW_PointSKUTime(0).cMax = 0
                aW_PointSKUTime(0).tType = "0"
                aW_PointSKUTime(0).dST = CDate("1900/01/01")
                aW_PointSKUTime(0).dED = CDate("1900/01/01")
                aW_PointSKUTime(0).tStaAct = "N"
                
                'การคิดแต้มกรณีที่มี MissRec อ้างจากเอกสาร External Spec
                '- ถ้า Cooperate Active อย่างเดียว ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Cooperate / General
                '- ถ้า Secsion Active อย่างเดียว ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Secsion / General (***หมายเหตุบวกเพิ่มที่ Secsion แรก)
                '- ถ้า Cooperate Active และ Secsion Active ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Cooperate / General เท่านั้น
                tSql = "SELECT  * "
                tSql = tSql & vbCrLf & " FROM TCNMMemberCooMtn"
                'tSql = tSql & vbCrLf & " WHERE ISNULL(FTMcmStaCoo,'N') = 'Y'"
                If SP_SQLvExecute(tSql, orsCoo, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                    If (orsCoo.BOF And orsCoo.EOF) Then
                        bMissRec = True
                    Else
                        If UCase(SP_FEDtChkString(orsCoo, "FTMcmStaCoo")) = "Y" Then
                             bMissRec = False
                        Else
                            bMissRec = True
                        End If
                    End If
                Else
                    bMissRec = True
                End If
                orsMall.Filter = adFilterNone
                Set orsTemp2 = orsTemp.Clone
                'การให้ Point สำหรับ Transaction Other Receive ไม่ให้ Point ส่วนของ Section Point
                'Allow Member Point from Sesion
                'Call SP_PRCbVerifyPointSec(orsTemp2, orsTemp3, cPoint, cPointAmt, cUT_SubReg, cUT_SubPro, cSubTotal, bMissRec)
                'Set orsTemp2 = orsTemp3.Clone
                cSecTemp = cPoint
                If cSecTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[2]", "Section = " & cSecTemp, tVB_MemPointID)
                'Allow Member Point from Cooperate
                Call SP_PRCbVerifyPointCoo(orsTemp2, orsTemp3, cPoint, cPointAmt, cUT_SubReg, cUT_SubPro, cSubTotal, Not bMissRec, orsCoo)
                cCooTemp = cPoint - cSecTemp
                If cCooTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[3]", "Cooperate = " & cCooTemp, tVB_MemPointID)
                'cCooTemp Member Point from SKU Allow
                Call SP_PRCbVerifyPointBySkuAlw(orsTemp, orsCoo, cPoint, cPointAmt)
                cSKUTemp = cPoint - (cSecTemp + cCooTemp)
