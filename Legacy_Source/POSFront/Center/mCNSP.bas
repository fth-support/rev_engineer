Public Function SP_SQLvExecute(ByVal ptSql As String, Optional ByRef poRs As Variant, Optional ByVal poCn As ADODB.Connection, Optional ByVal pbShwErr As Boolean = True, Optional ByVal pnTryRound% = 1, Optional ByRef pnEffect As Long, Optional ByVal pbMember As Boolean = False, Optional ByVal pbSwithOnline As Boolean = False, Optional ByVal pbWaitRep As Boolean = False) As Variant
'----------------------------------------------------------
'   Call:   ptSql as string of sql
'              poRs as reference optional recordset
'   Ret:   0 if execute ok, even if error no will return when error occur
'*KT 52-01-09 ให้แก้ไขโดยการวนแค่ 1 รอบจากเดิม 3 รอบ
'*KT 52-03-12
'----------------------------------------------------------
    On Error GoTo ErrHandle
    Dim oCNCon As ADODB.Connection
    Dim nCountRound%, nCmdTimeout%
    Dim nRet As Long
    Dim nTimeAdd%

    Set oCNCon = IIf(poCn Is Nothing, ocnAll, poCn)
    nCmdTimeout = oCNCon.CommandTimeout
    nRet = SP_SQLnPrcTimeOut(ptSql, poRs, oCNCon, pnEffect, pbMember, pbSwithOnline, pbWaitRep)
    nCountRound = 1
    Do While nRet = -2147217871 And nCountRound < pnTryRound
        nTimeAdd = (nCountRound - 1) * 30
        oCNCon.CommandTimeout = nCS_CNTimeOutLevel1 + nTimeAdd
        nCountRound = nCountRound + 1
        If nCountRound = pnTryRound Then
            Call SP_MSGnShowing("tms_CN005051", tCS_CNMsgErr)
            Call SP_CRTxLogPrg("ErrorNumber:" & nRet & " ErrorDesc:" & "" & " Form:mCNSP" & " Control:General" & " Events:SP_SQLvExecute")
            Call SP_APPxEndProgram
        End If
        '*KT 54-04-08 V.5.0.56 ป้องกันโปรแกรมหลุด
        'wCNSplash.tW_Caption = UT_tToken(SP_INItGetValue(tVB_CNPthFileINI, "All", "tms_CN005052"), ";", nVB_CNCutConst) & "(" & nCountRound & "/3)"
        'wCNSplash.Show vbModal
        Call SleepEx(3000, 0)
        nRet = SP_SQLnPrcTimeOut(ptSql, poRs, oCNCon, pnEffect, pbMember, pbSwithOnline, pbWaitRep)
    Loop
    oCNCon.CommandTimeout = nCmdTimeout
    SP_SQLvExecute = IIf(nRet = -1, 0, nRet)
    Set oCNCon = Nothing
    Exit Function
ErrHandle:
    SP_SQLvExecute = nRet
    Set oCNCon = Nothing
    If pbShwErr Then Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

