Public Function SP_UPDbPreviewDayHD() As Boolean
'------------------------------------------------------
'Ret:   True = Update success,False = No success
'Cmt:   *KT 53-10-30 ปรับปรุงข้อมูล Transaction HD ที่เกี่ยวกับ Preview Day
'-----------------------------------------------------
    Dim tSql$, tValue$, tWhr$
    Dim nEff As Long
On Error GoTo ErrHandle
    SP_UPDbPreviewDayHD = False
    tValue = " SET FTPrvCardType = ''" & nVB_RegPreType & "''"
    tValue = tValue & vbCrLf & " , FTPrvCardID = ''" & tVB_CNPreDayIDReg & "''"
    
    tWhr = " WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "''"
    tWhr = tWhr & vbCrLf & "  AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & "  AND FTShdTransType=''" & tVB_Transaction & "''"
    tWhr = tWhr & vbCrLf & "  AND FDShdTransDate =''" & tUT_SaleDate & "''"
    tWhr = tWhr & vbCrLf & "  AND FTShdStaDoc = ''2''"

    tSql = "STP_CNxSQLFunctionUpd @ptValue='" & tValue & "',@ptTable='" & tVB_CNTblHD & "',@ptWhere='" & tWhr & "'"
    If SP_SQLbExecute(tSql, , , nEff) Then
        If nEff > 0 Then
            SP_UPDbPreviewDayHD = True
        Else
            SP_UPDbPreviewDayHD = False
        End If
    Else
        SP_UPDbPreviewDayHD = False
    End If
    Exit Function
ErrHandle:
    SP_UPDbPreviewDayHD = False
End Function

Public Sub SP_ExcServiceOnOff()
'*KT 54-04-09 V.3.0.56 ทำการตรวจสอบ ServiceOnOff ถ้าไม่ Run ให้ Run ใหม่
    Dim tFile As String
    Dim oFSO As New FileSystemObject
On Error GoTo ErrHandle
    tFile = Left(App.Path, InStrRev(App.Path, "\") - 1) + "\POS\ServiceOnOff.exe"
    If Not SP_FLEbManFile(tFile, nEN_Fle1Exist) Then
            tFile = oFSO.GetParentFolderName(oFSO.GetParentFolderName(App.Path))
            tFile = tFile + "\POS\ServiceOnOff.exe"
            If Not SP_FLEbManFile(tFile, nEN_Fle1Exist) Then
                Call SP_MSGnShowing("tms_CN005139", nCS_Warning, , , tFile & vbCrLf & cUT.UT_STRtToken(SP_INItGetValue(tVB_CNPthFileINI, "All", "tms_CN004011"), ";", nVB_CNCutLang - 1))
                Call SP_CRTxLogPrg("ErrorNumber:0" & " ErrorDesc:" & "Can not run ServiceOnOff.exe" & " Form:mCNSP" & " Events:SP_ExcServiceOnOff")
            End If
    End If

    nVB_lServiceOnOffWnd = FindWindow(vbNullString, "ServiceOnOff")
    If nVB_lServiceOnOffWnd = 0 Then
        Call SP_CRTxLogPrg("ErrorNumber:0" & " ErrorDesc:" & "ShellEx ServiceOnOff.exe" & " Form:mCNSP" & " Events:SP_ExcServiceOnOff")
        Call ShellEx(nVB_lServiceOnOffWnd, "open", tFile, "", "", 10)
    End If
    Set oFSO = Nothing
    Exit Sub
ErrHandle:
    Call SP_CRTxLogPrg("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:mCNSP" & " Events:SP_ExcServiceOnOff")
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Set oFSO = Nothing
End Sub

