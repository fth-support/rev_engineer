Public Sub SP_INSxDepositTbl(ByVal ptTbl As String, ByVal ptWhere As String)
'-----------------------------------------------------------
'   Parameter :
'   Cmt :
'  1.find Column_Name of TPSTSal and TPSTDeposit  for INSERT Data
'   2.Check TransType
'   3.Check Deposit Have it ?
'   4.when deposit has not then INSERT data into table.
'   File Refer :
'   Developer : bung
'   Date Create : 19/10/2013 :  9:25:14
'-----------------------------------------------------------
    Dim tSql As String
    Dim orsTmp As New ADODB.Recordset
    Dim tSqlF As String
    Dim tTbl As String
    Dim tType06 As String
On Error GoTo ErrHandle
    tSqlF = ""
'Step of Job
'   1.Check TransType.
    tSql = "SELECT FTShdTransType FROM TPSTSalHD WHERE " & ptWhere
    
    '* Bump Replace ocnAll  ด้วย oDB.ocnOffLine ทั้งหมดในนี้ SP_INSxDepositTbl
    '*  เพื่อให้ import ลงที่ db offline
    Set orsTmp = oDB.ocnOffLine.Execute(tSql)
    'Set orsTmp = ocnAll.Execute(tSql)
    If Not (orsTmp.EOF And orsTmp.BOF) Then
        tType06 = orsTmp.Fields("FTShdTransType")
    End If
    If tType06 <> "06" Then Exit Sub
'  2.find Column_Name of TPSTSal and TPSTDeposit  for INSERT Data.
'   3.Check Deposit Have it ?
    Select Case ptTbl
        Case "TPSTSalHD"
            tTbl = "TPSTDepositHD"
            tSql = "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS" & vbCrLf
            tSql = tSql & "WHERE TABLE_NAME = 'TPSTSalHD'" & vbCrLf
            tSql = tSql & "AND COLUMN_NAME IN" & vbCrLf
            tSql = tSql & "(SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'TPSTDepositHD')" & vbCrLf
            Set orsTmp = oDB.ocnOffLine.Execute(tSql)
            If Not (orsTmp.BOF And orsTmp.EOF) Then
                tSqlF = orsTmp.Fields("COLUMN_NAME")
                orsTmp.MoveNext
                Do While Not (orsTmp.EOF)
                    tSqlF = tSqlF & "," & orsTmp.Fields("COLUMN_NAME")
                    orsTmp.MoveNext
                Loop
            End If
            tSql = "SELECT FTShdTransNo  FROM TPSTDepositHD WHERE " & ptWhere
            
        Case "TPSTSalDT"
            tTbl = "TPSTDepositDT"
            tSql = "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS" & vbCrLf
            tSql = tSql & "WHERE TABLE_NAME = 'TPSTSalDT'" & vbCrLf
            tSql = tSql & "AND COLUMN_NAME IN" & vbCrLf
            tSql = tSql & "(SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'TPSTDepositDT')" & vbCrLf
            Set orsTmp = oDB.ocnOffLine.Execute(tSql)
            If Not (orsTmp.BOF And orsTmp.EOF) Then
                tSqlF = orsTmp.Fields("COLUMN_NAME")
                orsTmp.MoveNext
                Do While Not (orsTmp.EOF)
                    tSqlF = tSqlF & "," & orsTmp.Fields("COLUMN_NAME")
                    orsTmp.MoveNext
                Loop
            End If
            tSql = "SELECT FTShdTransNo  FROM TPSTDepositDT WHERE " & ptWhere
            
        Case "TPSTSalRC"
            tTbl = "TPSTDepositRC"
            tSql = "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS" & vbCrLf
            tSql = tSql & "WHERE TABLE_NAME = 'TPSTSalRC'" & vbCrLf
            tSql = tSql & "AND COLUMN_NAME IN" & vbCrLf
            tSql = tSql & "(SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'TPSTDepositRC')" & vbCrLf
            Set orsTmp = oDB.ocnOffLine.Execute(tSql)
            If Not (orsTmp.BOF And orsTmp.EOF) Then
                tSqlF = orsTmp.Fields("COLUMN_NAME")
                orsTmp.MoveNext
                Do While Not (orsTmp.EOF)
                    tSqlF = tSqlF & "," & orsTmp.Fields("COLUMN_NAME")
                    orsTmp.MoveNext
                Loop
            End If
            tSql = "SELECT FTShdTransNo  FROM TPSTDepositRC  WHERE " & ptWhere
            
        Case "TPSTSalCD"
            tTbl = "TPSTDepositCD"
            tSql = "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS" & vbCrLf
            tSql = tSql & "WHERE TABLE_NAME = 'TPSTSalCD'" & vbCrLf
            tSql = tSql & "AND COLUMN_NAME IN" & vbCrLf
            tSql = tSql & "(SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'TPSTDepositCD')" & vbCrLf
            Set orsTmp = oDB.ocnOffLine.Execute(tSql)
            If Not (orsTmp.BOF And orsTmp.EOF) Then
                tSqlF = orsTmp.Fields("COLUMN_NAME")
                orsTmp.MoveNext
                Do While Not (orsTmp.EOF)
                    tSqlF = tSqlF & "," & orsTmp.Fields("COLUMN_NAME")
                    orsTmp.MoveNext
                Loop
            End If
             tSql = "SELECT FTShdTransNo  FROM TPSTDepositCD WHERE " & ptWhere
             
    End Select
'   4.When deposit has not then INSERT data into table.
    Set orsTmp = oDB.ocnOffLine.Execute(tSql)
    If orsTmp.BOF And orsTmp.EOF Then
        'import
        tSql = "INSERT INTO " & tTbl
        tSql = tSql & "(" & tSqlF & ")"
        tSql = tSql & "(SELECT " & tSqlF & " FROM " & ptTbl & " WHERE " & ptWhere & ")"
        Call oDB.ocnOffLine.Execute(tSql)
    Else
        'have data is nothing
    End If
    
    
    Exit Sub
ErrHandle:
    
End Sub

