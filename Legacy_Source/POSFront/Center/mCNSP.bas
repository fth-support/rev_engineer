Public Function SP_CHKbWebservice() As Boolean
'    Dim oChkToken As Object 'ปิดไว้
    '*Bmp 61-04-11
On Error GoTo Err_Handle

    SP_CHKbWebservice = True
    '** Store Parameter บอกว่า ไม่ต้อง Token
    If Not bVB_AlwToken Then Exit Function
    Call SP_CRTxLogPrg("SP_CHKbWebservice[1] Start Check")
    '*Tao 61-04-24 clear object ก่อน
    If Not (oTKToken Is Nothing) Then
        Set oTKToken = Nothing
        Call SleepEx(200, 0) '*จาก 500 เป็น 200
        Call SP_CRTxLogPrg("SP_CHKbWebservice[2] Reset Object Token")
    Else
        Call SP_CRTxLogPrg("SP_CHKbWebservice[2] Create Object Token")
    End If
    '========================
    '*Tao 61-04-20 ปิดไว้
'    Set oChkToken = CreateObject("MSSOAP.SoapClient30")
'    Call oChkToken.MSSoapInit(tVB_TokenURL, "", "")
    Set oTKToken = CreateObject("MSSOAP.SoapClient30")
    If (oTKToken Is Nothing) Then
        SP_CHKbWebservice = False
        bVB_AbleToken = False
        Call SP_CRTxLogPrg("SP_CHKbWebservice[3] Create Object Token Fail !")
        Exit Function
    Else
        Call SP_CRTxLogPrg("SP_CHKbWebservice[3] Create Object Token OK")
    End If
    '*Tao 61-05-17 Set ClientProperty
    'oTKToken.ClientProperty("ServerHTTPRequest") = True
    '===========================
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then '*Tao 61-04-20 ถ้า OnLine
        Call SP_CRTxLogPrg("SP_CHKbWebservice[4] Online")
        'Call SP_SETxIE_SSL '*61-04-26
        Call SP_CRTxLogPrg("SP_CHKbWebservice[5] Start SoapInit " & tVB_TokenURL)
        Call oTKToken.MSSoapInit(tVB_TokenURL, "", "") '*Tao 61-07-20 ให้ใช้ Object เดิม
        Call SP_CRTxLogPrg("SP_CHKbWebservice[5] END SoapInit " & tVB_TokenURL) '*TU 2020-03-23
        If Err <> 0 Then
