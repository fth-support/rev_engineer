Public Function SP_MSGnShowing(ByVal ptMsg$, ByVal ptStyle$, Optional ByVal pbNoCut As Boolean, Optional ByVal ptCaption$, Optional ByVal ptNextLine$, Optional ByVal ptValue$) As Byte
'----------------------------------------------------------
'   Call:   ptMSG is showing message
'               ptStyle is style of button
'               pbNoCut is optional, True if do not want to cut message
'               ptCaption is optional, if want to add on caption
'               ptNextLine is optional, if want to add on message (with vbCrLf)
'   Ret:    no. of pressed button
'*KT 53-05-29 แก้ไขการเกิด Dot send โดยการแก้ไขจากตัวตังต้น 3.0.19
'----------------------------------------------------------
    Dim tMsg$, tMsg2$
    Dim tAppTitle$
    Dim nPos As Integer
    Dim nCharPos As Integer
    Dim tTemp As String
    
    'Duang 50-07-09 เรื่องภาษา
    nPos = nVB_CNCutLang
    If tVB_CNPthFileINI = "" Then tVB_CNPthFileINI = App.Path & "\" & App.EXEName & ".ini"
    tTemp = SP_INItGetValue(tVB_CNPthFileINI, "All", ptMsg)
    If (tTemp = "") Then
        nPos = IIf(bVB_CNShwThai, 1, 2)
    Else
        ptMsg = tTemp
        nPos = nVB_CNCutLang
    End If
    ptMsg = IIf(tTemp = "", ptMsg, tTemp)
    
    Screen.MousePointer = vbDefault
    
    tAppTitle = tVB_CNAppTitle
    
    'add caption
    If Trim(ptCaption) <> "" Then
        tAppTitle = tAppTitle & " : " & ptCaption
    End If
    
    tMsg2 = ptMsg
    If Not pbNoCut Then     'if false(default) parameter tMsg will be cut (Thai/Eng)
        tMsg2 = cUT.UT_STRtToken(tMsg2, ";", nPos)
    End If
    
    tMsg = tMsg2
    
    'add Value
    If Trim(ptValue) <> "" Then
        tMsg = tMsg & " " & ptValue
    End If
    
    'add next line
    If Trim(ptNextLine) <> "" Then
        tMsg = tMsg & vbCrLf & ptNextLine
    End If

    Beep 5000, 1 '*KT 53-04-09 PH3-ML-SF-112 Allow Scanner when alert message
    
    '*Gon 50-07-14 Adding
    nCharPos = InStr(1, UCase(tMsg), UCase(" vbCr "))
    If nCharPos > 0 Then
        tMsg = Trim(Left(tMsg, nCharPos - 1)) & vbCr & Trim(Mid(tMsg, nCharPos + 6))
    End If
    '******
    If tMsg = "" Then
        tMsg = ptMsg & " is Not found language. Upload table TSysLang"
    End If
    SP_MSGnShowing = MsgBox(tMsg, ptStyle, tAppTitle)

End Function

