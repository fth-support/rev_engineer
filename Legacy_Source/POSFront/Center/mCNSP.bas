        Call SP_CRTxLogPrg("SP_ChkxClosingMissing Local LogCode=" & tLogCode)
        If tLogCode = "" Then
            tLogCode = SP_SQLtFunction("MAX", "FTLogCode", "TPSTSalHD", tWhr, oDB.ocnOnLine, True) '*Tao 61-09-11 ถ้าใน Local ไม่มี ให้หาจาก POSServer
            Call SP_CRTxLogPrg("SP_ChkxClosingMissing POSServer LogCode=" & tLogCode)
        End If
        If tLogCode <> "" Then
            tSql = "SELECT TOP 1 FTShdTransType,FDShdTransDate,FTShdTransNo FROM TPSTSalHD WITH(NOLOCK)"
            tSql = tSql & vbCrLf & "WHERE FTLogCode = '" & tLogCode & "' "
            tSql = tSql & vbCrLf & "AND FTShdStaDoc = '1'"
            If Not bVB_ReEntryMode Then tSql = tSql & vbCrLf & " AND FTShdTransType NOT IN ('38','41','48','43','46','49')"  '*Tao 61-09-10 ถ้าไม่ใช่ ReEntry Mode
            tSql = tSql & vbCrLf & "ORDER BY FTShdTransNo DESC"
            Call SP_SQLbExecute(tSql, orsTemp)
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                tUT_LoginCode = tLogCode
                Call SP_CRTxLogPrg("SP_ChkxClosingMissing Found Last DocNo in Local Database")
                tTransType = SP_FEDtChkString(orsTemp, "FTShdTransType")
                tSaleDate = UT_tStringDate(SP_FEDdChkDate(orsTemp, "FDShdTransDate")) '*Tao 61-01-18 เก็บค่า Sale Date ของเดิม
                tTransNo = SP_FEDtChkString(orsTemp, "FTShdTransNo") '*Tao 61-09-07 เก็บ Transaction No
                Call SP_CRTxLogPrg("SP_ChkxClosingMissing Get Last DocNo : " & tTransType & "," & tSaleDate & "," & tTransNo)
            Else
                Call SP_CRTxLogPrg("SP_ChkxClosingMissing Not Found Last DocNo in Local Database !")
                Call SP_DATxRsNothing(orsTemp)
                tLogCode = SP_SQLtFunction("MAX", "FTLogCode", "TPSTSalHD", tWhr, oDB.ocnOnLine, True) '*Tao 61-09-10 ของเดิม
                If tLogCode <> "" Then
                    Call SP_CRTxLogPrg("SP_ChkxClosingMissing LogCode=" & tLogCode)
                    tSql = "SELECT TOP 1 FTShdTransType,FDShdTransDate,FTShdTransNo FROM TPSTSalHD WITH(NOLOCK)"
                    tSql = tSql & vbCrLf & "WHERE FTLogCode = '" & tLogCode & "' "
                    tSql = tSql & vbCrLf & "AND FTShdStaDoc = '1'"
                    tSql = tSql & vbCrLf & "ORDER BY FTShdTransNo DESC"
                    Call SP_SQLbExecute(tSql, orsTemp, , , , oDB.ocnOnLine, True)
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                        tUT_LoginCode = tLogCode
                        Call SP_CRTxLogPrg("SP_ChkxClosingMissing Found Closing in POSServer Database")
                        tTransType = SP_FEDtChkString(orsTemp, "FTShdTransType")
                        tSaleDate = UT_tStringDate(SP_FEDdChkDate(orsTemp, "FDShdTransDate")) '*Tao 61-01-18 เก็บค่า Sale Date ของเดิม
                        tTransNo = SP_FEDtChkString(orsTemp, "FTShdTransNo") '*Tao 61-09-07 เก็บ Transaction No
                        Call SP_CRTxLogPrg("SP_ChkxClosingMissing Get Last DocNo : " & tTransType & "," & tSaleDate & "," & tTransNo)
                    Else
                        Call SP_CRTxLogPrg("SP_ChkxClosingMissing Not Found Last DocNo in POSServer Database !")
                    End If
                End If
            End If
            Call SP_DATxRsNothing(orsTemp)
            
            'If (tTransType = "37") Or (tTransType = "08") Or (tTransType = "41") Or (tTransType = "46") Then     '*Tao 61-06-26 ถ้าเป้น 37=OverShortReport , 08=Close ให้เปลี่ยน SaleDate เป็นของเดิมก่อน
            If (tTransType = "08") Or (tTransType = "41") Or (tTransType = "46") Then      '*Tao 61-06-26 ถ้าเป้น 37=OverShortReport , 08=Close ให้เปลี่ยน SaleDate เป็นของเดิมก่อน
                '*Tao 61-01-18 ถ้า SaleDate ไม่ตรงกัน ให้ใช้ SaleDate ที่ Missing เผื่อมีการเปิดรอบใหม่ โดยที่ยังไม่ปิดรอบ
                If (tUT_SaleDate <> tSaleDate) And (tSaleDate <> "") And bVB_FirstLoad Then
                    tUT_SaleDate = tSaleDate
                    tVB_EJDate = tUT_SaleDate
                    oTerminal.SaleDate = CDate(tUT_SaleDate)
                    Call SP_CRTxLogPrg("SP_ChkxClosingMissing Not Found Closing !")
                End If
            ElseIf (tTransType = "09") Then
                tVB_CNClosingReprint = tTransNo '*Tao 61-09-07 เก็บหมายเลข Closing
                Call SP_CRTxLogPrg("SP_ChkxClosingMissing Found Closing : " & tVB_CNClosingReprint)
            ElseIf (tTransType = "42") Then 'ReEntry Mode Closing Tax Include
                tVB_CNClosingReprint = tTransNo '*Tao 61-09-07 เก็บหมายเลข Closing
                Call SP_CRTxLogPrg("SP_ChkxClosingMissing Found Closing : " & tVB_CNClosingReprint)
            ElseIf (tTransType = "47") Then 'ReEntry Mode Closing Manual Tax
                tVB_CNClosingReprint = tTransNo '*Tao 61-09-07 เก็บหมายเลข Closing
                Call SP_CRTxLogPrg("SP_ChkxClosingMissing Found Closing : " & tVB_CNClosingReprint)
            End If
            '=============================================================================
        End If
        SP_ChkxClosingMissing = tTransType
'    End If
Exit Function
ErrHandle:
    SP_ChkxClosingMissing = ""
End Function

Public Function SP_CHKxSQLStatus(ByVal ptOnServerName$, ByVal ptOnUsrName$, ByVal ptOnUsrPwd$) As SQLDMO_SVCSTATUS_TYPE
