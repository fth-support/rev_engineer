Public Sub SP_FRMxGetCaptionFrmDB2Tag(pwForm As Form)
'----------------------------------------------------------
'   Call:
'   Cmt:   For All -> set default value to tag
'----------------------------------------------------------
    Dim oControl As Object
    Dim tField$
    Dim i%
    Dim tLang1$, tLang2$, tTemp$
    Dim nLoop%
    Dim aLang1() As String, aLang2() As String
    
    pwForm.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(pwForm.Caption, ";", 2), cUT.UT_STRtToken(pwForm.Caption, ";", 1))
    
    For Each oControl In pwForm.Controls
        If Left(oControl.Tag, 1) = "2" Then         '2:caption
            
            If TypeOf oControl Is Label Then oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))
            If TypeOf oControl Is CommandButton Then oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))
'            If TypeOf oControl Is ucButtons_H Then oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2))
            If TypeOf oControl Is Frame Then oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))
            If TypeOf oControl Is OptionButton Then oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))   'oControl.Caption =
            '*Duang 50-08-30
            If TypeOf oControl Is RadioButton Then oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))   'oControl.Caption =
            '-----------------------------------
            If TypeOf oControl Is CheckBox Then
                tTemp = cUT.UT_STRtToken(oControl.Tag, ";", 3, True) & ";" & cUT.UT_STRtToken(oControl.Tag, ";", 4, True)
                oControl.Tag = "2;" & IIf(SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1)) <> "", SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1)), ";;;;;")
                oControl.Tag = oControl.Tag & ";" & tTemp
            End If

            If TypeOf oControl Is SSTab Then
                For i = 0 To oControl.Tabs - 1
                    oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))
                Next i
            End If
            
             '*Gon 50-07-14 Add New Object Control
            If TypeOf oControl Is TabControl Then
                oControl.Tag = "2; "
                For i = 0 To oControl.ItemCount - 1
                    tTemp = SP_INItGetLang(pwForm.Name, "klg_" & oControl.Name, True)
                    tLang1 = cUT.UT_STRtToken(tTemp, ";", 1, True)
                    tLang2 = cUT.UT_STRtToken(tTemp, ";", 2, True)
                    aLang1 = Split(tLang1, ",")
                    aLang2 = Split(tLang2, ",")
                    nLoop = 0
                    For nLoop = 0 To UBound(aLang1)
                        oControl.Tag = oControl.Tag & aLang1(nLoop) & ";" & aLang2(nLoop) & ";"
                    Next nLoop
                Next i
            End If
            '*******************************

            If TypeOf oControl Is TabStrip Then
                For i = 1 To oControl.Tabs.Count
                    oControl.Tag = "2;" & SP_INItGetValue(tVB_CNPthFileINI, pwForm.Name, cUT.UT_STRtToken(oControl.Caption, ";", 2), cUT.UT_STRtToken(oControl.Caption, ";", 1))
                Next i
            End If
       End If
  Next oControl
End Sub

