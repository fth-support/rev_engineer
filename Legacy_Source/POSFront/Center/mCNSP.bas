    tSqlF = tSqlF & "FTShdStaPrcGL,"
    tSqlF = tSqlF & "FTMemberPriceID," '*KT 52-02-16 member price
    tSqlF = tSqlF & "FTCstPointName,"  '*KT 52-02-23 member point
    tSqlF = tSqlF & "FTCstPointName2,"  '*KT 52-02-23 member point
    tSqlF = tSqlF & "FTCstPointName3,"  '*KT 52-02-23 member point
    tSqlF = tSqlF & "FTShdStaType,"    '*KT 52-07-17
