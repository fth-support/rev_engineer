Public Function SP_EnCryptString(ByVal tString As String, Optional ByVal bCheckLengh As Boolean = True) As String
    '*Tao 59-02-26 เข้ารหัส
    On Error GoTo ErrHandle
    If bCheckLengh Then
        If Len(tString) > 40 Then 'ถ้ายาวเกิน 40 สันนิษฐานว่า Encrypt แล้ว ป้องกันการ EnCrypt ซ้ำซ้อน
            SP_EnCryptString = tString
        Else
            GoTo Encrypt
        End If
    Else
Encrypt:
        Set oEnCryptAES = CreateObject("AdaAES.cAES")
        If Not oEnCryptAES Is Nothing Then
            SP_EnCryptString = oEnCryptAES.EnCryptStr(tString, tW_PassKey, nW_KeySize)
            Set oEnCryptAES = Nothing
        Else
            GoTo ErrHandle
        End If
    End If
    Exit Function
ErrHandle:
    SP_EnCryptString = ""
End Function

Public Function SP_DeCryptString(ByVal tString As String, Optional ByVal bCheckLengh As Boolean = True) As String
    '*Tao 59-02-26 ถอดรหัส
    On Error GoTo ErrHandle
    If bCheckLengh Then
        If Len(tString) < 40 Then 'ถ้ายาวน้อยกว่า 40 สันนิษฐานว่า ยังไม่ได้ EnCrypt
            SP_DeCryptString = tString
        Else
            GoTo Decrypt
        End If
    Else
Decrypt:
        Set oDeCryptAES = CreateObject("AdaAES.cAES")
        If Not oDeCryptAES Is Nothing Then
            SP_DeCryptString = oDeCryptAES.DeCryptStr(tString, tW_PassKey, nW_KeySize)
            Set oDeCryptAES = Nothing
        Else
            GoTo ErrHandle
        End If
    End If
    Exit Function
ErrHandle:
    SP_DeCryptString = ""
End Function

Public Function SP_FEDtEnCryptString(ByVal poRs As ADODB.Recordset, ByVal ptField$, Optional pvRetOld) As String
'*Tao 59-02-26 เข้ารหัสจากการอ่านฐานข้อมูล
Dim bEmpty As Boolean
On Error GoTo ErrHandle
    If poRs.BOF And poRs.EOF Then
        bEmpty = True
    Else
        If IsNull(poRs.Fields(ptField)) Then
            bEmpty = True
        Else
            If Len(Trim(poRs.Fields(ptField))) = 0 Then
                bEmpty = True
            Else
                SP_FEDtEnCryptString = SP_EnCryptString(poRs.Fields(ptField))
            End If
        End If
    End If
    If bEmpty Then
        If IsMissing(pvRetOld) Then
            SP_FEDtEnCryptString = ""
        Else
            SP_FEDtEnCryptString = pvRetOld
        End If
    End If
    Exit Function
ErrHandle:
    SP_FEDtEnCryptString = ""
End Function

