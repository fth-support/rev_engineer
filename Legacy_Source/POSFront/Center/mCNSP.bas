Public Function SP_CHKtGetCardName(ptCardNumber As String) As String
'-------------------------------------------------------------------------------------------------------------------------------
'   Cmt : check type of credit card
'               *Tee 47-10-13
'
'-------------------------------------------------------------------------------------------------------------------------------
    
    Select Case Left$(ptCardNumber, 4)
        Case 1800, 2131, 3528 To 3589
            SP_CHKtGetCardName = "JCB (Japanese Credit Bureau)"
        Case 2014, 2149
            SP_CHKtGetCardName = "enRoute"
        Case 3000 To 3059, 3600 To 3699, 3800 To 3889
            SP_CHKtGetCardName = "Diners Club"
        Case 3400 To 3499, 3700 To 3799
            SP_CHKtGetCardName = "American Express"
        Case 3890 To 3899
            SP_CHKtGetCardName = "carteBlanche"
        Case 4000 To 4999
            SP_CHKtGetCardName = "VISA"
        Case 5100 To 5599
            SP_CHKtGetCardName = "MasterCard"
        Case 5610
            SP_CHKtGetCardName = "Australian BankCard"
        Case 6011
            SP_CHKtGetCardName = "Discover"
        Case Else
                Select Case Left$(ptCardNumber, 1)
                    Case 1 'Airline
                        SP_CHKtGetCardName = "Other (Airline)"
                    Case 2 'Airline and other industry assignments
                        SP_CHKtGetCardName = "Other (Airline and other idustries)"
                    Case 3 'Travel/Entertainment
                        SP_CHKtGetCardName = "Other (Travel/Entertainment)"
                    Case 4 'Banking and financial
                        SP_CHKtGetCardName = "Other (Banking/Financial)"
                    Case 5 'Banking and financial
                        SP_CHKtGetCardName = "Other (Banking/Financial)"
                    Case 6 'Merchandising and banking
                        SP_CHKtGetCardName = "Other (Merchandising/Banking)"
                    Case 7 'Petroleum
                        SP_CHKtGetCardName = "Other (Gas Company)"
                    Case 8 'HealthCare/Telecommunications and other
                        SP_CHKtGetCardName = "Other (HealthCare/Telecomm/Etc)"
                    Case 9 'National assignment
                        SP_CHKtGetCardName = "Other [Card Carrier Unknown]"
                    Case 0 'ISO/TC 68 and other industry assignments
                        SP_CHKtGetCardName = "Other [Card Carrier Unknown]"
            End Select
    End Select
End Function

