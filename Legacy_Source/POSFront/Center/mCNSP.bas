Public Sub SP_CHKInsHDKeepSQL(ByVal ptVB_CNTblHD As String, ByVal ptTmnNum As String, ByVal ptShdTransNo As String, ByVal ptShdTransDate As String, ByVal ptShdTransType As String, ByVal ptSQLIns As String)
