Public Function SP_EDCtReturnCase(ByVal pnRet As Long) As String
'-----------------------------------------------------------
'   Cmt : check return message
'   Create by : *Korn 55-10-08 Edit เพิ่ม procedure ใหม่
'-----------------------------------------------------------
    Dim tMsg As String
    
    tMsg = ""
    Select Case pnRet
        Case 0: tMsg = "PASS"
        Case 2: tMsg = "COM Port not found."
        Case 5: tMsg = "COM Port in use by another process."
        Case 13: tMsg = "Invalid data from Terminal(Bad Checksum)."
        Case 24: tMsg = "Command length is too long(Maximum = 1024 bytes)."
        Case 258: tMsg = "Terminal can not be reached thorugh this port."
        Case 592: tMsg = "Data is not accepted by Terminal(Bad Checksum)."
        Case 1460: tMsg = "Time Out"
        Case Else: tMsg = "Port Error"
    End Select
    
    SP_EDCtReturnCase = tMsg
    
End Function

Public Function SP_EDCtSetPort(ByVal ptEdcPort As String) As String
'____________________________________________________________
'   Call:
'   Cmt: Ao 2012/10/30
'____________________________________________________________
Dim tComport  As String
    Select Case ptEdcPort
        Case 1
            tComport = "Printer"
        Case 2
            tComport = "COM1"
        Case 3
            tComport = "COM2"
        Case 4
            tComport = "COM3"
        Case 5
            tComport = "COM4"
        Case 6
            tComport = "COM5"
        Case 7
            tComport = "COM6"
        Case 8
            tComport = "COM7"
        Case 9
            tComport = "COM8"
        Case Else
            tComport = ""
    End Select
    SP_EDCtSetPort = tComport
End Function

