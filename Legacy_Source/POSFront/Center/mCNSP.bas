    tSqlF = tSqlF & "FTShdTrainMode,FTShdVoucherNo,FCShdVoucherAmt,FTShdUpload," '51-02-12
    tSqlF = tSqlF & "FCShdDepositBal,FCShdDepositBPay,FCShdUnNontVat,FCShdSubReg,FCShdSubPro," '51-02-13
    tSqlF = tSqlF & "FTCstVIPCode,"
    tSqlF = tSqlF & "FTShdTransTypeSub,"
    tSqlF = tSqlF & "FTShdTransNameAbb,"
    tSqlF = tSqlF & "FTShdRecallMode,"
    tSqlF = tSqlF & "FCShdDepositPrvBal,"
    tSqlF = tSqlF & "FDShdSysDate,"
    tSqlF = tSqlF & "FNCstCardPoint,"
    tSqlF = tSqlF & "FNCstCardLPoint,"
    tSqlF = tSqlF & "FCCstCardAmt,"
    tSqlF = tSqlF & "FTCstCardCode2,"
    tSqlF = tSqlF & "FTCstCardType2,"
    tSqlF = tSqlF & "FNCstCardPoint2,"
    tSqlF = tSqlF & "FNCstCardLPoint2,"
    tSqlF = tSqlF & "FCCstCardAmt2,"
    tSqlF = tSqlF & "FTCstCardCode3,"
    tSqlF = tSqlF & "FTCstCardType3,"
    tSqlF = tSqlF & "FNCstCardPoint3,"
    tSqlF = tSqlF & "FNCstCardLPoint3,"
    tSqlF = tSqlF & "FCCstCardAmt3,"
    tSqlF = tSqlF & "FTStaSentOnOff,"
