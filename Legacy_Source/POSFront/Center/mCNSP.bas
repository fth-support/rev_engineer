Public Sub SP_PRCxPointCredit(ByVal tCardNo As String, ByVal ptTdmCode As String, ByVal ptSrcRetDocRef As String, ByVal pcSrcAmt As Double, ByVal ptCardExp As String, ptStaChkExp As String, ByVal pnSeqNo As Integer, Optional ByVal pbLowBP As Boolean = False, Optional ByVal pnLowBPPoint As Long = 0, Optional ByVal pcRefSrcAmt As Double = 0)
Dim orsMall As ADODB.Recordset
Dim orsTier As ADODB.Recordset

Dim tSql As String, tMemEvnCode As String, tCreditType As String, tTierType As String
Dim cMinTier As Double, cMaxTier As Double, cAmtPoint As Double, cAmtRank As Double, cTemp As Double
Dim bChk As Boolean, bTier As Boolean
Dim cDblPoint As Double  '*Tao 59-05-31 Double Point
Dim cAllPoint As Double  '*Tao 59-05-31 Total Double Point ( Point Mem + Point Credit )

On Error GoTo ErrorHandles
    cDblPoint = 0
    tSql = "SELECT TOP 1 TCNMCreditCard.*"
    tSql = tSql & vbCrLf & "FROM  TCNMCreditCard WITH(NOLOCK) "
    If ptTdmCode = "T015" Then          'NETS
        tSql = tSql & vbCrLf & " WHERE FTTdmCode = '" & ptTdmCode & "'"
        tSql = tSql & vbCrLf & " AND FTCdcAlwPoint = 'Y'"
    Else
        tSql = tSql & vbCrLf & "WHERE  FTCdcCreditType = '" & ptSrcRetDocRef & "'"              'T002,T003,T017
        tSql = tSql & vbCrLf & " AND FTTdmCode = '" & ptTdmCode & "'"
        tSql = tSql & vbCrLf & " AND FTCdcAlwPoint = 'Y'"
    End If
    If SP_SQLvExecute(tSql, orsMall, oDB.ocnOnLine, , , , , True, True) = 0 Then
        If Not (orsMall.BOF And orsMall.EOF) Then
            If Format(SP_FEDdChkDate(orsMall, "FDCdcStartDatePoint"), "yyyy/MM/dd") <= Format(SP_GETdChkDatePoint, "yyyy/MM/dd") And Format(SP_FEDdChkDate(orsMall, "FDCdcEndDatePoint"), "yyyy/MM/dd") >= Format(SP_GETdChkDatePoint, "yyyy/MM/dd") Then
                bChk = True
            Else
                bChk = False
            End If
            bW_ChkPointCredit = bChk '*Tao 60-05-18 จะคำนวน Point CreditCard
            If bChk Then
                tMemEvnCode = SP_FEDtChkString(orsMall, "FTEvnCode")
                cMinTier = SP_FEDvChkNumeric(orsMall, "FCCdcAmtMinPoint")
                cMaxTier = SP_FEDvChkNumeric(orsMall, "FCCdcAmtMaxPoint")
                tCreditType = SP_FEDtChkString(orsMall, "FTCdcCreditType")
                tTierType = SP_FEDtChkString(orsMall, "FTCdcStaTierPoint") '0 : Tier แบบ Time 1 : Tier แบบ Amount
                cAmtPoint = SP_FEDvChkNumeric(orsMall, "FCCdcAmtPoint")
                cAmtRank = SP_FEDvChkNumeric(orsMall, "FCCdcAmtRank")
                
                If Not pbLowBP Then '*Tao 60-04-10 ถ้าไม่ใช้ Low BP ให้คำนวนแบบเดิม
                    '*Tao 60-05-03 ปิดไว้
                    'If pcSrcAmt < cMinTier Then
                    '    Exit Sub
                    'End If
                    If pcSrcAmt > cMaxTier Then
                        pcSrcAmt = cMaxTier
                    End If
        
                    tSql = "SELECT * FROM TCNMCreditCardTierPoint WITH(NOLOCK) "
                    tSql = tSql & vbCrLf & "WHERE FTCdcCreditType = '" & tCreditType & "'"
                    tSql = tSql & vbCrLf & "AND FTTdmCode = '" & ptTdmCode & "'"
                    tSql = tSql & vbCrLf & "AND FCCtpAmt > 0"
                    tSql = tSql & vbCrLf & "ORDER BY FTCtpSeq DESC"
                    If SP_SQLvExecute(tSql, orsTier, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
                        bTier = False
                    Else
                        If (orsTier.BOF And orsTier.EOF) Then
                            bTier = False
                        Else
                            bTier = True
                        End If
                    End If
                    If bTier Then
                        If tTierType = "Y" Then 'Y : Tier แบบ Amount     N : Tier แบบ Time
                            cTemp = SP_PRCcTierAmountPointCrd(orsTier, pcSrcAmt, cMinTier, cMaxTier, True)
                        Else
                            cTemp = SP_PRCcTierTimePointCrd(orsTier, pcSrcAmt, cAmtRank, cAmtPoint, cMinTier, cMaxTier)
                        End If
                        cW_ChkPointMem = cW_ChkPointMem + cTemp '*Tao 60-04-10 เก็บค่า Point Mem + Point Credit
                        If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type7CrdPoint, cTemp, pcSrcAmt, "", tMemEvnCode, tCardNo, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointCredit) Then '*Tao 60-04-05 ของเดิม
                            Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type7CrdPoint & ",Credit Card Point" & ",Point =" & cTemp, tVB_MemPointID)
                        End If
                        
                        If cTemp > 0 Then '*Tao 59-06-01 ถ้า Point > 0 ค่อยคำนวน Double Point
                            '* Bmp 59-06-02 SP_CHKbNotAllowDoubleBP
                            '* รออธิบายให้พี่เต่าและอีฟ
                            'If SP_CHKbNotAllowDoubleBP(tVB_CNTerminalNum) Then
                                'ถ้าเครื่องจุดขายถูกกำหนดไว้ว่า ไม่ให้ Double BP ก็ไม่ต้องคำนวณ Double BP
                                
                            'Else
                                '* คำนวณ Double BP
                                If pcRefSrcAmt = 0 Then  '*Tao 60-05-02 ถ้าไม่ส่ง pcRefSrcAmt มา ให้ใช้ pcSrcAmt
                                    cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "2", ptTdmCode, tCreditType, cTemp, tCardNo, pcSrcAmt) '*Tao 60-05-02 ของเดิม
                                Else
                                    cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "2", ptTdmCode, tCreditType, cTemp, tCardNo, pcRefSrcAmt)  '*Tao 60-05-02 ใช้ยอดชำระทั้งหมด
                                End If
                                '*Tao,Bump 59-05-13 CommSheet TK-ISS3000-618 Double bonus points for all DBS cards at 2 specific POS Terminals.xls
                                '*Tao 59-05-17 Type 8 Double Point
                                If cDblPoint > 0 Then
                                    cAllPoint = cDblPoint + cW_PointMem
                                    If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type8AllPoint, cAllPoint, pcSrcAmt, "", tMemEvnCode, tCardNo, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointCredit) Then
                                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type8AllPoint & ",Credit Card Double Point" & ",Point =" & cAllPoint, tVB_MemPointID)
                                    End If
                                    cW_PointMem = 0
                                End If
                                '==========================
                            'End If
                        End If
                    End If
                Else
                    '*Tao 60-04-10 บันทึก Low BP Point
                    cW_ChkPointMem = pnLowBPPoint
                    If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type9LowBP, pnLowBPPoint, pcSrcAmt, "", tMemEvnCode, tCardNo, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointCredit) Then
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type9LowBP & ",Credit Card Point Low BP" & ",Point =" & pnLowBPPoint, tVB_MemPointID)
                    End If
                    If pnLowBPPoint > 0 Then
                        If pcRefSrcAmt = 0 Then  '*Tao 60-05-02 ถ้าไม่ส่ง pcRefSrcAmt มา ให้ใช้ pcSrcAmt
                            cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "2", ptTdmCode, tCreditType, pnLowBPPoint, tCardNo, pcSrcAmt) '*Tao 60-05-02 ของเดิม
                        Else
                            cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "2", ptTdmCode, tCreditType, pnLowBPPoint, tCardNo, pcRefSrcAmt)  '*Tao 60-05-02 ใช้ยอดชำระทั้งหมด
                        End If
                        If cDblPoint > 0 Then
                            cAllPoint = cDblPoint + cW_PointMem
                            If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type0DblLowBP, cAllPoint, pcSrcAmt, "", tMemEvnCode, tCardNo, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointCredit) Then
                                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type0DblLowBP & ",Credit Card Double Point Low BP" & ",Point =" & cAllPoint, tVB_MemPointID)
                            End If
                            cW_PointMem = 0
                        End If
                    End If
                    '============================
                End If
            End If
        End If
    End If
    Call SP_DATxRsNothing(orsMall)
    Call SP_DATxRsNothing(orsTier)
    If cW_PointMem > 0 Then
        If Not pbLowBP Then '*Tao 60-04-10 ถ้าไม่ใช้ Low BP
            If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type8AllPoint, cW_PointMem, pcSrcAmt, "", tW_MemEvnCode, tCardNo, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointCredit) Then
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type8AllPoint & ",Credit Card Double Point" & ",Point =" & cW_PointMem, tVB_MemPointID)
            End If
        Else
            If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type0DblLowBP, cW_PointMem, pcSrcAmt, "", tW_MemEvnCode, tCardNo, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointCredit) Then
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type0DblLowBP & ",Credit Card Double Point Low BP" & ",Point =" & cW_PointMem, tVB_MemPointID)
            End If
        End If
    End If
    cW_PointMem = 0
    tW_MemEvnCode = ""
    Exit Sub
ErrorHandles:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Public Function SP_CHKbNotAllowDoubleBP(ByVal ptTerminalNum As String) As Boolean
'----------------------------------------------------
'   Call:
'   Cmt:    '*Bmp 59-06-02
'               ต้องการเช็คว่าเครื่องจุดขาย ไม่อนุญาตให้ Double BP ใช่หรือไม่?
'               โดยที่ในตาราง TCNMPointCardPOS ที่ FTBpType = '0' จะหมายถึง รายการเครื่องจุดขายที่ ไม่อนุญาตให้ Doble BP
'
'               Req. 2 POSID เพื่อ Not Allow Double BP  ดังนี้ครับ 31311,32321
'----------------------------------------------------
    Dim orsTmp As ADODB.Recordset
    Dim tSql As String
    Dim bDoubleBP As Boolean
    
        On Error GoTo ErrorHandles
        
        SP_CHKbNotAllowDoubleBP = False
        
        tSql = "SELECT  DISTINCT FTBpTmnNum"
        tSql = tSql & vbCrLf & "FROM    TCNMPointCardPOS"
        tSql = tSql & vbCrLf & "WHERE FTBpType = '0' AND FTBpTmnNum = '" & ptTerminalNum & "'"
        
        If SP_SQLvExecute(tSql, orsTmp, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
            bDoubleBP = False
        Else
            If (orsTmp.BOF And orsTmp.EOF) Then
                bDoubleBP = False
            Else
                bDoubleBP = True
            End If
        End If
        
        SP_CHKbNotAllowDoubleBP = bDoubleBP
        
ErrorHandles:
        SP_CHKbNotAllowDoubleBP = False
End Function

Public Function SP_GETnDoubleBP(ByVal ptTerminalNum As String, ByVal ptBpCardType As String, ByVal ptTdmCode As String, ByVal ptCardType As String, ByVal pnPoint As Double, ByVal ptMemPointID As String, ByVal pcSrcAmt As Double) As Double
    '*Bump, Tao 59-05-10
    '*  ptTerminalNum   หมายเลขเครื่องจุดขาย
    '* ptBPCardType           1: Member card, 2: Credit card
    '*  ptTdmCode          ถ้า ptCardType ='1'  ให้ fix เป็น '0000'
    '                                      ถ้า ptCardType ='2' ประเภทรับชำระ T002 = Credit, T003 = Hire Purchase
    '*  ptCardType          ถ้า ptCardType ='1'
    '                                              ptCardType จะเป็นรหัสบัตร Member card--> TCNMMallCardMtn.FTMcdCode
    '                                      ถ้า ptCardType ='2'
    '                                              ptCardType จะเป็นประเภทบัตรเครดิต -->TCNMCreditCard.FTCdcCreditType
    '*  pnPoint                   จำนวนแต้มบัตรเตรดิตที่คำนวณได้ ก่อน คูณด้วย Double BP ของบัตรเครดิตประเภทนั้นๆ
    '*
    '--Ret/Cmt                  จำนวนแต้มได้จาก pnPoint คูณด้วย Double BP TCNMCreditCard.FNCdcDoubleBP
    '----------------------------------------------------------------
    
    Dim orsTmp As ADODB.Recordset
    Dim tSql As String
    Dim bDoubleBP As Boolean
    Dim tDoubleBP As String
    Dim nDoubleBP As Double
    Dim nDoubleBPNet As Double
    Dim tLog As String
    '*Tao 59-05-31 เพิ่ม StaAllPos และ MinPayAmt
    Dim nMinPayAmt As Double
    Dim bStaAllPos As Boolean
    On Error GoTo ErrorHandles
       
    tLog = "DoubleBP:" & ptMemPointID & "," & IIf(ptBpCardType = "1", "MemberCard", IIf(ptTdmCode = "T002", "Credit", "HirePurchase")) & "," & IIf(ptBpCardType = "1", "FTMcdCode:", "FTCdcCreditType:") & ptCardType
    
    If pnPoint = 0 Then
        SP_GETnDoubleBP = 0
        Exit Function
    End If
    
    '*Bump 66-09-22 version.6.2309.1        refer.CommSheet TTK-ISS3000-840 TK Issue - Offline trx did not show double BP_Rev03.xlsx
    '*Tao 59-05-31 เช็คก่อนว่า StaAllPos หรือไม่
    '** Comment ไว้ ** 'bStaAllPos = IIf(SP_SQLtFunction("DISTINCT", "FTBpStaAllPos", "TCNMPointCard", "WHERE TCNMPointCard.FTBpType = '" & ptBpCardType & "' AND TCNMPointCard.FTBpTdmCode = '" & ptTdmCode & "' AND TCNMPointCard.FTBpCardType = '" & ptCardType & "'", oDB.ocnOnLine) = "Y", True, False)
    Dim tStaAllPos  As String
    'tStaAllPos = SP_SQLtFunction("DISTINCT", "FTBpStaAllPos", "TCNMPointCard", "WHERE TCNMPointCard.FTBpType = '" & ptBpCardType & "' AND TCNMPointCard.FTBpTdmCode = '" & ptTdmCode & "' AND TCNMPointCard.FTBpCardType = '" & ptCardType & "'")
    
    ' '*KT 67-12-12 TTK-ISS3000-885,TTK-ISS3000-886
    '1. first read DB Server
    '2. If offline swith to read DB Local
    tStaAllPos = SP_SQLtFunction("DISTINCT", "FTBpStaAllPos", "TCNMPointCard", "WHERE TCNMPointCard.FTBpType = '" & ptBpCardType & "' AND TCNMPointCard.FTBpTdmCode = '" & ptTdmCode & "' AND TCNMPointCard.FTBpCardType = '" & ptCardType & "'", oDB.ocnOnLine, True, True)
    If UCase(tStaAllPos) = UCase("Y") Then
        bStaAllPos = True
    Else
        bStaAllPos = False
    End If
    '============================
    If bStaAllPos Then
        'tSql = "SELECT DISTINCT FTBpStaAlw, FNBpDoubleBP,FTBpStaAllPos,FCBpMinPayAmt"
        'tSql = tSql & vbCrLf & "FROM TCNMPointCard"
        'tSql = tSql & vbCrLf & "WHERE FTBpType = '" & ptBPCardType & "'"
        'tSql = tSql & vbCrLf & "AND FTBpTdmCode = '" & ptTdmCode & "'"
        'tSql = tSql & vbCrLf & "AND FTBpCardType = '" & ptCardType & "'"
        
        tSql = "SELECT DISTINCT TCNMPointCard.FTBpStaAlw, TCNMPointCard.FNBpDoubleBP,TCNMPointCard.FTBpStaAllPos,TCNMPointCard.FCBpMinPayAmt,TCNMTerminalMtn.FTTmnNum,TCNMPointCard.FTBpType"
        tSql = tSql & vbCrLf & "From TCNMPointCard"
        tSql = tSql & vbCrLf & "INNER JOIN TCNMTerminalMtn ON('" & tVB_CNTerminalNum & "' = TCNMTerminalMtn.FTTmnNum )"
        tSql = tSql & vbCrLf & "WHERE FTBpType = '" & ptBpCardType & "'"
        tSql = tSql & vbCrLf & "AND FTBpTdmCode = '" & ptTdmCode & "'"
        tSql = tSql & vbCrLf & "AND FTBpCardType = '" & ptCardType & "'"
        tSql = tSql & vbCrLf & "AND TCNMTerminalMtn.FTTmnNum NOT IN (SELECT DISTINCT FTBpTmnNum FROM TCNMPointCardPOS WHERE FTBpType = '0')"
    Else
        tSql = "SELECT DISTINCT TCNMPointCard.FTBpStaAlw, TCNMPointCard.FNBpDoubleBP,TCNMPointCard.FTBpStaAllPos,TCNMPointCard.FCBpMinPayAmt,TCNMPointCardPOS.FTBpTmnNum"
        tSql = tSql & vbCrLf & "FROM TCNMPointCard"
        tSql = tSql & vbCrLf & "INNER JOIN TCNMPointCardPOS ON(TCNMPointCard.FTBpType = TCNMPointCardPOS.FTBpType)"
        tSql = tSql & vbCrLf & "AND (TCNMPointCard.FTBpTdmCode = TCNMPointCardPOS.FTBpTdmCode)"
        tSql = tSql & vbCrLf & "AND (TCNMPointCard.FTBpCardType = TCNMPointCardPOS.FTBpCardType)"
        tSql = tSql & vbCrLf & "WHERE TCNMPointCard.FTBpType = '" & ptBpCardType & "'"
        tSql = tSql & vbCrLf & "AND TCNMPointCardPOS.FTBpTmnNum = '" & ptTerminalNum & "'"
        tSql = tSql & vbCrLf & "AND TCNMPointCard.FTBpTdmCode = '" & ptTdmCode & "'"
        tSql = tSql & vbCrLf & "AND TCNMPointCard.FTBpCardType = '" & ptCardType & "'"
        tSql = tSql & vbCrLf & "AND TCNMPointCardPOS.FTBpTmnNum NOT IN (SELECT DISTINCT FTBpTmnNum FROM TCNMPointCardPOS WHERE FTBpType = '0')" '*Tao 59-06-06 ยกเว้นบาง POS ที่เป็น FTBpType = '0'
    End If
        
    If SP_SQLvExecute(tSql, orsTmp, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
        bDoubleBP = False
    Else
        If (orsTmp.BOF And orsTmp.EOF) Then
            bDoubleBP = False
        Else
            bDoubleBP = True
        End If
    End If
    
    '** ถ้าไม่ให้ Double BP หรือ Error จาก tSql ให้ส่งค่า 0
    If Not bDoubleBP Then
        SP_GETnDoubleBP = 0
        Call SP_DATxRsNothing(orsTmp)
        Exit Function
    End If
    '* เช็คว่า Double BP ตั้งค่าไว้เป็น Y (ให้ Double BP) หรือ N (ไม่ให้ Double BP)
    tDoubleBP = SP_FEDtChkString(orsTmp, "FTBpStaAlw")
    Call SP_CRTxLogMallCardExtend(tLog & ",Allow=" & tDoubleBP)
    
    If tDoubleBP = "Y" Then
        nDoubleBP = SP_FEDvChkNumeric(orsTmp, "FNBpDoubleBP")
        Call SP_CRTxLogMallCardExtend(tLog & ",DoubleBP=" & nDoubleBP)
        '*Tao 59-05-31 เพิ่ม StaAllPos และ MinPayAmt
        nMinPayAmt = SP_FEDvChkNumeric(orsTmp, "FCBpMinPayAmt")
        bStaAllPos = IIf(SP_FEDtChkString(orsTmp, "FTBpStaAllPos") = "Y", True, False)
        If (nDoubleBP > 0) And (pcSrcAmt >= nMinPayAmt) Then '*Tao 59-05-31 ต้องได้ Point ก่อน และ ยอดเงิน ต้องมากกว่า MinPayAmt
            nDoubleBPNet = (pnPoint * nDoubleBP) - pnPoint
            SP_GETnDoubleBP = nDoubleBPNet
            Call SP_CRTxLogMallCardExtend(tLog & ",GiveDoubleBP=" & pnPoint & "*" & nDoubleBP & "=" & nDoubleBPNet)
        Else
            SP_GETnDoubleBP = 0
        End If
    Else
        SP_GETnDoubleBP = 0
    End If
    Call SP_DATxRsNothing(orsTmp)
    Exit Function
ErrorHandles:
    Call SP_CRTxLogMallCardExtend("SP_GETnCreditDoubleBP:Error, Credit card Point, Err Number " & Err.Number & ",Err Desc:" & Err.Description)
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

Public Sub SP_PRCxPointMEM(ByVal ptMemPointID As String, ByVal pcSrcAmt As Double, ByVal ptCardExp As String, ByVal pnSeqNo As Integer, ByRef ptStaChkExp As String, Optional ByVal pbSaveType8 As Boolean = True, Optional ByVal pbLowBP As Boolean = False, Optional ByVal pnLowBPPoint As Long = 0, Optional ByVal pcRefSrcAmt As Double = 0)
Dim orsMall As ADODB.Recordset
Dim orsTier As ADODB.Recordset

Dim tSql As String, tMemEvnCode As String
Dim tAlwPointAll  As String, tAlwPoint As String, tMcdCode As String, tTierType As String, tStaChkExp As String

Dim cMinTier As Double, cMaxTier As Double, cAmtPoint As Double, cAmtRank As Double, cTemp As Double
Dim bTier As Boolean, bChk As Boolean
Dim cDblPoint As Double '*Tao 59-05-31 Double Point
     
On Error GoTo ErrorHandles
    cW_PointMem = 0
    tW_MemEvnCode = ""
    cDblPoint = 0
    tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & ptMemPointID & "'"
    Call SP_SQLvExecute(tSql, orsMall, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not (orsMall.BOF And orsMall.EOF) Then
        tAlwPointAll = SP_FEDtChkString(orsMall, "FTMcdAlwPointAll")
        tAlwPoint = SP_FEDtChkString(orsMall, "FTMcdAlwPoint")
        ptStaChkExp = SP_FEDtChkString(orsMall, "FTMcdStaChkExp")
        If Format(SP_FEDdChkDate(orsMall, "FDMcdStartDatePoint"), "yyyy/MM/dd") <= Format(SP_GETdChkDatePoint, "yyyy/MM/dd") And Format(SP_FEDdChkDate(orsMall, "FDMcdEndDatePoint"), "yyyy/MM/dd") >= Format(SP_GETdChkDatePoint, "yyyy/MM/dd") Then
            bChk = True
        Else
            bChk = False
        End If
        If bChk Then
            If (tAlwPointAll = "Y" And tAlwPoint = "Y") Then
                bChk = True
            Else
                bChk = False
            End If
        Else
            bChk = False
        End If
        bW_ChkPointMem = bChk '*Tao 60-05-18 จะคำนวน Point Member
        If bChk Then
            tMcdCode = SP_FEDtChkString(orsMall, "FTMcdCode")
            tMemEvnCode = SP_FEDtChkString(orsMall, "FTEvnCode")
            cMinTier = SP_FEDvChkNumeric(orsMall, "FCMcdAmtMinPoint")
            cMaxTier = SP_FEDvChkNumeric(orsMall, "FCMcdAmtMaxPoint")
            tTierType = SP_FEDtChkString(orsMall, "FTMcdStaTier") '0 : Tier แบบ Time 1 : Tier แบบ Amount
            cAmtPoint = SP_FEDvChkNumeric(orsMall, "FCMcdAmtPoint")
            cAmtRank = SP_FEDvChkNumeric(orsMall, "FCMcdAmtRank")
            
            If Not pbLowBP Then '*Tao 60-04-10 ถ้าไม่ใช้ Low BP ให้คำนวนแบบเดิม
                '*Tao 60-05-03 ปิดไว้
                'If pcSrcAmt < cMinTier Then
                '    Exit Sub
                'End If
                If pcSrcAmt > cMaxTier Then
                    pcSrcAmt = cMaxTier
                End If
                tSql = "SELECT * FROM TCNMMallCardTier"
                tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE FTMcdCode = '" & tMcdCode & "'"
                tSql = tSql & vbCrLf & "AND FCMtrAmt > 0"
                tSql = tSql & vbCrLf & "ORDER BY FTMtrSeq DESC"
                If SP_SQLvExecute(tSql, orsTier, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
                    bTier = False
                Else
                    If orsTier.BOF And orsTier.EOF Then
                        bTier = False
                    Else
                        bTier = True
                    End If
                End If
                If bTier Then
                    If tTierType = "Y" Then 'Y : Tier แบบ Amount     N : Tier แบบ Time
                        cTemp = SP_PRCcTierAmountPointMall(orsTier, pcSrcAmt, cMinTier, cMaxTier, True)
                    Else
                        cTemp = SP_PRCcTierTimePointMall(orsTier, pcSrcAmt, cAmtRank, cAmtPoint, cMinTier, cMaxTier)
                    End If
                    cW_ChkPointMem = cTemp '*Tao 60-04-10 เก็บค่า Point
                    If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type6MemPoint, cTemp, pcSrcAmt, "", tMemEvnCode, ptMemPointID, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointMem) Then
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type6MemPoint & ",Member Card Point" & ",Point =" & cTemp, tVB_MemPointID)
                    End If
                    
                    If cTemp > 0 Then '*Tao 59-06-01 ถ้า Point > 0 ค่อยคำนวน Double Point
                        '*Tao,Bump 59-05-13 CommSheet TK-ISS3000-618 Double bonus points for all DBS cards at 2 specific POS Terminals.xls
                        
                        '* SP_CHKbNotAllowDoubleBP
                        'If SP_CHKbNotAllowDoubleBP(tVB_CNTerminalNum) Then
                            'ถ้าเครื่องจุดขายถูกกำหนดไว้ว่า ไม่ให้ Double BP ก็ไม่ต้องคำนวณ Double BP
                            
                        'Else
                            '* คำนวณ Double BP
                            If pcRefSrcAmt = 0 Then  '*Tao 60-05-02 ถ้าไม่ส่ง pcRefSrcAmt มา ให้ใช้ pcSrcAmt
                                cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "1", "0000", tMcdCode, cTemp, ptMemPointID, pcSrcAmt) '*Tao 60-05-02 ของเดิม
                            Else
                                cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "1", "0000", tMcdCode, cTemp, ptMemPointID, pcRefSrcAmt) '*Tao 60-05-02 ใช้ยอดชำระทั้งหมด
                            End If
                            
                            '*Tao 59-05-31 Type 8 Double Point
                            If cDblPoint > 0 And pbSaveType8 Then
                                If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type8AllPoint, cDblPoint, pcSrcAmt, "", tMemEvnCode, ptMemPointID, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointMem) Then
                                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type8AllPoint & ",Member Card Double Point" & ",Point =" & cDblPoint, tVB_MemPointID)
                                End If
                            Else
                                cW_PointMem = cDblPoint
                                tW_MemEvnCode = tMemEvnCode
                            End If
                            '==========================
                        'End If
                    End If
                End If
            Else
                '*Tao 60-04-10 บันทึก Low BP Point
                cW_ChkPointMem = pnLowBPPoint
                If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type9LowBP, pnLowBPPoint, pcSrcAmt, "", tMemEvnCode, ptMemPointID, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointMem) Then
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type9LowBP & ",Member Card Point Low BP" & ",Point =" & pnLowBPPoint, tVB_MemPointID)
                End If
                If pnLowBPPoint > 0 Then
                    If pcRefSrcAmt = 0 Then  '*Tao 60-05-02 ถ้าไม่ส่ง pcRefSrcAmt มา ให้ใช้ pcSrcAmt
                        cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "1", "0000", tMcdCode, pnLowBPPoint, ptMemPointID, pcSrcAmt) '*Tao 60-05-02 ของเดิม
                    Else
                        cDblPoint = SP_GETnDoubleBP(tVB_CNTerminalNum, "1", "0000", tMcdCode, pnLowBPPoint, ptMemPointID, pcRefSrcAmt) '*Tao 60-05-02 ใช้ยอดชำระทั้งหมด
                    End If
                    If cDblPoint > 0 And pbSaveType8 Then
                        If Not SP_PRCbSavSalePointEx(eEN_PointType.nEN_Type0DblLowBP, cDblPoint, pcSrcAmt, "", tMemEvnCode, ptMemPointID, ptCardExp, ptStaChkExp, pnSeqNo, bW_ChkPointMem) Then
                            Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type0DblLowBP & ",Member Card Double Point Low BP" & ",Point =" & cDblPoint, tVB_MemPointID)
                        End If
                    Else
                        cW_PointMem = cDblPoint
                        tW_MemEvnCode = tMemEvnCode
                    End If
                End If
                '============================
            End If
        End If
    End If
    Call SP_DATxRsNothing(orsMall)
    Call SP_DATxRsNothing(orsTier)
    Exit Sub
ErrorHandles:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Public Function SP_PRCtGetMemPointID() As String
'----------------------------------------------------
'   Call:
'   Cmt:    '*Ao 2013/03/14
'----------------------------------------------------
On Error GoTo ErrorHandles
Dim tSql As String, tMemPointID As String
Dim orsTemp As ADODB.Recordset

    tSql = "SELECT FTCstCardCode FROM " & tVB_CNTblHD
    tSql = tSql & vbCrLf & "WHERE  FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        tMemPointID = SP_FEDtChkString(orsTemp, "FTCstCardCode")
    Else
        tMemPointID = ""
    End If
    Call SP_CRTxLogMallCardExtend("SP_PRCtGetMemPointID: tMemPointID(FTCstCardCode) :[" & tMemPointID & "]")   '*[5.2209.0][65/09/10]*Bmp 65-09-10 TTK-ISS3000-809
    Call SP_DATxRsNothing(orsTemp)
    
    '*Bump 65-09-28 CommSheet TTK-ISS3000-809 TK ISSUE - Wrong member card number printed on receipt_Rev02.xlsx
    '* พบว่า log แสดง tMemPointID เป็นค่า ว่าง SP_PRCtGetMemPointID: tMemPointID :[]
    '** เพิ่ม query หา member card id กรณีที่ tMemPointID เป็นค่า ว่าง
    If tMemPointID = "" Then
        tSql = "SELECT DISTINCT TOP 1 FTSpoMemID"
        tSql = tSql & vbCrLf & "FROM  TPSTSalePoint WITH(NOLOCK)"
        tSql = tSql & vbCrLf & "WHERE  FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            tMemPointID = SP_FEDtChkString(orsTemp, "FTSpoMemID")
        End If
        Call SP_CRTxLogMallCardExtend("SP_PRCtGetMemPointID: tMemPointID(FTSpoMemID) :[" & tMemPointID & "]")   '*[5.2209.0][65/09/10]*Bmp 65-09-10 TTK-ISS3000-809
    End If
    
    SP_PRCtGetMemPointID = tMemPointID
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrorHandles:
    Call SP_MSGxShowError(Err.Number, "SP_PRCtGetMemPointID:" & Err.Description)
    SP_PRCtGetMemPointID = ""
End Function

Private Sub SP_PRCxPointMemberGroup(ByVal ptMemPointID As String, ByVal ptMemExp As String)
'--------------------------------------------
'   Call:
'   Cmt:    '*Ao 2014/04/30
'--------------------------------------------
Dim tSql  As String
Dim tAlwPointAll As String, tAlwPoint As String, tMcdCode As String, tCardType As String
Dim tStaChkExp  As String, tMbgGroup As String, tCardNo As String, tCardExp As String
Dim tAllowBP As String

Dim orsTemp As ADODB.Recordset
Dim orsMem As ADODB.Recordset
On Error GoTo ErrorHandles
    
    tCardNo = ptMemPointID
    tCardExp = ptMemExp
    
    ReDim aMBGroup(0)
    aMBGroup(0).FTMemberID = ""
    aMBGroup(0).FTMcdCode = ""
    aMBGroup(0).FTMcdCardType = ""
    aMBGroup(0).FTMbgGroup = ""
    aMBGroup(0).FTMcdStaChkExp = ""
    aMBGroup(0).FTDateExp = ""
    If ptMemPointID <> "" Then
        tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & ptMemPointID & "'"
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            tAlwPointAll = SP_FEDtChkString(orsTemp, "FTMcdAlwPointAll")
            tAlwPoint = SP_FEDtChkString(orsTemp, "FTMcdAlwPoint")
            tMcdCode = SP_FEDtChkString(orsTemp, "FTMcdCode")
            tCardType = SP_FEDtChkString(orsTemp, "FTMcdCardType")
            tStaChkExp = SP_FEDtChkString(orsTemp, "FTMcdStaChkExp")
            If (UCase(tAlwPointAll) = "Y") And (UCase(tAlwPoint) = "Y") Then
                tSql = "SELECT FTMbgGroup FROM TCNMMallCardMtn WITH(NOLOCK) "
                tSql = tSql & vbCrLf & "WHERE FTMcdCode = '" & tMcdCode & "'"
                Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    tMbgGroup = SP_FEDtChkString(orsTemp, "FTMbgGroup")
                    If tMbgGroup <> "" Then
                        ReDim Preserve aMBGroup(UBound(aMBGroup) + 1)
                        aMBGroup(UBound(aMBGroup)).FTMemberID = tCardNo
                        aMBGroup(UBound(aMBGroup)).FTMcdCode = tMcdCode
                        aMBGroup(UBound(aMBGroup)).FTMcdCardType = tCardType
                        aMBGroup(UBound(aMBGroup)).FTMbgGroup = tMbgGroup
                        aMBGroup(UBound(aMBGroup)).FTMcdStaChkExp = tStaChkExp
                        aMBGroup(UBound(aMBGroup)).FTDateExp = tCardExp
                    End If
                End If
            End If
        End If
    End If
    '--------------------------------------------
    tSql = "SELECT * FROM " & tVB_CNTblRC           'หา Credit card allow MEMBER
    tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE  FTTmnNum ='" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransNo ='" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate ='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & "AND FTTdmCode IN ('T002','T003','T017')"
    tSql = tSql & vbCrLf & "ORDER BY FNSrcSeqNo"
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        orsTemp.MoveFirst
        Do While Not orsTemp.EOF
            tCardNo = SP_FEDtChkString(orsTemp, "FTSrcCardNo")
            tCardExp = SP_FEDtChkString(orsTemp, "FTSrcCardExp")
            tAllowBP = SP_FEDtChkString(orsTemp, "FTSrcRmk")
            If UCase(tAllowBP) = UCase("Y") Then
                tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & tCardNo & "'"
                Call SP_SQLvExecute(tSql, orsMem, oDB.ocnOnLine, , , , , True, True) 'read master
                If Not (orsMem.BOF And orsMem.EOF) Then
                    tAlwPointAll = SP_FEDtChkString(orsMem, "FTMcdAlwPointAll")
                    tAlwPoint = SP_FEDtChkString(orsMem, "FTMcdAlwPoint")
                    tMcdCode = SP_FEDtChkString(orsMem, "FTMcdCode")
                    tCardType = SP_FEDtChkString(orsMem, "FTMcdCardType")
                    tStaChkExp = SP_FEDtChkString(orsMem, "FTMcdStaChkExp")
                    If (UCase(tAlwPointAll) = "Y") And (UCase(tAlwPoint) = "Y") Then
                        tSql = "SELECT FTMbgGroup FROM TCNMMallCardMtn WITH(NOLOCK) "
                        tSql = tSql & vbCrLf & "WHERE FTMcdCode = '" & tMcdCode & "'"
                        Call SP_SQLvExecute(tSql, orsMem, oDB.ocnOnLine, , , , , True, True) 'read master
                        If Not (orsMem.BOF And orsMem.EOF) Then
                            tMbgGroup = SP_FEDtChkString(orsMem, "FTMbgGroup")
                            If tMbgGroup <> "" Then
                                ReDim Preserve aMBGroup(UBound(aMBGroup) + 1)
                                aMBGroup(UBound(aMBGroup)).FTMemberID = tCardNo
                                aMBGroup(UBound(aMBGroup)).FTMcdCode = tMcdCode
                                aMBGroup(UBound(aMBGroup)).FTMcdCardType = tCardType
                                aMBGroup(UBound(aMBGroup)).FTMbgGroup = tMbgGroup
                                aMBGroup(UBound(aMBGroup)).FTMcdStaChkExp = tStaChkExp
                                aMBGroup(UBound(aMBGroup)).FTDateExp = tCardExp
                                If tVB_MemPointID = "" Then
                                    tVB_MemPointID = tCardNo
                                    tVB_MemExp = tCardExp
                                End If
                            End If
                        End If
                    End If
                End If
            End If
            orsTemp.MoveNext
        Loop
    End If
    
    Exit Sub
ErrorHandles:
    
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " Error Desc:" & Err.Description & ",Form:mCNSP:SP_PRCxMemberGroup")
End Sub

Private Function SP_PRCbPointGroup(ByRef ptCardNo As String, ByRef ptCardExp As String, ByVal ptTdmCode As String, ByVal ptSrcRetDocRef As String) As Boolean
'-----------------------------------------------------
'   Call:
'   Cmt:    '*Ao 2014/05/02  PRJ10001TK-PH2-External Spec-Member Card Group-00.02.04 FSBT
'-----------------------------------------------------
Dim tSql As String, tAlwPointAll As String, tAlwPoint As String, tMcdCode As String
Dim tMbgGroup  As String, tTenderGroup As String
Dim bChk As Boolean
Dim nI As Integer

Dim orsTemp As ADODB.Recordset

On Error GoTo ErrorHandles

    bChk = False
    
    tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & ptCardNo & "'"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        tAlwPointAll = SP_FEDtChkString(orsTemp, "FTMcdAlwPointAll")
        tAlwPoint = SP_FEDtChkString(orsTemp, "FTMcdAlwPoint")
        tMcdCode = SP_FEDtChkString(orsTemp, "FTMcdCode")
        If (UCase(tAlwPointAll) = "Y") And (UCase(tAlwPoint) = "Y") Then
            tSql = "SELECT FTMbgGroup FROM TCNMMallCardMtn WITH(NOLOCK) "
            tSql = tSql & vbCrLf & "WHERE FTMcdCode = '" & tMcdCode & "'"
            Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                tMbgGroup = SP_FEDtChkString(orsTemp, "FTMbgGroup")
                tSql = "SELECT * FROM TCNMTenderMember WITH(NOLOCK) "
                tSql = tSql & vbCrLf & "WHERE FTTdmCode = '" & ptTdmCode & "'"
                Select Case UCase(ptTdmCode)
                    Case UCase("T002"), UCase("T003"), UCase("T017")
                        tSql = tSql & vbCrLf & "AND FTCdcCreditType = '" & ptSrcRetDocRef & "'"
                End Select
                Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    orsTemp.MoveFirst
                    Do While Not orsTemp.EOF
                        tTenderGroup = SP_FEDtChkString(orsTemp, "FTMbgGroup")
                        If UCase(tMbgGroup) = UCase(tTenderGroup) Then
                            bChk = True
                            Exit Do
                        End If
                        orsTemp.MoveNext
                    Loop
                End If
            End If
        End If
    Else
        tSql = "SELECT * FROM TCNMTenderMember WITH(NOLOCK) "
        tSql = tSql & vbCrLf & "WHERE FTTdmCode = '" & ptTdmCode & "'"
        Select Case UCase(ptTdmCode)
            Case UCase("T002"), UCase("T003"), UCase("T017")
                tSql = tSql & vbCrLf & "AND FTCdcCreditType = '" & ptSrcRetDocRef & "'"
        End Select
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                tTenderGroup = SP_FEDtChkString(orsTemp, "FTMbgGroup")
                For nI = 0 To UBound(aMBGroup)
                    If UCase(aMBGroup(nI).FTMbgGroup) = UCase(tTenderGroup) Then
                        ptCardNo = aMBGroup(nI).FTMemberID
                        ptCardExp = aMBGroup(nI).FTDateExp
                        bChk = True
                        Exit Do
                    End If
                Next nI
                orsTemp.MoveNext
            Loop
        End If
    End If
    
    SP_PRCbPointGroup = bChk
Exit Function
ErrorHandles:
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0,Form:mCNSP:SP_PRCxMemberGroup")
End Function

Public Sub SP_PRCxPointALL()
'-----------------------------------------------------
'   Call:
'   Cmt:    '*Ao 2014/05/02  PRJ10001TK-PH2-External Spec-Member Card Group-00.02.04 FSBT
'-----------------------------------------------------
Dim tSql  As String, tTdmCode As String, tSrcRetDocRef As String, tWhere As String, tCardNo As String, tAllowBP As String
