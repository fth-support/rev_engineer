Public Function SP_CHKxIsFormOpen(ByVal ptFormName As String) As Boolean
'*Tao 60-01-19 เช็คว่า Form เปิดอยู่หรือไม่
Dim oFrm As Form
On Error GoTo ErrorHandle
    SP_CHKxIsFormOpen = False
    For Each oFrm In Forms
        If LCase(Trim(oFrm.Name)) = LCase(Trim(ptFormName)) Then
