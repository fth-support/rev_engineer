Public Sub SP_PRCxReMemberPointEx(Optional ByRef pnRound As Long = 2)
'------------------------------------------------------
'Call:
'Cmt: *KT 52-07-13 การคำนวนแต้มจากการได้ Ontop หรือ การใช้ Tender Special Gift Voucher , Special Coupon , Credit Card ที่ Not Allow Mall Cardของ Add Deposit ,Redeem
'------------------------------------------------------
    Dim tSql$
    Dim cPointOntop As Double
    Dim cPointAmtOntop  As Double
    Dim cPointSpec As Double
    Dim cPointAmtSpec   As Double
    Dim cMcmPoint As Double
    Dim cMcmRank As Double
    Dim orsCoo As ADODB.Recordset
    Dim orsMall As ADODB.Recordset
    Dim orsTemp As ADODB.Recordset
    Dim orsTender As ADODB.Recordset
    Dim orsCrd As ADODB.Recordset
    Dim bReMemberPoint As Boolean
    Dim bPass As Boolean
    Dim tCardNo As String
    Dim tCrdEvnCode As String
   
On Error GoTo ErrHandle

   '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
    If pnRound = 0 Then
        Call SP_DATxRsNothing(orsCoo)
        Call SP_DATxRsNothing(orsMall)
        Call SP_DATxRsNothing(orsTemp)
        bReMemberPoint = False
        Exit Sub
    End If
    pnRound = pnRound - 1
    bReMemberPoint = True
    
    If Trim(tVB_MemPointID) = "" Then
        tSql = "SELECT  FTCstCardCode FROM " & tVB_CNTblHD
        tSql = tSql & vbCrLf & "WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & "AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
        If SP_SQLvExecute(tSql, orsTemp) = 0 Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                tVB_MemPointID = SP_FEDtChkString(orsTemp, "FTCstCardCode")
            End If
        End If
        If tVB_MemPointID = "" Then '*Eaw 55-12-13
            tVB_MemPointID = tVB_CrdCardNo
        End If
    End If
    
    'อ่านค่าการรับชำระด้วย Credit Card Tender แบบ Group by Credit Card ID
    tSql = "SELECT  SUM(RC.FCSrcNet) AS FCSrcNet,RC.FTTmnNum, RC.FTShdTransNo, RC.FTShdTransType, RC.FDShdTransDate,"
    tSql = tSql & vbCrLf & "RC.FTSrcCardNo,RC.FTTdmCode,RC.FTSrcRetDocRef"
    tSql = tSql & vbCrLf & "FROM " & tVB_CNTblRC & " RC"
    tSql = tSql & vbCrLf & " WHERE RC.FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & " AND RC.FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & " AND RC.FTShdTransType = '" & tVB_Transaction & "'"
    tSql = tSql & vbCrLf & " AND RC.FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND RC.FTTdmCode IN ('T002','T003','T015','T017')"    '*Eaw 56-01-04 การคิดแต้ม Extra Point NETS
'    tSql = tSql & vbCrLf & " AND RC.FTTdmCode IN ('T002','T003')"
    tSql = tSql & vbCrLf & "GROUP BY RC.FTTmnNum, RC.FTShdTransNo, RC.FTShdTransType, RC.FDShdTransDate,"
    tSql = tSql & vbCrLf & "RC.FTSrcCardNo,RC.FTTdmCode,RC.FTSrcRetDocRef"
    tSql = tSql & vbCrLf & "ORDER BY RC.FTSrcRetDocRef"
    If SP_SQLvExecute(tSql, orsTender) = 0 Then
       If Not (orsTender.BOF And orsTender.EOF) Then
            Do While Not orsTender.EOF
                tSql = "SELECT TOP 1 TC.FTTdmCode, TC.FTCdcCreditType, TC.FTCdcDescCredit, TC.FTCdcDescRe,"
                tSql = tSql & vbCrLf & "TC.FNCdcDigits, TC.FNCdcDigitChk, TC.FNCdcOntopRate, TC.FTCdcMallCard,"
                tSql = tSql & vbCrLf & "TC.FTCdcOnTop, TC.FTCdcDepCode, TC.FCCdcAmtMax, TC.FCCdcAmtMin,"
                tSql = tSql & vbCrLf & "TC.FDCdcStartDate, TC.FDCdcEndDate, TC.FTCdcReg, TC.FTCdcPro,"
                tSql = tSql & vbCrLf & "TC.FTCdcAlwPoint, TC.FCCdcAmtRank, TC.FCCdcAmtPoint,"
                tSql = tSql & vbCrLf & "TC.FCCdcAmtMinPoint, TC.FCCdcAmtMaxPoint, TC.FDCdcStartDatePoint,"
                tSql = tSql & vbCrLf & "TC.FDCdcEndDatePoint, TC.FTCdcRegPoint, TC.FTCdcPromoPoint,"
                tSql = tSql & vbCrLf & "TC.FTCdcStaSubAllPoint, TC.FTCdcStaAdd, TC.FTCdcStaDeptCodePoint,"
                tSql = tSql & vbCrLf & "TC.FTCdcStaTierPoint, TC.FTCdcStaTimePoint, TC.FTCdcStaSubAll,"
                tSql = tSql & vbCrLf & "TC.FTCdcStaTier , TC.FTCdcStaTime,"
                tSql = tSql & vbCrLf & "TC.FTEvnCode" '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                tSql = tSql & vbCrLf & "FROM   TCNMCreditCard TC "
                '*Eaw 56-01-04 การคิดแต้ม Extra Point NETS
                If SP_FEDtChkString(orsTender, "FTTdmCode") = "T015" Then
                    tSql = tSql & vbCrLf & " WHERE TC.FTTdmCode = '" & SP_FEDtChkString(orsTender, "FTTdmCode") & "'"
                    tSql = tSql & vbCrLf & " AND TC.FTCdcAlwPoint = 'Y'"
                Else
                    tSql = tSql & vbCrLf & "WHERE  FTCdcCreditType = '" & SP_FEDtChkString(orsTender, "FTSrcRetDocRef") & "'"
                    tSql = tSql & vbCrLf & " AND TC.FTTdmCode = '" & SP_FEDtChkString(orsTender, "FTTdmCode") & "'"
                    tSql = tSql & vbCrLf & " AND TC.FTCdcAlwPoint = 'Y'"
                End If
                '------------------------------------------------------------------------------------
'                tSql = tSql & vbCrLf & "WHERE  FTCdcCreditType = '" & SP_FEDtChkString(orsTender, "FTSrcRetDocRef") & "'"
'                tSql = tSql & vbCrLf & " AND TC.FTTdmCode = '" & SP_FEDtChkString(orsTender, "FTTdmCode") & "'"
'                tSql = tSql & vbCrLf & " AND TC.FTCdcAlwPoint = 'Y'"
                tSql = tSql & vbCrLf & "GROUP BY TC.FTTdmCode, TC.FTCdcCreditType, TC.FTCdcDescCredit, TC.FTCdcDescRe,"
                tSql = tSql & vbCrLf & "TC.FNCdcDigits, TC.FNCdcDigitChk, TC.FNCdcOntopRate, TC.FTCdcMallCard,"
                tSql = tSql & vbCrLf & "TC.FTCdcOnTop, TC.FTCdcDepCode, TC.FCCdcAmtMax, TC.FCCdcAmtMin,"
                tSql = tSql & vbCrLf & "TC.FDCdcStartDate, TC.FDCdcEndDate, TC.FTCdcReg, TC.FTCdcPro,"
                tSql = tSql & vbCrLf & "TC.FTCdcAlwPoint, TC.FCCdcAmtRank, TC.FCCdcAmtPoint,"
                tSql = tSql & vbCrLf & "TC.FCCdcAmtMinPoint, TC.FCCdcAmtMaxPoint, TC.FDCdcStartDatePoint,"
                tSql = tSql & vbCrLf & "TC.FDCdcEndDatePoint, TC.FTCdcRegPoint, TC.FTCdcPromoPoint,"
                tSql = tSql & vbCrLf & "TC.FTCdcStaSubAllPoint, TC.FTCdcStaAdd, TC.FTCdcStaDeptCodePoint,"
                tSql = tSql & vbCrLf & "TC.FTCdcStaTierPoint, TC.FTCdcStaTimePoint, TC.FTCdcStaSubAll,"
                tSql = tSql & vbCrLf & "TC.FTCdcStaTier , TC.FTCdcStaTime,"
                tSql = tSql & vbCrLf & "TC.FTEvnCode"
                tSql = tSql & vbCrLf & "ORDER BY TC.FTCdcCreditType"
                If SP_SQLvExecute(tSql, orsCrd, oDB.ocnOnLine, , , , , True, True) = 0 Then
                    If Not (orsCrd.BOF And orsCrd.EOF) Then
                        'ทำการตรวจสอบว่าอนุญาตให้ Extra Point หรือไม่
                        If SP_FEDtChkString(orsCrd, "FTCdcAlwPoint") = "Y" Then
                            tCardNo = SP_FEDtChkString(orsTender, "FTSrcCardNo")
                            tCrdEvnCode = SP_FEDtChkString(orsCrd, "FTEvnCode") '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                         End If
                    End If
                End If
                orsTender.MoveNext
            Loop
        End If
    End If
        
    If Trim(tVB_MemPointID) <> "" Then
        tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & Trim(tVB_MemPointID) & "'"
        Call SP_SQLvExecute(tSql, orsMall, oDB.ocnOnLine, , , , , True, True) 'read master
        If Not (orsMall.BOF And orsMall.EOF) Then
            tVB_StaMemPointAlw = SP_FEDtChkString(orsMall, "FTMcdAlwPointAll")
            tVB_MemEvnCode = SP_FEDtChkString(orsMall, "FTEvnCode") '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
            '*KT 52-02-24 member point process คำนวณ point
            '---------------------------------------------------------------------------------------------
            'All
            cPointOntop = 0
            cPointAmtOntop = 0
            cPointSpec = 0
            cPointAmtSpec = 0
            If tVB_StaMemPointAlw = "Y" Then
                tSql = "SELECT  FNMcmPoint, FCMcmAmt "
                tSql = tSql & vbCrLf & " FROM TCNMMemberCooMtn"
                tSql = tSql & vbCrLf & " WHERE ISNULL(FTMcmStaCoo,'N') = 'Y'"
                tSql = tSql & vbCrLf & " AND '" & Format(SP_GETdChkDatePoint, "YYYY/MM/DD") & "' BETWEEN FDMcmStartDate AND FDMcmEndDate"
                If SP_SQLvExecute(tSql, orsCoo, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                        cMcmPoint = SP_FEDvChkNumeric(orsCoo, "FNMcmPoint")
                        cMcmRank = SP_FEDvChkNumeric(orsCoo, "FCMcmAmt")
                        If cVB_CNTotalOntopByTicket > 0 Then
                            cPointOntop = Int(cVB_CNTotalOntopByTicket / cMcmRank) * cMcmPoint
                            If cPointOntop > 0 Then cPointAmtOntop = cPointAmtOntop + cVB_CNTotalOntopByTicket
                        End If
                        If cVB_CNTotalSpecialByTicket > 0 Then
                            cPointSpec = Int(cVB_CNTotalSpecialByTicket / cMcmRank) * cMcmPoint
                            If cPointSpec > 0 Then cPointAmtSpec = cPointAmtSpec + cVB_CNTotalSpecialByTicket
                        End If
                        
                        If cPointOntop > 0 Or cPointSpec > 0 Then
                                ocnAll.BeginTrans
                                bPass = True
                                tSql = "UPDATE " & tVB_CNTblHD
                                tSql = tSql & " SET FNCstCardPoint = FNCstCardPoint - " & CLng(cPointOntop) & " + " & CLng(cPointSpec)
                                tSql = tSql & " ,FCCstCardAmt = FCCstCardAmt - " & cPointAmtOntop & " + " & cPointAmtSpec
                                tSql = tSql & "," & UT_tLastUpdSql
                                tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                                tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                                Call SP_SQLvExecute(tSql)
                                Select Case SP_VALnText2Double(tVB_TransactionSub)
                                    Case tEN_TrnAddDeposit
                                        'Update Point ของ Deposit Create  ที่ TPSTDepositHD บน Local
                                        tSql = "UPDATE TPSTDepositHD"
                                        tSql = tSql & " SET FNCstCardPoint = FNCstCardPoint - " & CLng(cPointOntop) & " + " & CLng(cPointSpec)
                                        tSql = tSql & " ,FCCstCardAmt = FCCstCardAmt - " & cPointAmtOntop & " + " & cPointAmtSpec
                                        tSql = tSql & "," & UT_tLastUpdSql
                                        tSql = tSql & " WHERE  FTTmnNum='" & tVB_TerminalNoAddDpt & "' AND FTShdTransNo='" & tVB_TransNoAddDpt & "'"
                                        tSql = tSql & " AND  FTShdTransType='" & Format(tEN_TrnAddDeposit, "00") & "' AND FDShdTransDate='" & Format(dVB_TransDateAddDpt, "YYYY/MM/DD") & "'"
                                        Call SP_SQLvExecute(tSql)
                                        'Update Point ของ Deposit Create  ที่ TPSTDepositHD บน Server
                                        tSql = "UPDATE TPSTDepositHD"
