Public Sub SP_PRCxOtherPoint(ByVal ptMemPointID As String)
Dim orsTemp As ADODB.Recordset
Dim orsCoo As ADODB.Recordset
Dim orsMall As ADODB.Recordset
Dim orsTemp2  As ADODB.Recordset
Dim orsTemp3 As ADODB.Recordset
Dim tPointSpecial  As String, tPointAdd As String, tMallCardKey As String, tMemEvnCode As String
Dim cPoint  As Double, cPointAmt As Double, cPointSku As Double, cPointAmtSku As Double, cPointDpt As Double, cPointAmtDpt As Double
Dim cPointGen As Double, cPointAmtGen As Double, cSecTemp As Double, cSubTotal As Double, cCooTemp  As Double
Dim cSKUTemp As Double

Dim tSql As String

    If ptMemPointID = "" Then Exit Sub
    
    tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & ptMemPointID & "'"
    Call SP_SQLvExecute(tSql, orsMall, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not (orsMall.BOF And orsMall.EOF) Then
        tVB_StaMemPointAlw = SP_FEDtChkString(orsMall, "FTMcdAlwPointAll")
        tPointSpecial = SP_FEDtChkString(orsMall, "FTMcdAlwPoint")
        tPointAdd = SP_FEDtChkString(orsMall, "FTMcdStaAddSku")
        tMallCardKey = SP_FEDtChkString(orsMall, "FTMcdCode") '
        tMemEvnCode = SP_FEDtChkString(orsMall, "FTEvnCode")
        
        cPoint = 0
        cPointAmt = 0
        cPointSku = 0
        cPointAmtSku = 0
        cPointDpt = 0
        cPointAmtDpt = 0
        cPointGen = 0
        cPointAmtGen = 0
        
        If (tVB_StaMemPointAlw = "Y") And (tPointSpecial = "Y") Then
            tSql = "SELECT *  FROM " & tVB_CNTblDT
            tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
            tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
            tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
            tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
            tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
            tSql = tSql & vbCrLf & "  AND SUBSTRING(ISNULL(FTSdtStaPdt,''),21,1) = '1'" '*KT 55-08-15 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
            Call SP_SQLvExecute(tSql, orsTemp)
            If orsTemp Is Nothing Then
                Set orsTemp = New ADODB.Recordset
            End If
            If orsTemp.State = adStateOpen Then orsTemp.Close
            orsTemp.Open tSql, ocnAll, adOpenKeyset, adLockPessimistic
            
            ReDim aW_PointSKUTime(0) As POINTSEQ
            aW_PointSKUTime(0).nSeqNo = 0
            aW_PointSKUTime(0).cPoint = 0
            aW_PointSKUTime(0).cRank = 0
            aW_PointSKUTime(0).cAmt = 0
            aW_PointSKUTime(0).cMin = 0
            aW_PointSKUTime(0).cMax = 0
            aW_PointSKUTime(0).tType = "0"
            aW_PointSKUTime(0).dST = CDate("1900/01/01")
            aW_PointSKUTime(0).dED = CDate("1900/01/01")
            aW_PointSKUTime(0).tStaAct = "N"
            Dim bMissRec  As Boolean
            
            'การคิดแต้มกรณีที่มี MissRec อ้างจากเอกสาร External Spec
            '- ถ้า Cooperate Active อย่างเดียว ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Cooperate / General
            '- ถ้า Secsion Active อย่างเดียว ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Secsion / General (***หมายเหตุบวกเพิ่มที่ Secsion แรก)
            '- ถ้า Cooperate Active และ Secsion Active ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Cooperate / General เท่านั้น
            tSql = "SELECT  * "
            tSql = tSql & vbCrLf & " FROM TCNMMemberCooMtn"
'            tSql = tSql & vbCrLf & " WHERE ISNULL(FTMcmStaCoo,'N') = 'Y'"
            If SP_SQLvExecute(tSql, orsCoo, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                If (orsCoo.BOF And orsCoo.EOF) Then
                    bMissRec = True
                Else
                    If UCase(SP_FEDtChkString(orsCoo, "FTMcmStaCoo")) = "Y" Then
                         bMissRec = False
                    Else
                        bMissRec = True
                    End If
                End If
            Else
                bMissRec = True
            End If
            
            Select Case Val(Format(tVB_TransactionSub))
                Case tEN_TrnDeposit, tEN_TrnAddDeposit, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel, tEN_TrnRedeem, tEN_TrnIPVRedeem
                    cSubTotal = (cVB_Total - cVB_TotalDiscAft)
                Case Else
                    cSubTotal = cVB_NetSale
            End Select
'            cSubTotal = cVB_NetSale
            
            orsMall.Filter = adFilterNone
            Set orsTemp2 = orsTemp.Clone
            'Allow Member Point from Sesion
'            Call SP_PRCbVerifyPointSec(orsTemp2, orsTemp3, cPoint, cPointAmt, cUT_SubReg, cUT_SubPro, cSubTotal, bMissRec)
            Call SP_PRCbVerifyPointSec(orsTemp2, orsTemp3, cPoint, cPointAmt, cVB_CNTenderAmtAlwPoint, cVB_CNTenderAmtAlwPoint, cSubTotal, bMissRec)
            Set orsTemp2 = orsTemp3.Clone
            cSecTemp = cPoint
            If cSecTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[2]", "Section = " & cSecTemp, tVB_MemPointID)
            'Allow Member Point from Cooperate
'            Call SP_PRCbVerifyPointCoo(orsTemp2, orsTemp3, cPoint, cPointAmt, cUT_SubReg, cUT_SubPro, cSubTotal, Not bMissRec, orsCoo)
            Call SP_PRCbVerifyPointCoo(orsTemp2, orsTemp3, cPoint, cPointAmt, cVB_CNTenderAmtAlwPoint, cVB_CNTenderAmtAlwPoint, cSubTotal, Not bMissRec, orsCoo)
            cCooTemp = cPoint - cSecTemp
            If cCooTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[3]", "Cooperate = " & cCooTemp, tVB_MemPointID)
            'cCooTemp Member Point from SKU Allow
            Select Case Val(Format(tVB_TransactionSub))
                Case tEN_TrnAddDeposit, tEN_TrnAddDepositCancel, tEN_TrnRedeem, tEN_TrnIPVRedeem
                    
                Case Else
                    Call SP_PRCbVerifyPointBySkuAlw(orsTemp, orsCoo, cPoint, cPointAmt)
            End Select
'            Call SP_PRCbVerifyPointBySkuAlw(orsTemp, orsCoo, cPoint, cPointAmt)
            cSKUTemp = cPoint - (cSecTemp + cCooTemp)
            If cSKUTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[4]", "SKU Point = " & cSKUTemp, tVB_MemPointID)
            
        End If
            
    End If
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, "SP_PRCxOtherPoint:" & Err.Description)
End Sub

Public Function SP_SplitBarcodeData(ByVal ptScanDataType As String, ByVal ptScanData As String, ByVal ptScanDataLabel As String) As String
'----------------------------------------------------------------------------
'   Call:
'   Cmt: '*Bump 56-02-22 การ scan barcode ของ scanner ถ้าเป็น Fujitsu Touch Scanner จะต้องเอา Prefix ออก
'----------------------------------------------------------------------------
    'EAN13 จะได้ดังนี้
    'ptScanDataType = 104
    'ptScanData = 'F8851959158166' มี F เป็น Prefix
    'ptScanDataLebel =  '8851959158166'
    
    
    'ptScanDataType = 106
    'ptScanData = 'P8851959158166'
    'ptScanDataLebel =  '8851959158166'
    
    'Code39 จะได้ดังนี้
    'ptScanDataType = 108
    'ptScanData = 'M*8851959158166*'            มี M* เป็น Prefix  และ * เป็น Suffix
    'ptScanDataLebel =  '*8851959158166*'    มี * เป็นทั้ง Prefix  และ Suffix
    
    'Code128 จะได้ดังนี้
    'ptScanDataType = 110
    'ptScanData = 'Q8851959158166'
    'ptScanDataLebel =  '8851959158166'
    
    'ptScanDataType = 101
    'ptScanData = 'A8851959158166'
    'ptScanDataLebel =  '8851959158166'
    Dim tBarcodeData As String
    Dim tPrefix As String
    Dim tPdtCode As String
    tPrefix = Left(ptScanData, 1)  '*BG 56-11-02 ScanBarCode ครั้งแรกหลังจากที่ทำ Transection อื่นๆ มันไม่ติดเพราะ Type =0 และไม่มีข้อมูลในScanDataLabel
    tPdtCode = Mid(ptScanData, 2, Len(ptScanData) - 1)
    tBarcodeData = ""
    If ptScanDataLabel <> "" Then
        Select Case ptScanDataType
            Case 101, 104, 106, 110
                tBarcodeData = ptScanDataLabel    'EAN13
            'Case 108: tBarcodeData = Mid(ptScanDataLabel, 2, (Len(ptScanDataLabel) - 2)) 'Code39 = *1234567890*
            Case 108
                tBarcodeData = Right(ptScanDataLabel, Len(ptScanDataLabel) - 1)
                tBarcodeData = Left(tBarcodeData, Len(tBarcodeData) - 1)
                'tBarcodeData = Mid(ptScanDataLabel, 2, (Len(ptScanDataLabel) - 2)) 'Code39 = *1234567890*
            Case Else
                    tBarcodeData = ptScanData
        End Select
    Else
    '*BG 56-11-02 ScanType = 0 ;ScanData ="A8851959158166" ; ScanDataLabel = "" จะเข้าเคสนี้ เอา ScanData มาตัดเอา PdtCode
        Select Case tPrefix
            Case "F", "Q", "A", "P"
                tBarcodeData = tPdtCode
            Case "M"
                tBarcodeData = Right(tPdtCode, Len(tPdtCode) - 1)
                tBarcodeData = Left(tBarcodeData, Len(tBarcodeData) - 1)
            Case Else
                tBarcodeData = ptScanData
        End Select
        '****
    End If
    SP_SplitBarcodeData = tBarcodeData
    
End Function

