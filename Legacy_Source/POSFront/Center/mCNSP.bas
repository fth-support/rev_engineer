        tSql = tSql & vbCrLf & " AND  FTTmnNum='" & tVB_CNTerminalNum & "'"
    End If
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine, nEff) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveLast
            SP_GETtLastTransType = SP_FEDtChkString(orsTemp, "FTShdTransType")
            pdDateReEntry = SP_FEDdChkDate(orsTemp, "FDShdTransDate")
            tVB_LastPosNo = SP_FEDtChkString(orsTemp, "FTShdPOSCN")  '*BG 56-10-31
            If tMode = "2" Then
                Select Case Val(Format(SP_GETtLastTransType))
