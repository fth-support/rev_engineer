Public Function SP_FLDbManFolder(ByVal ptPath As String, ByVal pnType As eEN_FldManage) As Boolean
'----------------------------------------------------------
'   Call:   ptPath is folder name
'               pnType  is enum of folder type 1:exist, 2:create, 3:delete
'   Ret :  true if completed
'----------------------------------------------------------
    Dim oFSO As Object
    Dim tPath$
    Dim nCol%, i%
    
    On Error GoTo ErrHandle
    
    SP_FLDbManFolder = False
    Set oFSO = CreateObject("Scripting.FileSystemObject")
    
    Select Case pnType
        Case nEN_Fld1Exist
            If oFSO.FolderExists(ptPath) Then
                SP_FLDbManFolder = True
            End If
        
        Case nEN_Fld2Delete
            If oFSO.FolderExists(ptPath) Then
                oFSO.DeleteFolder (ptPath)
                SP_FLDbManFolder = True
            End If
        
        Case nEN_Fld3Create
                If Not oFSO.FolderExists(ptPath) Then
                    tPath = ptPath
                    nCol = InStr(1, tPath, "\")
                    i = 0
                    Do While nCol > 0
                        i = i + 1
                        nCol = InStr(nCol + 1, tPath, "\")
                        If nCol = 0 Then
                            tPath = ptPath
                        Else
                            tPath = Left(tPath, nCol - 1)
                        End If
                        If Not oFSO.FolderExists(tPath) Then        'check server
                            If Not (Mid(tPath, 1, 2) = "\\" And i = 2) Then oFSO.CreateFolder (tPath)
                        End If
                        tPath = ptPath
                    Loop
                End If
                SP_FLDbManFolder = True
    End Select
    
    Exit Function
ErrHandle:
    SP_FLDbManFolder = False
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Modules mCNSP:SP_FLDbManFolder[ErrHanle]")
    Call SP_CRTxLogFile(Err.Number & ":" & Err.Description)            '*Ao 2014/03/04 CommSheet TK-ISS3000-468
End Function

Public Function SP_FLEbManFile(ByVal ptPath As String, ByVal pnType As eEN_FleManage) As Boolean
'----------------------------------------------------------
'   Call:   ptPath is folder name
'               pnType  is enum of folder type 1:exist, 2:delete
'   Ret :  true if completed
'----------------------------------------------------------
    Dim oFSO As Object
    Dim oFile As File
On Error GoTo ErrHandle
    
    SP_FLEbManFile = False
    If ptPath = "" Then Exit Function
    
    Set oFSO = CreateObject("Scripting.FileSystemObject")
    
    Select Case pnType
        Case nEN_Fle1Exist
            If oFSO.FileExists(ptPath) Then
                SP_FLEbManFile = True
            End If
        
        Case nEN_Fle2Delete
            If oFSO.FileExists(ptPath) Then
                Set oFile = oFSO.GetFile(ptPath)
                oFile.Attributes = Normal
                oFSO.DeleteFile (ptPath)
                SP_FLEbManFile = True
            End If
    End Select
    
    Exit Function
ErrHandle:
    SP_FLEbManFile = False
End Function

Public Sub SP_FRMxSetCapForm(ByVal pwForm As Form)
'----------------------------------------------------------
'   Call:   pwForm as form
'
'   Cmt:   set caption of Form(Label, Button ...)
'               show Thai or English
'----------------------------------------------------------
    Dim oControl As Object
    Dim nI%
   
    pwForm.Caption = cUT.UT_STRtToken(pwForm.Tag, ";", nVB_CNCutLang + 1)
    For Each oControl In pwForm.Controls
        If Left(oControl.Tag, 1) = "2" Or Left(oControl.Tag, 1) = "3" Then
            If TypeOf oControl Is Toolbar Then
                oControl.Buttons(1).Caption = cUT.UT_STRtToken(oControl.Buttons(1).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(2).Caption = cUT.UT_STRtToken(oControl.Buttons(2).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(4).Caption = cUT.UT_STRtToken(oControl.Buttons(4).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(5).Caption = cUT.UT_STRtToken(oControl.Buttons(5).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(8).Caption = cUT.UT_STRtToken(oControl.Buttons(8).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(9).Caption = cUT.UT_STRtToken(oControl.Buttons(9).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(10).Caption = cUT.UT_STRtToken(oControl.Buttons(10).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(11).Caption = cUT.UT_STRtToken(oControl.Buttons(11).Tag, ";", nVB_CNCutLang + 1)
                oControl.Buttons(13).Caption = cUT.UT_STRtToken(oControl.Buttons(13).Tag, ";", nVB_CNCutLang + 1)
                
                oControl.Buttons(1).ToolTipText = oControl.Buttons(1).Caption
                oControl.Buttons(2).ToolTipText = oControl.Buttons(2).Caption
                oControl.Buttons(4).ToolTipText = oControl.Buttons(4).Caption
                oControl.Buttons(5).ToolTipText = oControl.Buttons(5).Caption
                oControl.Buttons(8).ToolTipText = oControl.Buttons(8).Caption
                oControl.Buttons(9).ToolTipText = oControl.Buttons(9).Caption
                oControl.Buttons(10).ToolTipText = oControl.Buttons(10).Caption
                oControl.Buttons(11).ToolTipText = oControl.Buttons(11).Caption
                oControl.Buttons(13).ToolTipText = oControl.Buttons(13).Caption
            End If
            
            If TypeOf oControl Is Label Then oControl.Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1)
            If TypeOf oControl Is CommandButton Then oControl.Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1)
'            If TypeOf oControl Is ucButtons_H Then oControl.Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1)
            If TypeOf oControl Is Frame Then oControl.Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1)
            If TypeOf oControl Is OptionButton Then oControl.Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1)
            If TypeOf oControl Is CheckBox Then oControl.Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1)
            
            If TypeOf oControl Is SSTab Then
                For nI = 0 To oControl.Tabs - 1
                    oControl.TabCaption(nI) = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutLang + 1 + (nI * 2))
                Next nI
            End If
            
            If TypeOf oControl Is TabControl Then
                For nI = 0 To oControl.ItemCount - 1
                    oControl.Item(nI).Caption = cUT.UT_STRtToken(oControl.Tag, ";", nVB_CNCutTag + (nI * 2))
                Next nI
            End If

       End If
       
        If TypeOf oControl Is ComboBox Then
            If Left(oControl.Tag, 1) <> "X" And Left(oControl.Tag, 1) <> "" Then          'X:สำหรับ combo พิเศษที่ไม่ต้องจัด caption
                'Call SP_OBJxAddDataToCombo(oControl, oControl.ListIndex)       '*Duang 50-08-07 ดวงย้ายตัวที่อยู่ใน mCNSP_Old ไปอยู่ที่ mCNSP_Test_Duang การทำงานเหมือนเดิม
            End If
        End If
  Next oControl
    
End Sub

