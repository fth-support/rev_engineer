Public Sub SP_SQLxGetVariable(ByVal poRs As ADODB.Recordset)        '*Tee 51-02-19
'-----------------------------------------------------------
'   Call :
'   Cmt :
'   Developer : SOMJAI
'   Date Create : 02-15-2008 :  14:16:48
'*KT 52-02-17 เปลียน Conection Time และ Command Time ของ on และ off
'-----------------------------------------------------------
    On Error GoTo ErrHandle
    Dim tOnServerName$, tOnDbName$, tOnComName$, tOnUsrName$, tOnUsrPwd$
    Dim tServerName$, tDbName$, tComName$, tUsrName$, tUsrPwd$
    Dim nChkSlash As Integer
    Dim nChkDot As Integer
    Dim tMyIP As String
    
    Call SP_VARxFilterConfig(poRs, "SF_SQLDB1", tOnServerName, tOnDbName, tOnUsrName, tOnUsrPwd)
    tOnComName = cUT.UT_STRtToken(tOnServerName, "\", 1, True)
    Call SP_VARxFilterConfig(poRs, "SF_SQLDB2", tServerName, tDbName, tUsrName, tUsrPwd)
    tComName = cUT.UT_STRtToken(tServerName, "\", 1, True)
    
    '*Tao 60-07-04 ถ้า tServerName เป็นเครื่องตัวเอง ให้ใช้ .\ แทนชื่อเครื่อง
    nChkSlash = InStr(1, tServerName, "\")
    If nChkSlash > 2 Then 'มี \
        If tVB_CNComName = Left(tServerName, nChkSlash - 1) Then 'ชื่อเครื่อง = tServerName
            tServerName = Replace(tServerName, tVB_CNComName, ".")
        Else
            nChkDot = InStr(1, tServerName, ".")
            If nChkDot > 2 Then 'มี .
                tMyIP = SP_GETxLookupIPAddress(tVB_CNComName)
                If tMyIP = Left(tServerName, nChkSlash - 1) Then 'ไอพีเครื่อง = tServerName
                    tServerName = Replace(tServerName, tMyIP, ".")
                End If
            End If
        End If
    Else 'ไม่มี \
        If tVB_CNComName = tServerName Then
            tServerName = Replace(tServerName, tVB_CNComName, ".")
        Else
            nChkDot = InStr(1, tServerName, ".")
            If nChkDot > 2 Then 'มี .
                tMyIP = SP_GETxLookupIPAddress(tVB_CNComName)
                If tMyIP = tServerName Then 'ไอพีเครื่อง = tServerName
                    tServerName = Replace(tServerName, tMyIP, ".")
                End If
            End If
        End If
    End If
    '===============================================
    
    With oDB
        .OnCmdTimeOut = 30
        .OnCnnTimeOut = 30
        .OnComName = tOnComName
        .OnDbName = tOnDbName
        .OnServerName = tOnServerName
        .OnUsrName = tOnUsrName
        .OnUsrPwd = tOnUsrPwd
        
        .OffCmdTimeOut = 30
        .OffCnnTimeOut = 30
        .OffComName = tComName
        .OffDbName = tDbName
        .OffServerName = tServerName
        .OffUsrName = tUsrName
        .OffUsrPwd = tUsrPwd
    End With
    Call SP_CRTxLogPrg("Form:" & "mCNSP" & " Events:SP_SQLxGetVariable" & " tVB_CNComName:" & tVB_CNComName & " tComName:" & tComName & " tServerName:" & tServerName) '*Tao 60-07-04
    Exit Sub
ErrHandle:
    Call SP_MSGShowError
End Sub

Public Function SP_SQLbExecute(ByVal ptSql As String, Optional ByRef poRs As Variant, Optional ByVal pbUseBeginTrans As Boolean = False, Optional ByRef pnEffect As Long, Optional ByRef pnErr As Long, Optional ByVal poCn As ADODB.Connection, Optional ByVal pbSwithOnline As Boolean = False, Optional ByVal pbWaitRep As Boolean = False, Optional pbClone As Boolean = False) As Boolean '*Tee 51-02-19
'----------------------------------------------------------
'   Call:   ptSql as string of sql
'              poRs as reference optional recordset
'   Ret:   0 if execute ok, even if error no will return when error occur
'*KT 51-11-01
'*KT 52-03-12
'read master
'----------------------------------------------------------

    Dim bOk As Boolean
    Dim nCmdTimeout As Long
    Dim nCountRound As Long
    Dim tRepSta$
    Dim oCNCon As ADODB.Connection
    'Dim orsTemp As ADODB.Recordset
    Dim nErr As Long
    Dim bOn2Off As Boolean
    Dim tOnTime As String
    Dim nTime As String
    Dim tErrDesc As String
    Dim tTblLoss As String
On Error GoTo ErrHandle
    bOn2Off = False
    SP_SQLbExecute = False
    
    Set oCNCon = IIf(poCn Is Nothing, ocnAll, poCn)
    
    nCmdTimeout = oCNCon.CommandTimeout
    If oCNCon.ConnectionString = oDB.ocnOffLine.ConnectionString Then
        If pbWaitRep Then
            tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
            Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
                nCountRound = nCountRound + 1
                SleepEx 1000, 0
                tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
            Loop
        End If
    End If
    If oCNCon.ConnectionString = oDB.ocnOnLine.ConnectionString Then
         If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
            bOn2Off = True
             If IsMissing(poRs) Then
                oCNCon.Execute ptSql, pnEffect
            Else
                Set poRs = oCNCon.Execute(ptSql, pnEffect)
            End If
            pnErr = 0
            SP_SQLbExecute = True
            Exit Function
         Else
            If pbSwithOnline Then
                If pbWaitRep Then
                    tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
                        nCountRound = nCountRound + 1
                        SleepEx 1000, 0
                        tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Loop
                End If
                If IsMissing(poRs) Then
                    oDB.ocnOffLine.Execute ptSql, pnEffect
                Else
                    Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                End If
                pnErr = 0
                SP_SQLbExecute = True
                Exit Function
            Else
                pnErr = -2147467259
                SP_SQLbExecute = False
                Exit Function
            End If
         End If
    Else
        If IsMissing(poRs) Then
            If pbUseBeginTrans Then
                'ocnAll.BeginTrans '*KT 52-02-11  PH2-ML-SF-092 โปรแกรมหลุดมาที่ Desktop ตอนพิมพ์ receipt , ชำระด้วย Credit
                Call oCNCon.Execute(ptSql, pnEffect)
                'ocnAll.CommitTrans '*KT 52-02-11  PH2-ML-SF-092 โปรแกรมหลุดมาที่ Desktop ตอนพิมพ์ receipt , ชำระด้วย Credit
            Else
                Call oCNCon.Execute(ptSql, pnEffect)
            End If
        Else
            '*KT 54-03-25
            If pbClone Then
                'Set orsTemp = oCNCon.Execute(ptSql, pnEffect)
                'Call SP_RSTbClone2OfflineEx2(orsTemp, poRs)
                Set poRs = oCNCon.Execute(ptSql, pnEffect)
                'orsTemp
'                If poRs Is Nothing Then Set poRs = New ADODB.Recordset
'                If poRs.State = adStateOpen Then poRs.Close
'                poRs.CursorLocation = adUseClient
'                poRs.Open ptSql, oCNCon, adOpenStatic
            Else
                 Set poRs = oCNCon.Execute(ptSql, pnEffect)
            End If
        End If
    End If
    pnErr = 0
    SP_SQLbExecute = True
    Exit Function
ErrHandle:
    nErr = Err.Number
    tErrDesc = Err.Description
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute")
    If poCn.ConnectionString = oDB.ocnOnLine.ConnectionString Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute  DB : Online")
    ElseIf poCn.ConnectionString = oDB.ocnOffLine.ConnectionString Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute  DB : Offline")
'    ElseIf pbMember Then
'        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute  DB : Member")
    Else
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute  DB : " & poCn.ConnectionString)
    End If
    Call SP_CRTxWriteLogTerminated("ErrorDesc : " & tErrDesc)
    Call SP_CRTxWriteLogTerminated("Query : " & ptSql)
    '*KT 54-03-25 ป้องกันโปรแกรมหลุด โดยการหน่วงเวลาให้ ServiceOnOff ให้ทำงานเสร้จก่อนมีการใช้ Function oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
    Select Case nErr
            Case -2147467259, -2147217871, 91, 3704
                If bOn2Off Then
                    nTime = 1000
                    tOnTime = GetSetting("AdaPosMall", "POSFront", "OnTime")
                    If tOnTime = "" Then
                       nTime = 5000
                    Else
                        If IsNumeric(tOnTime) Then
                            nTime = Val(Format(tOnTime)) * 1000
                        Else
                            nTime = 5000
                        End If
                    End If
                    SleepEx nTime, 0
                End If
            '*KT 54-10-04 V.4.0.1 ML-PRV-070 Invalid object name 'Table name'
            Case -2147217865
                tTblLoss = GetSetting("AdaPosMall", "POSFront", "RepTblLoss")
                If tTblLoss = "1" Then
                    Call SP_MSGnShowing("tms_CN005227", nCS_Warning)
                    'MsgBox "Table on database loss. Please contact your administrator.Next step end program. Look file ..\\LOG\TableLossyyyymmdd.log"
                    Call SP_CRTxWriteLogTerminated("Table on database loss. Please contact your administrator.Next step end program. Look file ..\\LOG\TableLossyyyymmdd.log")
                    Call SP_APPxEndProgram
                    Exit Function
                End If
    End Select

    If Not oDB.ocnOnLine Is Nothing Then
        If oCNCon.ConnectionString = oDB.ocnOnLine.ConnectionString Then
            If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                Select Case nErr
                    Case -2147467259, -2147217871, 91, 3704
On Error GoTo ErrHandle2
                        If oDB.ocnOnLine.State = adStateOpen Then oDB.ocnOnLine.Close
                        If oDB.SQLbConnectDB(oDB.ocnOnLine, Online) Then
                            Set oDB.ActiveConnection2 = oDB.ocnOnLine
                            If IsMissing(poRs) Then
                                oDB.ocnOnLine.Execute ptSql, pnEffect
                            Else
                                'Set poRs = oDB.ocnOnLine.Execute(ptSql, pnEffect)
                                '*KT 54-03-25
                                If pbClone Then
                                   ' Set orsTemp = oDB.ocnOnLine.Execute(ptSql, pnEffect)
                                   'Call SP_RSTbClone2OfflineEx2(orsTemp, poRs)
                                    Set poRs = oDB.ocnOnLine.Execute(ptSql, pnEffect)
'                                    If poRs Is Nothing Then Set poRs = New ADODB.Recordset
'                                    If poRs.State = adStateOpen Then poRs.Close
