Public Function SP_REDtFileToString(ByVal ptPath As String) As String
    Dim nFile As Long
    Dim tTemp As String
    
    Dim sFileText As String
    Dim iFileNo As Integer

    On Error GoTo ErrHandler
    
    'MsgBox "SP_REDtFileToString " & ptPath
'    nFile = FreeFile
'    tTemp = ""
'    Open ptPath For Input Lock Write As #nFile
'        tTemp = StrConv(InputB$(LOF(nFile), nFile), vbUnicode)
'    Close #nFile
  
    iFileNo = FreeFile
    'open the file for reading
    Open ptPath For Input As #iFileNo 'change this filename to an existing file!  (or run the example below first)
    Do While Not EOF(iFileNo) 'read the file until we reach the end
      Input #iFileNo, sFileText
      tTemp = tTemp & sFileText 'show the text (you will probably want to replace this line as appropriate to your program!)
    Loop
    Close #iFileNo 'close the file (if you dont do this, you wont be able to open it again!)
    SP_REDtFileToString = Trim(tTemp)
Exit Function
ErrHandler:
    MsgBox Err.Description
End Function

Public Sub SP_CRTxText(ByVal ptPath As String)
