        tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & "AND FTShdTransNo= '" & tVB_Running & "'"
        tSql = tSql & vbCrLf & "AND FDShdTransDate= '" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql)
        Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (10) FNCstCardPoint =" & cPoint))   '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx

    End If
Exit Sub
ErrorHandles:
    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (11) FNCstCardPoint =" & 0 & ",Error:" & Err.Number & ",ErrDesc:" & Err.Description))   '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
End Sub

