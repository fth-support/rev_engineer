Public Function SP_FMTcCurPoint(ByRef pcValue As Variant, Optional ByVal pbNoComma As Boolean = True, Optional ByVal pbToShow As Boolean = True) As Variant
'----------------------------------------------------------
'   Call:   pcValue as double value
'   Cmt:   return format of number
'----------------------------------------------------------
    Dim nDecAmt As Integer
    
    nDecAmt = IIf(pbToShow, nVB_CNDecAmtForShw, nVB_CNDecAmtForSav)
    If pbNoComma Then
        SP_FMTcCurPoint = Format(pcValue, "########0." & String(nDecAmt, "0"))
    Else
        SP_FMTcCurPoint = Format(pcValue, "###,###,##0." & String(nDecAmt, "0"))
    End If
End Function

Public Function SP_CALcVatAmt(ByVal pbIsVatEx As Boolean, ByVal pcTotal As Double, ByVal pcVatRate As Double) As Double
'----------------------------------------------------------
'   Call:   pbIsVatEx True:Exclusive Vat, False:Inclusive Vat
'               pcTotal as value to calculate
'               pcVatRate as curent Vat rate
'   Ret:    Ex:Total + cal(Vat), In:Total - cal(Vat)
'----------------------------------------------------------
    Dim cRet As Double
    
    If pbIsVatEx Then       'exclusive vat
        cRet = pcTotal * ((100 + pcVatRate) / 100)          'val * (107/100)
    Else                                 'inclusive vat
        cRet = (pcTotal * 100) / (100 + pcVatRate)          '(val * 100)/107
    End If
    SP_CALcVatAmt = cRet
End Function

Public Function SP_CALcVatValue(ByVal pbIsVatEx As Boolean, ByVal pcTotal As Double, ByVal pcVatRate As Double) As Double
'----------------------------------------------------------
'   Call:   pbIsVatEx True:Exclusive Vat, False:Inclusive Vat
'               pcTotal as value to calculate
'               pcVatRate as curent Vat rate
'   Ret:    Ex:Total + cal(Vat), In:Total - cal(Vat)
'----------------------------------------------------------
    Dim cCal As Double
    Dim cRet As Double
    
    If pbIsVatEx Then       'exclusive Vat
        cCal = pcTotal * ((100 + pcVatRate) / 100)
        cRet = cCal - pcTotal
    Else                                 'inclusive Vat
        cCal = (pcTotal * 100) / (100 + pcVatRate)
        cRet = pcTotal - cCal
    End If
    SP_CALcVatValue = cRet
End Function

Public Function SP_FMTtNum2Shw(ByVal ptNumber As String, Optional ByVal pbNoDot As Boolean = False, Optional ByVal pbToShow As Boolean = True) As String
'----------------------------------------------------------
'   Call:   ptNumber is all number datatype
'   Cmt:   return format of number
'----------------------------------------------------------
    Dim tFormat As String
    Dim cValue As Double
    Dim nDecAmt As Integer
    
    nDecAmt = IIf(pbToShow, nVB_CNDecAmtForShw, nVB_CNDecAmtForSav)
    If Not IsNumeric(ptNumber) Then
        cValue = 0
    Else
        cValue = CDbl(ptNumber)
    End If
    
    If nDecAmt < 1 Or pbNoDot Then
        tFormat = "########0"
    Else
        tFormat = "###,###,##0." & String(nDecAmt, "0")
    End If
    
    SP_FMTtNum2Shw = Format(cValue, tFormat)
End Function

