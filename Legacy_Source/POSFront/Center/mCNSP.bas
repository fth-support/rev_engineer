Public Sub SP_PRCxTerminalRepOnToOff(Optional ByVal pbVitualPos As Boolean = False)
'----------------------------------------------------------
' Call
' Cmt : *KT 52-06-10 สำหรับการ Copy ข้อมูล Terminal Maintennance จาก Server มายัง Local โดยที่ถ้าใน Local มีข้อมุลของเครื่อง Terminal ที่ใช้งานอยู่จะไม่มีการ Replace ข้อมูล
'----------------------------------------------------------
    Dim orsTemp As ADODB.Recordset
    Dim i%, tSql$, tTmp$
    Dim tSqlH$, tSqlT$
    Dim tSqlF$, tSqlV$
    Dim nEff As Long
    
On Error GoTo ErrHandle
    If pbVitualPos Then
        tSql = "SELECT * FROM TCNMTerminalMtn  WHERE FTTmnNum= '" & tVB_CNTerminalNum & "'"
    Else
        tSql = "SELECT * FROM TCNMTerminalMtn  WHERE FTTmnName= '" & tVB_CNComName & "'"
    End If
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
    If orsTemp.BOF And orsTemp.EOF Then 'ไม่พบใน Local
            'ทำการดึงข้อมูลจาก Server มายังที่ Local
            If pbVitualPos Then
                tSql = "SELECT * FROM TCNMTerminalMtn WHERE FTTmnNum= '" & tVB_CNTerminalNum & "'"
            Else
                tSql = "SELECT * FROM TCNMTerminalMtn WHERE FTTmnName= '" & tVB_CNComName & "'"
            End If
'            Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)      '*Ao 2013/10/02    ServiceOnOff.exe   ยังทำงานไม่ทัน
            Set orsTemp = oDB.ocnOnLine.Execute(tSql)
            If Not (orsTemp.BOF And orsTemp.EOF) Then 'พบใน Server
                    If Not pbVitualPos Then
                        tSql = "TRUNCATE TABLE TCNMTerminalMtn"
'                        Call SP_SQLvExecute(tSql, , ocnAll) '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
                        Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)  '*Eaw 56-09-30
                    End If
                    Do While Not orsTemp.EOF
                        tSqlF = ""
                        tSqlV = ""
                        tSqlH = "INSERT INTO TCNMTerminalMtn" & " ("
                        tSqlT = " VALUES ("
                        For i = 0 To orsTemp.Fields.Count - 1
                            tSqlF = tSqlF & orsTemp.Fields(i).Name & ","
                            Select Case Mid(orsTemp.Fields(i).Name, 2, 1)
                                Case "T"
                                    If IsNull(orsTemp.Fields(i)) Then
                                        tSqlV = tSqlV & "Null" & ","
                                    Else
                                        If Len(Trim(orsTemp.Fields(i))) = 0 Then
                                            tSqlV = tSqlV & "Null" & ","
                                        Else
                                            tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(orsTemp, orsTemp.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                                        End If
                                    End If
                                Case "D"
                                    If IsNull(orsTemp.Fields(i).Value) Then
                                        tSqlV = tSqlV & "Null" & ","
                                    Else
                                        tSqlV = tSqlV & "'" & UT_tStringDate(orsTemp.Fields(i).Value) & "',"                         'มี เขาเดี่ยว
                                    End If
                                Case "N"
                                   tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(orsTemp, orsTemp.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                                Case "C"
                                    tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(orsTemp, orsTemp.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                            End Select
                            If i = orsTemp.Fields.Count - 1 Then
                                tSqlF = Left(tSqlF, Len(tSqlF) - 1)
                                tSqlV = Left(tSqlV, Len(tSqlV) - 1)
                            End If
                        Next i
                        tSql = tSqlH & tSqlF & ")" & tSqlT & tSqlV & ")"
'                        Call SP_SQLvExecute(tSql, , ocnAll) '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
                        Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)  '*Eaw 56-09-30
                        orsTemp.MoveNext
                    Loop
            Else
                    'ไม่มีข้อมูลทั้ง Server และ Local
            End If
    Else
            'Update Terminal
            If pbVitualPos Then
                tSql = "SELECT * FROM TCNMTerminalMtn WHERE FTTmnNum= '" & tVB_CNTerminalNum & "'"
            Else
                tSql = "SELECT * FROM TCNMTerminalMtn WHERE FTTmnName= '" & tVB_CNComName & "'"
            End If
'            Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)               '*Ao 2013/10/02    ServiceOnOff.exe   ยังทำงานไม่ทัน
            Set orsTemp = oDB.ocnOnLine.Execute(tSql)
            If Not (orsTemp.BOF And orsTemp.EOF) Then 'พบใน Server
                tSqlH = "UPDATE TCNMTerminalMtn SET "
                For i = 0 To orsTemp.Fields.Count - 1
                     tSqlF = orsTemp.Fields(i).Name
                    Select Case orsTemp.Fields(i).Name
                        Case "FTTmnCode", "FTTmnName"
                            'non
                        Case "FTTmnLSaleNo", "FDTmnLastDist", "FTTmnSrvName", "FTTmnDBUsrName", "FTTmnDBUsrPass", "FTTmnDBName", "FTEmpCode", "FTTmnComName"
                            'non
                        Case "FDTmnLOpenDate", "FTTmnLOpenTime", "FTTmnStatus", "FTTmnStaClossing"
                            'non
                        Case "FDDateUpd", "FTTimeUpd", "FTWhoUpd"
                            'non
                        Case Else                           'อื่นๆ
                            Select Case Mid(orsTemp.Fields(i).Name, 2, 1)
                                Case "T"
                                    If IsNull(orsTemp.Fields(i)) Then
                                        tSqlV = tSqlV & tSqlF & " = Null" & ","
                                    Else
                                        If Len(Trim(orsTemp.Fields(i))) = 0 Then
                                             tSqlV = tSqlV & tSqlF & " = ''" & ","
                                        Else
                                            tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(orsTemp, orsTemp.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                                        End If
                                    End If
                                Case "D"
                                    If IsNull(orsTemp.Fields(i).Value) Then
                                        tSqlV = tSqlV & tSqlF & " = Null" & ","
                                    Else
                                        tSqlV = tSqlV & tSqlF & " = '" & UT_tStringDate(orsTemp.Fields(i).Value) & "',"                          'มี เขาเดี่ยว
                                    End If
                                Case "N"
                                    tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(orsTemp, orsTemp.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                                Case "C"
                                    tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(orsTemp, orsTemp.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                            End Select
                    End Select
                Next i
                tSqlV = tSqlH & tSqlV & UT_tLastUpdSql
                If pbVitualPos Then
                    tSql = tSqlV & " WHERE  FTTmnNum= '" & tVB_CNTerminalNum & "'"
                Else
                    tSql = tSqlV & " WHERE  FTTmnName='" & tVB_CNComName & "'"
                End If
'                Call SP_SQLvExecute(tSql, , ocnAll, , , nEff) '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
                Call SP_SQLvExecute(tSql, , oDB.ocnOffLine, , , nEff) '*Eaw 56-09-30
            End If
            
            'ทำการลบข้อมูล Terminal อื่นที่ไม่ช่เครื่อง Com ที่ใช้อยู่
            If Not pbVitualPos Then
                tSql = "DELETE FROM TCNMTerminalMtn  WHERE FTTmnName <> '" & tVB_CNComName & "'"
'                Call SP_SQLvExecute(tSql, , ocnAll) '*KT 53-01-18  oDB.ocnOffLine >>> ocnAll
                Call SP_SQLvExecute(tSql, , oDB.ocnOffLine) '*Eaw 56-09-30
            End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Sub

