                                        Call SP_SQLvExecute(tSql)
                                        'Update Point ของ Deposit Create  ที่ TPSTDepositHD บน Server
                                        tSql = "UPDATE TPSTDepositHD"
                                        tSql = tSql & " SET FNCstCardPoint = FNCstCardPoint - " & CLng(cPointOntop) & " + " & CLng(cPointSpec)
                                        tSql = tSql & " ,FCCstCardAmt = FCCstCardAmt - " & cPointAmtOntop & " + " & cPointAmtSpec
