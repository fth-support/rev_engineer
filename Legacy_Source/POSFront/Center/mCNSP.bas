Public Sub SP_CRTxWriteLogTerminated(ByVal ptErr As String)
'----------------------------------------------------------
' Call
' Cmt :   Create File Log for Error Terminate Program
'----------------------------------------------------------

    Dim oFSO  As New FileSystemObject
    Dim nLof As Long
    Dim tFileName$
    Dim tFld$
    Dim oFile As File
    
On Error GoTo ErrHandler
        tFileName = Left(App.Path, InStrRev(App.Path, "\") - 1) + "\LOG\" & "ExitPrg" & Format(Date, "yyyymmdd") & ".Log"
