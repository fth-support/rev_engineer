Public Function SP_SQLnPrcTimeOut(ByVal ptSql As String, Optional ByRef poRs As Variant, Optional ByRef poCn As ADODB.Connection, Optional ByRef pnEffect As Long, Optional ByVal pbMember As Boolean = False, Optional ByVal pbSwithOnline As Boolean = False, Optional ByVal pbWaitRep As Boolean = False) As Long
'----------------------------------------------------------
'   Call:   ptSql as string of sql
'              poRs as reference optional recordset
'   Ret:   0 if execute ok, even if error no will return when error occur
'*KT 51-11-01
'*KT 52-03-12
'*KT 52-07-31 Read Master
'----------------------------------------------------------
    Dim orst As ADODB.Recordset
    Dim bOk As Boolean
    Dim nCmdTimeout As Long
    Dim nCountRound As Long
    Dim tRepSta$
    Dim nErr As Long
    Dim bOn2Off As Boolean
    Dim tOnTime As String
    Dim nTime As Long
    Dim tErrDesc As String
    Dim tTblLoss As String
On Error GoTo ErrHandle
    bOn2Off = False
    nCmdTimeout = poCn.CommandTimeout
    If poCn.ConnectionString = oDB.ocnOffLine.ConnectionString Then
        If pbWaitRep Then
            tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
            Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
                nCountRound = nCountRound + 1
                Call SleepEx(1000, 0)
                tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
            Loop
        End If
    End If
    If poCn.ConnectionString = oDB.ocnOnLine.ConnectionString Then
         If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
             bOn2Off = True
             If IsMissing(poRs) Then
                poCn.Execute ptSql, pnEffect
            Else
                Set poRs = poCn.Execute(ptSql, pnEffect)
            End If
            SP_SQLnPrcTimeOut = True
            Exit Function
         Else
            If pbSwithOnline Then
                 Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut  Swith to offline " & ptSql)
                If pbWaitRep Then
                    tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
                        nCountRound = nCountRound + 1
                        Call SleepEx(1000, 0)
                        tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Loop
                End If
                If IsMissing(poRs) Then
                    oDB.ocnOffLine.Execute ptSql, pnEffect
                Else
                    Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                End If
                SP_SQLnPrcTimeOut = True
                Exit Function
            Else
                SP_SQLnPrcTimeOut = -2147467259
                Exit Function
            End If
         End If
    Else
        If IsMissing(poRs) Then
            poCn.Execute ptSql, pnEffect
        Else
            Set poRs = poCn.Execute(ptSql, pnEffect)
        End If
        SP_SQLnPrcTimeOut = True
        Exit Function
    End If
ErrHandle:
    nErr = Err.Number
    tErrDesc = Err.Description
    SP_SQLnPrcTimeOut = nErr
    tVB_CNErrDescript = tErrDesc
    nVB_CNErrNo = nErr
    If poCn.ConnectionString = oDB.ocnOnLine.ConnectionString Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut  DB : Online")
    ElseIf poCn.ConnectionString = oDB.ocnOffLine.ConnectionString Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut  DB : Offline")
        Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " tVB_Transaction:" & tVB_Transaction))  '*Bump 57-11-04 TK_Issue 27/10/2017 รับชำระด้วย Credit ทำให้ Transaction Type เปลี่ยนจาก 03 เป็น 31
    ElseIf pbMember Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut  DB : Member")
    Else
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut  DB : " & poCn.ConnectionString)
    End If
    Call SP_CRTxWriteLogTerminated("ErrorDesc : " & tErrDesc)
    Call SP_CRTxWriteLogTerminated("Query : " & ptSql)
    '*KT 54-03-25 ป้องกันโปรแกรมหลุด โดยการหน่วงเวลาให้ ServiceOnOff ให้ทำงานเสร้จก่อนมีการใช้ Function oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
    Select Case nErr
            Case -2147467259, -2147217871, 91, 3704
                If bOn2Off Then
                    nTime = 1000
                    tOnTime = GetSetting("AdaPosMall", "POSFront", "OnTime")
                    If tOnTime = "" Then
                       nTime = 5000
                    Else
                        If IsNumeric(tOnTime) Then
                            nTime = Val(Format(tOnTime)) * 1000
                        Else
                            nTime = 5000
                        End If
                    End If
                    SleepEx nTime, 0
                End If
            '*KT 54-10-04 V.4.0.1 ML-PRV-070 Invalid object name 'Table name'
            Case -2147217865
                tTblLoss = GetSetting("AdaPosMall", "POSFront", "RepTblLoss")
                If tTblLoss = "1" Then
                    Call SP_MSGnShowing("tms_CN005227", nCS_Warning)
                    'MsgBox "Table on database loss. Please contact your administrator.Next step end program. Look file ..\\LOG\TableLossyyyymmdd.log"
                    Call SP_CRTxWriteLogTerminated("Table on database loss. Please contact your administrator.Next step end program. Look file ..\\LOG\TableLossyyyymmdd.log")
                    Call SP_APPxEndProgram
                    Exit Function
                End If
    End Select
    
    If Not oDB.ocnOnLine Is Nothing And Not pbMember Then
        If poCn.ConnectionString = oDB.ocnOnLine.ConnectionString Then
            If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                Select Case nErr
                    Case -2147467259, -2147217871, 91, 3704
On Error GoTo ErrHandle2
                        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Online]")
                        If oDB.ocnOnLine.State = adStateOpen Then oDB.ocnOnLine.Close
                        If oDB.SQLbConnectDB(oDB.ocnOnLine, Online) Then
                            Set oDB.ActiveConnection2 = oDB.ocnOnLine
                            If IsMissing(poRs) Then
                                oDB.ocnOnLine.Execute ptSql, pnEffect
                            Else
                                Set poRs = oDB.ocnOnLine.Execute(ptSql, pnEffect)
                            End If
                            SP_SQLnPrcTimeOut = True
                            Exit Function
                        End If
                End Select
            End If
            If pbSwithOnline Then
                 If pbWaitRep Then
                    tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
                        nCountRound = nCountRound + 1
                        SleepEx 1000, 0
                        tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Loop
                End If
'*KT 54-03-24 ป้องกันการเกิดโปรแกรมหลุด
                If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                        
                        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Offline][1]")
                        If SP_SQLnPrcTimeOutOff(ptSql, poRs, oDB.ocnOffLine, pnEffect) <> 0 Then
                            Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Offline][1.1]")
                            'If oDB.ocnOffLine.State = adStateOpen Then oDB.ocnOffLine.Close '*KT 54-04-11 V.3.0.56 ทำการ New  oDB.ocnOffLine ใหม่ก่อน Open
                            If Not oDB.ocnOffLine Is Nothing Then Set oDB.ocnOffLine = Nothing
                            Set oDB.ocnOffLine = New ADODB.Connection
                            If oDB.SQLbConnectDB(oDB.ocnOffLine, Offline) Then
                                Set ocnAll = oDB.ocnOffLine
                                Set oDB.ActiveConnection = ocnAll
                                If IsMissing(poRs) Then
                                    oDB.ocnOffLine.Execute ptSql, pnEffect
                                Else
                                    Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                                End If
                                SP_SQLnPrcTimeOut = True
                                Exit Function
                            Else
                                Call SP_MSGnShowing("tms_CN005199", nCS_Warning)
                                Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Not conect DB Local][1]")
                                Call SP_APPxEndProgram
                                Exit Function
                            End If
                        Else
                            SP_SQLnPrcTimeOut = True
                            Exit Function
                        End If
                End If
            Else
                '*Tao 60-01-25 ลองอีกที
                If IsMissing(poRs) Then
                    poCn.Execute ptSql, pnEffect
                Else
                    Set poRs = poCn.Execute(ptSql, pnEffect)
                End If
                SP_SQLnPrcTimeOut = True
                Exit Function
                '===============
            End If
        Else
            If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Offline][2]")
                     If SP_SQLnPrcTimeOutOff(ptSql, poRs, oDB.ocnOffLine, pnEffect) <> 0 Then
                        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Offline][2.1]")
                        'If oDB.ocnOffLine.State = adStateOpen Then oDB.ocnOffLine.Close '*KT 54-04-11 V.3.0.56 ทำการ New  oDB.ocnOffLine ใหม่ก่อน Open
                        If Not oDB.ocnOffLine Is Nothing Then Set oDB.ocnOffLine = Nothing
                        If oDB.SQLbConnectDB(oDB.ocnOffLine, Offline) Then
                            Set ocnAll = oDB.ocnOffLine
                            Set oDB.ActiveConnection = ocnAll
                            If IsMissing(poRs) Then
                                oDB.ocnOffLine.Execute ptSql, pnEffect
                            Else
                                Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                            End If
                            SP_SQLnPrcTimeOut = True
                            Exit Function
                        Else
                            Call SP_MSGnShowing("tms_CN005199", nCS_Warning)
                            Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Not conect DB Local][2]")
                            Call SP_APPxEndProgram
                            Exit Function
                        End If
                    Else
                        SP_SQLnPrcTimeOut = True
                        Exit Function
                    End If
             End If
        End If
    Else
        If poCn.ConnectionString = oDB.ocnOffLine.ConnectionString Then
            If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                     Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Offline][3]")
                    If SP_SQLnPrcTimeOutOff(ptSql, poRs, oDB.ocnOffLine, pnEffect) <> 0 Then
                        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Offline][3.1]")
                        'If oDB.ocnOffLine.State = adStateOpen Then oDB.ocnOffLine.Close '*KT 54-04-11 V.3.0.56 ทำการ New  oDB.ocnOffLine ใหม่ก่อน Open
                        If Not oDB.ocnOffLine Is Nothing Then Set oDB.ocnOffLine = Nothing
                        If oDB.SQLbConnectDB(oDB.ocnOffLine, Offline) Then
                            Set ocnAll = oDB.ocnOffLine
                            Set oDB.ActiveConnection = ocnAll
                            If IsMissing(poRs) Then
                                oDB.ocnOffLine.Execute ptSql, pnEffect
                            Else
                                Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                            End If
                            SP_SQLnPrcTimeOut = True
                            Exit Function
                        Else
                            Call SP_MSGnShowing("tms_CN005199", nCS_Warning)
                            Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOut[Not conect DB Local][3]")
                            Call SP_APPxEndProgram
                            Exit Function
                        End If
                    Else
                        SP_SQLnPrcTimeOut = True
                        Exit Function
                    End If
             End If
        Else
            '*Tao 60-01-25  ลองอีกที
            If IsMissing(poRs) Then
                poCn.Execute ptSql, pnEffect
            Else
                Set poRs = poCn.Execute(ptSql, pnEffect)
            End If
            nErr = Err.Number
            '===============
        End If
    End If
    SP_SQLnPrcTimeOut = nErr
    Exit Function
ErrHandle2:
    If Not oDB.ocnOnLine Is Nothing And Not pbMember Then
        If poCn.ConnectionString = oDB.ocnOnLine.ConnectionString Then
            If pbSwithOnline Then
                 If pbWaitRep Then
                    tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Do While tRepSta = "0" And nCountRound <= nCmdTimeout
                        nCountRound = nCountRound + 1
                        SleepEx 1000, 0
                        tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
                    Loop
                End If
                If IsMissing(poRs) Then
                    oDB.ocnOffLine.Execute ptSql, pnEffect
                Else
                    Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                End If
                SP_SQLnPrcTimeOut = True
                Exit Function
            End If
        Else
            '*Tao 60-01-25 ลองอีกที
            If IsMissing(poRs) Then
                poCn.Execute ptSql, pnEffect
            Else
                Set poRs = poCn.Execute(ptSql, pnEffect)
            End If
            '===============
        End If
    Else
        '*Tao 60-01-25 ลองอีกที
        If IsMissing(poRs) Then
            poCn.Execute ptSql, pnEffect
        Else
            Set poRs = poCn.Execute(ptSql, pnEffect)
        End If
        '===============
    End If
    SP_SQLnPrcTimeOut = Err.Number
End Function

Public Function SP_SQLnPrcTimeOutOff(ByVal ptSql As String, Optional ByRef poRs As Variant, Optional ByRef poCn As ADODB.Connection, Optional ByRef pnEffect As Long) As Long
'----------------------------------------------------------
'   Call:   ptSql as string of sql
'              poRs as reference optional recordset
'   Ret:   0 if execute ok, even if error no will return when error occur
'----------------------------------------------------------
    Dim nCmdTimeout As Long
    Dim nCountRound As Long
    Dim tRepSta$
    Dim nErr As Long
    Dim tErrDesc As String
    
On Error GoTo ErrHandle
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOutOff[Offline][1]")
    nCmdTimeout = poCn.CommandTimeout
    If poCn.ConnectionString = oDB.ocnOffLine.ConnectionString Then
        tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
        Do While tRepSta = "0" And nCountRound <= nCmdTimeout And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP)
            nCountRound = nCountRound + 1
            SleepEx 1000, 0
            tRepSta = GetSetting("AdaPosMall", "POSFront", "RepSta")
        Loop
    End If

    If IsMissing(poRs) Then
        poCn.Execute ptSql, pnEffect
    Else
        Set poRs = poCn.Execute(ptSql, pnEffect)
    End If
    SP_SQLnPrcTimeOutOff = 0
    Exit Function
ErrHandle:
    nErr = Err.Number
    tErrDesc = Err.Description
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLnPrcTimeOutOff[Offline][2]") '*KT 54-04-11 V.3.0.56 เก็บ Log
    Call SP_CRTxWriteLogTerminated("ErrorDesc:" & tErrDesc)  '*KT 54-04-11 V.3.0.56 เก็บ Log
    If poCn.ConnectionString = oDB.ocnOffLine.ConnectionString Then
        If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                If oDB.ocnOffLine.State = adStateOpen Then oDB.ocnOffLine.Close
                If oDB.SQLbConnectDB(oDB.ocnOffLine, Offline) Then
                    Set ocnAll = oDB.ocnOffLine
                    Set oDB.ActiveConnection = ocnAll
                    If IsMissing(poRs) Then
                        oDB.ocnOffLine.Execute ptSql, pnEffect
                    Else
                        Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
                    End If
                    SP_SQLnPrcTimeOutOff = 0
                    Exit Function
                End If
         End If
    End If
    SP_SQLnPrcTimeOutOff = nErr
End Function

