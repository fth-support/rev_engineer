                                Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute[Not conect DB Local][2]")
                                Call SP_APPxEndProgram
                                Exit Function
                            End If
                        Else
                            SP_SQLbExecute = True
                            Exit Function
                        End If
                 End If
            End If
        End If
    Else
          If oCNCon.ConnectionString = oDB.ocnOffLine.ConnectionString Then
            If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute[Offline][3]")
                    If SP_SQLnPrcTimeOutOff(ptSql, poRs, oDB.ocnOffLine, pnEffect) <> 0 Then
