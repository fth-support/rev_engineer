Public Function SP_GETxLookupIPAddress(ByVal sHostName As String) As String
'------------------------------------------------------
'Ret: ip adress
'Cmt: ทำ get ip adress ของเครื่องจาก parameter sHostName
'------------------------------------------------------
    Dim wsa As WSAdata
    Dim nRet As Long
    Dim nTemp As Long
    Dim bTemp(0 To 3) As Byte
    Dim sOut As String
    Dim he As Hostent
    
    On Error GoTo ErrHandle
    
    WSAStartup &H10, wsa

    nRet = gethostbyname(sHostName)
     
    If nRet = 0 Then
        sOut = ""
    Else
        CopyMemory he, ByVal nRet, Len(he)
        If he.hLength >= 4 Then
            CopyMemory nTemp, ByVal he.hAddrList, 4
            CopyMemory bTemp(0), ByVal nTemp, 4
            sOut = Format(bTemp(0)) & "." & Format(bTemp(1)) & "." & Format(bTemp(2)) & "." & Format(bTemp(3))
        Else
            sOut = ""
        End If
    End If
    WSACleanup
    SP_GETxLookupIPAddress = sOut
    Exit Function
ErrHandle:
    SP_GETxLookupIPAddress = ""
End Function

