Public Function SP_DATbChkDupData(ByVal ptCheck$, ByVal ptTable$, ByVal ptField$) As Boolean
 '------------------------------------------------------------------------
 '  Call:   ptCheck    คือ ค่าที่ต้องการ Check (ค่าใน TextBox)
 '              ptTypeField     คือ Type ของ  ptCheck (T:Text, N:Numeric, B:Boolean ...)
 '              ptTable             คือ ชื่อตารางที่ต้องการใช้ ค้นหา
 '              ptField   คือ ชื่อ Field ที่ต้องการใช้ ค้นหา
 '  Cmt. : ค้นได้ในกรณี Field  แรกเป็น Key
 '------------------------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset

    SP_DATbChkDupData = True

    tSql = "SELECT " & ptField & " FROM " & ptTable & " WHERE " & ptField
    Select Case UCase(Mid(ptField, 2, 1))
        Case "T"
            tSql = tSql & "='" & ptCheck & "'"

        Case "N", "C"
            tSql = tSql & "=" & ptCheck

        Case "D"
            tSql = tSql & "=#" & ptCheck & "#"

        Case "B"        'same "N","C"
            tSql = tSql & "=" & ptCheck

        Case Else       'else same "T"
            tSql = tSql & "='" & ptCheck & "'"

    End Select
   Call SP_SQLvExecute(tSql, orsTemp)
    If (orsTemp.BOF And orsTemp.EOF) Then SP_DATbChkDupData = False
    orsTemp.Close
End Function


Public Function SP_INSbTSysLogMaster(ByVal ptTableFrm$, ByVal ptTableTo$, Optional ByVal ptWhere$) As Boolean
'----------------------------------------------------------
'   Call: INSERT TSysLogPdt,TSysLogSpl,TSysLogCst
'           ptTableFrm      : เป็น table ที่เอาข้อมูลมา insert
'           ptTableTo        : table ที่จะ insert
'           ptWhere            : เงื่อนไขในการ insert
'----------------------------------------------------------
    Dim tSql$
    
    SP_INSbTSysLogMaster = False
    
    tSql = "INSERT INTO " & ptTableTo
    tSql = tSql & " SELECT * FROM " & ptTableFrm
    tSql = tSql & " WHERE " & ptWhere
    If SP_SQLbExecute(tSql) Then
        SP_INSbTSysLogMaster = True
    End If
End Function

Public Sub SP_FRMSetClrObj(ByVal pwForm As Form)
'----------------------------------------------------------
'   Call:   pwForm as form
'   Cmt:   set back color of object.Tag = 4,5,......
'----------------------------------------------------------
    Dim oControl As Object

    For Each oControl In pwForm.Controls

        If (TypeOf oControl Is Label) Then
              Select Case Left(oControl.Tag, 1)
                    Case "4"        'default สีส้ม
                           oControl.BackColor = nVB_CNClrBOlaTag4
                     Case "5"        'default สีเขียว
                           oControl.BackColor = nVB_CNClrBOlaTag5
              End Select
        End If

        If (TypeOf oControl Is TextBox) Then
              Select Case cUT.UT_STRtToken(oControl.Tag, ";", 3)
                    Case "4"         'default สีส้ม
                           oControl.BackColor = nVB_CNClrBLock
                           oControl.Locked = True

                     Case "5"    'default สีฟ้า
                            oControl.BackColor = nVB_CNClrBOtbCal
                            oControl.Locked = True

                     Case "6"        'default สีเขียว
                           oControl.BackColor = nVB_CNClrBOlaTag5
                            oControl.Locked = True

                        Case Else 'ปลด ล๊อก
                            oControl.BackColor = nVB_CNClrBUnLock
                            oControl.Locked = False
              End Select

        End If
    Next oControl
End Sub


