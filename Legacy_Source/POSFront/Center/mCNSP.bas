    Exit Function
Err_Handle:
    Call SP_CRTxLogPrg("SP_CHKbWebservice[8] Error : " & Err.Number & ",Err Desc:" & Err.Description)
    bVB_AbleToken = False
    SP_CHKbWebservice = False
