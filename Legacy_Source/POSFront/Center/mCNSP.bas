Public Function SP_GETdCurrentDate(Optional ByVal pbUseOperationConfig As Boolean) As Date
'--------------------------------------------------------------
'Ret: Current date on server
'Cmt: get current date on system date server
'-------------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim tTmp As String
    Dim dTmp As Date
On Error GoTo ErrHandle             '*Ao 2011/03/24  เพิ่ม On Error GoTo ErrHandle
    
    tSql = "SELECT GETDATE()"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True)
    If Not orsTemp Is Nothing Then '*KT 54-03-25 ป้องกันโปรแกรมหลุดให้ตรวจสอบ recordset  ว่า Nothing หรือไม่ก่อนใช้งาน
        If Not (orsTemp.BOF Or orsTemp.EOF) Then
            SP_GETdCurrentDate = orsTemp(0)
        Else
            SP_GETdCurrentDate = Date
        End If
    Else
        SP_GETdCurrentDate = Date
    End If
    
    '*Nirut 08-03-26 add
    If pbUseOperationConfig Then
        dTmp = SP_GETdCurrentDate
        tSql = "SELECT FTOdmStaDate FROM TSysOptDateMtn "
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
        If Not orsTemp Is Nothing Then '*KT 54-03-25 ป้องกันโปรแกรมหลุดให้ตรวจสอบ recordset  ว่า Nothing หรือไม่ก่อนใช้งาน
            If Not (orsTemp.BOF Or orsTemp.EOF) Then
                tTmp = SP_FEDtChkString(orsTemp, "FTOdmStaDate")
            End If
        End If
        If tTmp = "2" Then
                SP_GETdCurrentDate = DateAdd("d", 1, dTmp)
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_GETdCurrentDate = Date
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & ",Form:mCNSP," & "SP_GETdCurrentDate")
End Function

Public Sub SP_SYSxChangeSystemDate()
    Dim tSql As String
