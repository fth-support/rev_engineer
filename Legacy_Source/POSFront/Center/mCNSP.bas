    If Not poRs Is Nothing Then
            If poRs.State = adStateOpen Then poRs.Close          'ไม่ใช้  State เพราะกรณี recordset ยังไม่ได้เปิดจะ error
            Set poRs = Nothing
    End If
End Sub

