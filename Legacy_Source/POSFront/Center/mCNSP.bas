                        cSrcAmt = cRegAmt
                        cRegAmt = 0
                    Else
                        If Not bLowBP Then
                            cRegAmt = cNormalBPAmt - cSrcAmt
                        Else
                            cRegAmt = cLowBPAmt - cSrcAmt
                        End If
                    End If
                    '============================================
                    
                    Select Case UCase(tTdmCode)
                        Case UCase("T002"), UCase("T003"), UCase("T017")                'T002    Credit Card,T003    Hire Purchase,T017    TC Card
                            tCardNo = SP_FEDtChkString(orsTemp, "FTSrcCardNo")
                            tAllowBP = Left(SP_FEDtChkString(orsTemp, "FTSrcRmk"), 1)
                            tCardExp = SP_FEDtChkString(orsTemp, "FTSrcCardExp")
                            If UCase(tAllowBP) = UCase("Y") Then
                            
                                tSrcRetDocRef = SP_PRCtGetCreditType(tTdmCode, tCardNo, tSrcRetDocRef)
                                 Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (7) AllowBP= True,tSrcRetDocRef =" & tSrcRetDocRef))     '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
                                 
                                If SP_PRCbPointGroup(tCardNo, tCardExp, tTdmCode, tSrcRetDocRef) Then
                                    'tCardExp = SP_FEDtChkString(orsTemp, "FTSrcCardExp") '*Tao 60-06-01 ปิดไว้ก่อน
                                    If tCardExp = "" Then tCardExp = SP_FEDtChkString(orsTemp, "FTSrcCardExp") '*Tao 60-06-01 Exp Date จะได้ตรงกับ CardNo
                                    If SP_PRCbCheckAddBP(tTdmCode, tSrcRetDocRef) Then
                                        'Call SP_PRCxPointMEM(tCardNo, cSrcAmt, tCardExp, nSeqNo, tStaChkExp, False)           '*Ao 2015/01/05  CommSheet TK-ISS3000-570_Confirm
                                        
                                        '*Tao 60-04-07 เช็คก่อนว่าใช้ Low BP หรือไม่
                                        tTmpCardNo = tCardNo
                                        tTmpTdmCode = tTdmCode
                                        tTmptSrcRetDocRef = tSrcRetDocRef
                                        If bLowBP Then
                                            Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (8) bLowBP= True"))   '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
                                            If SP_PRCbChkLowBP(tTdmCode, tSrcRetDocRef, cSrcAmt, ChkPointType.MemPoint, nLowBPPoint) Then Call SP_PRCxPointMEM(tCardNo, cSrcAmt, tCardExp, nSeqNo, tStaChkExp, False, bLowBP, nLowBPPoint, cRefSrcAmt)
                                        Else
                                            Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (8) bLowBP= False"))   '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
                                            Call SP_PRCxPointMEM(tCardNo, cSrcAmt, tCardExp, nSeqNo, tStaChkExp, False, , , cRefSrcAmt)
                                        End If
                                        '=================================
                                        
                                    Else
                                        cW_PointMem = 0 '*Tao 59-05-17
                                    End If
                                    'Call SP_PRCxPointCredit(tCardNo, tTdmCode, tSrcRetDocRef, cSrcAmt, tCardExp, tStaChkExp, nSeqNo) '*Tao 60-04-05 ของเดิม
                                    
                                    '*Tao 60-04-07 เช็คก่อนว่าใช้ Low BP หรือไม่
                                    If bLowBP Then
                                        If SP_PRCbChkLowBP(tTdmCode, tSrcRetDocRef, cSrcAmt, ChkPointType.CreditPoint, nLowBPPoint) Or (cW_PointMem > 0) Then Call SP_PRCxPointCredit(tCardNo, tTdmCode, tSrcRetDocRef, cSrcAmt, tCardExp, tStaChkExp, nSeqNo, bLowBP, nLowBPPoint, cRefSrcAmt)
                                        'Call SP_PRCxPointCredit(tCardNo, tTdmCode, tSrcRetDocRef, cSrcAmt, tCardExp, tStaChkExp, nSeqNo, bLowBP, nLowBPPoint, cRefSrcAmt)
                                    Else
                                        Call SP_PRCxPointCredit(tCardNo, tTdmCode, tSrcRetDocRef, cSrcAmt, tCardExp, tStaChkExp, nSeqNo, , , cRefSrcAmt)
                                    End If
                                    '=================================
                                Else
                                    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (9) SP_PRCbPointGroup Not True"))   '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
                                End If
                            End If
'                            '*Tao 60-04-07 เช็คก่อนว่าใช้ Low BP หรือไม่
'                            If bLowBP Then
