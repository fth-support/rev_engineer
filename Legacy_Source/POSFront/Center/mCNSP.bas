Public Function SP_DTEbIsLeapYear(ByVal pdDate As Date) As Boolean
'-----------------------------------------------------------
'   Call :
'   Cmt :
'   Developer : SOMJAI
'   Date Create : 01-20-2006 :  14:00:42
'-----------------------------------------------------------
On Error GoTo ErrHandle
    Dim nYear%
    
    nYear = Year(pdDate)
    SP_DTEbIsLeapYear = False
    If nYear Mod 4 = 0 Then
        SP_DTEbIsLeapYear = True
        If nYear Mod 100 = 0 And nYear Mod 400 <> 0 Then
            SP_DTEbIsLeapYear = False
        End If
    End If
    Exit Function
