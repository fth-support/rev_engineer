                    End If
            End If
            'Addition Point
            bAdd = IIf(aW_PointSec2(nI).tAdd = "Y", True, False)
            If bAdd Then
                pcPoint = pcPoint + cTierPoint
                pcPointAmt = pcPointAmt + cTierPointAmt
                '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                 If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type5SecAddPoint, cTierPoint, cTierPointAmt, aW_PointSec2(nI).tCode, aW_PointSec2(nI).tEvnID, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type5SecAddPoint & ",Section ID = " & aW_PointSec2(nI).tCode & ",Point =" & cTierPoint, tVB_MemPointID)
                End If
            Else
                If SP_FEDtChkString(orsSec, "FTMsmStaAlw") = "Y" Then
                    pcPoint = pcPoint + cTierPoint
                    pcPointAmt = pcPointAmt + cTierPointAmt
                    '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                     If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type5SecAddPoint, cTierPoint, cTierPointAmt, aW_PointSec2(nI).tCode, aW_PointSec2(nI).tEvnID, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type5SecAddPoint & ",Section ID = " & aW_PointSec2(nI).tCode & ",Point =" & cTierPoint, tVB_MemPointID)
                    End If
                Else
                    pcPoint = pcPoint + 0
                    pcPointAmt = pcPointAmt + 0
                End If
            End If
            End If
    Next nI
    
    'ทำการเก็บค่ารายการ Item ที่ยังสามารถไปคำนวณ Point ในส่วนของ Cooperate
    '----------------------------------------------------------------------------------------------
    If UBound(aW_PointSKUSeq) = 0 Then
       nMax = 1
    Else
       nMax = UBound(aW_PointSKUSeq)
    End If
    If Not (porsTemp.BOF And porsTarget.EOF) Then porsTemp.MoveFirst
    Do While Not porsTemp.EOF
        nSeqNo = SP_FEDvChkNumeric(porsTemp, "FNSdtSeqNo")
        bFoundSeq = False
        For nI = 0 To nMax - 1
                If Val(Format(aW_PointSKUSeq(nI))) = nSeqNo Then
                    bFoundSeq = True
                    Exit For
                End If
        Next nI
        If Not bFoundSeq Then
            porsTarget.AddNew
            For nI = 1 To porsTemp.Fields.Count
                Select Case UCase(Mid(porsTemp.Fields(nI - 1).Name, 2, 1))
                    Case "T"
                        porsTarget.Fields(nI - 1).Value = porsTemp.Fields(nI - 1).Value & vbNullString
                    Case "C"
                        porsTarget.Fields(nI - 1).Value = SP_VALcText2Double(porsTemp.Fields(nI - 1).Value & vbNullString)
                    Case "N"
                        porsTarget.Fields(nI - 1).Value = SP_VALnText2Double(porsTemp.Fields(nI - 1).Value & vbNullString)
                    Case "D"
                        If IsNull(porsTemp.Fields(nI - 1).Value) Then
                            porsTarget.Fields(nI - 1).Value = "Null"
                        Else
                           porsTarget.Fields(nI - 1).Value = porsTemp.Fields(nI - 1).Value
                        End If
                End Select
            Next nI
        End If
        porsTemp.MoveNext
    Loop
    '----------------------------------------------------------------------------------------------
    
    If Not (porsTarget.BOF And porsTarget.EOF) Then porsTarget.MoveFirst
    Call SP_DATxRsNothing(orsMas)
    Call SP_DATxRsNothing(orsSec)
    Call SP_DATxRsNothing(orsNotAlw)
    Call SP_DATxRsNothing(orsAlw)
    Call SP_DATxRsNothing(orsTier)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsMas)
    Call SP_DATxRsNothing(orsSec)
    Call SP_DATxRsNothing(orsNotAlw)
    Call SP_DATxRsNothing(orsAlw)
    Call SP_DATxRsNothing(orsTier)
End Sub


