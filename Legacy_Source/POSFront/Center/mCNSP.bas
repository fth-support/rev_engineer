Public Sub SP_DTEControl(ByRef poDT As DTPicker)
'----------------------------------------------------------
'   Call:   poDT is DTPicker
'   Cmt:   control DTPicker when keychange
'               solve problem with Tha date (some machine)
'----------------------------------------------------------
    Dim tY$, tM$, td$
    Dim dDate As Date
    Dim tBuffer As String, apiType As SYSTEMTIME
    
    On Error GoTo ErrHandle
    
    'ค้นหาปี พุทธ หรือ คริส
    With apiType
        .wDay = Day(poDT.Day)
        .wMonth = Month(poDT.Month)
        .wYear = Year(poDT.Year)
    End With
    tBuffer = String(255, 0)
    GetDateFormat ByVal 0&, 0, apiType, vbNullString, tBuffer, Len(tBuffer)
    tBuffer = Format(Left$(tBuffer, InStr(1, tBuffer, Chr$(0)) - 1), "yyyy/mm/dd")
        
    tY = poDT.Year
    tM = poDT.Month
    td = poDT.Day
    
    'ถ้าวันที่คีย์ ไม่เป็นรูปแบบวันที่ หรือ วันที่คีย์น้อยกว่า mindate จะ exit
    If Not IsDate(tY & "/" & tM & "/" & td) Or (Format(tY & "/" & tM & "/" & td, "yyyy/mm/dd") < poDT.MinDate) Then
        Exit Sub
    End If
    
    dDate = poDT.Value          'เก็บค่าเดิม
    
    'เครื่องปกติ และไม่ปกติ จะถูกเซ็ตค่าใหม่
    poDT.Value = Format(tY & "/" & tM & "/" & td, "yyyy/mm/dd")
    
    'เครื่องไม่ปกติ + region(christ) เมื่อคีย์เป็นพุทธจะไม่แปลงเป็นคริสให้ จึงตรวจสอบต่อ
    'ถ้าปีของ system date(region) <= year(date) แสดงว่าเป็นคริส, จะตรวจสอบต่อ
    If CLng(Left(tBuffer, 4)) <= Year(Format(tY & "/" & tM & "/" & td, "yyyy/mm/dd")) Then
        If Year(poDT.Value) > Year(Format(tY & "/" & tM & "/" & td, "yyyy/mm/dd")) Then                                  'region เป็นคริสต์ แต่คีย์เป็นพุทธ (เฉพาะเครื่องที่ผิดปกติ)
            poDT.Value = DateAdd("yyyy", -543, poDT.Value)        'จะทำการลบลงด้วย 543
       End If
    End If
    Exit Sub
ErrHandle:
    poDT.Value = dDate
End Sub


Public Sub SP_GRDAfterEdit(ByVal poVsGrd As VSFlexGrid, ByVal pnRow As Long, ByVal pnCol As Long, ByVal pvGrdBeforeEdit As Variant)
'----------------------------------------------------------------------------
' Cmt:  chec to set flag
'
'----------------------------------------------------------------------------
    Dim tKeyEdit As String
    Dim vGrdAfterEdit As Variant
     
    With poVsGrd
        vGrdAfterEdit = .TextMatrix(pnRow, pnCol)
        tKeyEdit = .TextMatrix(pnRow, .ColIndex("KeyEdit"))           '1: Show ,2: Update ,3: Insert ,4: Delete
        Select Case tKeyEdit
            Case "1"     'Show                '1-->2   do
                If pvGrdBeforeEdit <> vGrdAfterEdit Then .TextMatrix(pnRow, .ColIndex("KeyEdit")) = 2
                
            Case "2", "3", "4"  'Update ,Insert , Delete
            
            Case Else       'Empty
                If vGrdAfterEdit <> "" And pvGrdBeforeEdit <> vGrdAfterEdit Then .TextMatrix(pnRow, .ColIndex("KeyEdit")) = 3
                
        End Select
    End With
End Sub

