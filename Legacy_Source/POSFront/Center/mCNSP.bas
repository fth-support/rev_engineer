    oDB.ocnOffLine.CommandTimeout = 1800
    tSql = "EXEC " & ptName & " " & ptParameter
    'Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
    oDB.ocnOffLine.Execute (tSql)
