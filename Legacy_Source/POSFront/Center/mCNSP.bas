                                Call SP_APPxEndProgram
                                Exit Function
                            End If
                        Else
                            SP_SQLbExecute = True
                            Exit Function
                        End If
                End If
'                If IsMissing(poRs) Then
'                    oDB.ocnOffLine.Execute ptSql, pnEffect
'                Else
'                    Set poRs = oDB.ocnOffLine.Execute(ptSql, pnEffect)
'                End If
'                pnErr = 0
'                SP_SQLbExecute = True
'                Exit Function
            End If
        Else
            If oCNCon.ConnectionString = oDB.ocnOffLine.ConnectionString Then
                If nErr = -2147467259 Or nErr = 91 Or nErr = -2147217871 Or nErr = 3704 Then
                        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & nErr & " ErrorDesc:" & " Module:mCNSP Events:SP_SQLbExecute[Offline][2]")
