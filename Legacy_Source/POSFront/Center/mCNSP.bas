Public Function SP_GETbTmnData() As Boolean
'------------------------------------------------------
'Ret:
'Cmt: Get ค่าของ Terminal เช่น มีการเปิดการขายอยู่หรือไม่
'-----------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim nErr As Long
On Error GoTo ErrHandle
    tSql = "SELECT FTTmnCode,FTTmnNum,FTTmnPrnDriver,FTTmnRegNum"
    tSql = tSql & vbCrLf & ",FTTmnStaClossing ,FTTmnPrnDriver ,FTTmnMsr,FTTmnEdc"
    tSql = tSql & vbCrLf & ",FTTmnFloor"
    tSql = tSql & vbCrLf & ",FTTmnDrawer"
    tSql = tSql & vbCrLf & ",FTTmnPrnEJ"
    tSql = tSql & vbCrLf & ",FTTmnDisplay"
    tSql = tSql & vbCrLf & ",FTTmnIPAddr"
    tSql = tSql & vbCrLf & ",FTTmn950SlipPrn"
    tSql = tSql & vbCrLf & ",FTTmnStatus"
    tSql = tSql & vbCrLf & ",FTTmnPrn"
    tSql = tSql & vbCrLf & ",FTTmnPrintType"
    tSql = tSql & vbCrLf & ",FTTmnEdcPort"
    tSql = tSql & vbCrLf & ",FTTmnMsrPort"
    tSql = tSql & vbCrLf & " FROM TCNMTerminalMtn WITH(NOLOCK)"
    tSql = tSql & vbCrLf & " WHERE FTTmnName= '" & tVB_CNComName & "'"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
    If Not (orsTemp.BOF Or orsTemp.EOF) Then
        tVB_CNTerminalIndex = SP_FEDtChkString(orsTemp, "FTTmnCode")
        tVB_CNTerminalNum = SP_FEDtChkString(orsTemp, "FTTmnNum")
        tVB_CNTerminalDrv = SP_FEDtChkString(orsTemp, "FTTmnPrnDriver")
        tVB_CNTerminalReg = SP_FEDtChkString(orsTemp, "FTTmnRegNum")
        tVB_CNTerminalFloor = SP_FEDtChkString(orsTemp, "FTTmnFloor")
        bVB_CNOpenTmnOff = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTmnStatus")) = "A", True, False)
        
        tVB_PrnDevice = SP_FEDtChkString(orsTemp, "FTTmnPrnDriver")
        bVB_CNNETSPos = IIf(SP_FEDtChkString(orsTemp, "FTTmnMsr") = "1", True, False)      'Magnetic Card
        
        bVB_CNEdcPos = IIf(SP_FEDtChkString(orsTemp, "FTTmnEdc") = "1", True, False)      'CreditCard
        bVB_CNDrwPos = IIf(SP_FEDtChkString(orsTemp, "FTTmnDrawer") = "1", True, False)      'Drawer
        bVB_CNDisplayPos = IIf(SP_FEDtChkString(orsTemp, "FTTmnDisplay") = "1", True, False)      'Customer Display
        bVB_CNEJPos = IIf(SP_FEDtChkString(orsTemp, "FTTmnPrnEJ") = "1", True, False)      'EJ
        tVB_CNIP = SP_FEDtChkString(orsTemp, "FTTmnIPAddr")
        bVB_CNPrnOPOS = IIf(SP_FEDtChkString(orsTemp, "FTTmn950SlipPrn") = "1", True, False) 'Print by OPOS or Driver         1: OPOS    2: Driver
'        tUT_Printer = SP_FEDtChkString(orsTemp, "FTTmnPrn") 'ชื่อเครื่อง Printer
'        tUT_PrintType = SP_FEDtChkString(orsTemp, "FTTmnPrintType") '2 : รวมพิมพ์โดยตรง 3 : รวมพิมพ์โดยวินโดว์
        tVB_CNEdcPort = CStr(Val(Format(SP_FEDtChkString(orsTemp, "FTTmnEdcPort"))) - 1)
        tVB_CNNETSPort = CStr(Val(Format(SP_FEDtChkString(orsTemp, "FTTmnMsrPort"))) - 1)
        SP_GETbTmnData = True
    Else
         tVB_CNTerminalIndex = ""
        tVB_CNTerminalNum = ""
        tVB_CNTerminalDrv = ""
        tVB_CNTerminalReg = ""
        tVB_CNTerminalFloor = ""
        bVB_CNOpenTmnOff = False
        tVB_PrnDevice = ""
        bVB_CNNETSPos = False
        bVB_CNEdcPos = False
        bVB_CNDrwPos = False    'Drawer
        bVB_CNDisplayPos = False   'Customer Display
        bVB_CNEJPos = False   'Customer Display
        tVB_CNIP = ""
'        tUT_Printer = "" 'ชื่อเครื่อง Printer
'        tUT_PrintType = "" '2 : รวมพิมพ์โดยตรง 3 : รวมพิมพ์โดยวินโดว์
        tVB_CNEdcPort = ""
        tVB_CNNETSPort = ""
        bVB_CNPrnOPOS = False 'Default as OPOS
    End If
    '57-05-08   20130504-ReEntry.xls เก็บ Physical Terminal Number
     tVB_CNPhysicalTerminalNum = tVB_CNTerminalNum
     
    tSql = "SELECT "
    tSql = tSql & vbCrLf & "FTTmnStaClossing "
    tSql = tSql & vbCrLf & ",FTTmnStatus "
    tSql = tSql & vbCrLf & "FROM TCNMTerminalMtn WITH(NOLOCK)"
    tSql = tSql & vbCrLf & "WHERE FTTmnName= '" & tVB_CNComName & "'"
    nErr = SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)
    If nErr = 0 Then
        If Not (orsTemp.BOF Or orsTemp.EOF) Then
            bVB_CNOpenTmn = IIf(UCase(SP_FEDtChkString(orsTemp, "FTTmnStatus")) = "A", True, False)
        Else
            bVB_CNOpenTmn = False
            'กรณีที่ Server สามารถติดต่อได้และไม่มีข้อมูล Terminal ก้อไม่ควรที่จะเปิดใช้งานได้ ยกเว้นกรณีที่ Offline
            If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                SP_GETbTmnData = False
            End If
        End If
    Else
        If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
            bVB_CNOpenTmn = False
            SP_GETbTmnData = False
        Else
            bVB_CNOpenTmn = False
        End If
    End If
    
    'Update กรณีที่เครื่อง POS  Online กับ Offline ตั้ง Terminal Number ไม่ตรงกัน
    '-----------------------------------------------------------------------------------------------------
    tSql = "SELECT FTTmnNum "
    tSql = tSql & vbCrLf & "FROM TCNMTerminalMtn "
    tSql = tSql & vbCrLf & " WHERE FTTmnName= '" & tVB_CNComName & "'"
    'Set orsTemp = oDB.ocnOffLine.Execute(tSql)
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            If SP_FEDtChkString(orsTemp, "FTTmnNum") <> tVB_CNTerminalNum Then
                tSql = "UPDATE  TCNMTerminalMtn WITH(ROWLOCK)"
                tSql = tSql & vbCrLf & "SET  FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " WHERE FTTmnName= '" & tVB_CNComName & "'"
                Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
                
                tSql = "UPDATE  TCNMTerminalMtn WITH(ROWLOCK)"
                tSql = tSql & vbCrLf & "SET  FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " WHERE FTTmnName= '" & tVB_CNComName & "'"
                Call SP_SQLvExecute(tSql, , oDB.ocnOnLine)
            End If
        End If
    End If
    '------------------------------------------------------------------------------------------------------
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_GETbTmnData = False
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Sub SP_MSGxShowError(ByVal pnErrNumber As Integer, ByVal ptErrDesc As String)
'----------------------------------------------------------
'   Call:
'   Cmt:   displays the error message with it's Err code
    '*KT 53-05-29 แก้ไขการเกิด Dot send โดยการแก้ไขจากตัวตังต้น 3.0.19
    '*KT 54-04-09 V.3.0.56 add parameter ptErrDesc
'----------------------------------------------------------
    Dim tMsg$, tMsg2$, tAppTitle$
    Dim nErrNo As Long
    Dim tErrDesc As String
    Dim tAllMsg As String
    Dim nPos%
On Error GoTo ErrHandle
'    nErrNo = Err.Number
    nErrNo = pnErrNumber
    If nErrNo = 91 Then
         Call SP_CRTxWriteLogTerminated("ErrorNumber:91" & " ErrorDesc:" & Err.Description & " Form:" & "mCNSP" & " Events:SP_MSGxShowError[1]")
        Exit Sub '***KT 52-07-20 กรณีเดียวที่เกิด Error 91 ที่เกิดจากการ Query Statement ตอนที่เครื่องกำลังทำการ Replicate
    End If
    tErrDesc = ptErrDesc 'Err.Description
    Screen.MousePointer = vbDefault
    If tVB_CNPthFileINI = "" Then tVB_CNPthFileINI = App.Path & "\" & App.EXEName & ".ini"
    
    tMsg = SP_INItGetValue(tVB_CNPthFileINI, "All", "tCS_CN000001")
    tMsg = cUT.UT_STRtToken(tMsg, ";", nVB_CNCutMsg)
    
    tMsg2 = SP_INItGetValue(tVB_CNPthFileINI, "All", "tCS_CN000002")
    tMsg2 = cUT.UT_STRtToken(tMsg2, ";", nVB_CNCutMsg)
    
    tAllMsg = tMsg & vbCrLf & vbCrLf       'vbCrLf = Carriage return and Line feed
    tAllMsg = tAllMsg & tMsg2 & nErrNo & vbCrLf
    tAllMsg = tAllMsg & Space(4) & tErrDesc
    
    Beep 5000, 1 '*KT 53-04-09 PH3-ML-SF-112 Allow Scanner when alert message
    
   If nErrNo <> 0 Then MsgBox tAllMsg, tCS_CNMsgErr, tVB_CNAppTitle
   If nErrNo = 0 Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & Err.Description & " Form:" & "mCNSP" & " Events:SP_MSGxShowError[2]")
    End If
    Exit Sub
ErrHandle:
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "mCNSP" & " Events:SP_MSGxShowError[3]")
End Sub



