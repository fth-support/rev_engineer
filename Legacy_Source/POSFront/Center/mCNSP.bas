Public Sub SP_FRMxSetMove(ByVal pwShw As Form)
'----------------------------------------------------------------------------
'   Call :pwShw is form pop up
'   Cmt:  เรียก  ใน Form Load ของหน้าจอที่ต้องการให้ popup  Copy ค่านี้วางในบันทัดแรกของ Form_Load
'   Ex.   Call SP_FRMxSetMove(Me)
'----------------------------------------------------------------------------
   Dim nRow As Long, nCol As Long
   Dim nCurX As Long, nCurY As Long
   Dim nBtnW As Long, nBtnH As Long
   Dim nCellW As Long, nCellH As Long
    
    nRow = nVB_CNBrwPosGrdRow: nCol = nVB_CNBrwPosGrdCol
    nCurX = nVB_CNBrwPosCurX: nCurY = nVB_CNBrwPosCurY
    nBtnW = nVB_CNBrwPosBtnW: nBtnH = nVB_CNBrwPosBtnH
    nCellW = nVB_CNBrwPosParentCellW: nCellH = nVB_CNBrwPosParentCellH
    If (nRow + nCol + nCurX + nCurY + nBtnW + nBtnH + nCellW + nCellH) = 0 Then
        Call SP_FRMxChildCenter(pwShw)
        Exit Sub
    End If

    If nRow < 0 And nCol < 0 Then   'ปุ่มทั่วไป
        'แกน X
'        If nCurX + pwShw.Width > Screen.Width Then
            nCurX = (nCurX) '+ pwShw.Width)  'ชิดปุ่มด้านซ้าย
            'nCurX = (pwShw.Left) '- 80) 'ชิดปุ่มด้านซ้าย
'        Else
'            nCurX = pwShw.Left - 80 'ชิดปุ่มด้านขวา
'        End If
        'แกน Y
        
        If nCurY + pwShw.Height > Screen.Height Then
            nCurY = (nCurY - pwShw.Height) - (nBtnH)            'ส่วนล่างเท่ากับขอบล่างของปุ่ม
        Else
            nCurY = (nCurY) '+ nBtnH)     'ส่วนบนเสมอปุ่ม
        End If
        
        
    Else   'vsflexgrid
        If nCurX + pwShw.Width > Screen.Width Then nCurX = (nCurX - pwShw.Width) + nCellW             'ชิดขอบล่างของ Cell
        If nCurY + pwShw.Height > Screen.Height Then nCurY = (nCurY - pwShw.Height) - nCellH                    'บน
    End If
    
    If nCurX < 0 Or nCurX > Screen.Width Then nCurX = (Screen.Width - pwShw.Width) / 2 '100
    If nCurY < 0 Or nCurY > Screen.Height Then nCurY = (Screen.Height - pwShw.Height) / 2 '100
    ' show popup
    pwShw.Move nCurX, nCurY
    
    nVB_CNBrwPosGrdRow = 0: nVB_CNBrwPosGrdCol = 0
    nVB_CNBrwPosCurX = 0: nVB_CNBrwPosCurY = 0
    nVB_CNBrwPosBtnW = 0: nVB_CNBrwPosBtnH = 0
    nVB_CNBrwPosParentCellW = 0: nVB_CNBrwPosParentCellH = 0
End Sub


