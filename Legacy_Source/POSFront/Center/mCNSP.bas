Public Sub SP_SETxTokenObjects()
Dim nErrorNo As Long
Dim tErrorDesc As String
'On Error GoTo Err_Handle '*Tao 61-04-20 ปิดไว้
On Error Resume Next '*Tao 61-04-20
   '*Bmp 61-02-15 C:\Program Files (x86)\Common Files\MSSoap\Binaries\MSSOAP30.dll
    'Set oTKToken = CreateObject("MSSOAP.SoapClient30")
    '*Bmp 61-03-28
    'bVB_AbleToken = False
    '*Tao 61-04-24 clear object ก่อน'*Bmp 61-04-24 test comment v.5.1804.16
    '*Tao 61-05-17 ต้องเคลียร์ clear object ก่อน เพราะไม่สามารถ MSSoapInit ซ้ำ 2 ครั้งได้
    If Not (oTKToken Is Nothing) Then
        Call SP_CRTxLogPrg("set oTKToken Nothing")
        Set oTKToken = Nothing
        Call SleepEx(200, 0)
    End If
    '========================
    Set oTKToken = CreateObject("MSSOAP.SoapClient30")
    Call SP_CRTxLogPrg("CreateObject oTKToken: prepare MSSoapInit URL:" & tVB_TokenURL)
    If (oTKToken Is Nothing) Then
        bVB_AbleToken = False
        Call SP_CRTxLogPrg("CreateObject oTKToken: Fail !")
        On Error GoTo 0
        Exit Sub
    Else
        Call SP_CRTxLogPrg("CreateObject oTKToken: OK")
    End If
    '*Tao 61-05-17 Set ClientProperty
    'oTKToken.ClientProperty("ServerHTTPRequest") = True
    '===========================
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then '*Tao 61-04-20 ถ้า OnLine'*61-04-26
        Call oTKToken.MSSoapInit(tVB_TokenURL, "", "")
        nErrorNo = Err.Number
        tErrorDesc = Err.Description
        If (nErrorNo <> 0) Then
             '* คิดก่อนว่าจะให้ servicetransfer write log ลงที่ไหน Call SP_CRTxLogMallCardExtend(ptFuncName & "Initial Token Web service Error: " & Err.Number & ":" & Err.Description)
             'MsgBox "Initial Token Web service Error: " & Err.Number & ":" & Err.Description, vbExclamation
             If (nErrorNo = -2147024809) Then
                Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit err: Invalid Web Service Request. Please check the Web Service URL")
             Else
                Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit err:" & tErrorDesc)
             End If
            bVB_AbleToken = False
            Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit is not completed.")
            Set oTKToken = Nothing '*Tao 61-05-23
            On Error GoTo 0 '*Tao 61-04-20
            Exit Sub
        Else
            '*Tao 61-05-17 Set ConnectorProperty
            'oTKToken.ConnectorProperty("UseSSL") = False
            oTKToken.ConnectorProperty("Timeout") = 10000
            oTKToken.ConnectorProperty("ConnectTimeout") = 10000
            '===============================
        End If
    Else
        bVB_AbleToken = False
        Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit is Offline") '*61-04-26
        Set oTKToken = Nothing '*Tao 61-05-23
        On Error GoTo 0
        Exit Sub
    End If
    bVB_AbleToken = True
    Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit is completed.")
    Set oTKToken = Nothing '*Tao 61-05-23
    On Error GoTo 0
    Exit Sub '*61-03-23 v.POSFront v.5.1803.2
Err_Handle:
    Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit err:" & Err.Description)
    bVB_AbleToken = False
    Call SP_CRTxLogPrg("Date:" & Date & " Time:" & Time$ & "TKToken.MSSoapInit is not completed.")
    Set oTKToken = Nothing '*Tao 61-05-23
    On Error GoTo 0
End Sub

Public Function SP_VALnText2Double(ByVal ptTextNum As String, Optional ByVal pnRetDefault As Long = 0) As Long
'----------------------------------------------------------
'   Cmt: แปลงค่าจากสตริงเป็นตัวเลข
'----------------------------------------------------------
    Dim nReturn  As Long
    On Local Error GoTo ErrHandle
    
    If Not IsNumeric(ptTextNum) Then
        nReturn = 0
    Else
        nReturn = CLng(Val(Format(ptTextNum)))
    End If
    
    If nReturn = 0 Then
        If pnRetDefault <> 0 Then nReturn = pnRetDefault
    End If
    
    SP_VALnText2Double = nReturn
    Exit Function
ErrHandle:
    SP_VALnText2Double = 0
End Function

Public Function SP_SQLtFunctionSTP(ByVal ptFunc$, ByVal ptField$, ByVal ptTable$, ByVal ptWhere$, Optional ByVal poCn As ADODB.Connection) As String
'----------------------------------------------------------
'   Call:   ptFunc is string of fuction such as SUM, AVG, COUNT
'               ptField is required filed by store procedure
'   Ret:    string of value sum, avg, count ...
'----------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim tValue As String
    Dim oCNCon As ADODB.Connection
    On Error GoTo ErrDB:
    Set oCNCon = IIf(poCn Is Nothing, ocnAll, poCn)
    
    SP_SQLtFunctionSTP = vbNullString
    
'    tSql = "SELECT " & ptFunc & "(" & ptField & ") AS FldValue"
'    tSql = tSql & " FROM " & ptTable & " " & ptWhere
    
    tSql = "STP_CNxSQLFunction @ptFunc = '" & ptFunc & "(" & ptField & ") AS FldValue' ,@ptTable = '" & ptTable & "',@ptWhere = '" & ptWhere & "'"

    Call SP_SQLvExecute(tSql, orsTemp, oCNCon)      '*Tee 49-06-09 Check Data

    If (orsTemp.BOF And orsTemp.EOF) Then
        tValue = ""
    Else
        tValue = CStr(IIf(IsNull(orsTemp.Fields("FldValue").Value), "", orsTemp.Fields("FldValue").Value))
    End If
    SP_SQLtFunctionSTP = tValue
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrDB:
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Function SP_SQLtFunction(ByVal ptFunc$, ByVal ptField$, ByVal ptTable$, ByVal ptWhere$, Optional ByVal poCn As ADODB.Connection, Optional ByVal pbSwithOnline As Boolean = False, Optional ByVal pbWaitRep As Boolean = False, Optional pnErr As Long = 0) As String
'----------------------------------------------------------
'   Call:   ptFunc is string of fuction such as SUM, AVG, COUNT
'               ptField is required filed
'   Ret:    string of value sum, avg, count ...
'*KT 53-05-29 แก้ไขการเกิด Dot send โดยการแก้ไขจากตัวตังต้น 3.0.19
'----------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim tValue As String
    Dim oCNCon As ADODB.Connection
    On Error GoTo ErrDB:
    Set oCNCon = IIf(poCn Is Nothing, ocnAll, poCn)
    
    SP_SQLtFunction = vbNullString
    
    tSql = "SELECT " & ptFunc & "(" & ptField & ") AS FldValue"
    tSql = tSql & " FROM " & ptTable & " WITH (NOLOCK) " & ptWhere
    
    pnErr = SP_SQLvExecute(tSql, orsTemp, oCNCon, , , , , pbSwithOnline, pbWaitRep) '*Tee 49-06-09 Check Data

    If (orsTemp.BOF And orsTemp.EOF) Then
        tValue = ""
    Else
        tValue = CStr(IIf(IsNull(orsTemp.Fields("FldValue").Value), "", orsTemp.Fields("FldValue").Value))
    End If
    
    SP_SQLtFunction = tValue
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrDB:
     pnErr = Err.Number
     Call SP_DATxRsNothing(orsTemp)
End Function

Public Function SP_FEDvChkNumeric(ByVal poRs As ADODB.Recordset, ByVal ptField$, Optional pvRetOld) As Variant
'----------------------------------------------------------
'   Call:   poRs as ADODB.Recordset
'               ptField is field to check
'               pvRetOld(variant) if empty, or null want to return old
'   Ret:    numeric value as variant(integer,long,single,double ...)
'----------------------------------------------------------
    Dim bEmpty As Boolean
    
    If poRs.BOF And poRs.EOF Then
        bEmpty = True
    Else
        If IsNull(poRs.Fields(ptField)) Then
            bEmpty = True
        Else
            If Len(Trim(poRs.Fields(ptField))) = 0 Then
                bEmpty = True
            Else
                SP_FEDvChkNumeric = poRs.Fields(ptField)
            End If
        End If
    End If
    If bEmpty Then
        If IsMissing(pvRetOld) Then
            SP_FEDvChkNumeric = 0
        Else
            SP_FEDvChkNumeric = pvRetOld
        End If
    End If
End Function

