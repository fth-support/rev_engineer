    End If
    
    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (2) bVB_ChkEmpPoint = True")) '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
    
    bVB_ChkEmpPoint = True  '*Ao 2013/09/23     ต้อง Set ค่าให้ คิด POINT
    
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnDepositCancel, tEN_TrnAddDeposit, tEN_TrnAddDepositCancel, tEN_TrnRedeem, tEN_TrnIPVRedeem
            tSql = "SELECT FTCstCardCode,FTCstCardType,FTCdpDepositNo,FTShdDepRefTmnNum,FTShdDepReTransNo FROM " & tVB_CNTblHD
            tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE  FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
            tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
            Call SP_SQLvExecute(tSql, orsTemp)
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                tVB_MemPointID = SP_FEDtChkString(orsTemp, "FTCstCardCode")
                tVB_MemExp = SP_FEDtChkString(orsTemp, "FTCstCardType")
                tDepositNo = SP_FEDtChkString(orsTemp, "FTCdpDepositNo")
                tText = "SP_PRCxPointALL :" & tVB_CNTerminalNum & "," & tVB_Running & "," & tVB_Transaction & "," & tUT_SaleDate
                tText = tText & "  " & tVB_MemPointID & " Expired date " & tVB_MemExp
                tRefTmnNum = SP_FEDtChkString(orsTemp, "FTShdDepRefTmnNum")
                tRefTransNo = SP_FEDtChkString(orsTemp, "FTShdDepReTransNo")
            Else
                tVB_MemPointID = ""
                tVB_MemExp = ""
                tText = "SP_PRCxPointALL :" & tVB_CNTerminalNum & "," & tVB_Running & "," & "," & tVB_Transaction & "," & tUT_SaleDate
                tText = tText & "  " & tVB_MemPointID & " Expired date " & tVB_MemExp
                tRefTmnNum = ""
                tRefTransNo = ""
            End If
            Call SP_CRTxLogPrg(tText)
            Call SP_DATxRsNothing(orsTemp)
            If Trim(tVB_MemPointID) = "" Then
                Call SP_PRCxDepositMem(tDepositNo, tVB_MemPointID, tVB_MemExp)            '*Ao 2014/10/15  V 4.2.150  CommSheet TK-ISS3000-562
            End If
    End Select
    
    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (3) SP_PRCxPointMemberGroup")) '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
    
    Call SP_PRCxPointMemberGroup(tVB_MemPointID, tVB_MemExp)
    
    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (4) Start Member Point")) '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
    
    '*Tao 60-04-05 ควรลบ TPSTSalePoint ของเดิมก่อน เผื่อมีการชำระเงินที่ยังทำไม่เสร็จ
    tSql = "DELETE FROM TPSTSalePoint WITH(ROWLOCK) WHERE FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "' AND FDShdTransDate='" & tUT_SaleDate & "' AND FTShdTransType='" & tVB_Transaction & "'"
    Call SP_SQLvExecute(tSql)
    cRefSrcAmt = 0
    If tVB_MemPointID = "" Then '*Thirapong 64-03-18 Performance tuning
        cNormalBPAmt = 0
        cLowBPAmt = 0
        Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (5) tVB_MemPointID = ''")) '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
    Else
        cNormalBPAmt = SP_PRCxRegAmount("2", tVB_CNTblDT) '*Tao 60-04-05 หาจำนวนเงินจากสินค้า Normal BP ที่ยอมให้ได้แต้ม
        cLowBPAmt = SP_PRCxRegAmount("1", tVB_CNTblDT) '*Tao 60-04-05 หาจำนวนเงินจากสินค้า Low BP ที่ยอมให้ได้แต้ม
        
        Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " Msg: " & "SP_PRCxPointALL (6) cNormalBPAmt ,cLowBPAmt= " & cNormalBPAmt & "," & cLowBPAmt))   '*Thirapong 64-12-28 เพิ่ม Log Monitor ไว้ตรวจสอบปัญหา CommSheet TTK-ISS3000-796 TK-ISSUE - Missing BP award to TKPlat.xlsx
    End If
    
    If cNormalBPAmt = 0 Then
        cRegAmt = cLowBPAmt
        bLowBP = True
    Else
        cRegAmt = cNormalBPAmt '*Tao 60-04-05 ใช้ Normal BP ก่อน
        bLowBP = False
    End If
    Select Case SP_VALnText2Double(tVB_TransactionSub)
    Case tEN_TrnRedeem, tEN_TrnAddDeposit, tEN_TrnAddDepositCancel '*Tao 60-04-28 คำนวนยอดชำระเดิมออกก่อน
        cTmp = 0
        tSql = "SELECT MAX(FCSpoAmt) AS FCSpoAmt,FTShdTransType FROM TPSTSalePoint"
        tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE FTTmnNum+FTShdTransNo IN"
        tSql = tSql & vbCrLf & "(SELECT FTTmnNum+FTShdTransNo FROM TPSTDepositHD WHERE FTCdpDepositNo = '" & tDepositNo & "')"
        'tSql = tSql & vbCrLf & "AND FCSpoPoint > 0" 'ไม่ได้ Point แต่อาจถูกคำนวน Point แล้ว (หัก Regular หรือ หัก LowBP)
        tSql = tSql & vbCrLf & "AND FTStaCalPoint = '1'" '*Tao 60-05-19 5 ถูกคำนวน Point
        tSql = tSql & vbCrLf & "GROUP BY FTShdTransNo,FNFOPSeq,FTShdTransType"
        tSql = tSql & vbCrLf & "ORDER BY FTShdTransNo,FNFOPSeq"
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True)
        'Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Do While Not orsTemp.EOF
                If SP_FEDvChkNumeric(orsTemp, "FTShdTransType") = tEN_TrnAddDepositCancel Then
                    cTmp = cTmp - SP_FEDvChkNumeric(orsTemp, "FCSpoAmt")  '*Tao 60-05-04 ให้หักยอดชำระเดิมออกก่อน
                Else
                    cTmp = cTmp + SP_FEDvChkNumeric(orsTemp, "FCSpoAmt")
                End If
                orsTemp.MoveNext
            Loop
        End If
        Call SP_DATxRsNothing(orsTemp)
        '*Tao 60-05-19 หักยอด Deposit Cancel ของบิลปัจุบัน
        If SP_VALnText2Double(tVB_TransactionSub) = tEN_TrnAddDepositCancel Then
            tWhere = "WHERE FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
            tWhere = tWhere & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
            cTmp = cTmp - SP_VALcText2Double(SP_SQLtFunction("SUM", "FCSrcNet", tVB_CNTblRC, tWhere))
        End If
        
        If cNormalBPAmt >= cTmp Then
            cRegAmt = cNormalBPAmt - cTmp
            cNormalBPAmt = cRegAmt
            If cRegAmt = 0 Then
                cNormalBPAmt = 0
                bLowBP = True
                cRegAmt = cLowBPAmt
            End If
        Else
            cLowBPAmt = (cTmp - cNormalBPAmt) - cLowBPAmt
            cNormalBPAmt = 0
            bLowBP = True
            cRegAmt = cLowBPAmt
        End If
    End Select
    '=============================================================
    
    bChkT015 = True
    bChkT018 = True
    
    If UBound(aMBGroup) > 0 Then
'        '*Tao 60-04-28 ของเดิม
        tSql = "SELECT FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo"
        tSql = tSql & vbCrLf & ",CASE WHEN FTTdmCode = 'T015' THEN '' ELSE FTSrcRmk END AS FTSrcRmk"
        tSql = tSql & vbCrLf & ",MIN(FNSrcSeqNo) AS FNSrcSeqNo,SUM(FCSrcNet) AS FCSrcNet FROM " & tVB_CNTblRC
        tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & "GROUP BY FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo,FTSrcRmk"
        tSql = tSql & vbCrLf & "ORDER BY FNSrcSeqNo"
        
'        '*Tao 60-05-04 ไม่ต้องรวม FTTdmCode ให้แยกทีละ FNSrcSeqNo
'        tSql = "SELECT FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo"
'        tSql = tSql & vbCrLf & ",CASE WHEN FTTdmCode = 'T015' THEN '' ELSE FTSrcRmk END AS FTSrcRmk"
'        tSql = tSql & vbCrLf & ",FNSrcSeqNo,FCSrcNet FROM " & tVB_CNTblRC
'        tSql = tSql & vbCrLf & "WHERE FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
'        tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
'        tSql = tSql & vbCrLf & "ORDER BY FNSrcSeqNo"
'        '==================================================
        
'        '*Tao 60-06-06 ให้คำนวน Point จาก Credit Card ก่อน
'        tSql = "SELECT FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo"
'        tSql = tSql & vbCrLf & ",CASE WHEN FTTdmCode = 'T015' THEN '' ELSE FTSrcRmk END AS FTSrcRmk"
'        tSql = tSql & vbCrLf & ",MIN(FNSrcSeqNo) AS FNSrcSeqNo,SUM(FCSrcNet) AS FCSrcNet ,0 AS FNRowNo FROM " & tVB_CNTblRC
'        tSql = tSql & vbCrLf & "WHERE FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
'        tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
'        tSql = tSql & vbCrLf & "AND FTTdmCode = 'T002'"
'        tSql = tSql & vbCrLf & "GROUP BY FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo,FTSrcRmk"
'        tSql = tSql & vbCrLf & "UNION"
'        tSql = tSql & vbCrLf & "SELECT FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo"
'        tSql = tSql & vbCrLf & ",CASE WHEN FTTdmCode = 'T015' THEN '' ELSE FTSrcRmk END AS FTSrcRmk"
'        tSql = tSql & vbCrLf & ",MAX(FNSrcSeqNo) AS FNSrcSeqNo,SUM(FCSrcNet) AS FCSrcNet,ROW_NUMBER() OVER(ORDER BY MIN(FNSrcSeqNo)) AS FNRowNo FROM " & tVB_CNTblRC
'        tSql = tSql & vbCrLf & "WHERE FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
'        tSql = tSql & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
'        tSql = tSql & vbCrLf & "AND FTTdmCode <> 'T002'"
'        tSql = tSql & vbCrLf & "GROUP BY FTTdmCode,FTSrcRetDocRef,FTSrcCardExp,FTSrcCardNo,FTSrcRmk"
'        tSql = tSql & vbCrLf & "ORDER BY FNRowNo,FNSrcSeqNo"
        
        Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                tTdmCode = SP_FEDtChkString(orsTemp, "FTTdmCode")
                nSeqNo = SP_FEDvChkNumeric(orsTemp, "FNSrcSeqNo")
                tSrcRetDocRef = SP_FEDtChkString(orsTemp, "FTSrcRetDocRef")
                'tTmpCardNo = ""
                Select Case UCase(tTdmCode)
                    Case UCase("T015")
                        If bChkT015 Then
                            tWhere = "WHERE FTTmnNum ='" & tVB_CNTerminalNum & "' AND FTShdTransNo ='" & tVB_Running & "'"
                            tWhere = tWhere & vbCrLf & "AND FTShdTransType ='" & tVB_Transaction & "' AND FDShdTransDate ='" & tUT_SaleDate & "'"
                            tWhere = tWhere & vbCrLf & "AND FTTdmCode = 'T015'"
                            cSrcAmt = SP_VALcText2Double(SP_SQLtFunction("SUM", "FCSrcNet", tVB_CNTblRC, tWhere))
