Public Sub SP_FILxWriteDataBatch(ByVal ptBatchPath As String, ByVal ptData As String, Optional ByVal IsEncode As Boolean = False)
'----------------------------------------------------------
' Call
' Cmt :   Create File Batch
'----------------------------------------------------------

    Dim oFSO  As New FileSystemObject
    Dim nLof As Long
    Dim tFileName$
    Dim tFld$
    Dim oFile As File
    Dim nLine%
On Error GoTo ErrHandler
    nLine = 1
    tFileName = ptBatchPath
'        tFileName = Left(App.Path, InStrRev(App.Path, "\") - 1) + "\encdec\" & "Decrypt.bat"
'        If Not SP_FLEbManFile(tFileName, nEN_Fle1Exist) Then
'                tFileName = oFSO.GetParentFolderName(oFSO.GetParentFolderName(App.Path))
'                tFileName = tFileName & "\encdec\" & "Decrypt.bat"
'                If Not SP_FLEbManFile(tFileName, nEN_Fle1Exist) Then
'                     tFileName = Left(App.Path, InStrRev(App.Path, "\") - 1) & "\encdec\" & "Decrypt.bat"
'                End If
'        End If
        
        '*Thirapong 64-12-10 CommSheet TTK-ISS3000-794 TK-ISSUE - Error 5 from EDC Response.xlsx
        'tFld = oFSO.GetParentFolderName(tFileName)
        tFld = oFSO.GetParentFolderName(Chr(34) & tFileName & Chr(34))
        tFld = Replace(tFld, """", "")
        tFld = Chr(34) & tFld & Chr(34)
        '=================================================================================
        
        If Not SP_FLDbManFolder(tFld, nEN_Fld1Exist) Then
           Call SP_FLDbManFolder(tFld, nEN_Fld3Create)
        End If
        nLine = 2
        oFSO.DeleteFile (tFileName)
        nLine = 3
        If Not SP_FLEbManFile(tFileName, nEN_Fle1Exist) Then
            oFSO.CreateTextFile (tFileName)
            Set oFile = oFSO.GetFile(tFileName)
            oFile.Attributes = Normal
        Else
            nLine = 4
            Set oFile = oFSO.GetFile(tFileName)
            oFile.Attributes = Normal
        End If
        nLine = 5
        If InStr(1, ptData, "#") > 0 Then ptData = Trim(Right(ptData, Len(ptData) - 1))

        Set oVB_LogFile = oFile.OpenAsTextStream(ForAppending)
        oVB_LogFile.WriteLine IIf(UCase(Left(tFld, 1)) = "D", "cd d:", "")
        oVB_LogFile.WriteLine "cd " & tFld
        oVB_LogFile.WriteLine "java Encdec -" & IIf(IsEncode, "e", "d") & " " & ptData & " > Decrypt.txt"
        oVB_LogFile.WriteLine "exit"
        oVB_LogFile.Close
        Set oFSO = Nothing
        nLine = 6
        
        Exit Sub '- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
ErrHandler:
        Call SP_CRTxLogMallCardEvent("Credit", "SP_FILxWriteDataBatch", "nLine=", nLine)   '*Thirapong 64-12-10    Log monitor CommSheet TTK-ISS3000-794 TK-ISSUE - Error 5 from EDC Response
        Set oFSO = Nothing
End Sub




Public Function SP_EDCxCheckTag(ByRef paTag() As String, ByVal pnCount As Integer, ByVal ptTag As String) As String
'----------------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao 2013/01/29
'----------------------------------------------------------------------------
Dim nLoop  As Integer
Dim tTag As String
On Error GoTo ErrorHandles
    tTag = ""
    For nLoop = 0 To pnCount
        If Trim(paTag(0, nLoop)) = Trim(ptTag) Then
            tTag = Trim(paTag(1, nLoop))
            If Trim(ptTag) = "98" Then tTag = Replace(tTag, "/", "") '*Tao 62-07-31 Holder Name มี "/" นำหน้า ต้องตัดออกด้วย
            Exit For
        End If
    Next nLoop
    'SP_EDCxCheckTag = tTag '*Tao 62-12-10 ของเดิม
    SP_EDCxCheckTag = Trim(tTag) '*Tao 62-12-10 เพิ่ม Trim
    Exit Function
ErrorHandles:
    SP_EDCxCheckTag = ""
End Function

