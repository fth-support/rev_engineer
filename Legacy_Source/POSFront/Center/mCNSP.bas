        tSql = "SELECT  FTShdTransType,FDShdTransDate,FTShdPOSCN  FROM " & tVB_CNTblHD  '*BG 56-10-31
        tSql = tSql & vbCrLf & "  WHERE FDShdTransDate ='" & tUT_SaleDate & "'"
