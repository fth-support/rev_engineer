                            cSrcAmt = cRefSrcAmt - cNormalBPAmt
                            cNormalBPAmt = 0
                            bLowBP = True
                            cRegAmt = cLowBPAmt
                            If cSrcAmt > 0 Then GoTo CalLowBP
