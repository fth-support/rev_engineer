Public Function SP_CHKbHDDFreeSpace() As Boolean
'----------------------------------------------------------------------------
'   Call:
'   Cmt: '*Bump 56-03-01 ตรวจสอบพื้นที่ HDD ว่าเหลือเท่าไหร่ก่อนเจ้งแตือน
'       ตรวจสอบพื้นที่ HDD ที่เก็บ Database ว่าเหลือเท่าใหร่
'       ถ้าเหลือน้อยกว่า ค่าที่กำหนดไว้ ให้ Return เป็น False
'       โดยที่ ค่าที่ตั้งไว้ คือ ถ้าพื้นที่ HHD เหลือ น้อยกว่า หรือเท่ากับ 20% ของพื้นที่ทั้งหมด จะแจ้งเตือนและไม่ให้เข้าไปทำรายการขาย
'       ค่า 20% นี้กำหนดใน Store Parameter แถวที่ 21
'   SELECT FTStpCode, FTStpDesc ,FTStpSelValue,FTStpStaAlw
'   FROM TCNMStorePara WHERE  FTStpCode = 21
'
'   ถ้า FTStpStaAlw = 'Y' คือ ให้เช็ค
'----------------------------------------------------------------------------
    Dim orsTmp As ADODB.Recordset
    Dim tSql As String
    Dim tDbName As String
    Dim tHDDDrive As String
    Dim lHDDFreeSize As Long
    Dim lHDDFreeSizeAllow As Long
    Dim lHDDTotalSize As Long
    Dim nPercentOfFreeSize As Long
    
    On Error GoTo Err_Handler
    
    If nVB_CNPerOffDiskSpace = 0 Then  'ถ้าเป็น 0 หมายถึงไม่ต้องเช็ค Free Space '*Eaw 56-05-08 CommSheet TK-ISS3000-187-ST 00 00 01.xls
        SP_CHKbHDDFreeSpace = True
        Exit Function
    End If
    tSql = "SELECT TOP 1 FTTmnOffDBName "
    tSql = tSql & " FROM TCNMTerminalMtn WHERE FTTMNNum = '" & tVB_CNPhysicalTerminalNum & "'" '*Bump 56-09-20  เปลี่ยนจาก tVB_CNTerminalNum  เป็น tVB_CNPhysicalTerminalNum   เพื่อให้ Tenant Sale ที่เป็น virtual POS เช็คได้ถูกต้อง Comsheet No.327
    If SP_SQLvExecute(tSql, orsTmp, oDB.ocnOffLine) <> 0 Then
        SP_CHKbHDDFreeSpace = True
        Exit Function
    End If
    
    If Not (orsTmp.BOF And orsTmp.EOF) Then orsTmp.MoveFirst
    tDbName = SP_FEDtChkString(orsTmp, "FTTmnOffDBName")
    
    tSql = "SELECT TOP 1 name as FTDBName ,filename as FTPath,LEFT(filename,1) as FTDrive"
    tSql = tSql & "  FROM  master.dbo.sysdatabases"
    tSql = tSql & "  WHERE name = '" & tDbName & "'"
    
    If SP_SQLvExecute(tSql, orsTmp, oDB.ocnOffLine) <> 0 Then
        SP_CHKbHDDFreeSpace = True
        Exit Function
    End If
    
    If Not (orsTmp.BOF And orsTmp.EOF) Then orsTmp.MoveFirst
    tHDDDrive = SP_FEDtChkString(orsTmp, "FTDrive")
    
    tSql = "EXEC  STP_SYSnEddrives  @ptHDDDrive= '" & tHDDDrive & "', @pnFreePercen = " & nVB_CNPerOffDiskSpace
    If SP_SQLvExecute(tSql, orsTmp) <> 0 Then
        SP_CHKbHDDFreeSpace = True
        Exit Function
    End If
    
    tSql = "SELECT FTDrive,FNFreeSize,FNTotalSize,FNFreeSizeAllow  FROM TDrFreeSpace"
    If SP_SQLvExecute(tSql, orsTmp) <> 0 Then
        SP_CHKbHDDFreeSpace = True
        Exit Function
    End If

    If Not (orsTmp.BOF And orsTmp.EOF) Then orsTmp.MoveFirst
    
    lHDDTotalSize = SP_FEDvChkNumeric(orsTmp, "FNTotalSize")
    lHDDFreeSize = SP_FEDvChkNumeric(orsTmp, "FNFreeSize")
    lHDDFreeSizeAllow = SP_FEDvChkNumeric(orsTmp, "FNFreeSizeAllow")
    'MsgBox lHDDTotalSize
    'MsgBox lHDDFreeSize
    'MsgBox lHDDFreeSizeAllow
    'พื้นที่ที่เหลือจริง น้อยกว่าหรือเท่ากับ พื้นที่เหลือที่อนุญาตให้มี จะต้องแสดงข้อความเตือน
'    If lHDDFreeSize <= lHDDFreeSizeAllow Then
    If lHDDFreeSizeAllow <= nVB_CNPerOffDiskSpace Then '*Bump เปลี่ยนวิธีคำนวณให้ถูกต้อง  โดยเปลี่ยนใน STP_SYSnEddrives
        SP_CHKbHDDFreeSpace = False
        Exit Function
    End If
    SP_CHKbHDDFreeSpace = True
    Call SP_DATxRsNothing(orsTmp)                   '*Ao 2013/08/27
    Exit Function
Err_Handler:
    
End Function

Public Sub SP_PRCxUpdateDiscountable()
'---------------------------------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao 2013/03/06
'---------------------------------------------------------------------------------------------
Dim tSql As String
Dim bChk  As Boolean
Dim orsTemp As ADODB.Recordset
Dim cSaleAmt As Double

On Error GoTo Err_Handler

    tSql = "SELECT FCShdWpTax FROM " & tVB_CNTblHD
    tSql = tSql & vbCrLf & "WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & "AND FCShdWpTax > 0"
    If SP_SQLvExecute(tSql, orsTemp) = 0 Then
        If (orsTemp.BOF And orsTemp.EOF) Then
            bChk = True
        Else
            bChk = False
        End If
    Else
        bChk = True
    End If

    If bChk Then
        tSql = "SELECT SUM(FCSdtSaleAmt) AS FCSdtSaleAmt FROM" & tVB_CNTblDT
        tSql = tSql & vbCrLf & "WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "'"
        tSql = tSql & vbCrLf & "AND FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate = '" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & "AND ISNULL(FTSkuStaMallEmpCard,'') = 'Y'"
        tSql = tSql & vbCrLf & "AND ISNULL(FTSdtCancelFlag,'0') = '0'"
        If SP_SQLvExecute(tSql, orsTemp) = 0 Then
            If (orsTemp.BOF And orsTemp.EOF) Then
                cSaleAmt = SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt")
            End If
        End If
        '**********************
        '*Bump 57-08-16(ใน Phase1 57-07-04 )
        Call SP_CHKInsHDRecovery(tVB_CNTblHD, tVB_CNTerminalNum, tVB_Running, tUT_SaleDate, tVB_Transaction)
        '**********************
        tSql = "UPDATE " & tVB_CNTblHD
        tSql = tSql & vbCrLf & "SET FCShdWpTax = " & cSaleAmt
        tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
        Call SP_SQLbExecute(tSql)
    End If
    Exit Sub
Err_Handler:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

