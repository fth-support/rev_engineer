    If bPass2 Then
        ocnAll.RollbackTrans
        bPass2 = False
        nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[23]", "Update Not Success", tVB_MemPointID)
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTemp2)
    Call SP_DATxRsNothing(orsTemp3)
'    Call SP_DATxRsNothing(orsTemp4)
    Call SP_DATxRsNothing(orsCoo)
    Call SP_DATxRsNothing(orsMall)
'    Call SP_DATxRsNothing(orsTender)
'    Call SP_DATxRsNothing(orsCrd)
'    Call SP_DATxRsNothing(orsProRate)

    '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
    If bReMemberPoint Then
        Call SP_PRCxReMemberPointOth(pnRound)
    End If
End Sub

Public Sub SP_PRCxReMemberPoint(Optional ByRef pnRound As Long = 2)
'------------------------------------------------------
'Call:
'Cmt: *KT 52-03-03 Member Point ทำการคำนวณแต้มใหม่หลังมีการเปลี่ยนแปลงส่วนลดลง(Special Gift Voucher,Special Coupon)
'          *KT 52-10-27 PH2-ML-SF-132 Extra Point ของ Card ถ้าไม่ Allow  [ADD] จะไม่คำนวน Extra Point ให้ (บัตรนั้นไม่ได้ Allow Dept/SKU)
'------------------------------------------------------
    Dim tSql$
    Dim cLastPoint As Double
    Dim tMemberName As String
    Dim orsMall As ADODB.Recordset
    Dim orsTemp As ADODB.Recordset
    Dim orsTemp2 As ADODB.Recordset
    Dim orsTemp3 As ADODB.Recordset
    Dim orsTemp4 As ADODB.Recordset
    Dim orsCoo As ADODB.Recordset
    Dim orsTender As ADODB.Recordset
    Dim orsCrd As ADODB.Recordset
    Dim orsProRate As ADODB.Recordset
    
    Dim cPoint As Double
    Dim cPointAmt As Double
    Dim bPass As Boolean
    Dim tPointSpecial As String
    Dim tPointAdd As String
    Dim cPointSku As Double
    Dim cPointAmtSku As Double
    Dim cPointDpt As Double
    Dim cPointAmtDpt  As Double
    Dim cPointGen As Double
    Dim cPointAmtGen As Double
    Dim bMissRec As Boolean
    Dim cSubTotal As Double
    Dim tMallCardKey As String
    Dim tCrdCardKey As String
    Dim cCrdAmt As Double
    Dim tTenderCode As String
    Dim nEff As Long
    Dim tCardNo As String
    Dim nPointCrd As Long
    Dim bPass2 As Boolean
    Dim cSecTemp As Double
    Dim cCooTemp As Double
    Dim cSKUTemp As Double
    Dim cTenderAmtAlw As Double
    Dim bReMemberPoint As Boolean
    Dim tMemEvnCode As String '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
    Dim tCrdEvnCode As String '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
    
    Dim bIsMemCard As Boolean  '*Eaw 55-12-13
    Dim cLPoint As Double        '*Eaw 56-02-07
    Dim tCstName As String      '*Eaw 56-02-07
On Error GoTo ErrHandle

   '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
    If pnRound = 0 Then
        Call SP_DATxRsNothing(orsTemp)
        Call SP_DATxRsNothing(orsTemp2)
        Call SP_DATxRsNothing(orsTemp3)
        Call SP_DATxRsNothing(orsTemp4)
        Call SP_DATxRsNothing(orsCoo)
        Call SP_DATxRsNothing(orsMall)
        Call SP_DATxRsNothing(orsTender)
        Call SP_DATxRsNothing(orsCrd)
        Call SP_DATxRsNothing(orsProRate)
        bReMemberPoint = False
        Exit Sub
    End If
    pnRound = pnRound - 1
    bReMemberPoint = True
    bIsMemCard = False  '*Eaw 55-12-13
    bPass2 = False
    '*KT 52-07-27 ป้องกันกรณีที่ tVB_MemPointID = "" แต่ว่าในฐานข้อมุลมีการเก็บค่าไว้แล้ว
    If Trim(tVB_MemPointID) = "" Then
        tSql = "SELECT FTCstCardCode FROM " & tVB_CNTblHD
        tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
        tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
        Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
             tVB_MemPointID = SP_FEDtChkString(orsTemp, "FTCstCardCode")
        End If
        If tVB_MemPointID = "" Then '*Eaw 55-12-13
'            tVB_MemPointID = tVB_CrdCardNo         '* Ao 2013/02/02
            tVB_MemPointID = SP_CHKtCheckCrdCardMEM     '* Ao 2013/02/02 หา Credit Card Mem
            bIsMemCard = True  '*Eaw 55-12-13
        End If
        Call SP_DATxRsClose(orsTemp)
    End If
    
    Select Case Val(Format(tVB_TransactionSub))
        Case tEN_TrnDeposit
            cSubTotal = (cVB_Total - cVB_TotalDiscAft)
        Case Else
            cSubTotal = cVB_NetSale
    End Select
    
    If tVB_MemPointID <> "" Then
        tSql = "STP_PRCxFindMallCardByID @ptAccNum= '" & tVB_MemPointID & "'"
        Call SP_SQLvExecute(tSql, orsMall, oDB.ocnOnLine, , , , , True, True) 'read master
        If Not (orsMall.BOF And orsMall.EOF) Then
        
            tVB_StaMemPointAlw = SP_FEDtChkString(orsMall, "FTMcdAlwPointAll")
            tPointSpecial = SP_FEDtChkString(orsMall, "FTMcdAlwPoint")
            tPointAdd = SP_FEDtChkString(orsMall, "FTMcdStaAddSku") 'Test 19
            tMallCardKey = SP_FEDtChkString(orsMall, "FTMcdCode") '
            tMemEvnCode = SP_FEDtChkString(orsMall, "FTEvnCode") '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
'            bIsMemCard = True  '*Eaw 55-12-13
            '*KT 52-02-24 member point process คำนวณ point
            '---------------------------------------------------------------------------------------------
            'All
            cPoint = 0
            cPointAmt = 0
            'Mall Card
            cPointSku = 0
            cPointAmtSku = 0
            cPointDpt = 0
            cPointAmtDpt = 0
            cPointGen = 0
            cPointAmtGen = 0

            If tVB_StaMemPointAlw = "Y" Then
                tSql = "SELECT *  FROM " & tVB_CNTblDT
                tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
                tSql = tSql & vbCrLf & "  AND SUBSTRING(ISNULL(FTSdtStaPdt,''),21,1) = '1'" '*KT 55-08-15 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
                Call SP_SQLvExecute(tSql, orsTemp)
                If orsTemp Is Nothing Then
                    Set orsTemp = New ADODB.Recordset
                End If
                If orsTemp.State = adStateOpen Then orsTemp.Close
                orsTemp.Open tSql, ocnAll, adOpenKeyset, adLockPessimistic
            ElseIf SP_FEDtChkString(orsMall, "FTMcdAlwPoint") = "Y" Then
                tSql = "SELECT *  FROM " & tVB_CNTblDT
                tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
                tSql = tSql & vbCrLf & "  AND SUBSTRING(ISNULL(FTSdtStaPdt,''),21,1) = '1'" '*KT 55-08-15 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
                Call SP_SQLvExecute(tSql, orsTemp)
                If orsTemp Is Nothing Then
                    Set orsTemp = New ADODB.Recordset
                End If
                If orsTemp.State = adStateOpen Then orsTemp.Close
                orsTemp.Open tSql, ocnAll, adOpenKeyset, adLockPessimistic
            End If
            
            'Allow Member Point from Mall Card Maintenance
            If tVB_StaMemPointAlw = "Y" Then
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[1]", "Section/Cooperate/SKU", tVB_MemPointID)
                
                'ใช้สำหรับการเก็บข้อมูลนำไปคิดแต้มตาม SKU CODE ทั้ง Amount/Time
                ReDim aW_PointSKUTime(0) As POINTSEQ
                aW_PointSKUTime(0).nSeqNo = 0
                aW_PointSKUTime(0).cPoint = 0
                aW_PointSKUTime(0).cRank = 0
                aW_PointSKUTime(0).cAmt = 0
                aW_PointSKUTime(0).cMin = 0
                aW_PointSKUTime(0).cMax = 0
                aW_PointSKUTime(0).tType = "0"
                aW_PointSKUTime(0).dST = CDate("1900/01/01")
                aW_PointSKUTime(0).dED = CDate("1900/01/01")
                aW_PointSKUTime(0).tStaAct = "N"
                
                'การคิดแต้มกรณีที่มี MissRec อ้างจากเอกสาร External Spec
                '- ถ้า Cooperate Active อย่างเดียว ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Cooperate / General
                '- ถ้า Secsion Active อย่างเดียว ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Secsion / General (***หมายเหตุบวกเพิ่มที่ Secsion แรก)
                '- ถ้า Cooperate Active และ Secsion Active ให้ MissRec บวกเพิ่มเพื่อคิดแต้มในส่วนของ Cooperate / General เท่านั้น
                'tSql = "SELECT  FTMcmStaCoo,FNMcmPoint,FCMcmAmt"
                tSql = "SELECT  * "
                tSql = tSql & vbCrLf & " FROM TCNMMemberCooMtn"
                'tSql = tSql & vbCrLf & " WHERE ISNULL(FTMcmStaCoo,'N') = 'Y'"
                If SP_SQLvExecute(tSql, orsCoo, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                    If (orsCoo.BOF And orsCoo.EOF) Then
                        bMissRec = True
                    Else
                        If UCase(SP_FEDtChkString(orsCoo, "FTMcmStaCoo")) = "Y" Then
                             bMissRec = False
                        Else
                            bMissRec = True
                        End If
                    End If
                Else
                    bMissRec = True
                End If
                orsMall.Filter = adFilterNone
                Set orsTemp2 = orsTemp.Clone
                'Allow Member Point from Sesion
                Call SP_PRCbVerifyPointSec(orsTemp2, orsTemp3, cPoint, cPointAmt, cUT_SubReg, cUT_SubPro, cSubTotal, bMissRec)
                Set orsTemp2 = orsTemp3.Clone
                cSecTemp = cPoint
                If cSecTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[2]", "Section = " & cSecTemp, tVB_MemPointID)
                'Allow Member Point from Cooperate
                Call SP_PRCbVerifyPointCoo(orsTemp2, orsTemp3, cPoint, cPointAmt, cUT_SubReg, cUT_SubPro, cSubTotal, Not bMissRec, orsCoo)
                cCooTemp = cPoint - cSecTemp
                If cCooTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[3]", "Cooperate = " & cCooTemp, tVB_MemPointID)
                'cCooTemp Member Point from SKU Allow
                Call SP_PRCbVerifyPointBySkuAlw(orsTemp, orsCoo, cPoint, cPointAmt)
                cSKUTemp = cPoint - (cSecTemp + cCooTemp)
                If cSKUTemp > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[4]", "SKU Point = " & cSKUTemp, tVB_MemPointID)
            End If
            If bIsMemCard Then   '*Eaw  55-12-13           '*Ao 2013/02/02
                Call SP_GETnMemLPoint(cLPoint, tCstName)
                tSql = "UPDATE " & tVB_CNTblHD
                tSql = tSql & " SET FTCstCardCode =  '" & tVB_MemPointID & "'" '*Eaw  56-01-14"
                tSql = tSql & vbCrLf & " ,FNCstCardLPoint = " & cLPoint    '*Eaw 56-02-07
                tSql = tSql & vbCrLf & " ,FTCstPointName = '" & tCstName & "'"      '*Eaw 56-02-07
                tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
                Call SP_SQLvExecute(tSql)
            End If
            'Addition Point from Mall Card Maintenance
            If tVB_StaMemPointAlw = "Y" And tPointSpecial = "Y" Then
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[5]", "Mall Card", tVB_MemPointID)
                bPass = True
                If SP_FEDtChkString(orsMall, "FTMcdStaDeptCodePoint") = "Y" Then 'Addition Point  Dpt Code/Sku Code
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[6]", "Mall Card Allow by SKU/Dept", tVB_MemPointID)
                     bPass = False
                     Set orsTemp2 = orsTemp.Clone
                     Call SP_PRCbVerifyPointSKU(tMallCardKey, orsTemp2, orsTemp3, orsTemp4, cPointSku, cPointAmtSku)
                     Set orsTemp2 = orsTemp3.Clone
                     If cPointSku > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[7]", "Mall Card Allow by SKU = " & cPointSku, tVB_MemPointID)
                     Call SP_PRCbVerifyPointDpt(tMallCardKey, orsTemp2, orsTemp3, orsTemp4, cPointDpt, cPointAmtDpt)
                     If cPointDpt > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[8]", "Mall Card Allow by Dept = " & cPointDpt, tVB_MemPointID)
                End If
                orsMall.Filter = "FDMcdStartDatePoint <= '" & Format(SP_GETdChkDatePoint, "YYYY/MM/DD") & "' AND FDMcdEndDatePoint >= '" & Format(SP_GETdChkDatePoint, "YYYY/MM/DD") & "'"  '*KT 52-06-04 ตรวจสอบวันที่หมดอายุของ point ตามที่กำหนดใน parameter
                If Not (orsMall.BOF And orsMall.EOF) Then
                   If UCase(tPointAdd) = "Y" Then 'Add เงื่อนไขถ้า Tik ให้เอา Point ที่เป็น Allow ของ SKU และ Dpt มาบวกกันกับ Point ที่คิดจาก General(Tier) ถ้าไม่ Tik ให้เอา Point  General(Tier) เท่านั้น
                        If bPass Then
                            Set orsTemp2 = orsTemp.Clone
                        Else
                            Set orsTemp2 = orsTemp4.Clone
                        End If
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[9]", "Mall Card General Tier", tVB_MemPointID)
                        Call SP_PRCbVerifyPointMall(orsMall, orsTemp2, cPointGen, cPointAmtGen, cUT_SubReg, cUT_SubPro, cSubTotal) 'Addition Point  Mall Card General
                        If cPointGen > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[10]", "Mall Card General Tier = " & cPointGen, tVB_MemPointID)
                    ElseIf UCase(tPointAdd) = "N" And SP_FEDtChkString(orsMall, "FTMcdStaDeptCodePoint") = "N" Then
                        Set orsTemp2 = orsTemp.Clone
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[11]", "Mall Card General Tier", tVB_MemPointID)
                        Call SP_PRCbVerifyPointMall(orsMall, orsTemp2, cPointGen, cPointAmtGen, cUT_SubReg, cUT_SubPro, cSubTotal) 'Addition Point  Mall Card General
                        If cPointGen > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[12]", "Mall Card General Tier = " & cPointGen, tVB_MemPointID)
                    End If
                End If
                If UCase(tPointAdd) = "Y" Then 'Add เงื่อนไขถ้า Tik ให้เอา Point ที่เป็น Allow ของ SKU และ Dpt มาบวกกันกับ Point ที่คิดจาก General ถ้าไม่ Tik ให้เอา Point ที่คิดจาก ของ SKU และ Dpt  เท่านั้น
                    cPoint = cPoint + cPointSku + cPointDpt + cPointGen
                    cPointAmt = cPointAmt + cPointAmtSku + cPointAmtDpt + cPointAmtGen
                    '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                    If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type6MemPoint, (cPointSku + cPointDpt + cPointGen), (cPointAmtSku + cPointAmtDpt + cPointAmtGen), "", tMemEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type6MemPoint & ",Member Card Point" & ",Point =" & (cPointSku + cPointDpt + cPointGen), tVB_MemPointID)
                    End If
                ElseIf UCase(tPointAdd) = "N" And SP_FEDtChkString(orsMall, "FTMcdStaDeptCodePoint") = "N" Then
                    cPoint = cPoint + cPointSku + cPointDpt + cPointGen
                    cPointAmt = cPointAmt + cPointAmtSku + cPointAmtDpt + cPointAmtGen
                    '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                    If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type6MemPoint, (cPointSku + cPointDpt + cPointGen), (cPointAmtSku + cPointAmtDpt + cPointAmtGen), "", tMemEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type6MemPoint & ",Member Card Point" & ",Point =" & (cPointSku + cPointDpt + cPointGen), tVB_MemPointID)
                    End If
                Else
                    cPoint = cPoint + cPointSku + cPointDpt
                    cPointAmt = cPointAmt + cPointAmtSku + cPointAmtDpt
                    '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                    If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type6MemPoint, (cPointSku + cPointDpt), (cPointAmtSku + cPointAmtDpt), "", tMemEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type6MemPoint & ",Member Card Point" & ",Point =" & (cPointSku + cPointDpt), tVB_MemPointID)
                    End If
                End If
            End If
            
            'Extra Point Credit Card
            'บัตรสมาชิกอนุญาตให้แต้มได้
            bPass2 = False
            If tVB_StaMemPointAlw = "Y" Then
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[11]", "Credit Card", tVB_MemPointID)
                 'อ่านค่าการรับชำระด้วย Credit Card Tender แบบ Group by Credit Card ID
                tSql = "SELECT  SUM(RC.FCSrcNet) AS FCSrcNet,RC.FTTmnNum, RC.FTShdTransNo, RC.FTShdTransType, RC.FDShdTransDate,"
                tSql = tSql & vbCrLf & "RC.FTSrcCardNo,RC.FTTdmCode,RC.FTSrcRetDocRef"
                tSql = tSql & vbCrLf & "FROM " & tVB_CNTblRC & " RC"
                tSql = tSql & vbCrLf & " WHERE RC.FTTmnNum = '" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND RC.FTShdTransNo = '" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND RC.FTShdTransType = '" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND RC.FDShdTransDate = '" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & " AND RC.FTTdmCode IN ('T002','T003','T015','T017')"    '*Eaw 56-01-04 การคิดแต้ม Extra Point NETS
'                 tSql = tSql & vbCrLf & " AND RC.FTTdmCode IN ('T002','T003')"
                tSql = tSql & vbCrLf & "GROUP BY RC.FTTmnNum, RC.FTShdTransNo, RC.FTShdTransType, RC.FDShdTransDate,"
                tSql = tSql & vbCrLf & "RC.FTSrcCardNo,RC.FTTdmCode,RC.FTSrcRetDocRef"
                tSql = tSql & vbCrLf & "ORDER BY RC.FTSrcRetDocRef"
                If SP_SQLvExecute(tSql, orsTender) = 0 Then
                    ocnAll.BeginTrans
                    bPass2 = True
                    nVB_CNCountBegin = nVB_CNCountBegin + 1
                    Do While Not orsTender.EOF
                        tSql = "SELECT TOP 1 TC.FTTdmCode, TC.FTCdcCreditType, TC.FTCdcDescCredit, TC.FTCdcDescRe,"
                        tSql = tSql & vbCrLf & "TC.FNCdcDigits, TC.FNCdcDigitChk, TC.FNCdcOntopRate, TC.FTCdcMallCard,"
                        tSql = tSql & vbCrLf & "TC.FTCdcOnTop, TC.FTCdcDepCode, TC.FCCdcAmtMax, TC.FCCdcAmtMin,"
                        tSql = tSql & vbCrLf & "TC.FDCdcStartDate, TC.FDCdcEndDate, TC.FTCdcReg, TC.FTCdcPro,"
                        tSql = tSql & vbCrLf & "TC.FTCdcAlwPoint, TC.FCCdcAmtRank, TC.FCCdcAmtPoint,"
                        tSql = tSql & vbCrLf & "TC.FCCdcAmtMinPoint, TC.FCCdcAmtMaxPoint, TC.FDCdcStartDatePoint,"
                        tSql = tSql & vbCrLf & "TC.FDCdcEndDatePoint, TC.FTCdcRegPoint, TC.FTCdcPromoPoint,"
                        tSql = tSql & vbCrLf & "TC.FTCdcStaSubAllPoint, TC.FTCdcStaAdd, TC.FTCdcStaDeptCodePoint,"
                        tSql = tSql & vbCrLf & "TC.FTCdcStaTierPoint, TC.FTCdcStaTimePoint, TC.FTCdcStaSubAll,"
                        tSql = tSql & vbCrLf & "TC.FTCdcStaTier , TC.FTCdcStaTime,"
                        tSql = tSql & vbCrLf & "TC.FTEvnCode" '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                        tSql = tSql & vbCrLf & "FROM   TCNMCreditCard TC "
                        '*Eaw 56-01-04 การคิดแต้ม Extra Point NETS
                        If SP_FEDtChkString(orsTender, "FTTdmCode") = "T015" Then
                            tSql = tSql & vbCrLf & " WHERE TC.FTTdmCode = '" & SP_FEDtChkString(orsTender, "FTTdmCode") & "'"
                            tSql = tSql & vbCrLf & " AND TC.FTCdcAlwPoint = 'Y'"
                        Else
                            tSql = tSql & vbCrLf & "WHERE  FTCdcCreditType = '" & SP_FEDtChkString(orsTender, "FTSrcRetDocRef") & "'"
                            tSql = tSql & vbCrLf & " AND TC.FTTdmCode = '" & SP_FEDtChkString(orsTender, "FTTdmCode") & "'"
                            tSql = tSql & vbCrLf & " AND TC.FTCdcAlwPoint = 'Y'"
                        End If
                        '------------------------------------------------------------------------------------
'                        tSql = tSql & vbCrLf & "WHERE  FTCdcCreditType = '" & SP_FEDtChkString(orsTender, "FTSrcRetDocRef") & "'"
'                        tSql = tSql & vbCrLf & " AND TC.FTTdmCode = '" & SP_FEDtChkString(orsTender, "FTTdmCode") & "'"
'                        tSql = tSql & vbCrLf & " AND TC.FTCdcAlwPoint = 'Y'"
                        tSql = tSql & vbCrLf & "GROUP BY TC.FTTdmCode, TC.FTCdcCreditType, TC.FTCdcDescCredit, TC.FTCdcDescRe,"
                        tSql = tSql & vbCrLf & "TC.FNCdcDigits, TC.FNCdcDigitChk, TC.FNCdcOntopRate, TC.FTCdcMallCard,"
                        tSql = tSql & vbCrLf & "TC.FTCdcOnTop, TC.FTCdcDepCode, TC.FCCdcAmtMax, TC.FCCdcAmtMin,"
                        tSql = tSql & vbCrLf & "TC.FDCdcStartDate, TC.FDCdcEndDate, TC.FTCdcReg, TC.FTCdcPro,"
                        tSql = tSql & vbCrLf & "TC.FTCdcAlwPoint, TC.FCCdcAmtRank, TC.FCCdcAmtPoint,"
                        tSql = tSql & vbCrLf & "TC.FCCdcAmtMinPoint, TC.FCCdcAmtMaxPoint, TC.FDCdcStartDatePoint,"
                        tSql = tSql & vbCrLf & "TC.FDCdcEndDatePoint, TC.FTCdcRegPoint, TC.FTCdcPromoPoint,"
                        tSql = tSql & vbCrLf & "TC.FTCdcStaSubAllPoint, TC.FTCdcStaAdd, TC.FTCdcStaDeptCodePoint,"
                        tSql = tSql & vbCrLf & "TC.FTCdcStaTierPoint, TC.FTCdcStaTimePoint, TC.FTCdcStaSubAll,"
                        tSql = tSql & vbCrLf & "TC.FTCdcStaTier , TC.FTCdcStaTime,"
                        tSql = tSql & vbCrLf & "TC.FTEvnCode"
                        tSql = tSql & vbCrLf & "ORDER BY TC.FTCdcCreditType"
                        If SP_SQLvExecute(tSql, orsCrd, oDB.ocnOnLine, , , , , True, True) = 0 Then
                            If Not (orsCrd.BOF And orsCrd.EOF) Then
                                'ทำการตรวจสอบว่าอนุญาตให้ Extra Point หรือไม่
                                 If SP_FEDtChkString(orsCrd, "FTCdcAlwPoint") = "Y" Then
                                        cPointSku = 0: cPointDpt = 0: cPointGen = 0
                                        cPointAmtSku = 0: cPointAmtDpt = 0: cPointAmtGen = 0
                                        tPointAdd = SP_FEDtChkString(orsCrd, "FTCdcStaAdd")
                                        tCrdCardKey = SP_FEDtChkString(orsCrd, "FTCdcCreditType")
                                        cCrdAmt = SP_FEDvChkNumeric(orsTender, "FCSrcNet")
                                        tTenderCode = SP_FEDtChkString(orsTender, "FTTdmCode")
                                        tCardNo = SP_FEDtChkString(orsTender, "FTSrcCardNo")
                                        tCrdEvnCode = SP_FEDtChkString(orsCrd, "FTEvnCode") '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                                        'Pro Rate ด้วยยอดเงินที่จ่ายด้วยบัตรเครดิตแต่ละใบ
                                        Set orsProRate = orsTemp.Clone
                                        Call SP_PRCxProrateSaleAmt(orsProRate, cCrdAmt)
                                        'Clear Recordset ที่เป็น Temp ทั้งหมด
                                        Call SP_DATxRsClose(orsTemp2)
                                        Call SP_DATxRsClose(orsTemp3)
                                        Call SP_DATxRsClose(orsTemp4)
                                        bPass = True
                                        'Addition Point  Dpt Code/Sku Code
                                        If SP_FEDtChkString(orsCrd, "FTCdcStaDeptCodePoint") = "Y" Then
                                            Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[12]", "Credit Card Allow SKU/Dept[" & tCardNo & "]", tVB_MemPointID)
                                             bPass = False
                                             Set orsTemp2 = orsProRate.Clone
                                             'Process Pont By SKU ทำการคิดแต้มส่วนของ Allow SKU และ Not Allow SKU
                                             Call SP_PRCbVerifyPointCrdBySKU(tCrdCardKey, tTenderCode, orsTemp2, orsTemp3, orsTemp4, cPointSku, cPointAmtSku)
                                             If cPointSku > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[13]", "Credit Card Allow SKU[" & tCardNo & "] = " & cPointSku, tVB_MemPointID)
                                             Set orsTemp2 = orsTemp3.Clone
                                             'Process Pont By Dept or Brand ทำการคิดแต้มส่วนของ Allow Dept.  และ Not Allow Dept.
                                             Call SP_PRCbVerifyPointCrdByDpt(tCrdCardKey, tTenderCode, orsTemp2, orsTemp3, orsTemp4, cPointDpt, cPointAmtDpt)
                                             If cPointSku > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[14]", "Credit Card Allow Dept[" & tCardNo & "] = " & cPointSku, tVB_MemPointID)
                                        End If
                                        'ตรวจสอบวันที่หมดอายุของ point ตามที่กำหนดใน Parameter
                                        If Format(SP_FEDdChkDate(orsCrd, "FDCdcStartDatePoint"), "YYYY/MM/DD") <= Format(SP_GETdChkDatePoint, "YYYY/MM/DD") And Format(SP_FEDdChkDate(orsCrd, "FDCdcEndDatePoint"), "YYYY/MM/DD") >= Format(SP_GETdChkDatePoint, "YYYY/MM/DD") Then
                                           'Add เงื่อนไขถ้า Tik ให้เอา Point ที่เป็น Allow ของ SKU และ Dpt มาบวกกันกับ Point ที่คิดจาก General(Tier) ถ้าไม่ Tik ให้เอา Point  General(Tier) เท่านั้น
                                           If UCase(tPointAdd) = "Y" Then
                                                If bPass Then
                                                    Set orsTemp2 = orsProRate.Clone
                                                Else
                                                    Set orsTemp2 = orsTemp4.Clone
                                                End If
                                                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[15]", "Credit Card General Tier : " & tCardNo & " = ", tVB_MemPointID)
                                                 'Process Pont By Tier Amount OR Tier Time
                                                Call SP_PRCbVerifyPointCrd(orsCrd, orsTemp2, cPointGen, cPointAmtGen, cUT_SubReg, cUT_SubPro, cSubTotal) 'Addition Point  Mall Card General
                                                If cPointGen > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[16]", "Credit Card General Tier[" & tCardNo & "] = " & cPointGen, tVB_MemPointID)
                                            ElseIf UCase(tPointAdd) = "N" And SP_FEDtChkString(orsCrd, "FTCdcStaDeptCodePoint") = "N" Then
                                                 Set orsTemp2 = orsProRate.Clone
                                                 Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[17]", "Credit Card General Tier : " & tCardNo & " = ", tVB_MemPointID)
                                                 'Process Pont By Tier Amount OR Tier Time
                                                Call SP_PRCbVerifyPointCrd(orsCrd, orsTemp2, cPointGen, cPointAmtGen, cUT_SubReg, cUT_SubPro, cSubTotal) 'Addition Point  Mall Card General
                                                If cPointGen > 0 Then Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[18]", "Credit Card General Tier[" & tCardNo & "] = " & cPointGen, tVB_MemPointID)
                                            End If
                                        End If
                                        'ทำการรวมแต้มที่จากแต่ละที
                                        'Add เงื่อนไขถ้า Tik ให้เอา Point ที่เป็น Allow ของ SKU และ Dpt มาบวกกันกับ Point ที่คิดจาก General ถ้าไม่ Tik ให้เอา Point ที่คิดจาก ของ SKU และ Dpt  เท่านั้น
                                        If UCase(tPointAdd) = "Y" Then
                                            cPoint = cPoint + cPointSku + cPointDpt + cPointGen
                                            cPointAmt = cPointAmt + cPointAmtSku + cPointAmtDpt + cPointAmtGen
                                            nPointCrd = CLng(cPointSku + cPointDpt + cPointGen)
                                            If nPointCrd > 0 Then
                                                If Not SP_PRCbSavePointToCrd(nPointCrd, tTenderCode, tCrdCardKey, tCardNo) Then
                                                    If bPass2 Then
                                                        ocnAll.RollbackTrans
                                                        bPass2 = False
                                                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                                                    End If
                                                    Call SP_DATxRsNothing(orsTemp)
                                                    Call SP_DATxRsNothing(orsTemp2)
                                                    Call SP_DATxRsNothing(orsTemp3)
                                                    Call SP_DATxRsNothing(orsTemp4)
                                                    Call SP_DATxRsNothing(orsCoo)
                                                    Call SP_DATxRsNothing(orsMall)
                                                    Call SP_DATxRsNothing(orsTender)
                                                    Call SP_DATxRsNothing(orsCrd)
                                                    Call SP_DATxRsNothing(orsProRate)
                                                    '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
                                                    If bReMemberPoint Then
                                                        Call SP_PRCxReMemberPoint(pnRound)
                                                    End If
                                                    Exit Sub
                                                End If
                                            End If
                                            '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                                            If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type7CrdPoint, (cPointSku + cPointDpt + cPointGen), (cPointAmtSku + cPointAmtDpt + cPointAmtGen), tCardNo, tCrdEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                                                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type7CrdPoint & ",Card No :" & tCardNo & ",Point =" & (cPointSku + cPointDpt + cPointGen), tVB_MemPointID)
                                            End If
                                        ElseIf UCase(tPointAdd) = "N" And SP_FEDtChkString(orsCrd, "FTCdcStaDeptCodePoint") = "N" Then
                                            cPoint = cPoint + cPointSku + cPointDpt + cPointGen
                                            cPointAmt = cPointAmt + cPointAmtSku + cPointAmtDpt + cPointAmtGen
                                            nPointCrd = CLng(cPointSku + cPointDpt + cPointGen)
                                            If nPointCrd > 0 Then
                                                If Not SP_PRCbSavePointToCrd(nPointCrd, tTenderCode, tCrdCardKey, tCardNo) Then
                                                    If bPass2 Then
                                                        ocnAll.RollbackTrans
                                                        bPass2 = False
                                                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                                                    End If
                                                    Call SP_DATxRsNothing(orsTemp)
                                                    Call SP_DATxRsNothing(orsTemp2)
                                                    Call SP_DATxRsNothing(orsTemp3)
                                                    Call SP_DATxRsNothing(orsTemp4)
                                                    Call SP_DATxRsNothing(orsCoo)
                                                    Call SP_DATxRsNothing(orsMall)
                                                    Call SP_DATxRsNothing(orsTender)
                                                    Call SP_DATxRsNothing(orsCrd)
                                                    Call SP_DATxRsNothing(orsProRate)
                                                    '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
                                                    If bReMemberPoint Then
                                                        Call SP_PRCxReMemberPoint(pnRound)
                                                    End If
                                                    Exit Sub
                                                End If
                                            End If
                                            '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                                            If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type7CrdPoint, (cPointSku + cPointDpt + cPointGen), (cPointAmtSku + cPointAmtDpt + cPointAmtGen), tCardNo, tCrdEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                                                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type7CrdPoint & ",Card No :" & tCardNo & ",Point =" & (cPointSku + cPointDpt + cPointGen), tVB_MemPointID)
                                            End If
                                        Else
                                            cPoint = cPoint + cPointSku + cPointDpt
                                            cPointAmt = cPointAmt + cPointAmtSku + cPointAmtDpt
                                            nPointCrd = CLng(cPointSku + cPointDpt)
                                            If nPointCrd > 0 Then
                                               If Not SP_PRCbSavePointToCrd(nPointCrd, tTenderCode, tCrdCardKey, tCardNo) Then
                                                    If bPass2 Then
                                                        ocnAll.RollbackTrans
                                                        bPass2 = False
                                                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                                                    End If
                                                    Call SP_DATxRsNothing(orsTemp)
                                                    Call SP_DATxRsNothing(orsTemp2)
                                                    Call SP_DATxRsNothing(orsTemp3)
                                                    Call SP_DATxRsNothing(orsTemp4)
                                                    Call SP_DATxRsNothing(orsCoo)
                                                    Call SP_DATxRsNothing(orsMall)
                                                    Call SP_DATxRsNothing(orsTender)
                                                    Call SP_DATxRsNothing(orsCrd)
                                                    Call SP_DATxRsNothing(orsProRate)
                                                    '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
                                                    If bReMemberPoint Then
                                                        Call SP_PRCxReMemberPoint(pnRound)
                                                    End If
                                                    Exit Sub
                                               End If
                                            End If
                                            '*KT 54-08-23 V.4.0.1 R4.0(Member Point) Req.1SKU Point with multiply by time
                                            If Not SP_PRCbSavSalePoint(eEN_PointType.nEN_Type7CrdPoint, (cPointSku + cPointDpt), (cPointAmtSku + cPointAmtDpt), tCardNo, tCrdEvnCode, tVB_MemPointID) Then '*KT 54-11-18 V.4.0.5  DCR_5411003 PRJ09010TheMall-R4-SE-External Spec.Upload Bonus Points-00.04.00-FSBT.doc
                                                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[Error]", "Type : " & eEN_PointType.nEN_Type7CrdPoint & ",Card No :" & tCardNo & ",Point =" & (cPointSku + cPointDpt), tVB_MemPointID)
                                            End If
                                        End If
                                 End If
                            End If
                         End If
                         orsTender.MoveNext
                    Loop
                End If
            End If
            Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[17]", "Total Point: = " & cPoint, tVB_MemPointID)
            '--------------------------------------------------------------------------------------------
            tSql = "UPDATE " & tVB_CNTblHD
            tSql = tSql & " SET FNCstCardPoint = " & CLng(cPoint)
            tSql = tSql & " ,FCCstCardAmt = " & cPointAmt
            tSql = tSql & "," & UT_tLastUpdSql
            tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
            tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
            If SP_SQLvExecute(tSql, , , , , nEff) = 0 Then
                If nEff > 0 Then
                    If bPass2 Then
                        ocnAll.CommitTrans
                        bPass2 = False
                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                    End If
                    bReMemberPoint = False
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[18]", "Update Success", tVB_MemPointID)
                Else
                    If bPass2 Then
                        ocnAll.RollbackTrans
                        bPass2 = False
                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                    End If
                    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[19]", "Update Not Success", tVB_MemPointID)
                End If
            Else
                If bPass2 Then
                    ocnAll.RollbackTrans
                    bPass2 = False
                    nVB_CNCountBegin = nVB_CNCountBegin - 1
                End If
                Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[20]", "Update Not Success", tVB_MemPointID)
            End If
        Else
            Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[21]", "No Process Point", tVB_MemPointID)
        End If
    Else
        Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[22]", "No Process Point", tVB_MemPointID)
    End If
    
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTemp2)
    Call SP_DATxRsNothing(orsTemp3)
    Call SP_DATxRsNothing(orsTemp4)
    Call SP_DATxRsNothing(orsCoo)
    Call SP_DATxRsNothing(orsMall)
    Call SP_DATxRsNothing(orsTender)
    Call SP_DATxRsNothing(orsCrd)
    Call SP_DATxRsNothing(orsProRate)
    Exit Sub
ErrHandle:
    If bPass2 Then
        ocnAll.RollbackTrans
        bPass2 = False
        nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    Call SP_CRTxLogMallCardEvent("MSR/Keyboard", "Member Point[23]", "Update Not Success", tVB_MemPointID)
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTemp2)
    Call SP_DATxRsNothing(orsTemp3)
    Call SP_DATxRsNothing(orsTemp4)
    Call SP_DATxRsNothing(orsCoo)
    Call SP_DATxRsNothing(orsMall)
    Call SP_DATxRsNothing(orsTender)
    Call SP_DATxRsNothing(orsCrd)
    Call SP_DATxRsNothing(orsProRate)
    '*KT 54-09-29 V.4.0.1 ML-PRV-069 ให้ Call SP_PRCxReMemberPoint ใหม่อีกครั้ง
    If bReMemberPoint Then
        Call SP_PRCxReMemberPoint(pnRound)
    End If
End Sub

Public Function SP_PRCbSavePointToCrd(ByVal pnPoint As Long, ByVal ptTenderCode As String, ByVal ptCardType As String, ByVal ptCardNo As String) As Boolean
'------------------------------------------------------
'Ret: กรณีที่บันทึกสำเร็จ = True บันทึกไม่สำเร็จ = False
'Cmt: ทำการเก็บแต้มที่ได้จากส่วน Credit Card ให้กับข้อมูล RC เพื่อทำการ Sale Export File
'------------------------------------------------------
    Dim tSql As String
    Dim nEff As Long
On Error GoTo ErrHandle
   tSql = "UPDATE " & tVB_CNTblRC
   tSql = tSql & vbCrLf & "SET FNSrcCrdPoint = " & pnPoint
   tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
   tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
   tSql = tSql & vbCrLf & " AND FTShdTransType = '" & tVB_Transaction & "'"
   tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
   tSql = tSql & vbCrLf & " AND FTTdmCode = '" & ptTenderCode & "'"
'   tSql = tSql & vbCrLf & " AND FTSrcRetDocRef = '" & ptCardType & "'"  '*Eaw 56-01-04 การคิด Extra Point NETS
    tSql = tSql & vbCrLf & " AND FTSrcAbb = '" & ptCardType & "'"
   tSql = tSql & vbCrLf & " AND FTSrcCardNo = '" & ptCardNo & "'"
   tSql = tSql & vbCrLf & " AND FNSrcSeqNo IN (SELECT TOP 1 FNSrcSeqNo FROM " & tVB_CNTblRC
   tSql = tSql & vbCrLf & "                                             WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
   tSql = tSql & vbCrLf & "                                              AND FTShdTransNo = '" & tVB_Running & "'"
   tSql = tSql & vbCrLf & "                                              AND FTShdTransType = '" & tVB_Transaction & "'"
   tSql = tSql & vbCrLf & "                                              AND FDShdTransDate = '" & tUT_SaleDate & "'"
   tSql = tSql & vbCrLf & "                                              AND FTTdmCode = '" & ptTenderCode & "'"
'    tSql = tSql & vbCrLf & "                                            AND FTSrcRetDocRef = '" & ptCardType & "'"  '*Eaw 56-01-04 การคิด Extra Point NETS
   tSql = tSql & vbCrLf & "                                              AND FTSrcAbb = '" & ptCardType & "'"
    tSql = tSql & vbCrLf & "                                              AND FTSrcCardNo = '" & ptCardNo & "'"
    tSql = tSql & vbCrLf & "                                              ORDER BY FNSrcSeqNo)"
    
   nEff = 0
   If SP_SQLvExecute(tSql, , , , , nEff) = 0 Then
        If nEff > 0 Then
            SP_PRCbSavePointToCrd = True
        Else
            SP_PRCbSavePointToCrd = False
        End If
   Else
        SP_PRCbSavePointToCrd = False
   End If
   Exit Function
ErrHandle:
    SP_PRCbSavePointToCrd = False
End Function

