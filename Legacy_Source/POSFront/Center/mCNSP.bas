Public Function SP_PRCtCheckPRT(ByVal ptTransType As String) As String
'--------------------------------------------------------------------
'
'   Cmt: '*Ao 2013/09/05
'--------------------------------------------------------------------
Dim nI As Integer, nIndex As Integer
Dim tTypePrinter As String

On Error GoTo ErrHandle
    nIndex = -1
    
    SP_PRCtCheckPRT = "1"
    
    If bVB_CNPrnOPOS Then
        For nI = 0 To UBound(aVB_TransMode)
            If aVB_TransMode(nI).ID = ptTransType Then
                nIndex = nI
                Exit For
            End If
        Next nI
        If nIndex >= 0 Then
            tTypePrinter = aVB_TransMode(nIndex).PrintType
        Else
            tTypePrinter = "1"
        End If
        If tTypePrinter = "0" Or tTypePrinter = "2" Then
            If Not oOposSlip.oPrinterDeviceEnabled Then
                oOposSlip.ClosePrint
                oOposSlip.OpenPrint tVB_CashSlipPrinter, nVB_MaxCharSlip, nVB_CashCodePage 'Open Printer OPOS
            End If
        End If
        If tTypePrinter = "2" Then
            If oOposSlip.SlpEmpty = False Then
                If MsgBox("Do you want print slip ? ", vbQuestion + vbYesNo, "Transaction") = vbYes Then
                    tTypePrinter = "0"
                Else
                    tTypePrinter = "1"
                End If
            Else
                 tTypePrinter = "1"
            End If
        End If
    Else
        tTypePrinter = "1"
    End If
    SP_PRCtCheckPRT = tTypePrinter
Exit Function
ErrHandle:
    SP_PRCtCheckPRT = "1"
End Function

Private Function SP_CHKbEmpAlowPoint() As Boolean
