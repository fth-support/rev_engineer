                    End If
                End If 'กรอง Dept/Brd
                orsVB_CNDeptMall.Filter = adFilterNone
                If bExit Then
                    SP_PRCbChkMallStaSKUNotAlw = True
                    Exit Function
                End If
            End If 'Not Allow Dept/Brd   Y : มีข้อมูล  N : ไม่มีข้อมูล
            
        End If 'ระดับ Dept/Brd
        '-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
    End If 'Step 1
    Exit Function
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    SP_PRCbChkMallStaSKUNotAlw = False
End Function


