   ' tSql = tSql & ",TCNMTenderMtn.FTTdmStaBPSale" '*KT 55-08-15 ไม่มี field นี้
    tSql = tSql & ",TCNMTenderMtn.FTTdmStaBPReturn"
    tSql = tSql & ",TCNMTenderMtn.FTTdmStaExpDate"
    tSql = tSql & ",TCNMTenderMtn.FTTdmStaReEntry"
    tSql = tSql & " FROM  TSysMenu INNER JOIN"
    tSql = tSql & " TCNMTenderMtn ON TSysMenu.FTSmnID = TCNMTenderMtn.FTSmnID INNER JOIN"
    tSql = tSql & " TSysPosMenu ON TSysMenu.FTSmnID = TSysPosMenu.FTSpmID"
    tSql = tSql & " WHERE  (TSysPosMenu.FTSpmGrp = 'Tender Type')"
    'tSql = tSql & " ORDER BY TCNMTenderMtn.FNTdmSeqNo,TCNMTenderMtn.FTTdmCode"    '*Eaw 55-11-26 เปลี่ยนไป order by TCNMTenderMtn.FNTdmSeqNo ตัวเดียว
    tSql = tSql & " ORDER BY TCNMTenderMtn.FNTdmSeqNo"    '*Eaw 55-11-26 เปลี่ยนไป order by TCNMTenderMtn.FNTdmSeqNo ตัวเดียว
    
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    If Not orsTemp Is Nothing Then  '*KT 54-03-25 ป้องกันโปรแกรมหลุด
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Do While Not orsTemp.EOF
                aVB_TenderMnu(UBound(aVB_TenderMnu)).ID = SP_FEDtChkString(orsTemp, "FTTdmCode")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).Name = SP_FEDtChkString(orsTemp, "FTTdmType")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).DefLangPri = SP_FEDtChkString(orsTemp, "FTDefLangPri")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).DefLangSec = SP_FEDtChkString(orsTemp, "FTDefLangSec")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).UsrLangPri = SP_FEDtChkString(orsTemp, "FTUsrLangPri")
                aVB_TenderMnu(UBound(aVB_TenderMnu)).UsrLangSec = SP_FEDtChkString(orsTemp, "FTUsrLangSec")
