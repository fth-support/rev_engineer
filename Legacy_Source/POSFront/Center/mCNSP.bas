Public Function SP_CONbMemberServer(Optional ByVal pbSplash As Boolean = False, Optional ptSplashText As String = "", Optional pbMessage As Boolean = True) As Boolean
'________________________________________________
'   Call:
'   Cmt: '*Ao 51-06-26
'*KT 51-11-01
'________________________________________________
    Dim tCon As String
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim nErr As Long
On Error GoTo ErrHandle:
    SP_CONbMemberServer = False
    
'*KT 54-04-07 ป้องกันโปรแกรมหลุด 3.0.56
'    'Connect Member Online
'    If pbSplash Then
'        If ptSplashText = "" Then
'            Call SP_STAxSplashByAct("Connect database member")
'        Else
'            Call SP_STAxSplashByAct(ptSplashText)
'        End If
'    End If

    If ocnMember Is Nothing Then
        Set ocnMember = New ADODB.Connection
        tCon = "Provider=SQLOLEDB.1;Password=" & tVB_CNOnMemDbSQLAuthUsrP & ";Persist Security Info=True;User ID=" & tVB_CNOnMemDbSQLAuthUsrC & ";Initial Catalog=" & tVB_CNOnMemDbCurFile & ";Data Source=" & tVB_CNOnMemDbSrc
        ocnMember.CursorLocation = adUseClient
'        ocnMember.ConnectionTimeout = 30   '1.5 นาที
'        ocnMember.CommandTimeout = 30
        ocnMember.ConnectionTimeout = IIf(nVB_CNCnnTimeOutMem = 0, 10, nVB_CNCnnTimeOutMem)              '*Ao 2010/12/23      ให้ Timeout เร็วขึ้น
        ocnMember.CommandTimeout = IIf(nVB_CNCmdTimeOutMem = 0, 10, nVB_CNCmdTimeOutMem)
        ocnMember.Open tCon
        If ocnMember.State = adStateOpen Then '*Tao 59-10-14 ถ้าติดต่อ MemServer ได้
            Call SaveSetting("AdaPosMall", "POSFront", "MemSrvOnline", "1") '*Tao 60-04-03 ใช้แทน serviceonoff
            SP_CONbMemberServer = True
        End If
    End If
    tSql = "SELECT Name FROM Sys.Sysobjects WHERE Name = 'TCNMMallCard'"
    nErr = SP_SQLvExecute(tSql, orsTemp, ocnMember, , , , True)
    Select Case nErr
        Case -2147467259, -2147217871, 91, 3704  '-2147467259, 91 '*KT 54-04-07 แก้ไขโปรแกรมหลุด 3.0.56
            Set ocnMember = New ADODB.Connection
            tCon = "Provider=SQLOLEDB.1;Password=" & tVB_CNOnMemDbSQLAuthUsrP & ";Persist Security Info=True;User ID=" & tVB_CNOnMemDbSQLAuthUsrC & ";Initial Catalog=" & tVB_CNOnMemDbCurFile & ";Data Source=" & tVB_CNOnMemDbSrc
            ocnMember.CursorLocation = adUseClient
            ocnMember.ConnectionTimeout = IIf(nVB_CNCnnTimeOutMem = 0, 10, nVB_CNCnnTimeOutMem)
            ocnMember.CommandTimeout = IIf(nVB_CNCmdTimeOutMem = 0, 10, nVB_CNCmdTimeOutMem)
'            ocnMember.ConnectionTimeout = 30   '1.5 นาที
'            ocnMember.CommandTimeout = 30
            ocnMember.Open tCon
            SP_CONbMemberServer = True
            tSql = "SELECT Name FROM Sys.Sysobjects WHERE Name = 'TCNMMallCard'"
            Call SP_SQLvExecute(tSql, orsTemp, ocnMember, , , , True)
        Case 0
            SP_CONbMemberServer = True              '*Ao 2012/07/26  PRJ10001TK-External Specification Member Service-00.02.00.doc
    End Select
    If orsTemp.BOF And orsTemp.EOF Then
        If pbMessage Then MsgBox "การติดต่อกับฐานข้อมูล Member ผิดพลาด กรุณาตรวจสอบที่ ISSTools อีกครั้ง"
        SP_CONbMemberServer = False
        Set ocnMember = Nothing
    End If
    bVB_CNSplash = False '*KT 51-09-17 ป้องการ Key กรณีที่ Splash ขึ้น
    Exit Function
ErrHandle:
    Call SaveSetting("AdaPosMall", "POSFront", "MemSrvOnline", "0") '*Tao 60-04-03 ใช้แทน serviceonoff
    '*KT 51-10-02 3.0.127 Offline กลับมา Online แล้วขึ้น Can not connect database Member Server
    '---------------------------------------------------------------------------
    If pbMessage Then Call SP_MSGnShowing("tms_CN005134", tCS_CNMsgWarn)
    Set ocnMember = Nothing
    SP_CONbMemberServer = False
    bVB_CNSplash = False '*KT 51-09-17 ป้องการ Key กรณีที่ Splash ขึ้น
End Function

Public Function SP_GETtIPAddressSrv(ByVal ptLocalIP As String) As String
'---------------------------------------------------------------
'Call:
'Cmt: Get IP Address จาก  SQLSERVER
'--------------------------------------------------------------

    Dim tIP$
    Dim tSubL1$
    Dim tSubL2$
    Dim tSubL3$
    Dim tSubS1$
    Dim tSubS2$
    Dim tSubS3$
    Dim tTmpIPLocal$
    Dim tTmpIPSrv$
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    
    SP_GETtIPAddressSrv = ""
    If Not oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
        SP_GETtIPAddressSrv = ""
    Else
        tSql = "STP_CNxGetIPAddressSrv"
        Call SP_SQLvExecute(tSql, , oDB.ocnOnLine)
        tSql = "SELECT LTRIM(RTRIM(SUBSTRING(t, CHARINDEX(':', t) +1, LEN(t)))) as IPAddress"
        tSql = tSql & vbCrLf & " From TTmpIPAddress"
        tSql = tSql & vbCrLf & " where t like '%IP Address%'"
        tSql = tSql & vbCrLf & " OR t like '%IPv4 Address%'" '*Tao 60-02-03 for Win7
        tSql = tSql & vbCrLf & " order by t DESC"
        Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)
        If Not orsTemp Is Nothing Then '*KT 54-03-25 ป้องกันโปรแกรมหลุดให้ตรวจสอบ recordset  ว่า Nothing หรือไม่ก่อนใช้งาน
            If Not (orsTemp.BOF Or orsTemp.EOF) Then
                If orsTemp.RecordCount = 1 Then
                    SP_GETtIPAddressSrv = SP_FEDtChkString(orsTemp, "IPAddress")
                Else
                    Do While Not orsTemp.EOF
                        tTmpIPLocal = ptLocalIP
                        tIP = SP_FEDtChkString(orsTemp, "IPAddress")
                        tTmpIPSrv = tIP
                        
                        tSubL1 = cUT.UT_STRtToken(tTmpIPLocal, ".", 1, False)
                        tSubL2 = cUT.UT_STRtToken(tTmpIPLocal, ".", 1, False)
                        tSubL3 = cUT.UT_STRtToken(tTmpIPLocal, ".", 1, False)
                        
                        tSubS1 = cUT.UT_STRtToken(tTmpIPSrv, ".", 1, False)
                        tSubS2 = cUT.UT_STRtToken(tTmpIPSrv, ".", 1, False)
                        tSubS3 = cUT.UT_STRtToken(tTmpIPSrv, ".", 1, False)
                        
                        If tSubL1 = tSubS1 And tSubL2 = tSubS2 And tSubL3 = tSubS3 Then
                            SP_GETtIPAddressSrv = tIP
                            Exit Do
                        End If
                        orsTemp.MoveNext
                    Loop
                End If
            Else
                SP_GETtIPAddressSrv = ""
            End If
        Else
            SP_GETtIPAddressSrv = ""
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    'SP_GETtIPAddressSrv
    Call SP_CRTxLogPrg("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " : mCNSP.SP_GETtIPAddressSrv")
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

