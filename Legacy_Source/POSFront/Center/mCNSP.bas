    'เพื่อความชัวกำหนดให้ตัวตั้งต้นเป็น "TPSDT" & tVB_CNTerminalNum แทนที่จะใช้ตัวแปร tVB_CNTblDT
    tSql = "STP_CNxSQLMovSal2Tmp @ptTbl='" & tVB_CNTblDTTmp & "',@ptTblTmp='" & "TPSDT" & tVB_CNTerminalNum & "',@ptWhr = '" & tWhr & "'"
