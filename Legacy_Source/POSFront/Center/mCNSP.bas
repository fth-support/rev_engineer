    Loop Until Timer > nTime + 0.5
    nHwnd = FindWindow(vbNullString, "Calculator")
    SetWindowPos nHwnd, HWND_TOPMOST, 0, 0, 0, 0, SWP_NOACTIVATE Or SWP_SHOWWINDOW Or SWP_NOMOVE Or SWP_NOSIZE
End Sub

