        bVB_CNSplash = False '*KT 51-09-17 ป้องการ Key กรณีที่ Splash ขึ้น
        SP_SQLbConnect = True
        
        '*Ao 51-06-26  ย้ายไป SP_CONbMemberServer   เพื่อเอาไปใช้ offline มา online ต้อง Connect ใหม่
        Call SP_CONbMemberServer(True)
    End With
    Exit Function
ErrHandle:

End Function

