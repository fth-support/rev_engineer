Public Function SP_RSTbClone2Offline(ByVal porsSource As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, Optional ByVal pbGetData As Boolean = True) As Boolean
    Dim nLoop As Integer
On Error GoTo Err_Handler
    Set porsTarget = New ADODB.Recordset
    If porsSource.RecordCount <= 0 Then Exit Function
    For nLoop = 1 To porsSource.Fields.Count
        Call porsTarget.Fields.Append(porsSource.Fields(nLoop - 1).Name, porsSource.Fields(nLoop - 1).Type, porsSource.Fields(nLoop - 1).DefinedSize)
    Next nLoop
    porsTarget.CursorType = adOpenStatic
    porsTarget.Open
    If pbGetData Then
        porsSource.MoveFirst
        Do While Not porsSource.EOF
            porsTarget.AddNew
            For nLoop = 1 To porsSource.Fields.Count
                porsTarget.Fields(nLoop - 1) = porsSource.Fields(nLoop - 1).Value & vbNullString
            Next nLoop
            porsSource.MoveNext
        Loop
    End If
    SP_RSTbClone2Offline = True
    Exit Function
Err_Handler:
End Function

Public Function SP_RSTbClone2OfflineEx(ByVal porsSource As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, Optional ByVal pbGetData As Boolean = True) As Boolean
    Dim nLoop As Integer
On Error GoTo Err_Handler
    Set porsTarget = New ADODB.Recordset
    If porsSource.RecordCount <= 0 Then Exit Function
    For nLoop = 1 To porsSource.Fields.Count
        Call porsTarget.Fields.Append(porsSource.Fields(nLoop - 1).Name, porsSource.Fields(nLoop - 1).Type, porsSource.Fields(nLoop - 1).DefinedSize)
    Next nLoop
    porsTarget.CursorType = adOpenStatic
    porsTarget.Open
    If pbGetData Then
        porsSource.MoveFirst
        Do While Not porsSource.EOF
            porsTarget.AddNew
            For nLoop = 1 To porsSource.Fields.Count
'                porsTarget.Fields(nLoop - 1) = porsSource.Fields(nLoop - 1).Value & vbNullString
                
                Select Case UCase(Mid(porsSource.Fields(nLoop - 1).Name, 2, 1))
                    Case "T"
                        porsTarget.Fields(nLoop - 1).Value = porsSource.Fields(nLoop - 1).Value & vbNullString
                    Case "C"
                        porsTarget.Fields(nLoop - 1).Value = SP_VALcText2Double(porsSource.Fields(nLoop - 1).Value & vbNullString)
                    Case "N"
                        porsTarget.Fields(nLoop - 1).Value = SP_VALnText2Double(porsSource.Fields(nLoop - 1).Value & vbNullString)
                    Case "D"
                        If IsNull(porsSource.Fields(nLoop - 1).Value) Then
                            porsTarget.Fields(nLoop - 1).Value = "Null"
                        Else
                           porsTarget.Fields(nLoop - 1).Value = porsSource.Fields(nLoop - 1).Value
                        End If
                End Select
            Next nLoop
            porsSource.MoveNext
        Loop
    End If
    SP_RSTbClone2OfflineEx = True
    Exit Function
Err_Handler:
    
End Function

Public Function SP_RSTbClone2OfflineEx2(ByVal porsSource As ADODB.Recordset, ByRef porsTarget As ADODB.Recordset, Optional ByVal pbGetData As Boolean = True) As Boolean
'-----------------------------------------------------------------------------------
'Cmt: หลังการ Clone ข้อมูลมายังอีก Recordset หนึ่ง ให้ทำการตรวจสอบว่า Cursor อยู่ที่ Record ไหนของตัวที่ Clone และตัว Recordset ต้นฉบับ อาจใช้คำสั่ง Sort หรือ MoveNext เพื่อกลับไปที่ Recordeset แรกเสมอ
'-----------------------------------------------------------------------------------
    Dim nLoop As Integer
On Error GoTo Err_Handler
    Set porsTarget = New ADODB.Recordset
    For nLoop = 1 To porsSource.Fields.Count
        Call porsTarget.Fields.Append(porsSource.Fields(nLoop - 1).Name, porsSource.Fields(nLoop - 1).Type, porsSource.Fields(nLoop - 1).DefinedSize)
    Next nLoop
    porsTarget.CursorType = adOpenStatic
    porsTarget.Open
    If porsSource.RecordCount <= 0 Then Exit Function
    If pbGetData Then
        porsSource.MoveFirst
        Do While Not porsSource.EOF
            porsTarget.AddNew
            For nLoop = 1 To porsSource.Fields.Count
'                porsTarget.Fields(nLoop - 1) = porsSource.Fields(nLoop - 1).Value & vbNullString
                
                Select Case UCase(Mid(porsSource.Fields(nLoop - 1).Name, 2, 1))
                    Case "T"
                        porsTarget.Fields(nLoop - 1).Value = porsSource.Fields(nLoop - 1).Value & vbNullString
                    Case "C"
                        porsTarget.Fields(nLoop - 1).Value = SP_VALcText2Double(porsSource.Fields(nLoop - 1).Value & vbNullString)
                    Case "N"
                        porsTarget.Fields(nLoop - 1).Value = SP_VALnText2Double(porsSource.Fields(nLoop - 1).Value & vbNullString)
                    Case "D"
                        If IsNull(porsSource.Fields(nLoop - 1).Value) Then
                            porsTarget.Fields(nLoop - 1).Value = "1900/01/01"
                        Else
                           porsTarget.Fields(nLoop - 1).Value = porsSource.Fields(nLoop - 1).Value
                        End If
                End Select
            Next nLoop
            porsSource.MoveNext
        Loop
    End If
    SP_RSTbClone2OfflineEx2 = True
    Exit Function
Err_Handler:
    
End Function


'SP_GETtPthLoadImageFromField(tW_DataSource, tW_ImageField, tW_DataField & "=" & SP_GETtQuote(otbForm(0).Text))
Public Function SP_GETtPthLoadImageFromField(ByVal ptTableName$, ByVal ptImageField$, ByVal ptWhere$) As String
'----------------------------------------------------------
'   Cmt :   Load Field Image
'----------------------------------------------------------
    Dim tSql$, tFile$, n%, nSize&
    Dim aBuff() As Byte
    Dim orsTmp As ADODB.Recordset
    
On Error GoTo ErrHandle
    ptWhere = Trim$(Replace$(ptWhere, "where", "", 1, 1, vbDatabaseCompare))
'    tSql = "SELECT " & ptImageField & " FROM " & ptTableName & " WHERE " & ptWhere & ";"            '*Ao 09-07-23
    tSql = "SELECT " & ptImageField & " FROM " & ptTableName & " WHERE " & ptWhere & ""
    If Not SP_SQLbExecute(tSql, orsTmp, , , , oDB.ocnOnLine, True, True) Then Exit Function
'Load field to buffer
    If orsTmp.BOF And orsTmp.EOF Then Exit Function
    With orsTmp
        nSize = .Fields(ptImageField).ActualSize
        If nSize > 0 Then aBuff = .Fields(ptImageField).GetChunk(nSize)
        .Close
    End With
    Set orsTmp = Nothing
    If nSize = 0 Then
         SP_GETtPthLoadImageFromField = ""
        Exit Function
    End If
    
'Save buffer to file
    tFile = SP_GETtNewTempFile 'กำหนดชื่อไฟล์ Temporary
    If tFile = "" Then Exit Function
    n = FreeFile
    Open tFile For Binary As #n
    Put #n, , aBuff()
    Close #n
    
'Load file to picture
     SP_GETtPthLoadImageFromField = tFile
    Exit Function

ErrHandle:
    Call SP_MSGShowError
    SP_GETtPthLoadImageFromField = ""
End Function

Public Function SP_GETtNewTempFile() As String
'----------------------------------------------------------
'   Cmt :   กำหนดชื่อ File Temporary ใหม่
'----------------------------------------------------------
    Dim tTmp As String, tFile As String, tPath As String
    Dim nLen As Long, nC As Long

'Temporary Path
    tTmp = String(255, 0)
    nLen = GetTempPath(255, tTmp)
    If nLen <> 0 Then
        tPath = Left$(tTmp, nLen)
    Else
        SP_GETtNewTempFile = ""
        Exit Function
    End If
    
    nC = 0
    Do
        nC = nC + 1
        tFile = tPath & Format$(Now(), "_yyyymmddhhnnss") & Format$(nC, "00000000") & ".BMP"
    Loop Until Dir(tFile) = ""
    SP_GETtNewTempFile = tFile
End Function

Public Sub SP_SHWxErrPrinter(Optional ByVal pbRefresh As Boolean = False, Optional ptPrinterType As String = "1")
'------------------------------------
'Call:
'Cmt: แสดงหน้าจอ error result  ของ Printer
'------------------------------------
Dim nLevel As Long

On Error GoTo ErrHandle
'    If ptPrinterType = "0" Then
    If ptPrinterType = "0" Or ptPrinterType = "2" Then '*Eaw 56-07-23 CommSheet TK-ISS3000-274 TR FAPL-053 00.00.02.xls
        Exit Sub                                                                                    '*Ao ไม่ต้องเช็ค ในหน้าจอ Item Empty แต่ให้ไปเช็คก่นอการพิมพ์ Slip
        With oOposSlip
            nLevel = .nCheckHealth(OPOS_CH_INTERNAL)
            If nLevel = OPOS_E_ILLEGAL Then            '*Ao 2013/07/18      CommSheet TK-ISS3000-274 TR FAPL-053.xls
                wCNMsgSlip.Show vbModal      '*Ao 2013/07/18      CommSheet TK-ISS3000-274 TR FAPL-053.xls
            End If
'            .Printnormal PTR_S_SLIP, ESC & Chr(64)                 'ESC @      [Name] Initialize printer   [Description] Clears the data in the print buffer and resets the printer mode to the mode that was in effect when the power was turned on.
        End With
    Else
        With oOpos
             Select Case .ResultCode
                 Case OPOS_SUCCESS
                     If .oPrinterState = 4 Then
                         wCNMsgErr.Show vbModal
                     ElseIf .CoverOpen Then
                         wCNMsgErr.Show vbModal
                     ElseIf .ErrorLevel = 2 Then
                         wCNMsgErr.Show vbModal
                     End If
                 Case OPOS_E_EXTENDED
                     Select Case .ResultCodeExtended
                         Case OPOS_EPTR_COVER_OPEN
                             '*KT 51-09-19  ML-SF- 554
                             '---------------------------------------------------------------------------------
                             If .PowerState = 2004 Then
                                       wCNMsgErr.Show vbModal
                             ElseIf .oPrinterState = 4 Then
                                       wCNMsgErr.Show vbModal
                             Else
                                 If .CoverOpen Then
                                     wCNMsgErr.Show vbModal
                                 ElseIf .ErrorLevel = 2 Then
                                       wCNMsgErr.Show vbModal
                                 End If
                             End If
                             '-----------------------------------------------------------------------------------
                         Case OPOS_EPTR_REC_EMPTY
                             'wCNMsgErr.Show vbModal
                             If .PowerState = 2004 Then
                                 wCNMsgErr.Show vbModal
                             ElseIf .oPrinterState = 4 Then
                                 wCNMsgErr.Show vbModal
                             Else
                                 If .CoverOpen Then
                                     wCNMsgErr.Show vbModal
                                 ElseIf .ErrorLevel = 2 Then
                                     wCNMsgErr.Show vbModal
                                 End If
                             End If
                     End Select
             End Select
        End With
    End If
    Exit Sub
ErrHandle:
    
End Sub


Public Sub SP_GEToLogo()
'---------------------------------------------------------------------
