Public Function SP_GETxDriveType(ByVal ptDrive As String) As String
    '*Bump 57-11-21 CommSheet TK-ISS3000-567(USB).xlsx
    '* การเรียกใช้ SP_GETxDriveType("C:")
    Dim fso As FileSystemObject
    
