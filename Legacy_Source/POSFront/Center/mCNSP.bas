Public Function SP_DEFtChangeNum(ByVal ptNum As String) As String       '*AO51-03-12
    Dim nDecAmtForShw As Long
    Dim tLeft As String
    Dim tRight As String
    Dim tTmp As String
    
On Error GoTo ErrHandle
    
    nDecAmtForShw = IIf(nVB_CNDecAmtForShw = 0, 2, nVB_CNDecAmtForShw)
    
    If Len(ptNum) = 1 Then
        ptNum = "0.0" & Trim(ptNum)
'        otbTmp.SelStart = Len(otbTmp.Text)
    Else
        If Len(ptNum) > 4 Then
            If Left(ptNum, 1) = "0" Then
                ptNum = Right(ptNum, Len(ptNum) - 1)
            End If
            tTmp = Replace(Trim(ptNum), ".", "")
            tTmp = Trim(tTmp)
            
            If Len(tTmp) > 2 Then
                tLeft = Left(tTmp, Len(tTmp) - nDecAmtForShw)                            'nVB_CNDecAmtForShw
            Else
                tLeft = "0"
            End If
            tRight = Right(tTmp, nDecAmtForShw)
            ptNum = tLeft & "." & tRight
'            If Len(otbForm.Text) > 6 Then
'                otbForm.Text = SP_FMTtNum2Shw(otbForm.Text)
'                otbForm.SelStart = Len(otbForm.Text)
'            End If
        Else
            If Len(ptNum) < 5 Then
                tTmp = Replace(Trim(ptNum), ".", "")
                tTmp = Trim(tTmp)
                If Len(tTmp) > 2 Then
                    tLeft = Left(tTmp, Len(tTmp) - nDecAmtForShw)
                Else
                    tLeft = "0"
                End If
                tRight = Right(tTmp, nDecAmtForShw)
                ptNum = tLeft & "." & tRight
            End If
        End If
    End If
    SP_DEFtChangeNum = ptNum
    Exit Function
ErrHandle:
    SP_DEFtChangeNum = "0.00"
End Function

Public Function SP_GETnTimeDisplayMsg() As Long
'-------------------------------------
'Ret: เป็นจำนวนนาที
'Cmt: ทำการหาจำนวนนาทีที่จะให้ Front ทำการ Display ข้อมุลที่ส่งให้ Cashier อ่าน
