Public Function SP_PRCtStrMarkX(ByVal ptCardID As String, Optional ByVal ptOptMarkX As String = "3") As String
'*Tao 61-09-18 Mark X หมายเลขบัตรเครดิต หรือ หมายเลขสมาชิก
Dim tTmp As String, tFirst As String, tLast As String, tCard As String
Dim nI As Integer
    On Error GoTo ErrHandle
    Select Case Trim(ptOptMarkX)
        Case "1"
            tTmp = ""
            If Len(ptCardID) > 8 Then
                For nI = 1 To Len(ptCardID) - 8
                    tTmp = tTmp & "X"
                Next nI
                tFirst = Left(ptCardID, 4)
                tLast = Right(ptCardID, 4)
                tCard = tFirst & tTmp & tLast
                tTmp = ""
                For nI = 1 To Len(tCard)
                    Select Case nI
                        Case 5, 9, 13, 17, 21, 25
                            tTmp = tTmp & " "
                    End Select
                    tTmp = tTmp & Mid(tCard, nI, 1)
                Next nI
            Else
                If Len(ptCardID) < 5 Then
                    tTmp = ptCardID
                Else
                    For nI = 1 To Len(ptCardID) - 4
                        tTmp = tTmp & "X"
                    Next nI
                    tLast = Right(ptCardID, 4)
                    tCard = tTmp & tLast
                    tTmp = ""
                    For nI = 1 To Len(tCard)
                        Select Case nI
                            Case 5, 9, 13
                                tTmp = tTmp & " "
                        End Select
                        tTmp = tTmp & Mid(tCard, nI, 1)
                    Next nI
                End If
            End If
            SP_PRCtStrMarkX = tTmp
        Case "2"
            tTmp = "XXXX XXXX XXXX "
            Select Case Len(ptCardID)
                Case 1
                    tLast = "000" & ptCardID
                    SP_PRCtStrMarkX = tTmp & tLast
                Case 2
                    tLast = "00" & ptCardID
                    SP_PRCtStrMarkX = tTmp & tLast
                Case 3
                    tLast = "0" & ptCardID
                    SP_PRCtStrMarkX = tTmp & tLast
                Case 4
                    tLast = ptCardID
                    SP_PRCtStrMarkX = tTmp & tLast
                Case Else
                    tLast = Mid(ptCardID, Len(ptCardID) - 3)
                    SP_PRCtStrMarkX = tTmp & tLast
             End Select
        Case "3" 'Mark X Last 4 Digit
            If Len(ptCardID) > 4 Then
                tFirst = Left(ptCardID, Len(ptCardID) - 4)
                tLast = "XXXX"
                tCard = tFirst & tLast
            Else
                tCard = ptCardID
            End If
            SP_PRCtStrMarkX = tCard
    End Select
    Exit Function
ErrHandle:
    SP_PRCtStrMarkX = ptCardID
End Function
