Public Function SP_CHKtClosingReport() As String
    '----------------------------------------------------------
'   Cmt:  หา Transaction ล่าสุดเป้น Closing Report หรือไม่ ถ้าใช่ ให้ส่งการ Reprint Closing Report ถ้าไม่ใช่ ให้สร้าง Closing Report ใหม่
'   Ret:   "3" : Reprint Closing Report
'              "7" : Closing Report
'----------------------------------------------------------
Dim tSql$
Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle

    tSql = "SELECT FTTmnNum,FTShdTransNo,FDShdTransDate,FTShdTransType FROM TPSTSalHD WITH(NOLOCK)"
    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & " AND   ISNULL(FTShdStaDoc,'')='1'"
    tSql = tSql & vbCrLf & " ORDER BY  FTShdTransNo DESC"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine) = 0 Then
        If (orsTemp.BOF And orsTemp.EOF) Then
            Call SP_DATxRsNothing(orsTemp)
            Call SP_SQLbExecute(tSql, orsTemp, , , , oDB.ocnOnLine, True)
        End If
        If orsTemp.RecordCount > 0 Then
            Select Case SP_FEDtChkString(orsTemp, "FTShdTransType")
                Case "09", "42", "47"
                    SP_CHKtClosingReport = "3"
                    If tVB_CNClosingReprint = "" Then
                        tVB_CNClosingReprint = SP_FEDtChkString(orsTemp, "FTShdTransNo")
                    Else
                        If tVB_CNClosingReprint <> SP_FEDtChkString(orsTemp, "FTShdTransNo") Then
                            tVB_CNClosingReprint = SP_FEDtChkString(orsTemp, "FTShdTransNo")
                        End If
                    End If
               Case Else
                    SP_CHKtClosingReport = "8" '*Tao 60-01-20 "7" : Closing Report เปลี่ยนเป้น 8 เนื่องจากเพิ่มเมนู EJ Veiwer ต่อจากการแก้ไข CommSheet TK-ISS3000-587-CLOSING Report is missing.xls
            End Select
        Else
            SP_CHKtClosingReport = "8" '*Tao 60-01-20 "7" : Closing Report เปลี่ยนเป้น 8 เนื่องจากเพิ่มเมนู EJ Veiwer
        End If
    Else
        SP_CHKtClosingReport = "8" '*Tao 60-01-20 "7" : Closing Report เปลี่ยนเป้น 8 เนื่องจากเพิ่มเมนู EJ Veiwer
    End If
    Call SP_DATxRsNothing(orsTemp)
Exit Function
ErrHandle:
    SP_CHKtClosingReport = "8"
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Function

