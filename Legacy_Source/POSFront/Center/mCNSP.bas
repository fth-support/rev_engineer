Public Sub SP_MSGShowError()       '*Tee 51-02-19
'----------------------------------------------------------
'   Call:
'   Cmt:   displays the error message with it's Err code
'----------------------------------------------------------
    Dim tMsg$, tMsg2$, tAppTitle$
    Dim nPos%
    
    
    If Err = 0 Then Exit Sub
    Screen.MousePointer = vbDefault
    
    tMsg = Err.Source & "(" & Err.Number & ")" & vbCr
    tMsg = tMsg & Err.Description & vbCr
    tMsg = tMsg & tVB_CNSqlLastCmd
    Beep 5000, 1 '*KT 53-04-09 PH3-ML-SF-112 Allow Scanner when alert message
    MsgBox tMsg, tCS_CNMsgErr, App.Title
End Sub

