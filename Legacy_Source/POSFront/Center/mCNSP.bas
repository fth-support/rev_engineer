'*TW 51-07-15 Service
Public Function SP_SVCbCheckService(ByVal pnRecur As Integer) As Boolean
'----------------------------------------------------------------
'   Cmt :  This sub checks service status and open it if possible
'----------------------------------------------------------------
    Dim nServState As SERVICE_STATE
    Dim nCount As Integer
    Dim bPass As Boolean
On Error GoTo Err_Handler
    If pnRecur > 2 Then Exit Function
    Do
        nCount = nCount + 1
        If NT_CHKnSetStatus() = 0 Then 'Installed
            nServState = NT_GETnServStatus()
            Select Case nServState
                Case SERVICE_RUNNING
                    bPass = True
                Case SERVICE_STOPPED
                    If NT_SETnStartService <> 0 Then
                        SP_SVCbCheckService = False
                        Exit Do
                    Else
                        bPass = True
                    End If
                Case SERVICE_PAUSED

                Case SERVICE_CONTINUE_PENDING

                Case SERVICE_PAUSE_PENDING

                Case SERVICE_START_PENDING

                Case SERVICE_STOP_PENDING

                Case Else

            End Select

        Else 'Not Installed Yet
            If NT_SETnNTService = 0 Then 'Call Install if success call chk again
                If NT_SETnStartService <> 0 Then
                    SP_SVCbCheckService = False
                    Exit Do
                Else
                    bPass = True
                End If
            Else 'if non success exit ,False
                SP_SVCbCheckService = False
            End If
        End If
    Loop Until (nCount >= 4) Or bPass
    SP_SVCbCheckService = bPass
    Exit Function
Err_Handler:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

Public Function SP_CHKbOnlineEnable() As Boolean
'PH 2.0.0
    Dim tSql$
On Error GoTo ErrHandle
    If oDB.ocnOnLine Is Nothing Then
        SP_CHKbOnlineEnable = False
    Else
        If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
            tSql = "SELECT GETDATE()"
            oDB.ocnOnLine.Execute (tSql)
            SP_CHKbOnlineEnable = True
        Else
            SP_CHKbOnlineEnable = False
        End If
    End If
    Exit Function
ErrHandle:
    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
         If Not oDB.ocnOnLine Is Nothing Then
            If oDB.ocnOnLine.State = adStateOpen Then oDB.ocnOnLine.Close
        End If
         Call oDB.SQLbConnectDB(oDB.ocnOnLine, Online)
    End If
    SP_CHKbOnlineEnable = False
End Function

