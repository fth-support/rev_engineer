          paDSlpMag(5) = SP_FEDtChkString(orsTemp, "FTSlpDescLine6")
          paDSlpMag(6) = SP_FEDtChkString(orsTemp, "FTSlpDescLine7")
    End If
  End If
 Call SP_DATxRsNothing(orsTemp)
 Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub


