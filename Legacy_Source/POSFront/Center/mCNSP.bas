    tSql = tSql & vbCrLf & "AND FNDctNo IN (12)"
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        tRefCode = SP_FEDtChkString(orsTemp, "FTDctRefCode")
        tAllowPoint = cUT.UT_STRtToken(tRefCode, ",", 3, True)
        If UCase(Trim(tAllowPoint)) = UCase("Y") Then
            bChk = True
        Else
            bChk = False
        End If
    Else
        If bVB_ChkEmpPoint Then '*Eaw 56-08-21
            bChk = True
        Else
            bChk = False
        End If
    End If
    SP_CHKbEmpAlowPoint = bChk
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
HandleError:
    SP_CHKbEmpAlowPoint = True
End Function

Public Function SP_CHKbEmpPolicy(ByVal ptTable As String, ByVal ptWhere As String) As Boolean
'-------------------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao 2013/07/26            Lock Discount Member Discount,TC      Not Emp
'-------------------------------------------------------------------------------
Dim tSql As String, tDiscType As String, tStaPolicy As String
Dim bChk As Boolean
Dim orsTemp As ADODB.Recordset, orsChk As ADODB.Recordset
Dim nDctNo As Integer

On Error GoTo HandleError
    tSql = "SELECT DISTINCT FTScdDiscType,FNDctNo FROM " & ptTable
    tSql = tSql & vbCrLf & "WHERE " & ptWhere
    tSql = tSql & vbCrLf & "AND FNDctNo = 11"
    If Not SP_SQLbExecute(tSql, orsTemp) Then
        SP_CHKbEmpPolicy = True
        Exit Function
    End If
    If (orsTemp.BOF And orsTemp.EOF) Then
        SP_CHKbEmpPolicy = True
        Exit Function
    Else
        orsTemp.MoveFirst
    End If
    Do While Not orsTemp.EOF
        tDiscType = SP_FEDtChkString(orsTemp, "FTScdDiscType")
        nDctNo = SP_FEDvChkNumeric(orsTemp, "FNDctNo")
        If tDiscType = "1" Then         'Member Discount
            tSql = "SELECT FTDdpStaPolicy,FNDdpNo1,FNDdpNo2 "
            tSql = tSql & vbCrLf & "FROM TCNMDoubleDiscPolicy"
            tSql = tSql & vbCrLf & "WHERE FNDdpNo1 = 11"
            tSql = tSql & vbCrLf & "AND FNDdpNo2 = 12"
            Call SP_SQLvExecute(tSql, orsChk, oDB.ocnOnLine, , , , , True, True) 'read master
            If Not (orsChk.BOF And orsChk.EOF) Then
                tStaPolicy = SP_FEDtChkString(orsChk, "FTDdpStaPolicy")
                If (UCase(tStaPolicy) = UCase("Y")) Or (tStaPolicy = "") Then
                    bChk = True
                Else
                    bChk = False
                    Exit Do
                End If
            Else
                bChk = True
            End If
        Else        'TC Discount
            tSql = "SELECT FTDdpStaPolicy,FNDdpNo1,FNDdpNo2 "
            tSql = tSql & vbCrLf & "FROM TCNMDoubleDiscPolicy"
            tSql = tSql & vbCrLf & "WHERE FNDdpNo1 = 28"
            tSql = tSql & vbCrLf & "AND FNDdpNo2 = 12"
            Call SP_SQLvExecute(tSql, orsChk, oDB.ocnOnLine, , , , , True, True) 'read master
            If Not (orsChk.BOF And orsChk.EOF) Then
                tStaPolicy = SP_FEDtChkString(orsChk, "FTDdpStaPolicy")
                If (UCase(tStaPolicy) = UCase("Y")) Or (tStaPolicy = "") Then
                    bChk = True
                Else
                    bChk = False
                    Exit Do
                End If
            End If
        End If
        orsTemp.MoveNext
    Loop

    SP_CHKbEmpPolicy = bChk
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsChk)
    Exit Function
HandleError:
    SP_CHKbEmpPolicy = True
End Function

