Public Function SP_RNDcChange(ByVal pcChange As Double, ByRef pcRounding As Double) As Double
'----------------------------------------------------------
'Ret :
'Cmt: pcChange:  Change
'----------------------------------------------------------
    Dim cPart As Double
    Dim cIntPart As Double
    Dim nI As Long
    cPart = pcChange - Int(pcChange)
    cIntPart = Int(pcChange)
'    Select Case cPart
'        Case 0
'            SP_RNDcChange = cIntPart + 0
'        Case Is >= 0.75
'            SP_RNDcChange = cIntPart + 0.75
'        Case Is >= 0.5
'            SP_RNDcChange = cIntPart + 0.5
'        Case Is >= 0.25
'            SP_RNDcChange = cIntPart + 0.25
'        Case Is >= 0
'            SP_RNDcChange = cIntPart + 0
'        Case Else
'            SP_RNDcChange = cIntPart + cPart
'    End Select
    For nI = UBound(aVB_CNStangRndAlw) To LBound(aVB_CNStangRndAlw) Step -1  ' - 1'*KT 51-10-16  Communication Sheet ML-SF 578 Run Time Error on POST.xls
        If IsNumeric(aVB_CNStangRndAlw(nI)) Then
            If cPart >= aVB_CNStangRndAlw(nI) Then
                SP_RNDcChange = cIntPart + aVB_CNStangRndAlw(nI)
                Exit For
            End If
        End If
    Next nI
    pcRounding = (cPart + cIntPart) - SP_RNDcChange
End Function

