Public Function SP_DATnGetLocCaldLst(pnLCID As Long, pnTMP_CAL_START As Long, pnTMP_CAL_END As Long) As Long
'----------------------------------------------------------
'   Call:   pnLCID as LOCALE ID,
'               pnTMP_CAL_START as name(data type is long)  first,
'               pnTMP_CAL_END  as name(data type is long)  last
'   Ret:   Date  string  since  first  to  last
