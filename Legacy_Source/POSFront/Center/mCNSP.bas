Public Sub SP_ARYxQuickSort(ByRef paMyArray(), ByVal nLBound As Long, ByVal nUBound As Long)
    Dim nlngPivot As Long
    Dim nK As Long
    Dim nP As Long
    Dim nlngTemp As Long
    
    If nLBound >= nUBound Then
        Exit Sub
    End If
    nK = nLBound + 1
    If nUBound = nK Then
        If paMyArray(nLBound) > paMyArray(nUBound) Then
            'swap paMyArray(nLBound) and paMyArray(nUBound)
            nlngTemp = paMyArray(nLBound)
            paMyArray(nLBound) = paMyArray(nUBound)
            paMyArray(nUBound) = nlngTemp
        End If
        Exit Sub
    End If
    
    nlngPivot = paMyArray(nLBound)
    nP = nUBound
    
    Do Until (paMyArray(nK) > nlngPivot) Or (nK >= nUBound)
        nK = nK + 1
    Loop
    
    Do Until paMyArray(nP) <= nlngPivot
        nP = nP - 1
    Loop
    
    Do While nK < nP
        'swap paMyArray(k) and paMyArray(p)
        nlngTemp = paMyArray(nK)
        paMyArray(nK) = paMyArray(nP)
        paMyArray(nP) = nlngTemp
        
        Do
            nK = nK + 1
        Loop Until paMyArray(nK) > nlngPivot
        
        Do
            nP = nP - 1
        Loop Until paMyArray(nP) <= nlngPivot
    Loop
    
    'swap paMyArray(p) and paMyArray(nLBound)
    nlngTemp = paMyArray(nP)
    paMyArray(nP) = paMyArray(nLBound)
    paMyArray(nLBound) = nlngTemp
    
    SP_ARYxQuickSort paMyArray, nLBound, nP - 1
    SP_ARYxQuickSort paMyArray, nP + 1, nUBound
End Sub

Public Function SP_GETtVocabularyTicketFromArray(ByVal ptSpmID As String, ByRef pArray() As MAINMNU, ByRef ptSmnID As String) As String
'----------------------------------------------------------
'   Cmt :  หาคำศัพทืที่ใช้สำหรับพิมพ์ลง Ticket จาก SpmID ที่ส่งมา
'----------------------------------------------------------
    Dim nI As Long
On Error GoTo ErrHandle
    SP_GETtVocabularyTicketFromArray = ""
    For nI = LBound(pArray) To UBound(pArray) - 1
        If pArray(nI).SmnID = ptSpmID Then
            SP_GETtVocabularyTicketFromArray = pArray(nI).NameUsr
            ptSmnID = pArray(nI).SmnID
            Exit For
        End If
    Next nI
    Exit Function
ErrHandle:
    
End Function

Public Sub SP_CALxExceptSale(ByVal pogdTemp As VSFlexGrid, ByVal pnRow As Integer, ByRef pcSalePrice As Double)
'______________________________________
'   Call:
'   Cmt: กรณี Excep Sale ต้องถอด Vat
'   เก็บ FCSdtB4DisChg เป็นค่าที่เก็บก่อนมีการถอด Vat
'         FCSdtSalePrice  เป็นค่าที่ทำการถอด Vat
'______________________________________
'FCSdtQty,FTTaxCode,FCSdtTax,
    Dim tSql  As String
    Dim tSKUTaxCode As String
    Dim cSKUTaxRate As Double, cQty As Double
    Dim cTemp As Double
    Dim cSaleAmt As Double
On Error GoTo ErrHandle
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnTaxExceptSale 'กรณีเข้าขายแบบ Tax Except Sale
            With pogdTemp
                tSKUTaxCode = .TextMatrix(pnRow, .ColIndex("FTTaxCode"))
                cSKUTaxRate = SP_VALcText2Double(.TextMatrix(pnRow, .ColIndex("FCSdtTax")))
                cQty = SP_VALcText2Double(.TextMatrix(pnRow, .ColIndex("FCSdtQty")))
                cTemp = pcSalePrice
                If cSKUTaxRate > 0 And tSKUTaxCode <> "00" Then
                    pcSalePrice = SP_FMTcCurPoint(pcSalePrice - (pcSalePrice * cSKUTaxRate) / (100 + cSKUTaxRate), True, False)
                    cSaleAmt = SP_FMTcCurPoint(pcSalePrice * cQty, True, False)
                    tSql = "UPDATE "
                    tSql = tSql & tVB_CNTblDT
                    tSql = tSql & " SET FCSdtSalePrice = " & pcSalePrice
                    tSql = tSql & " ,FCSdtSaleUnit= " & pcSalePrice
                    tSql = tSql & " ,FCSdtSaleAmt= " & cSaleAmt
                    tSql = tSql & " ,FCSdtQtyAllDisAvi= " & cSaleAmt '*KT 52-01-24 ปรับปรุง FCSdtQtyAllDisAvi เพื่อนำไปใช้ในการคำนวณส่วนลด
                    '*KT 52-04-27 PH1.8-ML-SF-015 ทำรายการ Tax Except Sale, บางครั้งไม่แสดง VAT,  บางครั้งแสดง VAT ผิด, ราคา Net  คำนวณผิด (see attached TaxExcept.jpg)
                    If bVB_SKUisPromotion Then
                        tSql = tSql & " ,FCSdtBSubReg = " & 0
                        tSql = tSql & " ,FCSdtBSubPro = " & cSaleAmt
                        tSql = tSql & " ,FCSdtBluePrice = " & 0
                        tSql = tSql & " ,FCSdtYellowPrice = " & cSaleAmt
                    Else
                        tSql = tSql & " ,FCSdtBSubReg = " & cSaleAmt
                        tSql = tSql & " ,FCSdtBSubPro = " & 0
                        tSql = tSql & " ,FCSdtBluePrice = " & cSaleAmt
                        tSql = tSql & " ,FCSdtYellowPrice = " & 0
                    End If
                    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                    tSql = tSql & " AND   FNSdtSeqNo=" & .TextMatrix(pnRow, .ColIndex("FNSdtSeqNo"))
                    Call SP_SQLvExecute(tSql)
                    .TextMatrix(pnRow, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(pcSalePrice, False)
                    .TextMatrix(pnRow, .ColIndex("FCSdtSaleUnit")) = SP_FMTcCurPoint(pcSalePrice, False)
                    .TextMatrix(pnRow, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(pcSalePrice * cQty, False, True)
                End If
            End With
    End Select
    Exit Sub
ErrHandle:
        
End Sub

Public Sub SP_MOVxEJToOnline()
'-----------------------------------------------------------------
'Call:
'Cmt: ทำการ ย้าย File EJ ที่เกิดใน ณ ขณะที่เป็น Offline เมื่อเป็น Offline ให้ย้ายไปที่ Path Online ทันที่
'-----------------------------------------------------------------
    Dim tPth$
    Dim tPthEJ$
    Dim oFSO As New FileSystemObject
    Dim oFldInbox As Folder
    Dim oFile As File
    Dim objFile As File
    Dim tTemp As String
    Dim bCopy As Boolean
On Error GoTo ErrHandle
    tPth = oFSO.GetParentFolderName(App.Path) & "\POSEJ\" & Format(CDate(tUT_SaleDate), "yyMMdd")
'    MsgBox "tPth = " & tPth
    tPthEJ = tVB_CNOnDbSrcEJ & "\" & Format(CDate(tUT_SaleDate), "yyMMdd")
'    MsgBox "tPthEJ = " & tPthEJ
    '*KT 54-09-20 V.4.0.1 ป้องกันกรณีที่ Path EJ Local กับ Server ที่เดียวกัน
    If UCase(tPth) <> UCase(tPthEJ) Then
        'C:\Program Files\ISS3000\POSEJ  กับ
        '\\Ada54a\ISS3000\POSEJ
        If UCase("\\" & cUT.UT_SYStGetComName) = UCase(Mid(tPthEJ, 1, 2 + Len(cUT.UT_SYStGetComName))) Then
            tTemp = Replace(UCase(tPthEJ), UCase("\\" & cUT.UT_SYStGetComName), "")
            If UCase(Right(tPth, Len(tTemp))) = UCase(Right(tPthEJ, Len(tTemp))) Then
                bCopy = False
                Call SP_CRTxLogFile("UCase(Right(tPth, Len(tTemp))) = UCase(Right(tPthEJ, Len(tTemp)))")
                Call SP_CRTxLogFile("tPthEJ:" & tPthEJ & " tTemp:" & tTemp)
            Else
                bCopy = True
            End If
        Else
            bCopy = True
        End If
    Else
        bCopy = False
        Call SP_CRTxLogFile("tPthEJ:" & tPthEJ & " tTemp:" & tTemp)
    End If

    If bCopy Then
        If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then                        'เช็ค ON LINE หรือไม่        '*Ao 2011/03/19   CommSheet ML-PRV-046- POS Front  Terminate  Reboot and Not responding.xls
'            MsgBox "ON LINE"
            If SP_FLDbManFolder(tPthEJ, nEN_Fld3Create) Then
                If SP_FLDbManFolder(tPth, nEN_Fld3Create) Then
                    Set oFldInbox = oFSO.GetFolder(tPth)
                    For Each oFile In oFldInbox.Files
                        If UCase(Right(oFile.Path, 3)) = ".EJ" Then
                            If oFSO.FileExists(tPthEJ & "\" & oFile.Name) Then
                                Set objFile = oFSO.GetFile(tPthEJ & "\" & oFile.Name)
                                objFile.Attributes = Normal
                            End If
                             oFile.Attributes = Normal
                             Call SP_FLEbManFile(tPthEJ & "\" & oFile.Name, nEN_Fld2Delete)
                             'oFSO.MoveFile oFile.Path, tPthEJ & "\" '*KT 52-01-09 เปลี่ยนเป็นการ Copy File แล้วค่อย Delete ที่หลัง
                             oFSO.CopyFile oFile.Path, tPthEJ & "\"
                             If SP_FLEbManFile(tPthEJ & "\" & oFile.Name, nEN_Fle1Exist) Then
                                Call SP_CRTxLogFile("Send completed:" & oFile.Name)                             '*Ao 2014/03/04 CommSheet TK-ISS3000-468
                                oFSO.DeleteFile oFile.Path
                            Else
                                Call SP_CRTxLogFile("Send not completed:" & oFile.Name)                     '*Ao 2014/03/04 CommSheet TK-ISS3000-468
                            End If
                        End If
                    Next
                Else
                    Call SP_CRTxLogFile("Can not create:" & tPth)                     '*Ao 2014/03/04 CommSheet TK-ISS3000-468
                End If
            Else
                Call SP_CRTxLogFile("Can not create:" & tPthEJ)                     '*Ao 2014/03/04 CommSheet TK-ISS3000-468
            End If
        Else
            Call SP_CRTxLogFile("OFF LINE")
        End If
    End If

    Set oFSO = Nothing
    Exit Sub
ErrHandle:
'    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxLogFile("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Events:SP_MOVxEJToOnline" & " Type:Process move EJ to Server") '*KT 52-12-21 ทำการเก้บ Log การเกิด Error ที่เกี่ยวข้องการการทำ Dat File และ EJ
End Sub

