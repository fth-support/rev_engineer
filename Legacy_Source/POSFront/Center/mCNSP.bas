Public Function SP_INItGetLang(ByVal ptSectionName$, ByVal ptFunctionName$, Optional ByVal pbReturn As Boolean = False, Optional ByVal peCutLang As eEN_FedLang = nEN_FedLang1) As String
'----------------------------------------------------------
'   Call: รับค่า Section มาเพื่อนำมา Get ค่าจากไฟล์ .ini
'              นำข้อมูลที่Get มาได้ ตัดเอาเฉพาะภาษาที่ต้องการ
'               peCutLang= กรณีที่ต้องการส่งค่า Enum มาด้วย แต่ถ้าไม่ส่งมาให้ กำหนดตามภาษา
'   Ret:    String Lang
'----------------------------------------------------------
'
    Dim tCutValue$
    Dim nCut%
    
    'เช็คว่าเป็นภาษาหรือไม่ ถ้าเป็นภาษาให้ เลือกตามภาษากลาง
    If peCutLang = nEN_FedLang1 Or peCutLang = nEN_FedLang2 Then
        peCutLang = IIf(nVB_CNCutLang = 1, nEN_FedLang1, nEN_FedLang2)
    End If
    
    'เช็คว่ามีไฟล์ ini หรือเปล่า ถ้าไม่พบให้ Get ฐานข้อมูลใหม่
'    If Dir(tVB_CNPthFileINI) = "" Then                             ใช้  Dir(tVB_CNPthFileINI) ให้ค่า = ""
'            Call SP_INItLodDB2INI
'    End If
    If Not (SP_FLEbManFile(tVB_CNPthFileINI, nEN_Fle1Exist)) Then               '*Ao 51-06-10
        Call SP_INItLodDB2INI
    End If
    'เช็คดูว่าเป็นตัวเลขหรือเปล่า หรือมีค่าว่าง
    If Not IsNumeric(peCutLang) Then
        nCut = 1
    Else
        nCut = peCutLang
    End If
    
    'get ค่าจากไฟล์ ini
    tCutValue = SP_INItGetValue(tVB_CNPthFileINI, ptSectionName, ptFunctionName)
    
    If Trim(tCutValue) <> "" Then
        If pbReturn = False Then
            SP_INItGetLang = cUT.UT_STRtToken(tCutValue, ";", nCut)
        Else
            SP_INItGetLang = tCutValue
        End If
    End If
End Function

Public Sub SP_INItLodDB2INI()
    '------------------------------------------------------------------------
    ' Cmt :  Get ค่าในฐานข้อมูล เก็บไว้ใน Ini เก็บตาม Section
    '------------------------------------------------------------------------
    Dim oFSO As New FileSystemObject
    Dim tFunctionVal$, tValue$, tSectionName$, tSql$
    Dim orsTemp As ADODB.Recordset
    Dim bINISta As Boolean
    Dim tLangTemp$, tLang1$, tLang2
    Dim nLang1%, nLang2%
On Error GoTo Err_Handler
    
    tSql = " SELECT FTSlnForm, FTSlnKey,"
    tSql = tSql & " CASE WHEN " & tCS_CNLangPri & " IS NULL THEN '' ELSE  " & tCS_CNLangPri & "  END"
    tSql = tSql & " + ';' + CASE WHEN  " & tCS_CNLangSec & "  IS NULL THEN '' ELSE  " & tCS_CNLangSec & "  END"
    tSql = tSql & "  + ';' + CASE WHEN FTSlnGrp IS NULL THEN '' ELSE FTSlnGrp END"
    tSql = tSql & "  + ';' + CASE WHEN FTSlnGrdFed IS NULL THEN '' ELSE FTSlnGrdFed END"
    tSql = tSql & "  + ';' + CASE WHEN FTSlnGrdWidth IS NULL THEN '' ELSE FTSlnGrdWidth END"
    tSql = tSql & " FROM TSysLang "
    tSql = tSql & " WHERE (FTSlnStaUse = '1' OR FTSlnStaUse = '4')"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master
    tVB_CNPthFileINI = App.Path & "\" & App.EXEName & ".ini"        'Path ที่ใช้เก็บไฟล์ ini พร้อมชื่อไฟล์

    If SP_FLEbManFile(tVB_CNPthFileINI, nEN_Fle1Exist) Then
        Call SetAttr(tVB_CNPthFileINI, vbNormal)
        Call SP_FLEbManFile(tVB_CNPthFileINI, nEN_Fle2Delete)
    End If
    If SP_INIbSet(orsTemp, tVB_CNPthFileINI) Then
       ' Call SetAttr(tVB_CNPthFileINI, vbHidden)
    End If
    Call SP_DATxRsNothing(orsTemp)
    Set oFSO = Nothing
    Exit Sub
Err_Handler:
    Call SP_DATxRsNothing(orsTemp)
     Set oFSO = Nothing
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Public Function SP_INIbSet(ByVal porsTemp As ADODB.Recordset, ByVal ptFileName$) As Boolean
    '------------------------------------------------------------------------
    ' Cmt :  Get ค่าในฐานข้อมูล เก็บไว้ใน Ini เก็บตาม Section
    '------------------------------------------------------------------------
    Dim oFSO As New FileSystemObject
    Dim objFile As File
    Dim otsTemp As TextStream
    Dim tField1 As String
    Dim tField2 As String
    Dim tField3 As String
    Dim tTemp1Old As String
    Dim tTemp1 As String
    Dim tTemp2 As String
    Dim tTemp3 As String
    
    Dim tSql As String
    SP_INIbSet = False      '*Ao 51-06-10
    tField1 = porsTemp.Fields(0).Name
    tField2 = porsTemp.Fields(1).Name
    tField3 = porsTemp.Fields(2).Name
    
    If SP_FLEbManFile(tVB_CNPthFileINI, nEN_Fle1Exist) Then
        Call SP_FLEbManFile(tVB_CNPthFileINI, nEN_Fle2Delete)
    End If
    
    oFSO.CreateTextFile (tVB_CNPthFileINI)
    
    Set objFile = oFSO.GetFile(ptFileName)
    Set otsTemp = objFile.OpenAsTextStream(ForWriting)
    porsTemp.Sort = tField1
    If Not (porsTemp.BOF And porsTemp.EOF) Then
        porsTemp.MoveFirst
        Do While Not porsTemp.EOF
            tTemp1 = SP_FEDtChkString(porsTemp, tField1)
            tTemp2 = SP_FEDtChkString(porsTemp, tField2)
            tTemp3 = SP_FEDtChkString(porsTemp, tField3)
            If tTemp1Old = tTemp1 Then
            Else
                otsTemp.WriteLine "[" & tTemp1 & "]"
            End If
            otsTemp.WriteLine tTemp2 & "=" & tTemp3
            tTemp1Old = tTemp1
            porsTemp.MoveNext
        Loop
    End If
    otsTemp.Close
    Set oFSO = Nothing
    SP_INIbSet = True
End Function

