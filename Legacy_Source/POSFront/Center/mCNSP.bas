Private Function W_CHKbFindData(psBuff As WIN32_FIND_DATA _
    , ByVal pbArchive As Boolean _
    , ByVal pbCompressed As Boolean _
    , ByVal pbDirectory As Boolean _
    , ByVal pbHidden As Boolean _
    , ByVal pbNormal As Boolean _
    , ByVal pbReadOnly As Boolean _
    , ByVal pbSystem As Boolean _
    , ByVal pbTemporary As Boolean) As Boolean
    
    If (pbArchive) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_ARCHIVE > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbCompressed) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_COMPRESSED > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbDirectory) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_DIRECTORY > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbHidden) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_HIDDEN > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbNormal) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_NORMAL > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbReadOnly) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_READONLY > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbSystem) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_SYSTEM > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    If (pbSystem) And (psBuff.dwFileAttributes And FILE_ATTRIBUTE_TEMPORARY > 0) Then
        W_CHKbFindData = True
        Exit Function
    End If
    
    W_CHKbFindData = False
End Function

Public Function SP_DATbCrtTrigger(Optional ByVal pbOnline As Boolean = True, Optional ByVal pbOffline As Boolean = True) As Boolean '*KT 51-09-2008 ใส่ Byval หลัง Optional ด้วย
