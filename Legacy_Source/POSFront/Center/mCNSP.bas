                    Else
                        tSqlV = tSqlV & CStr(cVB_CNGSTRate) & ","
                    End If
                Case Else
                    Select Case UCase(Mid(tStr, 2, 1))
                        Case "T"
                            tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                        Case "N", "C"
                            tSqlV = tSqlV & 0 & ","
                        Case "D"
                            tSqlV = tSqlV & "NULL" & ","
                    End Select
            End Select
          tStr = cUT.UT_STRtToken(tF, ",", 1)
    Loop
    tSqlV = " VALUES (" & tSqlV & UT_tLastInsSql & ")"
    tSql = tSql & tSqlF & tSqlV
    nEff = 0
'    If SP_SQLvExecute(tSql, , , , , nEff) = 0 Then
'        If nEff < 1 Then
'            'เก็บ Log ไว้กรณี Insert ไม่ได้
