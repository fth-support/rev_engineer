            '*Bump 57-08-16 เก็บ sql insert HD เอาไว้ Recovery comsheet204 Missing EJ
            Call SP_CHKInsHDKeepSQL(ptTblHD, tVB_CNTerminalNum, tVB_Running, tUT_SaleDate, tVB_Transaction, tSql)
        End If
    Else
        pbIns = False
    End If
    '***********************************************
    nStep = 1

   'พี่ยูรแนะนำว่า เมื่อเริ่มบิลใหม่ ควรลบ DT and RC ทิ้งก่อนจะได้ไม่ซ้ำ
   tSql = "DELETE FROM " & tTblDT & " WITH(ROWLOCK) "
