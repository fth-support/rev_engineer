Public Function SP_GETbFindFile(ByVal ptPath As String _
    , Optional ByVal pbArchive As Boolean = True _
    , Optional ByVal pbCompressed As Boolean = True _
    , Optional ByVal pbDirectory As Boolean = True _
    , Optional ByVal pbHidden As Boolean = True _
    , Optional ByVal pbNormal As Boolean = True _
    , Optional ByVal pbReadOnly As Boolean = True _
    , Optional ByVal pbSystem As Boolean = True _
    , Optional ByVal pbTemporary As Boolean = True) As Long
'----------------------------------------------------------
'   Cmt:    ค้นหาไฟล์ เช่น C:\*.INI
'               Return ค่าเป็น Long คือจำนวนไฟล์ที่พบ ถ้า 0 คือไม่พบ
'               โดยจะเก็บชื่อไฟล์ใน tVB_FileName()
'   *** Copy มาจาก mCNSP ของ Storeback
'-----------------------------------------------------------
    Dim nHandle&, nCount&
    Dim oBuff As WIN32_FIND_DATA
    
    SP_GETbFindFile = 0
    ReDim tVB_FileName(0)
    nCount = 0
    
    nHandle = FindFirstFile(ptPath, oBuff)
    If nHandle = INVALID_HANDLE_VALUE Then Exit Function    'ไม่พบ File
    
    If W_CHKbFindData(oBuff, pbArchive, pbCompressed, pbDirectory, pbHidden, pbNormal, pbReadOnly, pbSystem, pbTemporary) Then
        nCount = nCount + 1
        ReDim Preserve tVB_FileName(nCount)
        tVB_FileName(nCount) = oBuff
    End If
    
    Do While FindNextFile(nHandle, oBuff)
        If W_CHKbFindData(oBuff, pbArchive, pbCompressed, pbDirectory, pbHidden, pbNormal, pbReadOnly, pbSystem, pbTemporary) Then
            nCount = nCount + 1
            ReDim Preserve tVB_FileName(nCount)
            tVB_FileName(nCount) = oBuff
        End If
    Loop
    
    Call FindClose(nHandle)
    SP_GETbFindFile = nCount

End Function


