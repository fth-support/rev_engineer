Public Sub SP_TBLxAddPrimaryKey(ByVal ptDBName$, ByVal ptTblName$, ByVal ptFedKeyName$, Optional ByVal poCn As ADODB.Connection)
'----------------------------------------------------------
'   Cmt:Alter Create Primary Key
'   Ret:
'----------------------------------------------------------
    Dim oCNCon As ADODB.Connection
    Dim tSql$
    On Error GoTo ErrHandle
    
    Set oCNCon = IIf(poCn Is Nothing, ocnAll, poCn)
    
    tSql = "ALTER TABLE [dbo].[" & ptTblName & "] ADD CONSTRAINT"
    tSql = tSql & " [" & ptDBName & ptTblName & "_PK] PRIMARY KEY CLUSTERED (" & ptFedKeyName & ")"
    tSql = tSql & " WITH( STATISTICS_NORECOMPUTE = OFF, IGNORE_DUP_KEY = OFF, ALLOW_ROW_LOCKS = ON, ALLOW_PAGE_LOCKS = ON)"
    tSql = tSql & " ON [PRIMARY]"
    oCNCon.Execute tSql
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

