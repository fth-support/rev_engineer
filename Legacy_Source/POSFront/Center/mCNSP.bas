Public Function SP_USRtMnuGetAutho(ByVal pnRight As eEN_UsrAutho, ByVal ptMenu$, Optional ByVal ptUsrC$) As String
'----------------------------------------------------------
'   Call:   pnRight is type of right
'               ptMenu is menu name
'   Cmt:   get authoright of user
'----------------------------------------------------------
    Dim tSql$, tFedAll$, tFed$, tAll$
    Dim tUsrC$, i%
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle

    SP_USRtMnuGetAutho = "0"       'default not allow
    
    tUsrC = IIf(ptUsrC = "", tVB_CNUserCode, ptUsrC)
    
    tFedAll = "FTSumFull,FTSumRead,FTSumAdd,FTSumEdit,FTSumDelete,FTSumCancel,FTSumAppv"
    Select Case pnRight
        Case nEN_Usr0AthAll:    tFed = tFedAll
        Case nEN_Usr1AthFull:   tFed = "FTSumFull"
        Case nEN_Usr2AthRead:   tFed = "FTSumRead"
        Case nEN_Usr3AthAdd:    tFed = "FTSumAdd"
        Case nEN_Usr4AthEdit:   tFed = "FTSumEdit"
        Case nEN_Usr5AthDelete: tFed = "FTSumDelete"
        Case nEN_Usr6AthCancel: tFed = "FTSumCancel"
        Case nEN_Usr7AthAppv:   tFed = "FTSumAppv"
    End Select
    
    tSql = "SELECT " & tFed & " FROM TSysUserMenu"
    tSql = tSql & " WHERE FTUsrCode='" & tUsrC & "'"
    tSql = tSql & " AND FTSmnID ='" & ptMenu & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) <> 0 Then Exit Function
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        If pnRight = nEN_Usr0AthAll Then
            For i = 1 To 7
                tFed = cUT.UT_STRtToken(tFedAll, ",")
                tAll = IIf(tAll = "", "", tAll & ";")
                tAll = tAll & tFed & "-" & SP_FEDtChkString(orsTemp, tFed)
            Next i
        Else
            SP_USRtMnuGetAutho = SP_FEDtChkString(orsTemp, tFed)
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    SP_USRtMnuGetAutho = "0"
    Call SP_DATxRsNothing(orsTemp)
End Function

