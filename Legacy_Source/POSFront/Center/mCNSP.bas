                    tSqlV = tSqlV & "'" & tTerminal & "',"
                Case UCase("FTShdStaType"):
                    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                        tSqlV = tSqlV & "'" & "1" & "',"
                    Else
                       tSqlV = tSqlV & "'" & "0" & "',"
                    End If
                Case UCase("FTShdStaPrcCst"):
                    tSqlV = tSqlV & "'" & "0" & "',"
                Case UCase("FTShdStaJob")
                    tSqlV = tSqlV & "'" & tVB_CNAccTypeReEntryMode & "',"
                Case UCase("FNLogStaExport")   '*Eaw 56-10-22 TK-CommSheet 382
                    tSqlV = tSqlV & "" & SP_VALnText2Double(tVB_CNTypePrinter) & ","
                Case UCase("FTCstCardCode3")
                    tSqlV = tSqlV & "'" & tVB_EJDate & "',"
                Case UCase("FTShdDisChgTxt")                '*Ao 2014/05/06
