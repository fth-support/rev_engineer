Public Sub SP_MSGxNoSendData()
'----------------------------------------------------------------------
'Cmt:  ทำการแสดงข้อความเตือนพร้อมเก็บ Lot ข้อมุลที่ยังไม่มีการส่งขึ้น Server
'----------------------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim tMsg As String
    Dim nCount As Long
On Error GoTo ErrHandle
    tMsg = ""
    tSql = "SELECT FTTmnNum,FTShdTransNo,FDShdTransDate, FTShdTransType"
    tSql = tSql & vbCrLf & "FROM TPSTSalHD WITH(NOLOCK)"
    tSql = tSql & vbCrLf & "WHERE ISNULL(FTStaSentOnOff,'0') <> '1'"
     tSql = tSql & vbCrLf & "AND FDShdTransDate <= '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " ORDER BY FTShdTransNo ASC"
    If SP_SQLvExecute(tSql, orsTemp) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            nCount = orsTemp.RecordCount
            If nCount > 0 Then
'                '*Tao 61-11-20 ของเดิม
'                tMsg = "DO NOT SEND DATA " & nCount & " TRANSACTION " & " BEGIN " & SP_FEDtChkString(orsTemp, "FTShdTransNo")
'                If nCount > 1 Then
'                    orsTemp.MoveLast
'                    tMsg = tMsg & " TO " & SP_FEDtChkString(orsTemp, "FTShdTransNo")
'                Else
'                    tMsg = tMsg & " TO " & SP_FEDtChkString(orsTemp, "FTShdTransNo")
'                End If

                '*Tao 61-11-20 TK-ISS3000-712 TK ISSUE - TK Request - Modify exit terminal for resend transaction
                tMsg = nCount & " trx " & "(" & SP_FEDtChkString(orsTemp, "FTShdTransNo")
                If nCount > 1 Then
                    orsTemp.MoveLast
                    tMsg = tMsg & " - " & SP_FEDtChkString(orsTemp, "FTShdTransNo") & ")"
                Else
                    tMsg = tMsg & ")"
                End If
                tMsg = tMsg & " has not been sent."
            End If
        End If
    End If
    If tMsg <> "" Then
        MsgBox tMsg, vbCritical
        Call SP_CRTxLogPrg("ErrorNumber:0" & " ErrorDesc:" & tMsg & " Form:" & "mCNSP" & " Step:Audit results send data to Server" & " Events:SP_MSGxNoSendData")
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    
End Sub

