            'เก็บ Log ไว้กรณี Insert ไม่ได้
            Call SP_LOGxTableUpdate("INSERTHD", "SaleHD", "TmnNum:" & tVB_CNTerminalNum & " TransNo:" & tVB_Running & " TransDate:" & tUT_SaleDate, 2)
            Call SP_CRTxWriteLogTerminated("INSERTHD(" & "TmnNum:" & tVB_CNTerminalNum & " TransNo:" & tVB_Running & " TransDate:" & tUT_SaleDate & ") Error:" & tSql) '*Bump 57-07-03
            pbIns = False
        Else
