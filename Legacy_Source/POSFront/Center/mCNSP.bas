Public Sub SP_GRDxSetProperty(ByVal poVsGrd As VSFlexGrid, ByVal ptFedCsShw$, ByVal ptColWidth$, _
                                                                    ByVal pnColShw As Long, Optional pbNoKeyEdit As Boolean, Optional pnColStart% = 1)
'----------------------------------------------------------
'   Call:   poVsGrd as VsFlexGrid
'               ptFedCsShw constant field to be in column, "FTSdtCode,FTSdtName,..."
'               ptColWidth width of each column,    "900;1200;100;.."
'               pnColShw number of columns to show
'   Cmt:   set grid properties such as Key, DataType, Format, Alignment, Width
'----------------------------------------------------------
    Dim tTempStr$, tCut$
    Dim nCol As Long
    Dim nPos As Long
    Dim i%

    With poVsGrd
        tTempStr = ptFedCsShw
        nCol = pnColStart
        Do While tTempStr <> ""
            tCut = Trim(cUT.UT_STRtToken(tTempStr, ","))
            nPos = InStrRev(tCut, " ", Len(tCut))
            tCut = Mid(tCut, nPos + 1)
            .ColKey(nCol) = tCut        'Set  column key
            .FixedAlignment(nCol) = flexAlignCenterCenter        'Set column header alignment
            Select Case Mid(.ColKey(nCol), 2, 1)
                Case "T"
                       .ColDataType(nCol) = flexDTString
                       .ColAlignment(nCol) = flexAlignLeftCenter
                Case "N"
                       .ColDataType(nCol) = flexDTLong
                       .ColAlignment(nCol) = flexAlignRightCenter
                       .ColFormat(nCol) = "########0"
                Case "C"
'                       .ColDataType(nCol) = flexDTCurrency
                       .ColDataType(nCol) = flexDTDouble        '*AO 51-03-31
                       .ColAlignment(nCol) = flexAlignRightCenter
                       .ColFormat(nCol) = SP_FMTtNum2Set
                       
                Case "D"
                       .ColDataType(nCol) = flexDTDate
                       .ColAlignment(nCol) = flexAlignCenterCenter
                       .ColFormat(nCol) = "dd/mm/yyyy"
                Case "B"
                       .ColDataType(nCol) = flexDTBoolean
                       .ColAlignment(nCol) = flexAlignCenterCenter
                Case Else
            End Select
            tCut = cUT.UT_STRtToken(ptColWidth, ";")
            .ColWidth(nCol) = SP_VALcText2Double(tCut, 100)
            nCol = nCol + 1
        Loop
        
        For i = pnColShw To .Cols - 1
            .ColHidden(i) = True
        Next i
        
        'some grid no need KeyEdit, KeyDummy, ค่าปรกติจะเป็น False แสดงว่าต้องการ
        If Not pbNoKeyEdit Then
            .ColKey(.Cols - 2) = "KeyEdit"          'from constant field get "1 AS KeyEdit", so rewrite again
            .ColKey(.Cols - 1) = "KeyDummy"  'from constant field get "1 AS KeyDummy", so rewrite again
        End If
    End With
End Sub

