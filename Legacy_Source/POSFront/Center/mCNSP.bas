Public Function SP_FLEbExist(ByVal ptFileName$, ByVal pbShowErr As Boolean) As Boolean
'----------------------------------------------------------
'   Call:   ptFileName is file that want to check
'   Ret:    True, if file existing
'----------------------------------------------------------
    Dim tFileExist$, bNotFound As Boolean
    Dim i%, tMsg$
    Dim oFSO As Object
    
    On Error GoTo ErrHandler
    
    SP_FLEbExist = False
        
    tFileExist = Trim(ptFileName)
    If tFileExist = "" Then
        Exit Function
    End If
    
    'check file existing
    Set oFSO = CreateObject("Scripting.FileSystemObject")
    If (oFSO.FileExists(ptFileName)) Then
        SP_FLEbExist = True
    Else
        bNotFound = True
        GoTo ErrHandler
    End If
    
    Exit Function
ErrHandler:
    SP_FLEbExist = False
    If bNotFound Then
        If pbShowErr Then
            Dim nPos%
            nPos = IIf(bVB_CNShwThai, 1, 2)
            tMsg = UT_tToken(SP_INItGetValue(tVB_CNPthFileINI, "All", "tms_CN008026"), ";", nPos)
            tMsg = tMsg & " '" + tFileExist + "'"
            i = SP_MSGnShowing(tMsg, nCS_Error, True)
        End If
    Else
        Call SP_MSGxShowError(Err.Number, Err.Description)
    End If
End Function

Public Function SP_THAnCutLng(ByVal pnCutType As eEN_CutCaption) As Integer
'----------------------------------------------------------
'   Call:
'   Cmt:    set position to cut string in cUT.UT_STRtToken, Primary Language=1, Socondary Language = 2
'----------------------------------------------------------
    Dim nPos As Integer
    Select Case pnCutType
        Case nEN_Cut1Msg
            nPos = IIf(nVB_CNCutLang = 2, 1, 2)
        Case nEN_Cut2Tag
            nPos = IIf(nVB_CNCutLang = 2, 3, 2)
        Case nEN_Cut3Const
            nPos = IIf(nVB_CNCutLang = 2, 1, 2)
    End Select
    SP_THAnCutLng = nPos
End Function

