Public Sub SP_CLRxClearImp(ByVal ptPthClear As String, Optional ByVal ptFileType As String = "")
'-------------------------------------------------------------------------------------------------
'   Cmt:  Move ZipFile From Inbox To BackUp's Folder
'              & Cleare Folders/Files in Import's Folder Before Unzip To..
'-------------------------------------------------------------------------------------------------
On Error GoTo ErrHandle
    Dim oFSO As New FileSystemObject
    Dim tPthImp$, tFileImp$, tFileSubBch$, tFileSubMST$, tFldSubMST$, tFldSubBch$
    Dim oFldImp As Folder
    Dim oFldSBch As Folders
    Dim oFldSubBch As Folder
    Dim oFldSMST As Folders
    Dim oFldSubMST As Folder
    Dim oFileImp As File
    Dim oFileSubBch As File
    Dim oFileSubMST As File

    tPthImp = ptPthClear
    Set oFldImp = oFSO.GetFolder(tPthImp)
    For Each oFileImp In oFldImp.Files
        tFileImp = oFileImp.Path
        oFileImp.Attributes = Normal
        If ptFileType <> "" Then
             If UCase(Right(tFileImp, 4)) = UCase(ptFileType) Then
                oFSO.DeleteFile (tFileImp)
            End If
        Else
            oFSO.DeleteFile (tFileImp)
        End If
    Next oFileImp
    Set oFldSBch = oFldImp.SubFolders
    For Each oFldSubBch In oFldSBch
        For Each oFileSubBch In oFldSubBch.Files
            tFileSubBch = oFileSubBch.Path
            oFileSubBch.Attributes = Normal
            If ptFileType <> "" Then
                If UCase(Right(tFileSubBch, 4)) = UCase(ptFileType) Then
                    oFSO.DeleteFile (tFileSubBch)
                End If
            Else
                oFSO.DeleteFile (tFileSubBch)
            End If
        Next oFileSubBch
        Set oFldSMST = oFldSubBch.SubFolders
        For Each oFldSubMST In oFldSMST
            For Each oFileSubMST In oFldSubMST.Files
                tFileSubMST = oFileSubMST.Path
                oFileSubBch.Attributes = Normal
                If ptFileType <> "" Then
                    If UCase(Right(tFileSubMST, 4)) = UCase(ptFileType) Then
                        oFSO.DeleteFile (tFileSubMST)
                    End If
                Else
                    oFSO.DeleteFile (tFileSubMST)
                End If
            Next oFileSubMST
            If ptFileType = "" Then
                tFldSubMST = oFldSubMST.Path
                oFldSubMST.Attributes = Normal
                oFSO.DeleteFolder (tFldSubMST)
            End If
        Next oFldSubMST
        If ptFileType = "" Then
            tFldSubBch = oFldSubBch.Path
            oFldSubBch.Attributes = Normal
            oFSO.DeleteFolder (tFldSubBch)
        End If
    Next oFldSubBch
    Set oFSO = Nothing
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxLogPrg("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "mCNSP" & " Control:mCNSP" & " Events:SP_CLRxClearImp")
End Sub

Public Function SP_FLDtBrowser(ByVal pwForm As Form, ByVal ptTitle As String) As String
'----------------------------------------------------------
'   Call:   pwForm as form
'               ptTitle as title of dialogue
'   Ret:    string of filename
'----------------------------------------------------------
    Dim nResult As Long
    Dim oTypeBrw As BROWSEINFO        'API
    Dim nList As Long
    Dim tPath As String
    Dim nPos As Integer
    
    oTypeBrw.pidlRoot = 0
    oTypeBrw.pszDisplayName = String$(266, vbNullChar)
    oTypeBrw.ulFlags = BIF_NEWDIALOGSTYLE
    oTypeBrw.lpfn = 0
    oTypeBrw.hOwner = pwForm.hwnd
    oTypeBrw.lpszTitle = ptTitle
    
    nList = SHBrowseForFolder(oTypeBrw)
    tPath = Space$(512)
    nResult = SHGetPathFromIDList(ByVal nList, ByVal tPath)
    If nResult Then
        nPos = InStr(tPath, Chr(0))
        SP_FLDtBrowser = Left$(tPath, nPos - 1)
    Else
        SP_FLDtBrowser = ""
    End If
End Function

Public Sub SP_PrnPollDisplay(ByVal ptPrint As String)
'---------------------------------------
'Call:
'Cmt: Display by OPOS
'----------------------------------------
    Dim nLine As Long
    Dim nColumn As Long
    Dim nI As Integer
    Dim tPrint$
On Error GoTo ErrHandle
    nLine = 2
    nColumn = 20
    If Not bVB_OPOSLineDisplayEnable Then Exit Sub
    With oOpos
        .ClearDisplay
        For nI = 1 To nLine
            tPrint = UT_tToken(ptPrint, ";", nI, True)
            If nI = 1 Then
                tPrint = Left(Trim(tPrint), 20)
                tPrint = tPrint & String(20 - Len(tPrint), Space(1))
            Else
                tPrint = Chr(10) & Format(tPrint, "@@@@@@@@@@@@@@@@@@@@")
            End If
            .DisplayLine tPrint, DISP_DT_NORMAL
        Next nI
    End With
    Exit Sub
ErrHandle:
    MsgBox "Line Display is problems.", vbCritical
End Sub

Public Function SP_CHKtCurPoint(ByVal ptCurPoint As String) As String   '*AO51-03-12    Comm.Sheet SF- 070
'_____________________________________________________________
'   Call:
'   Cmt:    ตัดทศนิยม 2 ตำแหน่ง
'_____________________________________________________________
    Dim tRight As String, tLeft As String
    If Len(ptCurPoint) < 3 Then
        SP_CHKtCurPoint = "0"
