            cPointSumAvg = 0
            pcPointAmt = pcPointAmt + cSKUAmtSec
            For nI = 0 To UBound(aW_SKUAmtBySec) - 1
               ' ตรวจสอบ Min สาเหตุที่ไม่ตรวจสอบตั้งแต่ขั้นแรก เนื่องมีความเป็นไปได้ที่มีการ Scan ขายสินค้าเดียวกันมากกว่า 1 รายการ จึงต้องตรวจสอบในขั้นนี้
                If Val(Format(SP_FMTcCurPoint(aW_SKUAmtBySec(nI).cAmt, True, False))) >= Val(Format(SP_FMTcCurPoint(aW_SKUAmtBySec(nI).cMin, True, False))) Then
                    If aW_SKUAmtBySec(nI).cRank > 0 Then
                        cPointSec = (aW_SKUAmtBySec(nI).cAmt \ IIf(aW_SKUAmtBySec(nI).cRank = 0, 1, aW_SKUAmtBySec(nI).cRank)) * aW_SKUAmtBySec(nI).nTime
                    Else
                        cPointSec = 0
                    End If
                    porsTemp.MoveFirst
                    porsTemp.Filter = "FTSKUCode='" & aW_SKUAmtBySec(nI).tSKU & "'"
                    porsTemp.Sort = "FNSdtSeqNo ASC"
                    If Not (porsTemp.BOF And porsTemp.EOF) Then
                        porsTemp.MoveLast
                        nLSeqNo = SP_FEDtChkString(porsTemp, "FNSdtSeqNo")
                        porsTemp.MoveFirst
                        Do While Not porsTemp.EOF
                            nSeq = SP_FEDvChkNumeric(porsTemp, "FNSdtSeqNo")
