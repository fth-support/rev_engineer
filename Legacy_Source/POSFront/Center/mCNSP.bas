                                                            Call SP_PRCxPointMEM(tCardNo, cSrcAmt, tCardExp, nSeqNo, tStaChkExp, False, bLowBP, nLowBPPoint, cRefSrcAmt)
                                                        Else
                                                            cW_PointMem = 0
                                                        End If
                                                    Else
                                                        Call SP_PRCxPointMEM(tCardNo, cSrcAmt, tCardExp, nSeqNo, tStaChkExp, False, , , cRefSrcAmt)
                                                    End If
