Public Sub W_AddxCloseSuspend(ByVal ptTblHD As String, ByVal ptTransType As String, ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
'-------------------------------------------------------------------------
