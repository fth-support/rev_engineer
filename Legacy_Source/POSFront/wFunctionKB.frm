        nCRow = .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))
        If nCRow > 0 Then
             Call SP_MSGnShowing("tms_CN005109", nCS_Information)
             cUT_Qty = 1
            If bVB_CNTrStaRegPreviewDay Then
                Call SP_INIxSwitchModePreviewDay(True)
            Else
                Call SP_INIxSwitchModePreviewDay(False)
            End If
             wMain.otbPrompt.Locked = False
             wMain.otbPrompt.Text = vbNullString
             Call SP_OBJxSetFocus(wMain.otbPrompt)
             Exit Sub         'if no item in grid, nothing to do
         End If
    End With

    If bAccept Then     'if level is ok
        Select Case SP_VALnText2Double(tVB_TransactionSub)
            Case tEN_TrnSale, tEN_TrnDeposit, tEN_TrnCreateVIP, tEN_TrnTaxExceptSale, tEN_TrnDutyFreeSale
                If (tEN_TrnCreateVIP = SP_VALnText2Double(tVB_TransactionSub)) And tVB_CNPreDayIDReg <> "" Then
                    Call SP_MSGnShowing("tms_CN005107", nCS_Information)
                    Exit Sub
                End If
                If SP_CHKbPeriodPreDay Then
                    wCNPreDayMenu.Show vbModal
                    If bVB_CNTrStaRegPreviewDay Then
                        Call SP_INIxSwitchModePreviewDay(True)
                        wMain.olaTransName.Caption = "Preview/" & tVB_TransName
                        Select Case nVB_RegPreType
                            Case 1 'Credit Card
                                Call SP_GETxRecDataCrdPrv
                            Case 2 'Member Card
                                Call SP_GETxRecDataMallPrv
                            Case 3 'None Card
                                Call SP_GETxRecDataMallPrv
                        End Select
                        If Not SP_UPDbPreviewDayHD Then 'บันทึกข้อมูล Preview Day ลงตาราง HD
                            Call SP_MSGnShowing("tms_CN005221", nCS_Warning)
                            Call SP_INIxSwitchModePreviewDay(False)
                            Call SP_INIxClearVarPrv
                            wMain.olaTransName.Caption = tVB_TransName
                        End If
                    Else
                        Call SP_INIxSwitchModePreviewDay(False)
                        Call SP_INIxClearVarPrv
                        wMain.olaTransName.Caption = tVB_TransName
                    End If
                Else
                    Call SP_INIxSwitchModePreviewDay(False)
                    Call SP_INIxClearVarPrv
                    Call SP_MSGnShowing("tms_CN005107", nCS_Information)
                    wMain.olaTransName.Caption = tVB_TransName
                End If
            Case Else
                Call SP_INIxSwitchModePreviewDay(False)
                Call SP_INIxClearVarPrv
                Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        End Select
    Else    'level ไม่ผ่าน
        Call SP_INIxSwitchModePreviewDay(False)
        Call SP_INIxClearVarPrv
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
End Sub

