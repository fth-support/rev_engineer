'----------------------------------------------------------
    Dim nRow As Long
    Dim tSql$
    Dim tWhr$
    Dim orsTemp As ADODB.Recordset
    Dim nSeqNo As Long
    
    
    With wMain.ogdForm
        .Row = .FixedRows
        .rows = nUT_GridMaxRow
        nRow = .FixedRows
        tSql = "SELECT *  "
        tSql = tSql & " FROM " & tVB_CNTblDT
        tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
         tSql = tSql & " ORDER BY FNSdtSeqNo"
        Call SP_SQLvExecute(tSql, orsTemp)
        Do While Not orsTemp.EOF
            If nRow >= .rows Then .rows = .rows + 1
            nSeqNo = SP_FEDvChkNumeric(orsTemp, "FNSdtSeqNo")
            tWhr = " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
            tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
            tWhr = tWhr & " AND  FNSdtSeqNo=" & nSeqNo
            tWhr = tWhr & " AND  FNDctNo IN (1,2,3,21)" '*KT 52-09-07 Member + Consignment
            tWhr = tWhr & " AND ISNULL(FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
            bVB_SKUisPromotion = IIf(SP_FMTtNum2Shw(SP_SQLtFunction("", "FCScdAmt", tVB_CNTblCD, tWhr)) > 0, True, False)
            'อ้างอิง Comm.Sheet  ML-SF-083 (Mall Card Flag = No)  ต้องมีเครื่องหมาย * อยู่หน้า Barcode
            If Not bVB_SKUisPromotion Then
                bVB_SKUisPromotion = IIf(SP_FEDtChkString(orsTemp, "FTSkuStaMallEmpCard") = "Y", False, True)  '*KT 51-03-27 Comsheet ML-SF-083
            End If
            '*KT 55-08-17 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
            tVB_SKUSymbol = ""
             '*Eaw 55-12-06  เปลี่ยนเป็นใช้เครื่องหมาย *สำหรับ Alw Member Card ,# สำหรับ Alw Emp Card
             tVB_CNSkuStaAlw = SP_FEDtChkString(orsTemp, "FTSdtStaPdt")
            If Mid(tVB_CNSkuStaAlw, 20, 1) = "0" Then tVB_SKUSymbol = "#"       'ไม่ให้ส่วนลดEmp card
            If Mid(tVB_CNSkuStaAlw, 9, 1) = "0" Then tVB_SKUSymbol = "*"       'ไม่ให้ส่วนลดMember card
            If Mid(tVB_CNSkuStaAlw, 20, 1) = "0" And Mid(tVB_CNSkuStaAlw, 9, 1) = "0" Then tVB_SKUSymbol = "*" 'ไม่ให้ส่วนลด Mall+Emp
'            If Mid(tVB_CNSkuStaAlw, 9, 1) = "1" And Mid(tVB_CNSkuStaAlw, 21, 1) = "1" Then
'                tVB_SKUSymbol = "@"
'            ElseIf Mid(tVB_CNSkuStaAlw, 9, 1) = "1" Then
'                tVB_SKUSymbol = "#"
'            End If
            
            .TextMatrix(nRow, .ColIndex("FTPmt")) = IIf(bVB_SKUisPromotion, "*", "")
            .TextMatrix(nRow, .ColIndex("FTSymbol")) = tVB_SKUSymbol '*KT 55-08-17 Takashimaya
            .TextMatrix(nRow, .ColIndex("FNSdtSeqNo")) = nSeqNo
            '*KT 52-03-01 PH2-ML-SB-XXX
            If SP_FEDtChkString(orsTemp, "FTSdtInstoreBar") = "" Then
                    .TextMatrix(nRow, .ColIndex("FTSdtBarCode")) = SP_FEDtChkString(orsTemp, "FTSdtBarCode")  'Barcode
            Else
                    .TextMatrix(nRow, .ColIndex("FTSdtBarCode")) = SP_FEDtChkString(orsTemp, "FTSdtInstoreBar")  'Barcode
            End If
            .TextMatrix(nRow, .ColIndex("FTSkuCode")) = SP_FEDtChkString(orsTemp, "FTSkuCode")    'รหัสสินค้า
            .TextMatrix(nRow, .ColIndex("FCSdtQty")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtQty"), False, True) 'จำนวนเป็นจำนวนเต็ม
            .TextMatrix(nRow, .ColIndex("FCSdtRegPrice")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtRegPrice"), False, True)     'ราคา ป.ป.
            .TextMatrix(nRow, .ColIndex("FNSdtQty")) = Format(SP_FEDvChkNumeric(orsTemp, "FCSdtQty"), "#,##0") 'จำนวนเป็นจำนวนเต็ม
            .TextMatrix(nRow, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSalePrice"), False, True)    'ราคา ป.ป.
            .TextMatrix(nRow, .ColIndex("FCSdtSaleUnit")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleUnit"), False, True)     'ราคา ป.ป.
            .TextMatrix(nRow, .ColIndex("FTSkuAbbName")) = SP_FEDtChkString(orsTemp, "FTSkuAbbName")
            .TextMatrix(nRow, .ColIndex("FTSkuAbbNameSnd")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSnd")
            .TextMatrix(nRow, .ColIndex("FTSkuAbbNameSrvDoc")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSrvDoc")
            .TextMatrix(nRow, .ColIndex("FTSkuAbbNameSndSrvDoc")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSndSrvDoc")
            .TextMatrix(nRow, .ColIndex("FTSdtUnitName")) = SP_FEDtChkString(orsTemp, "FTSdtUnitName")
            .TextMatrix(nRow, .ColIndex("FCSdtDis")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtDis"), False, True)
            .TextMatrix(nRow, .ColIndex("FCSdtChg")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtChg"), False, True)
            .TextMatrix(nRow, .ColIndex("FTTaxCode")) = SP_FEDtChkString(orsTemp, "FTTaxCode")
            .TextMatrix(nRow, .ColIndex("FCSdtTax")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtTax"), False, True)
            .TextMatrix(nRow, .ColIndex("FCSdtQtyAll")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtQtyAll"), False, True)
            .TextMatrix(nRow, .ColIndex("FTTaxSign")) = SP_FEDtChkString(orsTemp, "FTTaxSign")
            .TextMatrix(nRow, .ColIndex("FTTaxStaSign")) = SP_FEDtChkString(orsTemp, "FTTaxStaSign")
            .TextMatrix(nRow, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt"), False, True)
            .TextMatrix(nRow, .ColIndex("FTSdtPriceOverideFlag")) = SP_FEDtChkString(orsTemp, "FTSdtPriceOverideFlag")
            .TextMatrix(nRow, .ColIndex("FTSdtCancelFlag")) = SP_FEDtChkString(orsTemp, "FTSdtCancelFlag")
            .TextMatrix(nRow, .ColIndex("FTSdtStaPdt")) = SP_FEDtChkString(orsTemp, "FTSdtStaPdt")
            .TextMatrix(nRow, .ColIndex("FTSdtStaRfd")) = SP_FEDtChkString(orsTemp, "FTSdtStaRfd")
            .TextMatrix(nRow, .ColIndex("FTSdtWeight")) = SP_FEDtChkString(orsTemp, "FTSdtWeight") 'PH 2.0 ML-SF-042  Cannot Cancel weight item on TP2000 ?????????? ???????? 13 line
            .TextMatrix(nRow, .ColIndex("FTSdtConsignFlag")) = SP_FEDtChkString(orsTemp, "FTSdtConsignFlag")  '*KT 52-08-06
            .Refresh '*KT 53-01-14 DoEvents
            nRow = nRow + 1
            orsTemp.MoveNext
        Loop
       Call SP_DATxRsNothing(orsTemp)
    End With
End Sub

