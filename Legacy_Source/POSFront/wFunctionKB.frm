    cQty = 0: cAmt = 0
    tName = "TotRoundDiffIn"
    tSql = "SELECT  "
    tSql = tSql & vbCrLf & " COUNT(FTShdTransNo) AS FCNum"
    If bVB_ReEntryMode Then
        Select Case tVB_CNMnuCurrent
            Case "172003", "172005"
                 tSql = tSql & vbCrLf & " ,SUM(CASE WHEN  FTShdTransType IN ('" & Format(0, "00") & "')"                                           '*Ao 2013/08/14 CommSheet TK-ISS3000-312-313 -UAT-FAPL-089.xlsx
'                tSql = tSql & vbCrLf & " ,SUM(CASE WHEN  FTShdTransType IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "')"
            Case "172103", "172105"
                tSql = tSql & vbCrLf & " ,SUM(CASE WHEN  FTShdTransType IN ('" & Format(0, "00") & "')"
'                tSql = tSql & vbCrLf & " ,SUM(CASE WHEN  FTShdTransType IN ('" & Format(tEN_TrnSaleManualTax, "00") & "')"
                
            Case Else
