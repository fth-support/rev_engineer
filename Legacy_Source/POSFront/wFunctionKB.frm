                '4 ตรวจสอบ member price '*KT 52-02-16 member price
                Call W_PRCxMemberPrice(nCurRow, tUT_SKUCode, cMBQty) '*KT 52-09-23 Analyse code
                
                '5 ตรวจสอบ Cooperate Discount
                If Format(SP_FEDdChkDate(orsSKU, "FDSkuCoDisEndDate"), "YYYY/MM/DD") >= Format(SP_GETdChkDateDisc, "YYYY/MM/DD") And SP_FEDtChkString(orsSKU, "FTSkuStaCoDisAlw") = "Y" Then '*KT 52-06-04 ตรวจสอบวันที่หมดอายุตามวันที่ที่กำหนดใน parameter
                    Call W_PRCxCoDisc(nCurRow)
                End If
                                                    
        End Select
        
        cNet = SP_VALcText2Double(wMain.ogdForm.TextMatrix(nCurRow, wMain.ogdForm.ColIndex("FCSdtSaleAmt")))
        'cVat = IIf(tVB_SKUTaxCode <> "00", SP_FMTcCurPoint(SP_CALcVatValue(IIf(tVB_CNRetVATInOrEx = "1", True, False), cNet, cVB_SKUTaxRate), True, False), 0)                            '1:vat, 2:novat (0)
        cVat = IIf(tVB_SKUTaxCode <> "00", SP_FMTcCurPoint(SP_CALcVatValue(IIf(tVB_CNRetVATInOrEx = "2", True, False), cNet, cVB_SKUTaxRate), True, False), 0)  '*tVB_CNRetVATInOrEx 1:รวมใน, 2: แยกนอก แก้ไขให้ถูกต้องตามการคำนวณใน SP_CALcVatValue '*Bump 66-03-23
        cVatable = IIf(tVB_SKUTaxCode <> "00", cNet - cVat, 0)
        Select Case Val(Format(tVB_TransactionSub)) '*Eaw 56-08-26 CommSheet TK-ISS3000-283 TR FAPL-63 00.00.04.xls
        Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax
            cVatable = cNet
        End Select
        tSql = "UPDATE " & tVB_CNTblDT
        tSql = tSql & vbCrLf & "SET FCSdtVat = " & SP_FMTcCurPoint(cVat, True, False)
        tSql = tSql & vbCrLf & ",FCSdtVatable = " & SP_FMTcCurPoint(cVatable, True, False)
        If tVB_StaMemPriceAlw = "N" Then
            tSql = tSql & vbCrLf & ",FTSdtStaRfd= '" & "N" & "'"
        End If
        '*Ao 2010/12/24    Price Override
        tSql = tSql & vbCrLf & ",FCAFGroupPM = " & SP_FMTcCurPoint(cNet, True, False)
        '______________________________________________________________________________
        tSql = tSql & vbCrLf & " WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND  FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND   FNSdtSeqNo = " & nCurRow 'wMain.ogdForm.TextMatrix(nCurRow, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
        
        Call SP_SQLvExecute(tSql)
        
        bVB_CNStaMain = False
        
        'show detail item
       '  If wMain.olaChange.Visible Then wMain.olaChange.Visible = False '*KT 54-09-20 V.4.0.1 กรณีที่ไม่เป็น OPOS ในการแสดงเงินทอน
        wMain.olaPrice.Caption = SP_FMTcCurPoint(wMain.ogdForm.TextMatrix(nCurRow, wMain.ogdForm.ColIndex("FCSdtSaleAmt")), False)
        wMain.olaBarcode.Caption = tUT_SKUBarC
        wMain.olaSKUName.Caption = tUT_SKUName
        wMain.otbPrompt.Text = vbNullString
        If wMain.otbPrompt.Visible And wMain.otbPrompt.Enabled Then wMain.otbPrompt.SetFocus

        'show poll
         If bVB_OPOSLineDisplayEnable Then
            'tPrint = wMain.ogdForm.TextMatrix(nCurRow, wMain.ogdForm.ColIndex("FTSdtBarCode")) & ";" & wMain.ogdForm.TextMatrix(nCurRow, wMain.ogdForm.ColIndex("FCSdtSaleAmt"))
            '*KT 52-05-20 PH 1.8 ML-SF-067  Customer Display เวลาแสดงScan สินค้า ให้แสดงชื่อแผนก (Department Description) และราคา
'            tPrint = Mid(SP_SQLtFunction("", "FTDpcName", "TCNMSkuDepCls", " WHERE FTDpcCode = '" & tVB_CNDpcCode & "'", oDB.ocnOnLine, True, True), 1, 20) 'read master
'            tPrint = Mid(SP_FEDtChkString(orsSKU, "FTDpcName"), 1, 20) 'read Department/class description '*KT 52-09-23 Analyse code
            tPrint = Trim(tUT_SKUName) '*Eaw 56-07-01 '*Eaw 56-07-01CommSheet TK-ISS3000-252-TR.xls แก้ให้แสดง Display เป็น SKU Name
            tPrint = tPrint & ";" & wMain.ogdForm.TextMatrix(nCurRow, wMain.ogdForm.ColIndex("FCSdtSaleAmt"))
            Call SP_PrnPollDisplay(tPrint)
        End If
        
        Call wMain.W_ClearValAfterInsTSDT
        Call wMain.W_SumAmount
        Call wMain.W_UPDxTransHD
        cUT_Qty = 1
        wMain.olaRef.Caption = ""
        If Not (orsSKU Is Nothing) Then Call SP_DATxRsNothing(orsSKU)  'orsSKU.Close
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        If bVB_CNTrStaRegPreviewDay Then
           Call SP_INIxSwitchModePreviewDay(True)
        Else
           Call SP_INIxSwitchModePreviewDay(False)
        End If
    End If
   Call SP_DATxRsNothing(orsSKU)
   Exit Sub
ErrHandle:
    tSql = "DELETE " & tVB_CNTblDT
    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND   FNSdtSeqNo=" & nCurRow
    Call SP_SQLvExecute(tSql)
    tSql = "DELETE " & tVB_CNTblCD
    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND   FNSdtSeqNo=" & nCurRow
    Call SP_SQLvExecute(tSql)
    wMain.ogdForm.RemoveItem nCurRow
    If nCurRow <= nUT_GridMaxRow Then wMain.ogdForm.rows = nUT_GridMaxRow
    Call wMain.W_ClearValAfterInsTSDT
    Call wMain.W_SumAmount
    Call wMain.W_UPDxTransHD
     wMain.otbPrompt.Text = vbNullString
    cUT_Qty = 1
    wMain.olaRef.Caption = ""
    If bVB_OPOSLineDisplayEnable Then
        tPrint = ""
        Call SP_PrnPollDisplay(tPrint)
    End If
    If Not (orsSKU Is Nothing) Then Call SP_DATxRsNothing(orsSKU)  'orsSKU.Close
End Sub


Private Sub W_PRCxFindSKUPoint(ByVal ptSKUCode As String)
'----------------------------------------------------------
'   Call:
'   Cmt: หา Member Point ของ SKU
'----------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle

'    tSql = " SELECT    TP.FTSkuCode, TP.FDPpcStaMemPoint, TP.FCPpcStaMemPoint,"
'    tSql = tSql & vbCrLf & "TP.FTPpcStaMemPointAlw , TP.FTPpcStaActsku, TP.FTEvnCode"
'    tSql = tSql & vbCrLf & "FROM   TCNMSKU SKU INNER JOIN"
'    tSql = tSql & vbCrLf & "TCNMSkuPoint TP ON SKU.FTSkuCode = TP.FTSkuCode"
'    tSql = tSql & vbCrLf & "WHERE TP.FTSkuCode = '" & Trim(ptSKUCode) & "'"

'    tSql = " SELECT    TP.FTSkuCode, TP.FDPpcStaMemPoint, TP.FCPpcStaMemPoint,"
'    tSql = tSql & vbCrLf & "TP.FTPpcStaMemPointAlw , TP.FTPpcStaActsku, TP.FTEvnCode"
'    tSql = tSql & vbCrLf & "FROM   TCNMSkuPoint TP "
'    tSql = tSql & vbCrLf & "WHERE TP.FTSkuCode = '" & Trim(ptSKUCode) & "'"
    If bVB_CNModePreviewDay And tVB_CNSKUFlagNotAlwPrvUse = "N" Then
         tSql = "STP_CNxGETDataSKUPointPreDayBySKUCode @ptSKUCode ='" & Trim(ptSKUCode) & "'"
    Else
        tSql = "STP_CNxGETDataSKUPointBySKUCode @ptSKUCode ='" & Trim(ptSKUCode) & "'"
    End If
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then  'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            dVB_CNSkuDatePoint = SP_FEDdChkDate(orsTemp, "FDPpcStaMemPoint")
            If Format(dVB_CNSkuDatePoint, "YYYY/MM/DD") >= Format(SP_GETdChkDatePoint, "YYYY/MM/DD") Then
                 tVB_CNSkuPointCooAlw = SP_FEDtChkString(orsTemp, "FTPpcStaMemPointAlw")
                 tVB_CNSkuPointAlw = "Y"
                 tVB_CNSkuEventPoint = SP_FEDtChkString(orsTemp, "FTEvnCode")
                 tVB_CNSKUStaFixPointFlag = SP_FEDtChkString(orsTemp, "FTPpcStaFixPointFlag") '*KT 54-08-10 V.4.0.1 Req.1 Phase4.0(Member Point) SKU Point with multiply by time
                 tVB_CNSKUStaFixPointFlag = IIf(tVB_CNSKUStaFixPointFlag = "", "N", tVB_CNSKUStaFixPointFlag) 'ป้องกันค่าเดิมที่ไม่มีค่า
                 'ถ้า FTPpcStaFixPointFlag ="Y" ให้เก็บ cVB_CNSkuPointAmt =FCPpcStaMemPoint ถ้าไม่ใช่  cVB_CNSkuPointAmt =FNPpcMemTime
                If tVB_CNSKUStaFixPointFlag = "Y" Then
                    cVB_CNSkuPointAmt = SP_FEDvChkNumeric(orsTemp, "FCPpcStaMemPoint")
                Else
                    cVB_CNSkuPointAmt = SP_FEDvChkNumeric(orsTemp, "FNPpcMemTime")
                End If
                tVB_CNSkuPointAlwDiscountMall = SP_FEDtChkString(orsTemp, "FTPpcStaAlwMDisc") '*KT 54-06-20 V.4.0.0 Ph.4.0 Req.13 การให้ Special Point(SKU Point)และสิทธิส่วนลด
             Else
                tVB_CNSkuPointCooAlw = "Y"
                 tVB_CNSkuPointAlw = "N"
                 tVB_CNSkuEventPoint = ""
                 cVB_CNSkuPointAmt = 0
                 tVB_CNSkuPointAlwDiscountMall = "N"
                  tVB_CNSKUStaFixPointFlag = "N"
             End If
        Else
            tVB_CNSkuPointCooAlw = "Y"
            tVB_CNSkuPointAlw = "N"
            tVB_CNSkuEventPoint = ""
            cVB_CNSkuPointAmt = 0
             tVB_CNSkuPointAlwDiscountMall = "N"
             tVB_CNSKUStaFixPointFlag = "N"
        End If
    Else
        tVB_CNSkuPointCooAlw = "Y"
        tVB_CNSkuPointAlw = "N"
        tVB_CNSkuEventPoint = ""
        cVB_CNSkuPointAmt = 0
         tVB_CNSkuPointAlwDiscountMall = "N"
         tVB_CNSKUStaFixPointFlag = "N"
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    tVB_CNSkuPointCooAlw = "Y"
    tVB_CNSkuPointAlw = "N"
    tVB_CNSkuEventPoint = ""
    cVB_CNSkuPointAmt = 0
    tVB_CNSkuPointAlwDiscountMall = "N"
    tVB_CNSKUStaFixPointFlag = "N"
    Call SP_DATxRsNothing(orsTemp)
End Sub



Public Sub W_KBXEsc()
'----------------------------------------------------------
'   Call:
'
'   Cmt:    close form, back to previous screen, or cancel
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim nRow As Long
    Dim tSql$
    Dim nEffecr As Long
    
    'ใส่ชื่อ ฟังก์ชัน แทน XXX ข้างล่าง
    If tVB_2LineCode <> "" Or cVB_2LinePrice > 0 Then  '*Eaw 56-03-02 กรณีของ 2Line Barcode
        tVB_2LineCode = ""
        cVB_2LinePrice = 0
        wMain.otcForm1(21).Visible = False
        wMain.opbWeight.Visible = False
        Exit Sub
    End If
    bAccept = W_CheckLevelPass("W_KBXEsc")
    If bAccept Then     'if level is ok
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnIPV
                    tSql = "DELETE " & tVB_CNTblHD
                    tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
                    tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
                    tSql = tSql & "  AND FTShdTransType='" & tVB_Transaction & "'"
                    tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
                    tSql = tSql & "  AND FTShdStaDoc = '2'"
                    'Call DB_ExecuteSQL(tSql)
                    Call SP_SQLvExecute(tSql)
                    Call SP_PRCxClearSceenMain
                    Exit Sub
                    wMain.W_FRMxActivate
        End Select
        
        If bVB_NagativeScan Then
            wMain.ostForm.Panels(2).Text = "Ready..."
            bVB_NagativeScan = False
            wMain.otbPrompt.Locked = False
            Exit Sub
        End If
        If bVB_PriceOveride Then
            wMain.ostForm.Panels(2).Text = "Ready..."
            bVB_NagativeScan = False
            wMain.otbPrompt.Locked = False
            Exit Sub
        End If
        nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
        If nRow > 0 Then
            'แสดงว่ารายการสินค้าค้างอยู่
            Call SP_MSGnShowing("tms_CN005109", nCS_Warning)
            Exit Sub
        End If
        'Member Price
        If bVB_CNMemberPrice Then
            wMain.ostForm.Panels(2).Text = "Ready..."
            bVB_CNMemberPrice = False
            xVB_CNMemberP.ID = ""
            xVB_CNMemberP.FName = ""
            xVB_CNMemberP.LName = ""
            xVB_CNMemberP.Tel = ""
            xVB_CNMemberP.Expire = Date
            xVB_CNMemberP.Status = ""
            '------------------------------------------------------
            xVB_CNMemberP.MallCardType = ""
            xVB_CNMemberP.MallCardExpire = Date
            xVB_CNMemberP.MallCardMemberPrice = ""
        End If
        'Preview Day
        If bVB_CNTrStaRegPreviewDay Then
            Call SP_INIxSwitchModePreviewDay(False)
        End If
        Call SP_DELxRecordBlank
        If bVB_ReEntryMode Then
            wCNReEntryMnu2.Show vbModal
        Else
            wCNBegin.Show vbModal
        End If
         Exit Sub
    Else
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
End Sub

