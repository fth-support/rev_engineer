'------------------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim nEff As Long
    Dim tFed$, tF$, tStr$, tSqlV$, tSqlF$
    Dim nI As Long
    Dim cQty As Double
