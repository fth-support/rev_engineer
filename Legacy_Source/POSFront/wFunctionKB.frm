    tSql = tSql & vbCrLf & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
    Call SP_SQLvExecute(tSql)
    '--------------------------------------------------------------------------------------------------------------------------------------
    
    wFunctionKB.W_SetToComplete 'ทำการย้ายมาจากหลังการ Copy ข้อมูลไปที่ TPSTHoldCD
    
    tTable = "TPSTHoldHD"            'HD ก่อน
