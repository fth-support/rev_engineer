Public Function W_PRCxDrawerOpen() As Boolean
'-------------------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao 2013/02/20    Cash drawer open
'-------------------------------------------------------------------------------
Dim bChk As Boolean
Dim tSql As String
Dim orsTemp As ADODB.Recordset

On Error GoTo ErrHandle

    bChk = True
    
    tSql = "SELECT " & tVB_CNTblRC & ".* FROM " & tVB_CNTblRC
    tSql = tSql & vbCrLf & "INNER JOIN TCNMTenderMtn"
    tSql = tSql & vbCrLf & "ON " & tVB_CNTblRC & ".FTTdmCode = TCNMTenderMtn.FTTdmCode"
    tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransType = '" & tVB_Transaction & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & "AND TCNMTenderMtn.FTTdmDrawerOpen = 'Y'"
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        bChk = True
    Else
        bChk = False
    End If
    Select Case SP_VALnText2Double(tVB_TransactionSub) '*Eaw 56-06-24 ถ้าเป็น No sale ให้เปิด Drawer เสมอ CommSheet TK-ISS3000-241-ST 00.00.01.xls
        Case tEN_TrnNoSale
            bChk = True
        Case tEN_TrnDeposit 'Deposit Create Transaction
            If cVB_DepositAmt <= 0 Then                                            '*Ao 2013/09/04 CommSheet TK-ISS3000-339-UAT-FAPL-075_Aoo_560905
                bChk = False
            End If
    End Select
    W_PRCxDrawerOpen = bChk
    Exit Function
ErrHandle:
    W_PRCxDrawerOpen = True
End Function

Public Sub W_KBMarkNonTax()
'____________________________________
'   Call:
'   Cmt: '*Ao 2012/07/26        PRJ10001TK-External Specification Function Menu-00.01.00.doc
'____________________________________
Dim bAccept As Boolean, bVoid As Boolean
Dim nRow As Long
Dim tTaxCode As String, tSql As String
Dim cTax As Double, cSalePrice As Double, cQty As Double, cSaleAmt As Double
Dim nEff As Long
Dim bChk As Boolean
Dim orsTemp As ADODB.Recordset
Dim tTaxSign As String   '*Eaw 56-02-18
Dim tTaxStaSign As String   '*Eaw 56-02-18

On Error GoTo ErrHandle
    
    Select Case SP_VALnText2Double(tVB_Transaction)
        Case tEN_TrnTaxExceptSale
            Call SP_MSGnShowing("tms_CN005107", nCS_Information)
            Exit Sub
    End Select
    bAccept = W_CheckLevelPass("W_KBMarkNonTax")
    If bAccept Then     'if level is ok
        tVB_CNMnuCurrent = "1866"
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
            MsgBox "No Active", vbCritical
            wMain.otbPrompt.Text = vbNullString
            Call SP_OBJxSetFocus(wMain.otbPrompt)
            Exit Sub
        End If
         '_________________________________________________________________________
        With wMain.ogdForm
            If bMainFunc Then  'เรียกคำสั่ง CallByName จากหน้าจอ main
                nRow = .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))
            Else
                nRow = nVB_CNScollItem
            End If
            '_________________________________________________________________________
            If nRow < 1 Then
                Call SP_MSGnShowing("tms_CN005104", nCS_Information)
                wMain.otbPrompt.Text = vbNullString
                Call SP_OBJxSetFocus(wMain.otbPrompt)
                Exit Sub
            End If
            '_________________________________________________________________________
            If Trim(.TextMatrix(nRow, .ColIndex("FTSdtCancelFlag"))) = "1" Then bVoid = True
            If bVoid Then
                Call SP_MSGnShowing("tms_CN005161", nCS_Information)
                Exit Sub
            End If
            tSql = "SELECT TOP 1.* FROM " & tVB_CNTblCD
            tSql = tSql & vbCrLf & "WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
            tSql = tSql & vbCrLf & "AND  FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
            tSql = tSql & vbCrLf & "AND FNSdtSeqNo = " & .TextMatrix(nRow, .ColIndex("FNSdtSeqNo"))
            Call SP_SQLvExecute(tSql, orsTemp, , , , nEff)
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                MsgBox "No Active", vbCritical
                wMain.otbPrompt.Text = vbNullString
                Call SP_OBJxSetFocus(wMain.otbPrompt)
                Exit Sub
            End If
            Call SP_DATxRsNothing(orsTemp)
            'เช็คว่าได้ทำ MarknonTax
            tSql = "SELECT ISNULL(FTSdtStaPrcStk,0) AS  FTSdtStaPrcStk FROM " & tVB_CNTblDT
            tSql = tSql & vbCrLf & "WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
            tSql = tSql & vbCrLf & "AND  FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
            tSql = tSql & vbCrLf & "AND FNSdtSeqNo = " & .TextMatrix(nRow, .ColIndex("FNSdtSeqNo"))
            Call SP_SQLvExecute(tSql, orsTemp, , , , nEff)
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                If SP_FEDtChkString(orsTemp, "FTSdtStaPrcStk") = "1" Then
                    MsgBox "No Active", vbCritical
                    wMain.otbPrompt.Text = vbNullString
                    Call SP_OBJxSetFocus(wMain.otbPrompt)
                    Exit Sub
                End If
            Else
                Exit Sub
            End If
            wMain.otbPrompt.Text = ""
            tTaxCode = Trim(.TextMatrix(nRow, .ColIndex("FTTaxCode")))
            cTax = SP_FMTcCurPoint(.TextMatrix(nRow, .ColIndex("FCSdtTax")))
            If cTax > 0 And tTaxCode <> "00" Then
                cSalePrice = SP_FMTcCurPoint(.TextMatrix(nRow, .ColIndex("FCSdtSalePrice")))
                cQty = SP_VALcText2Double(.TextMatrix(nRow, .ColIndex("FCSdtQty")))
                Select Case SP_VALnText2Double(tVB_Transaction)
                    Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax
'                        cSalePrice = SP_FMTcCurPoint(cSalePrice - (cSalePrice * cTax) / (100 + cTax), True, False)     '*Ao 2013/08/30  CommSheet TK-ISS3000-333-UAT-FAPL-108
                        cSaleAmt = SP_FMTcCurPoint(cSalePrice * cQty, True, False)
                    Case Else
                        cSalePrice = SP_FMTcCurPoint(cSalePrice - (cSalePrice * cTax) / (100 + cTax), True, False)
                        cSaleAmt = SP_FMTcCurPoint(cSalePrice * cQty, True, False)
                End Select
'                cSalePrice = SP_FMTcCurPoint(cSalePrice - (cSalePrice * cTax) / (100 + cTax), True, False)
'                cSaleAmt = SP_FMTcCurPoint(cSalePrice * cQty, True, False)
                
                tSql = "UPDATE " & tVB_CNTblDT & " SET "
                tSql = tSql & vbCrLf & "FTTaxCode = '00'"
                tSql = tSql & vbCrLf & ",FCSdtTax = 0"
                tSql = tSql & vbCrLf & ",FCSdtSalePrice = " & cSalePrice
                tSql = tSql & vbCrLf & ",FCSdtSaleUnit = " & cSalePrice
                tSql = tSql & vbCrLf & ",FCSdtSaleAmt = " & cSaleAmt
                tSql = tSql & vbCrLf & ",FCSdtAmtDisAvi = " & cSaleAmt
                tSql = tSql & vbCrLf & ",FCSdtVatable = 0"
                tSql = tSql & vbCrLf & ",FCSdtVat = 0"
                tSql = tSql & vbCrLf & ",FCAFGroupPM = " & cSalePrice
                tSql = tSql & vbCrLf & ",FCSdtB4DisChg = " & cSalePrice
                tSql = tSql & vbCrLf & ",FTSdtStaPrcStk = '1'"
                If Trim(.TextMatrix(nRow, .ColIndex("FTPmt"))) = "*" Then
                    tSql = tSql & " ,FCSdtBSubReg = " & 0
                    tSql = tSql & " ,FCSdtBSubPro = " & cSaleAmt
                    tSql = tSql & " ,FCSdtBluePrice = " & 0
                    tSql = tSql & " ,FCSdtYellowPrice = " & cSaleAmt
                Else
                    tSql = tSql & " ,FCSdtBSubReg = " & cSaleAmt
                    tSql = tSql & " ,FCSdtBSubPro = " & 0
                    tSql = tSql & " ,FCSdtBluePrice = " & cSaleAmt
                    tSql = tSql & " ,FCSdtYellowPrice = " & 0
                End If
                tSql = tSql & vbCrLf & "WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                tSql = tSql & vbCrLf & "AND  FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & "AND FNSdtSeqNo = " & .TextMatrix(nRow, .ColIndex("FNSdtSeqNo"))
               Call SP_SQLvExecute(tSql, , , , , nEff)

                If nEff > 0 Then
                    .TextMatrix(nRow, .ColIndex("FTTaxCode")) = "00"
                    .TextMatrix(nRow, .ColIndex("FCSdtTax")) = "0"
                    .TextMatrix(nRow, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cSalePrice, False)
                    .TextMatrix(nRow, .ColIndex("FCSdtSaleUnit")) = SP_FMTcCurPoint(cSalePrice, False)
                    .TextMatrix(nRow, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(cSaleAmt, False)
                    '*Eaw 56-02-18
                    '-------------------------------------------------------------------
                    tTaxCode = "00"
                    tSql = "STP_CNxGetDataTax @ptTaxCode = '" & tTaxCode & "'"
                    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                        If Not (orsTemp.BOF And orsTemp.EOF) Then
                            tTaxSign = SP_FEDtChkString(orsTemp, "FTTaxSign")
                            tTaxStaSign = SP_FEDtChkString(orsTemp, "FTTaxStaSign")
                        Else
                            tTaxSign = ""
                            tTaxStaSign = ""
                        End If
                    Else
                        tTaxSign = ""
                        tTaxStaSign = ""
                    End If
                    tSql = "UPDATE " & tVB_CNTblDT & " SET "
                    tSql = tSql & vbCrLf & "FTTaxSign = '" & tTaxSign & "'"
                    tSql = tSql & vbCrLf & ",FTTaxStaSign = '" & tTaxStaSign & "'"
                    tSql = tSql & vbCrLf & "WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                    tSql = tSql & vbCrLf & "AND  FTShdTransType = '" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
