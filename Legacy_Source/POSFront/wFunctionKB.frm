Private Sub W_CHKxCreditVoucher(ByVal ptTable As String, ByVal ptVB_TerminalIPV As String, ByVal ptVB_TransNoIPV As String, ByVal ptVB_TransTypeIPV As String, ByVal pdVB_TransDateIPV As Date)
'----------------------------------------------------------
'   Call:
'   Cmt:'*Ao 2013/0221
'----------------------------------------------------------
Dim tSql As String, tStatusCode As String
Dim orsTemp As ADODB.Recordset
Dim tCVNumRef As String
Dim tCVNum As String
On Error GoTo ErrHandle
    
'    tVB_CNCVNumRefCancel = ""
'    cVB_CNCVNumRefCancelAmt = 0
    
    tSql = "SELECT FCSrcNet FROM " & ptTable
    tSql = tSql & vbCrLf & "WHERE  FTTmnNum='" & ptVB_TerminalIPV & "' AND FTShdTransNo='" & ptVB_TransNoIPV & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransType='" & ptVB_TransTypeIPV & "' AND FDShdTransDate='" & Format(dVB_TransDateIPV, "yyyy/MM/dd") & "'"
    tSql = tSql & vbCrLf & "AND FTTdmCode = 'T018'"         'Credit Voucher
'    tSql = tSql & vbCrLf & "AND FTSrcCardNo = '" & tVB_CNCVNumRefRCCancel & "'"
    If SP_SQLvExecute(tSql, orsTemp) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Do While Not orsTemp.EOF
'                tVB_CNCVNumRefCancel = SP_FEDtChkString(orsTemp, "FTSrcCardNo")
'                If tVB_CNCVNumRefCancel <> "" Then
'                    If Val(Format(ptVB_TransTypeIPV)) = tEN_TrnReturn Then
''                        tStatusCode = "4"
'                        tStatusCode = "2"
'                    Else
'                        tStatusCode = "1"
'                    End If
'                    tSql = "UPDATE TPSTCV"
'                    tSql = tSql & vbCrLf & "  SET FTCVStatusCode = '" & tStatusCode & "'"
'                    tSql = tSql & vbCrLf & " , FTSendUp = '0'"
'                    tSql = tSql & vbCrLf & " , FCCVBalAmt = FCCVAmt"
'                    tSql = tSql & vbCrLf & "," & UT_tLastUpdSql
'                    tSql = tSql & vbCrLf & ",FTCVCashierID = '" & tVB_CNUserCode & "'"         '*Eaw 56-01-29 เพิมฟิลด์ให้ CV
'                    tSql = tSql & vbCrLf & " WHERE  FTCVNum='" & tVB_CNCVNumRefCancel & "'"
'                    Call SP_SQLvExecute(tSql, , oDB.ocnOnLine)
'                End If
                If Val(Format(ptVB_TransTypeIPV)) = tEN_TrnReturn Then
                    cVB_CNCVNumRefCancelAmt = 0
                Else
                    cVB_CNCVNumRefCancelAmt = cVB_CNCVNumRefCancelAmt + SP_FEDvChkNumeric(orsTemp, "FCSrcNet")
                End If
                orsTemp.MoveNext
            Loop
        Else
'            tVB_CNCVNumRefCancel = ""
'            cVB_CNCVNumRefCancelAmt = 0
        End If
        Call SP_DATxRsClose(orsTemp)

        If Val(Format(ptVB_TransTypeIPV)) <> tEN_TrnReturn Then
                tCVNumRef = tVB_CNCVNumRefRCCancel
                tCVNum = tVB_CNCVNumRefCancel
                Do While tCVNumRef <> ""
                    tSql = "SELECT FTCVNum,FTCVNumRef,FCCVAmt FROM TPSTCV"
                    tSql = tSql & vbCrLf & "WHERE  FTCVNumRef='" & tCVNum & "'"
                    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) = 0 Then
                        If Not (orsTemp.BOF And orsTemp.EOF) Then
                            cVB_CNCVNumRefCancelAmt = cVB_CNCVNumRefCancelAmt - SP_FEDvChkNumeric(orsTemp, "FCCVAmt")
                            tCVNumRef = SP_FEDtChkString(orsTemp, "FTCVNumRef")
                            tCVNum = SP_FEDtChkString(orsTemp, "FTCVNum")
                        Else
                            tCVNumRef = ""
                            tCVNum = ""
                        End If
                    Else
                        tCVNumRef = ""
                        tCVNum = ""
                    End If
                    If tCVNumRef <> "" Then
                        Call SP_DATxRsClose(orsTemp)
                        tSql = "SELECT FCSrcNet FROM " & ptTable
                        tSql = tSql & vbCrLf & "WHERE  FTSrcCardNo='" & tCVNumRef & "'"
                        tSql = tSql & vbCrLf & "AND FTTdmCode = 'T018'"         'Credit Voucher
                        If SP_SQLvExecute(tSql, orsTemp) = 0 Then
                            If Not (orsTemp.BOF And orsTemp.EOF) Then
                                Do While Not orsTemp.EOF
                                    cVB_CNCVNumRefCancelAmt = cVB_CNCVNumRefCancelAmt - SP_FEDvChkNumeric(orsTemp, "FCSrcNet")
                                    orsTemp.MoveNext
                                Loop
                            End If
                        End If
                        Call SP_DATxRsClose(orsTemp)
                    End If
                Loop
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

