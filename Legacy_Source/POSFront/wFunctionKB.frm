    '*****************************************
    '*Amorn 65-08-05 เปลี่ยน FCShdTotal เป็น FCShdGrand
'    tSql = "SELECT FCShdTotal FROM " & tVB_CNTblHD & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "' AND FDShdTRansDate = '" & tUT_SaleDate & "'"
    tSql = "SELECT FCShdGrand ,FCShdTotal FROM " & tVB_CNTblHD & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "' AND FDShdTRansDate = '" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine, , , , , True, True) <> 0 Then
        W_PRCbHD_DT_IsDIFF = False
        Exit Function
    End If
    
    'cSumZ = wMain.w_GetxSumSdtSaleAmt() '* นับรายการสินค้าว่ามีกี่ รายการ '*Tao 62-01-23 ของเดิม
    cSumZ = wMain.ogdForm.Aggregate(flexSTCount, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo")) '*Tao 62-01-23 เปลี่ยนเป็นนับแทน

    If Not (orsTemp.BOF And orsTemp.EOF) Then
        cFCShdTotal = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCShdTotal"), False)
        Call SP_DATxRsNothing(orsTemp)
        Dim tDT As String
        tDT = tVB_CNTblDT '*Bump 58-04-09 ทำให้เช็ค DEAL & FREE ได้
        'tDT = "TPSDT" & tVB_CNTerminalNum '*Bump 58-02-25 เช็คจาก TPSDTXXXXX แทนการเช็คจาก TPSDTXXXXXTmp
        'tSql = "SELECT SUM(FCSdtSaleAmt) AS FCSdtSaleAmt FROM " & tDT & " WHERE ISNULL(FTSdtCancelFlag,'0') = '0' AND FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "' AND FDShdTRansDate = '" & tUT_SaleDate & "'" '*Tao 62-01-23 ของเดิม
        
'        Amorn 65-08-05 เปลี่ยน FCSdtSaleAmt เป็น  FCSdtRegPrice - FCSdtDis
        tSql = "SELECT ROUND(SUM(FCSdtSaleAmt),2) AS FCSdtSaleAmt FROM " & tDT & " WHERE ISNULL(FTSdtCancelFlag,'0') = '0' AND FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "' AND FDShdTRansDate = '" & tUT_SaleDate & "'" '*Tao 62-01-23 ปัดเศษ
       ' tSql = "SELECT ROUND(SUM(FCSdtRegPrice - FCSdtDis),2) AS FCSdtSaleAmt FROM " & tDT & " WHERE ISNULL(FTSdtCancelFlag,'0') = '0' AND FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "' AND FDShdTRansDate = '" & tUT_SaleDate & "'" '*Tao 62-01-23 ปัดเศษ
        If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine, , , , , True, True) <> 0 Then
            W_PRCbHD_DT_IsDIFF = False
            Exit Function
        End If
        
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            cSumFCSdtSaleAmt = SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt")
            Call SP_DATxRsNothing(orsTemp)
            
            tSql = "SELECT COUNT(FNSdtSeqNo) AS FNCount  FROM " & tDT & " WHERE  FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo = '" & tVB_Running & "' AND FDShdTRansDate = '" & tUT_SaleDate & "'"
            
            If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine, , , , , True, True) <> 0 Then
                W_PRCbHD_DT_IsDIFF = False
                Exit Function
            End If
            cCountZ = SP_FEDvChkNumeric(orsTemp, "FNCount")
            Call SP_DATxRsNothing(orsTemp)
            If (CDec(cFCShdTotal) <> CDec(cSumFCSdtSaleAmt)) Or (CDec(cSumZ) <> CDec(cCountZ)) Then
            'If (CDec(cFCShdTotal) <> CDec(cSumFCSdtSaleAmt)) Or (CDec(cSumZ) <> CDec(cSumFCSdtSaleAmt)) Then
                W_PRCbHD_DT_IsDIFF = True
            End If
        Else
            W_PRCbHD_DT_IsDIFF = False
        End If
    Else
        W_PRCbHD_DT_IsDIFF = False
    End If
