Private Function W_GETtSdtSeqNo(ByVal ptWhere As String) As String
    '*Thirapong 64-10-20
    '*CommSheet_MP-POSC-0251 R1.xlsx
    'Root cause                          การหา ค่า  FNSdtSeqNo  ของรายการ โปรแกรม หาจาก Local DB
    '                            แต่เนื่องจาก เป็นการขาย ของ วันก่อนหน้า(การขายใน อดีต) ทำให้ หาไม่เจอ เนื่องจากข้อมูลการขาย ของวันก่อนหน้า ไม่มีอยู่ใน Local DB
    '                            แต่มีอยู่ใน POS Server BackUp DB
    '
    '                            จึงทำให้ การ update บิลขายของ วันก่อนหน้า ใน field จำนวนที่คืน ของสนิค้าบางรายการ ไม่ได้ เนื่องจาก หา FNSdtSeqNo ไม่เจอ ตาม root cause
    '
    'การแก้ไข                            ถ้าหา  FNSdtSeqNo ของบิลขาย บน Local DB ไม่เจอ
    '                            ระบบจะหาจาก
    '                            1. POSSDB
    '                            2. หาจาก POSSDB ไม่เจอ ก็จะหาจาก POSSDB_BKK ด้วย


    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim nSeqNo As Long
On Error GoTo ErrHandle

                        
    nSeqNo = 0
    
    tSql = "SELECT FNSdtSeqNo FROM TPSTSalDT WITH(NOLOCK)"
    tSql = tSql & vbCrLf & ptWhere
    
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            nSeqNo = SP_FEDvChkNumeric(orsTemp, "FNSdtSeqNo")
        End If
    End If
    
    
    Call SP_DATxRsNothing(orsTemp)
    
    W_GETtSdtSeqNo = Str(nSeqNo)
    
    Exit Function
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
    W_GETtSdtSeqNo = "0"
End Function



