'                tVB_SKUSymbol = "@"
'            ElseIf Mid(tVB_CNSkuStaAlw, 9, 1) = "1" Then
'                tVB_SKUSymbol = "#"
'            End If

            .TextMatrix(nRow + 1, .ColIndex("FTPmt")) = IIf(bVB_SKUisPromotion, "*", "")
            .TextMatrix(nRow + 1, .ColIndex("FTSymbol")) = tVB_SKUSymbol '*KT 55-08-17 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
            .TextMatrix(nRow + 1, .ColIndex("FNSdtSeqNo")) = nRow + 1
            '*KT 52-03-01 PH2-ML-SB-XXX
             If SP_FEDtChkString(orsTemp, "FTSdtInstoreBar") = "" Then
                .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode")) = SP_FEDtChkString(orsTemp, "FTSdtBarCode") 'Barcode
            Else
                .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode")) = SP_FEDtChkString(orsTemp, "FTSdtInstoreBar") 'Barcode
            End If
            .TextMatrix(nRow + 1, .ColIndex("FTSkuCode")) = SP_FEDtChkString(orsTemp, "FTSkuCode")   'รหัสสินค้า
            .TextMatrix(nRow + 1, .ColIndex("FCSdtQty")) = SP_FEDvChkNumeric(orsTemp, "FCSdtQty")
            .TextMatrix(nRow + 1, .ColIndex("FCSdtRegPrice")) = SP_FEDvChkNumeric(orsTemp, "FCSdtRegPrice") 'ราคาเดิม
             cUT_Qty = SP_FEDvChkNumeric(orsTemp, "FCSdtQty")
            .TextMatrix(nRow + 1, .ColIndex("FNSdtQty")) = SP_FMTtNum2Shw(cUT_Qty \ 1, True) 'จำนวนเป็นจำนวนเต็ม
            .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FEDvChkNumeric(orsTemp, "FCSdtSalePrice")      'ราคา ป.ป.
            '*KT 52-02-19 PH2-ML-SF-103 กรณีที่ทำการขาย VIP Create แล้วมีส่วนลด Line Dis , Line Markdown, Cooperate Dis  เมื่อทำ VIP Finish จะแสดงราคา Sale Price ผิด โดยจะไม่หักส่วนลด
            .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")) = SP_FEDvChkNumeric(orsTemp, "FCSdtSalePrice")  'SP_FEDvChkNumeric(orsTemp, "FCSdtSaleUnit")      'ราคา ป.ป.
            .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbName")) = SP_FEDtChkString(orsTemp, "FTSkuAbbName")
            .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbNameSnd")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSnd")
            .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbNameSrvDoc")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSrvDoc")
            .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbNameSndSrvDoc")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSndSrvDoc")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtUnitName")) = SP_FEDtChkString(orsTemp, "FTSdtUnitName")
            .TextMatrix(nRow + 1, .ColIndex("FTTaxCode")) = SP_FEDtChkString(orsTemp, "FTTaxCode")
            .TextMatrix(nRow + 1, .ColIndex("FCSdtTax")) = SP_FEDvChkNumeric(orsTemp, "FCSdtTax")
            .TextMatrix(nRow + 1, .ColIndex("FCSdtQtyAll")) = SP_FEDvChkNumeric(orsTemp, "FCSdtQtyAll")
            .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")) = SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt")
            .TextMatrix(nRow + 1, .ColIndex("FTTaxSign")) = SP_FEDtChkString(orsTemp, "FTTaxSign")
            .TextMatrix(nRow + 1, .ColIndex("FTTaxStaSign")) = SP_FEDtChkString(orsTemp, "FTTaxStaSign")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtPriceOverideFlag")) = SP_FEDtChkString(orsTemp, "FTSdtPriceOverideFlag")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtCancelFlag")) = SP_FEDtChkString(orsTemp, "FTSdtCancelFlag")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtStaPdt")) = SP_FEDtChkString(orsTemp, "FTSdtStaPdt")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtStaRfd")) = SP_FEDtChkString(orsTemp, "FTSdtStaRfd")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtWeight")) = SP_FEDtChkString(orsTemp, "FTSdtWeight")
            .TextMatrix(nRow + 1, .ColIndex("FTSdtConsignFlag")) = SP_FEDtChkString(orsTemp, "FTSdtConsignFlag") '*KT 52-08-06
            .Refresh '*KT 53-01-14 DoEvents
            '--------------
            wMain.olaPrice.Caption = SP_FMTtNum2Shw(.TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")), False, True)
            wMain.olaBarcode.Caption = .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode"))
            wMain.olaSKUName.Caption = .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbName"))
        End With
        
        nRow = nRow + 1
        orsTemp.MoveNext
    Loop
    Call SP_DATxRsNothing(orsTemp)
    Call wMain.W_SumAmountEx
    Call wMain.W_ClearValAfterInsTSDT '*KT 52-08-13 PH2-ML-SF- 110 VIP Create เมื่อ ถ้า Cancel รายการสินค้า เมื่อทำ VIP Sale แล้วขายสินค้าเพิ่ม จำนวนสินค้า และ จำนวนเงินจะติดลบ
    wMain.otbPrompt.Text = vbNullString
    Call SP_OBJxSetFocus(wMain.otbPrompt)
End Sub

Public Sub W_PRCxIPVTicket()
'----------------------------------------------------------
'   Call:
'   Cmt:    retrive bill from holding
'PH 2.0.0
'*KT 53-05-29 แก้ไขการเกิด Dot send โดยการแก้ไขจากตัวตั้งต้น 3.0.19
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim orsTemp As ADODB.Recordset
    Dim tSql$, tTable$
    Dim tWhr$
    Dim nRow As Long
    Dim nSeqNo As Long
    Dim cDiscBHome As Double
    Dim cSKUTaxRate As Double
'    Dim tMemberPrice As String
    Dim cMemPriceAmt As Double
    Dim cB4DiscChg As Double
    Dim tMemberPriceAlw As String, tTaxCode As String
    Dim cSalPrice As Double
    Dim cRegPrice As Double
    Dim nErr As Long
    Dim orsTm As ADODB.Recordset
    
    'level ok, process
    nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
    If nRow > 1 Then
        Call SP_MSGnShowing("tms_CN005109", nCS_Warning)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub     'กำลังทำรายการอื่นอยู่ทำไม่ได้
    End If

    'find last insert DT
    '*Ao 51-06-17
    tTable = "TPSTSalDT"
    tWhr = "WHERE  FTTmnNum=''" & tVB_TerminalIPV & "'' AND FTShdTransNo=''" & tVB_TransNoIPV & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_TransTypeIPV & "'' AND FDShdTransDate=''" & Format(dVB_TransDateIPV, "YYYY/MM/DD") & "''"
    tWhr = tWhr & vbCrLf & " ORDER BY FNSdtSeqNo"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tTable & "',@ptWhere = '" & tWhr & "'"
    
    '*KT 53-02-26  PH3-ML-SF-089 IPV Dat File don't have TableDT detail กรณีที่ไม่สามารถทำการ Copy Data DT ในการทำ IPV จะไม่อนุญาติให้ดำเนินงานต่อไปได้
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) <> 0 Then
        MsgBox "Terminal is Offline.IPV is Failed.", vbCritical 'tms_CN005228
        bVB_IPV = False
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub 'PH 2.0.0 ติดต่อฐานข้อมูล Server เท่านั้น
    End If
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        'insert to TSDTXXX
        Do While Not orsTemp.EOF
            tTable = tVB_CNTblDT
            'Call W_DupTblBtwSleNHold(orsTemp, tTable, nSeqNo, False)
             Call W_DupTblBtwSleNHold(orsTemp, tTable, nSeqNo, False, 0, 0, False, False, 2) '*KT 67-08-23 TTK-ISS3000-877
            orsTemp.MoveNext
        Loop
    Else
        MsgBox "Terminal is Offline.IPV is Failed.", vbCritical 'tms_CN005228
        bVB_IPV = False
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If
    
    tTable = tVB_CNTblDT
    'find last insert DT
    tWhr = "WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tWhr = tWhr & vbCrLf & " ORDER BY FNSdtSeqNo"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblDT & "',@ptWhere = '" & tWhr & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then
        MsgBox "This transaction IPV not data.", vbCritical '*KT 53-02-26 IPV Dat File don't have TableDT detail  กรณีที่ไม่มีข้อมูลไม่อนุญาติให้ทำงานต่อไป 'tms_CN005232
        bVB_IPV = False
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If
    'insert into grid     อาจจะไม่ถูกนัก ถ้าแยกเอา promotion แยก table ออกมาต่างหาก, หรือไม่ต้อง return table promotion ด้วย
    nRow = 0
    Do While Not orsTemp.EOF
        With wMain.ogdForm
            If nRow + 1 >= .rows Then
                .rows = .rows + 1
                .TopRow = nRow + 1
            End If
            nSeqNo = SP_FEDvChkNumeric(orsTemp, "FNSdtSeqNo")
            tVB_StaMemPriceAlw = SP_FEDtChkString(orsTemp, "FTSdtStaRfd")
            cMemPriceAmt = SP_FEDvChkNumeric(orsTemp, "FCSdtMemberPrice")
            cB4DiscChg = SP_FEDvChkNumeric(orsTemp, "FCSdtB4DisChg")
            tMemberPriceAlw = tVB_StaMemPriceAlw 'SP_FEDtChkString(orsTemp, "FTSdtStaRfd")

            tWhr = "WHERE  FTTmnNum='" & tVB_TerminalIPV & "' AND FTShdTransNo='" & tVB_TransNoIPV & "'"
            tWhr = tWhr & vbCrLf & " AND  FTShdTransType ='" & tVB_TransTypeIPV & "' AND FDShdTransDate='" & Format(dVB_TransDateIPV, "YYYY/MM/DD") & "'"
            tWhr = tWhr & " AND  FNSdtSeqNo=" & nSeqNo
            tWhr = tWhr & " AND  FNDctNo IN (1,2,3,4,5,6,21,22)" 'Deal,Promotion,Promotion Time,Coop Disc,Line Discount,Line Markdown '*KT 52-09-07 Member + Consignment
            tWhr = tWhr & " AND  ISNULL(FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
            cDiscBHome = SP_FMTcCurPoint(CDbl(Val(Format(SP_SQLtFunction("SUM", "FCScdAmt", "TPSTSalCD", tWhr, oDB.ocnOnLine, , , nErr)))), True, False) '*KT 51-12-16 V 1.0.3 Phase 2 ข้อ 16  Communication Sheet PH2-ML-SF-003 Coop. Dis is not shown on Screen when Copy Sale.xls 'PH 2.0.0 ติดต่อฐานข้อมูล Server เท่านั้น
            '*KT 53-02-26 IPV Dat File don't have TableDT detail  กรณีสามารถทำการค้นหาข้อมูลจาก Server ได้ไม่อนุญาติให้ทำงานต่อไป
            If nErr <> 0 Then
                MsgBox "Terminal is Offline.IPV is Failed.", vbCritical 'tms_CN005228
                bVB_IPV = False
                Call SP_DATxRsNothing(orsTemp)
                Exit Sub
            End If
            
            tWhr = " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
            tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
            tWhr = tWhr & " AND  FNSdtSeqNo=" & nSeqNo
            tWhr = tWhr & " AND  FNDctNo IN (1,2,3,21)" '*KT 52-09-07 Member + Consignment
            tWhr = tWhr & " AND  ISNULL(FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
            'Promotion ต้องมีเครื่องหมาย * อยู่หน้า Barcode
            bVB_SKUisPromotion = IIf(SP_FMTtNum2Shw(SP_SQLtFunction("", "FCScdAmt", "TPSTSalCD", tWhr, oDB.ocnOnLine, , , nErr)) > 0, True, False)
            '*KT 53-02-26 IPV Dat File don't have TableDT detail  กรณีสามารถทำการค้นหาข้อมูลจาก Server ได้ไม่อนุญาติให้ทำงานต่อไป
            If nErr <> 0 Then
                MsgBox "Terminal is Offline.IPV is Failed.", vbCritical 'tms_CN005228
                bVB_IPV = False
                Call SP_DATxRsNothing(orsTemp)
                Exit Sub
            End If
            'อ้างอิง Comm.Sheet  ML-SF-083 (Mall Card Flag = No)  ต้องมีเครื่องหมาย * อยู่หน้า Barcode
            If Not bVB_SKUisPromotion Then
                bVB_SKUisPromotion = IIf(SP_FEDtChkString(orsTemp, "FTSkuStaMallEmpCard") = "Y", False, True)   '*Ao 51-06-05 Comsheet ML-SF-083
            End If
        
             '*KT 55-08-17 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
            tVB_CNSkuStaAlw = SP_FEDtChkString(orsTemp, "FTSdtStaPdt")
            tVB_SKUSymbol = ""
             '*Eaw 55-12-06  เปลี่ยนเป็นใช้เครื่องหมาย *สำหรับ Alw Member Card ,# สำหรับ Alw Emp Card
            If Mid(tVB_CNSkuStaAlw, 20, 1) = "0" Then tVB_SKUSymbol = "#"       'ไม่ให้ส่วนลดEmp card
            If Mid(tVB_CNSkuStaAlw, 9, 1) = "0" Then tVB_SKUSymbol = "*"       'ไม่ให้ส่วนลดMember card
            If Mid(tVB_CNSkuStaAlw, 20, 1) = "0" And Mid(tVB_CNSkuStaAlw, 9, 1) = "0" Then tVB_SKUSymbol = "*" 'ไม่ให้ส่วนลด Mall+Emp
'            If Mid(tVB_CNSkuStaAlw, 9, 1) = "1" And Mid(tVB_CNSkuStaAlw, 21, 1) = "1" Then
'                tVB_SKUSymbol = "@"
'            ElseIf Mid(tVB_CNSkuStaAlw, 9, 1) = "1" Then
'                tVB_SKUSymbol = "#"
'            End If
            
            .TextMatrix(nRow + 1, .ColIndex("FTPmt")) = IIf(bVB_SKUisPromotion, "*", "")
            .TextMatrix(nRow + 1, .ColIndex("FTSymbol")) = tVB_SKUSymbol    '*KT 55-08-17 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
            .TextMatrix(nRow + 1, .ColIndex("FNSdtSeqNo")) = nRow + 1
            '*KT 52-03-01 PH2-ML-SB-XXX
            If SP_FEDtChkString(orsTemp, "FTSdtInstoreBar") = "" Then
                .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode")) = SP_FEDtChkString(orsTemp, "FTSdtBarCode") 'Barcode
            Else
                .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode")) = SP_FEDtChkString(orsTemp, "FTSdtInstoreBar") 'Barcode
            End If
            .TextMatrix(nRow + 1, .ColIndex("FTSkuCode")) = SP_FEDtChkString(orsTemp, "FTSkuCode")   'รหัสสินค้า
            Select Case Val(Format(tVB_Transaction))
                Case tEN_TrnIPVTaxExceptSale
                    cSKUTaxRate = SP_FEDvChkNumeric(orsTemp, "FCSdtTax")
                    cRegPrice = SP_FEDvChkNumeric(orsTemp, "FCSdtRegPrice") 'ราคาเดิม
                     '*KT 52-05-07 PH1.8-ML-SF-012 ทำ IPV บนหน้าจอ แสดงราคาของสินค้าผิด แสดงเป็นราคาหลังหักส่วนลด
                     '*KT 52-04-30 PH 1.8 ML-SF-050 IPV สินค้าที่จัด M price แสดงราคาผิดโดย ไปแสดงราคาเต็ม แต่ ซึ่งโปรโมชั่นแสดงราคาถูก
                     '*KT 52-05-07 PH 1.8 ML-SF-057 IPV Tax Exp Sale จะแสดงราคาที่ไม่ถอด VAT
                    If cMemPriceAmt > 0 And tMemberPriceAlw = "Y" And cMemPriceAmt = cB4DiscChg Then
                        cSalPrice = SP_FMTcCurPoint(cRegPrice - (cRegPrice * cSKUTaxRate) / (100 + cSKUTaxRate), True, False)
                        cMemPriceAmt = SP_FMTcCurPoint(cMemPriceAmt - (cMemPriceAmt * cSKUTaxRate) / (100 + cSKUTaxRate), True, False)
                    Else
                        cSalPrice = SP_FMTcCurPoint(cRegPrice - (cRegPrice * cSKUTaxRate) / (100 + cSKUTaxRate), True, False)
                    End If
                Case Else
                    cRegPrice = SP_FEDvChkNumeric(orsTemp, "FCSdtRegPrice") 'ราคาเดิม
                    cSalPrice = cRegPrice
            End Select
            .TextMatrix(nRow + 1, .ColIndex("FCSdtRegPrice")) = cRegPrice
             cUT_Qty = SP_FEDvChkNumeric(orsTemp, "FCSdtQty")
            .TextMatrix(nRow + 1, .ColIndex("FNSdtQty")) = SP_FMTtNum2Shw(cUT_Qty \ 1, True) 'จำนวนเป็นจำนวนเต็ม
            '*KT 52-05-07 PH1.8-ML-SF-012 ทำ IPV บนหน้าจอ แสดงราคาของสินค้าผิด แสดงเป็นราคาหลังหักส่วนลด
            '*KT 52-04-30 PH1.8 ML-SF-050 IPV สินค้าที่จัด M price แสดงราคาผิดโดย ไปแสดงราคาเต็ม แต่ ซึ่งโปรโมชั่นแสดงราคาถูก
            '*KT 52-05-07 PH 1.8 ML-SF-057 IPV Tax Exp Sale จะแสดงราคาที่ไม่ถอด VAT
             If cMemPriceAmt > 0 And tMemberPriceAlw = "Y" And cMemPriceAmt = cB4DiscChg Then
                .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cMemPriceAmt - (cDiscBHome / cUT_Qty), True, False)
                .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")) = .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice"))
                .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) * cUT_Qty, True, False)
            Else
                Select Case Val(Format(tVB_Transaction))
                    Case tEN_TrnIPVTaxExceptSale
                        .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cSalPrice - (cDiscBHome / cUT_Qty), True, False)
                        .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")) = .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice"))
                        .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) * cUT_Qty, True, False)
                    Case Else
                        '--------------------------------------------
                        If Trim(SP_FEDtChkString(orsTemp, "FTSdtStaPrcStk")) = "1" Then                 '*Ao 2013/03/18   MarkNonTax
                            tTaxCode = "01"
                            tSql = "STP_CNxGetDataTax @ptTaxCode = '" & tTaxCode & "'"
                            If SP_SQLvExecute(tSql, orsTm, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                                If Not (orsTm.BOF And orsTm.EOF) Then
                                    cSKUTaxRate = SP_FEDvChkNumeric(orsTm, "FCTaxRate")
                                End If
                            End If
                            cRegPrice = SP_FMTcCurPoint(cRegPrice - (cRegPrice * cSKUTaxRate) / (100 + cSKUTaxRate), True, False)
                            .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cRegPrice - (cDiscBHome / cUT_Qty), True, False)
                            .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")) = .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice"))
                            .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) * cUT_Qty, True, False)
                        Else
                            If SP_FEDvChkNumeric(orsTemp, "FCLineOver") > 0 Then        '*Ao 2013/03/18   Line Over
                                .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCLineOver"), True, False)
                            Else
                                .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cRegPrice - (cDiscBHome / cUT_Qty), True, False)
                            End If
'                            .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cRegPrice - (cDiscBHome / cUT_Qty), True, False)
                            .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")) = .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice"))
                            .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) * cUT_Qty, True, False)
                        End If
                        '--------------------------------------------
'                        .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) = SP_FMTcCurPoint(cRegPrice - (cDiscBHome / cUT_Qty), True, False)
'                        .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")) = .TextMatrix(nRow + 1, .ColIndex("FCSdtSalePrice"))
'                        .TextMatrix(nRow + 1, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSalePrice")) * cUT_Qty, True, False)
                End Select
            End If
            .TextMatrix(nRow + 1, .ColIndex("FCSdtQty")) = cUT_Qty
            .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbName")) = Trim(SP_FEDtChkString(orsTemp, "FTSkuAbbName"))
            .TextMatrix(nRow + 1, .ColIndex("FTSkuAbbNameSnd")) = SP_FEDtChkString(orsTemp, "FTSkuAbbNameSnd")
