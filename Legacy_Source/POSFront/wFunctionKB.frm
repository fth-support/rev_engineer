Private Sub W_AddxCloseVatAmt(ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "", Optional ByVal pcVatHD As Double)
'------------------------------------------------------------------
'Call:
