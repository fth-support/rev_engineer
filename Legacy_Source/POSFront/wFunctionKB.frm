                    tSql = tSql & vbCrLf & ", FTSendUp = '0'"                       '*Ao 2013/02/21  TK
                    '---------------------------------------------------------------------------------------
                    tSql = tSql & vbCrLf & "," & UT_tLastUpdSql
                    tSql = tSql & vbCrLf & "WHERE  FTShdVoucherNo = '" & tVoucherNo & "'"
                    tSql = tSql & vbCrLf & "AND  ISNULL(FTShdStaCancel,'N') <> 'Y'"
                    tSql = tSql & vbCrLf & "AND  FTShdStaDoc ='1'"
                    tSql = tSql & vbCrLf & "AND  FTShdTransType = '" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnVoucher, "00")) & "'"
                    nEffect = 0
                    If SP_SQLvExecute(tSql, , oDB.ocnOnLine, , , nEffect) = 0 Then 'PH 2.0.0 ติดต่อฐานข้อมูล server เท่านั้น
                        If nEffect > 0 Then
                            Call SP_SQLvExecute(tSql)
                            bOffline = False
                        Else
                            If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                                bOffline = True
                                Exit Do
                            Else
                                bOffline = False
                            End If
                        End If
                    Else
                        bOffline = True
                        Exit Do
                    End If
                    nStep = 17
                End If
                orsTemp.MoveNext
            Loop
        End If
        Call SP_DATxRsNothing(orsTemp)
        
        bVB_CNTrnOnlineSuccess = True
        'เงินทอน
        nStep = 18
        If Not W_PRCxHandleTrnOnline(bOffline) Then
            nStep = 19
            '----------------------------------------------------------------------------------------------
            If bPassOn Then
                oDB.ocnOnLine.CommitTrans ' If Not oDB.ocnOnLine Is Nothing And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then oDB.ocnOnLine.CommitTrans
                bPassOn = False
                nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
            End If
            If bPass Then
                ocnAll.CommitTrans
                bPass = False
                nVB_CNCountBegin = nVB_CNCountBegin - 1
            End If
            nStep = 20
            '*KT 51-10-24 V 3.0.141/V 3.0.200
            '----------------------------------------------------------------------------------------------
            Call SP_UPDxSetCompleteTerminalMtn
            '----------------------------------------------------------------------------------------------
            nStep = 21
        Else
                nStep = 22
                If bPassOn Then
                    oDB.ocnOnLine.RollbackTrans
                    bPassOn = False
                    nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
                End If
                If bPass Then
                    ocnAll.RollbackTrans
                    bPass = False
                    nVB_CNCountBegin = nVB_CNCountBegin - 1
                End If
                nStep = 23
                tWhr = " WHERE  FTTmnNum='" & tVB_TerminalIPV & "' AND FTShdTransNo='" & tVB_TransNoIPV & "'"
                tWhr = tWhr & " AND  FTShdTransType='" & tVB_TransTypeIPV & "' AND FDShdTransDate='" & Format(dVB_TransDateIPV, "YYYY/MM/DD") & "'" '*KT 52-03-17 PH1.5-ML-SF-122
                Call SP_LOGxTableUpdate("IPV", Err.Number, tWhr & "(W_KBIPV[RollbackTrans]" & nStep & ")", 2)    '*KT 52-03-17 PH1.5-ML-SF-122
                Call SP_MSGnShowing("tms_CN005088", tCS_CNMsgErr)
                Call SP_DATxRsNothing(orsTemp)
                bVB_IPV = False '*KT 53-02-26  PH3-ML-SF-089 IPV Dat File don't have TableDT detail ถ้ามีการ Exit Sub จาก Sub นี้จะไม่อนุญาตให้ทำการ IPV ต่อ
                Exit Sub
        End If
    Else
        nStep = 24
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        bVB_IPV = False '*KT 53-02-26  PH3-ML-SF-089 IPV Dat File don't have TableDT detail ถ้ามีการ Exit Sub จาก Sub นี้จะไม่อนุญาตให้ทำการ IPV ต่อ
        Exit Sub
    End If
    wMain.otbPrompt.Text = vbNullString
    Call SP_OBJxSetFocus(wMain.otbPrompt)
    Call UT_GenSaleNewDoc
    tVB_CNMnuCurrent = "1700"
    If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
        Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
    Else
        wMain.W_FRMxActivate
    End If

    nStep = 25
    Exit Sub
HandleErr:
    If bTranSrv Then
        oDB.ocnOnLine.RollbackTrans
        bTranSrv = False
    End If
    
    If bPassOn Then
        oDB.ocnOnLine.RollbackTrans
        bPassOn = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
    If bPass Then
        ocnAll.RollbackTrans
        bPass = False
        nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    
    tWhr = " WHERE  FTTmnNum='" & tVB_TerminalIPV & "' AND FTShdTransNo='" & tVB_TransNoIPV & "'"
    tWhr = tWhr & " AND  FTShdTransType='" & tVB_TransTypeIPV & "' AND FDShdTransDate='" & Format(dVB_TransDateIPV, "YYYY/MM/DD") & "'" '*KT 52-03-17 PH1.5-ML-SF-122
    Call SP_LOGxTableUpdate("IPV", Err.Number, tWhr & "(W_KBIPV" & nStep & ")", 2)   '*KT 52-03-17 PH1.5-ML-SF-122
    Call SP_MSGnShowing("tms_CN005088", tCS_CNMsgErr)
    Call SP_DATxRsNothing(orsTemp)
End Sub

Private Sub W_GETxRedeemRef(ByRef ptTmnNo$, ByRef ptTrnNo$, ByRef pdTrnDate As Date)
'---------------------------------
'Call:
'Cmt: ทำการหาเลขที่ใบ Deposit ที่ใบ Redeem อ้างอิง ค้นหาจาก TPSTDepositHD ของ Server
'--------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    tSql = "SELECT FTShdDepRefTmnNum,FTShdDepReTransNo,FDShdDepReTransDate"
    tSql = tSql & " FROM TPSTDepositHD" '& tVB_CNTblHD '*KT 52-03-17 Communication Sheet PH1.5-ML-SF-122 Can't re redeem when IPV redeem.xls
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_TerminalIPV & "' AND FTShdTransNo='" & tVB_TransNoIPV & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_TransTypeIPV & "' AND FDShdTransDate='" & Format(dVB_TransDateIPV, "YYYY/MM/DD") & "'" '*KT 52-03-17 PH1.5-ML-SF-122
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        ptTmnNo = SP_FEDtChkString(orsTemp, "FTShdDepRefTmnNum")
        ptTrnNo = SP_FEDtChkString(orsTemp, "FTShdDepReTransNo")
        pdTrnDate = SP_FEDdChkDate(orsTemp, "FDShdDepReTransDate")
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    tSql = " WHERE  FTTmnNum='" & tVB_TerminalIPV & "' AND FTShdTransNo='" & tVB_TransNoIPV & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_TransTypeIPV & "' AND FDShdTransDate='" & Format(dVB_TransDateIPV, "YYYY/MM/DD") & "'"  '*KT 52-03-17 PH1.5-ML-SF-122
    Call SP_LOGxTableUpdate("IPV", Err.Number, tSql & "(W_GETxRedeemRef)", 2)   '*KT 52-03-17 PH1.5-ML-SF-122
End Sub

