    cSumTmp = 0
    W_DEFcSUMChangeAll = 0
    If Not (porsTemp.BOF And porsTemp.EOF) Then
        Do While Not porsTemp.EOF
'            cSumTmp = cSumTmp + SP_FEDvChkNumeric(porsTemp, ptTemp)
