Public Sub W_AddxDataPrintClosingOther(ByVal pcQty As Double, ByVal ptName$, pcAmt As Double, ByRef pnSeqNo As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "", Optional ByVal ptTender As String = "", Optional ByVal ptClosingFlag As String = "", Optional ByVal pcRateCur As Double = 0, Optional ByVal ptForFac As String = "", Optional ByVal pcRteFac As Double = 0)
'--------------------------------------
'Cmt:
'Call: Insert tender to DT(Print Closing Report)
'--------------------------------------
    Dim tFed$, tStr$, tF$
    Dim tSql$, tSqlF$, tSqlV$
    Dim tTblDT As String
    Dim tFUpd As String
    Dim tVUpd As String
    Dim cTmpValue As Double
On Error GoTo ErrHandle
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxDataPrintClosingOther[1]")
    tFed = "": tStr = "": tF = ""
    tSql = "": tSqlF = "": tSqlV = ""
    tVUpd = ""
    
    If pbSal Then
        tTblDT = "TPSTSalDT"
    Else
        tTblDT = tVB_CNTblDT
    End If
On Error GoTo ErrHandle
    If pbCloseTmn Then
         'pnSeqNo = 100
        tFed = "FNCloSeqNo,FTCloCode,FTCloName,FTCloGrp,FCCloQty,FCCloAmt,FTCloMode,FCCloRate,FTRemark"
    Else
        tFed = "FTStmCode,FTTmnNum,FTShdTransNo,FNSdtSeqNo,FTSkuCode"
        tFed = tFed & ",FTSkuAbbName,FTShdTransType,FDShdTransDate,FTSdtBarCode,FTSdtStkCode"
        tFed = tFed & ",FCSdtStkFac,FTTaxCode,FTDpcCode,FTSkuDepCode,FTSkuBrdCode"
        tFed = tFed & ",FTPunCode,FTSdtUnitName,FCSdtRegPrice,FTSdtEventPrice,FCSdtQty"
        tFed = tFed & ",FCSdtSaleTaxAmt,FCSdtReturnTaxAmt"
        tFed = tFed & ",FTSdtInstoreBar,FCSdtB4DisChg,FTSdtDisChgTxt,FCSdtDis"
        tFed = tFed & ",FCSdtChg,FCSdtSaleAmt,FCSdtVat,FCSdtVatable,FCSdtQtyAll"
        tFed = tFed & ",FTSdtStaPdt"
        tFed = tFed & ",FTSdtWeight,FTSdtConsignFlag"
        tFed = tFed & ",FTSdtCancelFlag,FCSdtTax,FCSdtSalePrice,FTShdTransTime"
        tFed = tFed & ",FTSkuAbbNameSnd,FTSkuAbbNameSrvDoc,FTSkuAbbNameSndSrvDoc"
        tFed = tFed & ",FTTaxSign,FTTaxStaSign"
        tFed = tFed & ",FCSdtSaleUnit"
        tFed = tFed & ",FCSdtQtyAllDisAvi"
        tFed = tFed & ",FCSdtAmtDisAvi"
        tFed = tFed & ",FCSdtDutyFreeAmt"
        tFed = tFed & ",FCSdtDutyFreeQty"
        tFed = tFed & ",FCSdtDutyDeposit"
        tFed = tFed & ",FCSdtWeight"
        tFed = tFed & ",FTSdtPriceOverideFlag"
    End If
    
    tSqlF = tFed
    tSqlF = "(" & tSqlF & "," & tCS_CNLastFedIns
    tF = tFed
    If pbCloseTmn Then
         tSql = "INSERT INTO TPSTClose"
         If ptForFac = "1" Then
            pcQty = pcRteFac
         End If
    Else
         tSql = "INSERT INTO " & tTblDT
    End If
    tStr = cUT.UT_STRtToken(tF, ",", 1)
    
    Do While tStr <> ""
        If pbCloseTmn Then
            Select Case UCase(tStr)
                Case UCase("FNCloSeqNo"): tSqlV = tSqlV & pnSeqNo & ","
                Case UCase("FTCloGrp"): tSqlV = tSqlV & "'" & ptCloRunning & "',"
                Case UCase("FTCloCode")
                        If ptTender = "" Then
                            tSqlV = tSqlV & "'" & ptName & "',"
                            tFUpd = "FTCloCode = '" & ptName & "'"
                        Else
                            tSqlV = tSqlV & "'" & ptTender & "',"
                            tFUpd = "FTCloCode = '" & ptTender & "'"
                        End If
                Case UCase("FTCloName")
                        tSqlV = tSqlV & "'" & ptName & "',"
                       ' tFUpd = "FTCloCode = '" & ptName & "'" '*KT 55-07-01 4.0.18  CommSheet ML-PH4-R3-027 Closing Report total sale  incorrect  แก้ไขเรื่อง Tender Closinf Report ผิดพลาดเนื่องจากการแก้ไขการแสดงชื่อ Tender ตาม Config ไม่ Fix คำ   กำหนด ptTender เป็น Optional ในการ Case ว่าเป้น Process ของ Tender
                Case UCase("FCCloQty")
                        tSqlV = tSqlV & pcQty & ","
                        'tVUpd = "FCCloQty = FCCloQty + " & pcQty
                        tVUpd = IIf(tVUpd <> "", tVUpd & "," & "FCCloQty = FCCloQty + " & pcQty, "FCCloQty = FCCloQty + " & pcQty)
                Case UCase("FCCloAmt")
                        tSqlV = tSqlV & pcAmt & ","
                       ' tVUpd = "FCCloAmt = FCCloAmt + " & pcAmt
                        tVUpd = IIf(tVUpd <> "", tVUpd & "," & "FCCloAmt = FCCloAmt + " & pcAmt, "FCCloAmt = FCCloAmt + " & pcAmt)
                Case UCase("FCCloRate")
                         tSqlV = tSqlV & pcRateCur & ","
                         tVUpd = IIf(tVUpd <> "", tVUpd & "," & "FCCloRate = " & pcRateCur, "FCCloRate = " & pcRateCur)
                Case UCase("FTRemark")
                        tSqlV = tSqlV & "'" & ptClosingFlag & "',"                      '*Ao 2013/03/01
                        tFUpd = "FTRemark = '" & ptClosingFlag & "'"
'                        Select Case ptClosingFlag   '*BG 56-07-09 CommSheet TK-ISS3000-208-ST 00 00 01.xls   เกี่ยวกับจ่าย Gift Card                   '*Ao 2013/08/07   ทำให้การพิมพ์ Closing ผิด
'                            Case "T002", "T003", "T015", "T017"   'T002: Credit Card , T003: Hire Purchase , T012 : Foreign Currency , T015:NETS , T017:TC Card
'                                If pcQty = 0 Then
'                                    tSqlV = tSqlV & "'" & ptClosingFlag & "',"
'                                    tFUpd = "FTRemark = '" & ptClosingFlag & "'"
'                                Else
'                                    tSqlV = tSqlV & "'" & ptName & "',"
'                                    tFUpd = "FTRemark = '" & ptName & "'"
'                                End If
'                            Case "T012"
'                                tSqlV = tSqlV & "'" & ptName & "',"
'                            Case Else
'                                tSqlV = tSqlV & "'" & ptClosingFlag & "',"
'                                tFUpd = "FTRemark = '" & ptClosingFlag & "'"
'                        End Select
                Case UCase("FTCloMode"): tSqlV = tSqlV & "'" & ptForFac & "',"   '*Eaw 56-04-11
                Case Else
                    Select Case UCase(Mid(tStr, 2, 1))
                        Case "T"
                            tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                        Case "N", "C"
                            tSqlV = tSqlV & 0 & ","
                        Case "D"
                            tSqlV = tSqlV & "NULL" & ","
                    End Select
            End Select
            tStr = cUT.UT_STRtToken(tF, ",", 1)
        Else
            Select Case UCase(tStr)
                Case UCase("FTStmCode"): tSqlV = tSqlV & "'" & tVB_CNStoreCode & "',"
                Case UCase("FTTmnNum"): tSqlV = tSqlV & "'" & tVB_CNTerminalNum & "',"
                Case UCase("FTShdTransNo"): tSqlV = tSqlV & "'" & tVB_Running & "',"
                Case UCase("FTShdTransType"): tSqlV = tSqlV & "'" & Format(tVB_Transaction, "00") & "',"  'Case UCase("FTShdTransType"): tSqlV = tSqlV & "'" & Format(tEN_TrnPrintClose, "00") & "',"  '*KT 52-09-05 พบว่าการทำ Total Report มีการทำการบันทึก Type 09 ที่เป็น Type ของการ Print Closing ให้เปลี่ยนมาใช้  tVB_Transaction แทน
                Case UCase("FDShdTransDate"): tSqlV = tSqlV & "'" & tUT_SaleDate & "',"
                Case UCase("FTShdTransTime"): tSqlV = tSqlV & "'" & Time$ & "',"
                Case UCase("FNSdtSeqNo"): tSqlV = tSqlV & pnSeqNo & ","
                Case UCase("FTEmpCode"): tSqlV = tSqlV & "'" & tVB_CNUserCode & "',"
                Case UCase("FTSkuAbbName"), UCase("FTSkuAbbNameSnd"), UCase("FTSkuAbbNameSrvDoc"), UCase("FTSkuAbbNameSndSrvDoc")
                        tSqlV = tSqlV & "'" & ptName & "',"
                Case UCase("FCSdtSaleAmt"): tSqlV = tSqlV & pcAmt & ","
                Case UCase("FTSdtConsignFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FTTaxStaSign"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FTSkuStaMallEmpCard"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FTSdtPriceOverideFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FCSdtQty"), UCase("FCSdtQtyAll"): tSqlV = tSqlV & pcQty & ","
                Case UCase("FTSkuCode"): tSqlV = tSqlV & "'" & ptClosingFlag & "',"
                Case UCase("FCSdtStkFac"): tSqlV = tSqlV & pcRateCur & ","
                Case UCase("FTSdtStkCode"): tSqlV = tSqlV & "'" & ptForFac & "',"   '*Eaw 56-04-11
                Case UCase("FCSdtDutyFreeAmt")
                    tSqlV = tSqlV & pcRteFac & ","                                        '*Ao 2014/06/27
'                Case UCase("FTSdtBarCode"): tSqlV = tSqlV & "'" & ptClosingFlag & "',"   '*Ao 2013/05/31 CommSheet TK-ISS3000-208-ST 00 00 01-Ao.xls
                Case UCase("FTSdtBarCode"): 'tSqlV = tSqlV & "'" & ptClosingFlag & "',"   '*BG 56-07-09 CommSheet TK-ISS3000-208-ST 00 00 01.xls   เกี่ยวกับจ่าย Gift Card
                    Select Case ptClosingFlag
                        Case "T002", "T003", "T015", "T017"           'T002: Credit Card , T003: Hire Purchase , T012 : Foreign Currency , T015:NETS , T017:TC Card
                            If pcQty = 0 Then
                                tSqlV = tSqlV & "'" & ptClosingFlag & "',"
                            Else
                                tSqlV = tSqlV & "'" & ptName & "',"
                            End If
                        Case "T012"
                            tSqlV = tSqlV & "'" & ptName & "',"
                        Case Else
                            tSqlV = tSqlV & "'" & ptClosingFlag & "',"
                    End Select
                Case Else
                    Select Case UCase(Mid(tStr, 2, 1))
                        Case "T"
                            tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                        Case "N", "C"
                                tSqlV = tSqlV & 0 & ","
                        Case "D"
                            tSqlV = tSqlV & "NULL" & ","
                    End Select
            End Select
            tStr = cUT.UT_STRtToken(tF, ",", 1)
        End If
    Loop
