Private Function W_AddcCloseRedeemQty(ByVal ptTransType As String, ByVal ptTblHD As String, ByVal pbCloseTmn As Boolean) As Double
'----------------------------------------------------------------------------
'   Call:
'   Cmt: '*Ao 2013/06/04
'----------------------------------------------------------------------------
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim nEff As Long
Dim cQty As Double

On Error GoTo ErrHandle

    ptTransType = IIf(bVB_TrainingMode, "FTShdTransTypeSub", "FTShdTransType")
    
    tSql = "SELECT COUNT(FTShdTransNo) AS FCLayawayDeposit"
    tSql = tSql & vbCrLf & "FROM " & ptTblHD
    tSql = tSql & vbCrLf & "WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & "AND FTShdStaDoc = '1'"
    tSql = tSql & vbCrLf & "AND FTShdStaPrcDoc = '1'"
'    tSql = tSql & vbCrLf & "AND FTLogCode  = '" & tUT_LoginCode & "'"                                                                       '*Ao 2013/08/23 TK
'    If Not pbCloseTmn Then tSql = tSql & vbCrLf & "AND FTEmpCode  = '" & tVB_CNUserCode & "'"               '*Ao 2013/08/23 TK
    tSql = tSql & vbCrLf & "AND  " & ptTransType & " IN ("
    tSql = tSql & vbCrLf & "'" & Format(tEN_TrnRedeem, "00") & "'"
    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVRedeem, "00") & "'"
    tSql = tSql & vbCrLf & ")"
    Call SP_SQLvExecute(tSql, orsTemp, , , , nEff)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        cQty = SP_FEDvChkNumeric(orsTemp, "FCLayawayDeposit")
    Else
        cQty = 0
    End If
    W_AddcCloseRedeemQty = cQty
Exit Function
ErrHandle:
    W_AddcCloseRedeemQty = 0
End Function

