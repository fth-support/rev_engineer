        'Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        wMain.otbPrompt.Locked = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        bVB_CNStartBill = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        bVB_CNTrnOnlineSuccess = True
        bOffline = True
        If Not W_PRCxHandleTrnOnline Then
            With wMain
                .olaBarcode.Caption = ""
                .olaSKUName.Caption = ""
                .olaPrice.Caption = ""
                .olaSumQty.Caption = ""
                .olaTSubReg.Caption = ""
                .olaTSubPro.Caption = ""
                .olaTSubTotal.Caption = ""
                With .ogdForm
                    .rows = 1
                    .rows = nUT_GridMaxRow
                End With
                bTranSrv = False
                 If Not oDB.ocnOnLine Is Nothing And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                    oDB.ocnOnLine.BeginTrans
                    bTranSrv = True
                    nVB_CNCountBeginSrv = nVB_CNCountBeginSrv + 1
                End If
                'เงินทอน
                Select Case Val(Format(tVB_TransactionSub))
                    Case tEN_TrnReturn, tEN_TrnOtherDisbursement, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnDeposit
                        bOffline = Not W_PRCbMoveDataToDeposit
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnRedeem
                        bOffline = Not W_PRCbUpdTmpDeposit
                        If Not bOffline Then
                            bOffline = Not W_PRCbMoveDataToDeposit
                        End If
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
                        bOffline = Not W_PRCbUpdTmpDeposit
                        If Not bOffline Then
                            bOffline = Not W_PRCbMoveDataToDeposit
                        End If
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnAddDeposit
                        bOffline = Not W_PRCbMoveDataToDeposit
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnVoucher
                        bOffline = Not W_PRCbMoveDataToVoucher
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnCancelVoucher
'                        bOffline = Not W_PRCbUpdTmpVoucher(bTranSrv)
                         bOffline = Not W_PRCbUpdTmpVoucher
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnVIPSale
                        bOffline = Not W_PRCbDelCreateVIP
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case Else
                        bOffline = False
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                End Select
                .Refresh
'                DoEvents '*KT 53-01-14 DoEvents
            End With
            If Not W_PRCxHandleTrnOnline(bOffline, bTranSrv) Then
                Call W_PRCxCashDrawerAct
            End If
        End If
        Call SP_UPDxSetCompleteTerminalMtn
        'เริ่ม Ticket ใหม่
         '*KT 54-09-20 V.4.0.1 กรณีที่ไม่เป็น OPOS ในการแสดงเงินทอน
        Select Case SP_VALnText2Double(tVB_TransactionSub)
            Case 1, 5, 8, 9, 14, 17, 25, 26, 27, 28, 29, 30, 31, 32, 34, 35, 36
                    bFlagShwChg = False
            Case Else
                    If bVB_OPOSCashDrawerEnable Then
                        bFlagShwChg = False
                    Else
                        bFlagShwChg = True
                    End If
        End Select
         bVB_CNShwChange = bFlagShwChg
         Call UT_GenSaleNewDoc(bFlagShwChg)
         
        'Unload wSub '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnSaleTaxInc, tEN_TrnReturnTaxInc, tEN_TrnTotalReportTaxInc, tEN_TrnOverShortReportTaxInc, tEN_TrnClosingReportTaxInc
                    tVB_CNMnuCurrent = "172001"
            Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax, tEN_TrnTotalReportManualTax, tEN_TrnOverShortReportManualTax, tEN_TrnClosingReportManualTax
                    tVB_CNMnuCurrent = "172101"
            Case Else
                    tVB_CNMnuCurrent = "1700"
        End Select
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
            Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
        Else
            wMain.W_FRMxActivate
        End If
        Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
'        DoEvents '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero '*KT 53-01-14 DoEvents
        wMain.otbPrompt.Locked = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        bVB_CNStartBill = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    End If
    If bTranSrv Then
        oDB.ocnOnLine.CommitTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
    Exit Sub
ErrHandle:
    If bTranSrv Then
        oDB.ocnOnLine.RollbackTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
End Sub

Public Sub W_KBRcvCredit()
'----------------------------------------------------------
'   Call:
'   Cmt:    paid by Credit Card
 '              *KT 51-11-18 กรณีที่จบการทำ Deposit Cancel และ Add Deposit Cancel ด้วย Credit Card และ Credit Store ต้องทำการไม่มี Misc Recv.
'               *KT 52-10-21 ปรับปรุง ใส่ On Error GoTo ErrHandle
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim tSql As String
    Dim cAmount As Double
    Dim cPer As Double
    Dim cPay  As Double
    Dim cNet As Double
    Dim cFAmt As Double
    Dim bComplete As Boolean
    Dim nRow As Long
    Dim tPrint$
    Dim orsTemp As ADODB.Recordset
    Dim cMeaningDef As Double
    Dim bOffline As Boolean
    Dim bTranSrv As Boolean
    Dim bFlagShwChg As Boolean
    Dim tMsg As String
    Dim cTempBal As Double
    Dim cDiscMalCrdOfCrd As Double '*Tao 62-07-24 เก็บยอด Discount
    Dim cMalCrdOfOntop As Double '*Tao 62-07-24 เก็บยอด OnTop
    Dim tWhere As String
    
On Error GoTo ErrHandle
    bComplete = False
    bAccept = W_CheckLevelPass("W_KBRcvCredit")

    If Not bAccept Then         'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        'Call SP_OBJxSetFocus(wmai.otbPrompt)                                       '*AO51-03-17  Comm.Sheet SF-092
        Exit Sub
    End If

    With wSub
        '*KT 52-08-19 เกิด Offline ขณะทำรายการ tEN_TrnIPV, tEN_TrnIPVDutyFreeSale, tEN_TrnIPVRedeem, tEN_TrnIPVReturn, tEN_TrnIPVTaxExceptSale, tEN_TrnIPVVIPService, tEN_TrnIPVOtherReceive, tEN_TrnIPVOtherDisbursement
        'tEN_TrnDeposit, tEN_TrnRedeem, tEN_TrnAddDeposit, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
        'tEN_TrnVoucher, tEN_TrnCancelVoucher
        If bVB_TicketNotSuccess Then
            Unload wSub
            'เริ่ม Ticket ใหม่
            Call UT_GenSaleNewDoc
            'Unload wSub '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
            tVB_CNMnuCurrent = "1700"
            If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
                Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
            Else
                wMain.W_FRMxActivate
            End If
            Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
'            DoEvents '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero '*KT 53-01-14 DoEvents
            wMain.otbPrompt.Locked = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
            bVB_CNStartBill = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
            Exit Sub '*KT 52-12-01 ก่อนหน้า POSFront 3.0.7 นั้นไม่มีการ Exit Sub ซึ่งมีผลต่อโปรแกรมมาก
        End If
        
        cTempBal = cVB_Balance '*KT 54-11-15 V.4.0.4
        
        '*Tao 62-07-19 ถ้ามีการใช้ Credit Redeem ให้แยก RC โดยใช้ ข้อมูลชุดเดิม
        If (UCase(tVB_TenderCode) = "T002") And (cVB_CreditRedeemAmt > 0) Then
            If (cVB_CreditRedeemAmt = cVB_Pay) Then 'ถ้าเท่ากัน แสดงว่า Full Redeem
                cDiscMalCrdOfCrd = cVB_AdjustDiscMalCrdOfCrd
                cMalCrdOfOntop = cVB_AdjustMalCrdOfOntop
            Else
                cDiscMalCrdOfCrd = 0
                cMalCrdOfOntop = 0
            End If
            nUT_SeqRC = W_FNDnFindSeqRC(tVB_CNTblRC)
            cFAmt = cVB_Balance
            If CDbl(cVB_CreditRedeemAmt) < CDbl(SP_FMTcCurPoint((cVB_Balance), True, True)) Then   'เงินรับ น้อยกว่า เงินที่จะต้องจ่าย(ยังค้างชำระอยู่)
                cNet = cVB_CreditRedeemAmt
                cVB_Balance = SP_FMTcCurPoint(cVB_Balance - cVB_CreditRedeemAmt, True, True)
                cVB_RoundRcv = 0
                cVB_Change = 0
            ElseIf CDbl(cVB_CreditRedeemAmt) = CDbl(SP_FMTcCurPoint((cVB_Balance), True, True)) Then
                cNet = SP_FMTcCurPoint(cVB_Balance, True, False)
                cVB_Change = 0
                cVB_Balance = 0
                cVB_RoundRcv = 0
                bComplete = True
            Else
                cNet = SP_FMTcCurPoint(cVB_Balance, True, False)
                cVB_Change = 0
                cVB_Balance = 0
                cVB_RoundRcv = 0
                bComplete = True
            End If
            cAmount = cNet
            cPer = cAmount * 100 / cFAmt
            Select Case SP_VALnText2Double(tVB_TransactionSub)
            Case tEN_TrnReturn, tEN_TrnOtherDisbursement, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                If UCase(tVB_CrdStaBPReturn) = UCase("Y") Then
                    tVB_NETType = "Y"
                Else
                    tVB_NETType = "N"
                End If
            Case Else
                If UCase(tVB_CrdStaBPSale) = UCase("Y") Then
                    tVB_NETType = "Y"
                Else
                    tVB_NETType = "N"
                End If
            End Select
            tSql = "DELETE " & tVB_CNTblRC & " WITH(ROWLOCK) "
            tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
            tSql = tSql & vbCrLf & "AND FTShdTransNo = '" & tVB_Running & "'"
            tSql = tSql & vbCrLf & "AND FNSrcSeqNo = " & nUT_SeqRC & ""
            tSql = tSql & vbCrLf & "AND FDShdTransDate = '" & tUT_SaleDate & "'"
            tSql = tSql & vbCrLf & "AND FTShdTransType = '" & tVB_Transaction & "'"
            If SP_SQLvExecute(tSql) <> 0 Then
                tMsg = cUT.UT_STRtToken(tMS_CN502, ";", CInt(nVB_CNCutLang))
                Call SP_MSGnShowing(tMsg, nCS_Warning, True)
                Call SP_CRTxWriteLogTerminated("Form:" & Me.Name & " Events:W_KBRcvCredit " & "(" & tSql & ")")
            End If
            tSql = "INSERT INTO " & tVB_CNTblRC
            tSql = tSql & "(FTRemark,FTTmnNum,FTShdTransNo,FNSrcSeqNo,"
            tSql = tSql & "FTShdTransType,FDShdTransDate,FTTdmCode,"
            tSql = tSql & "FTTdmType,FTSrcCardNo,FTApprCode,"
            tSql = tSql & "FCSrcCardChg,FCSrcFAmt,FCSrcAmt,"
            tSql = tSql & "FCSrcNet,FCSrcChg,FTSrcStaPrc,"
            tSql = tSql & "FTSrcRmk,FCSrcRetAmt,"
            tSql = tSql & "FNShdStaSend,"
            tSql = tSql & "FTRteCode,"
            tSql = tSql & "FCSrcRteAmt ,"
            tSql = tSql & "FCSrcRteFac,"
            tSql = tSql & "FCSrcRndMnyChg,"
            tSql = tSql & "FTSrcAbb,"
            tSql = tSql & "FTSrcCardExp,"
            tSql = tSql & "FCSrcOntopAmt,"
            tSql = tSql & "FNSrcCrdPoint,"
            tSql = tSql & "FTEvnCode,"
            tSql = tSql & "FTEDCDetail,"
           ' tSql = tSql & vbCrLf & "FTREFNO,FTSrcRetDocRef,FTVendorCnpFlag," '*KT 66-12-08 CR Bank Instant Point Redemption
            tSql = tSql & vbCrLf & "FTREFNO,FTSrcRetDocRef," '*KT 67-01-29 Downgrade CR Bank Instant Point Redemption
            tSql = tSql & tCS_CNLastFedIns
            tSql = tSql & " VALUES('" & tVB_IsFreeRange & "','" & tVB_CNTerminalNum & "','" & tVB_Running & "'," & nUT_SeqRC & ","
            tSql = tSql & "'" & tVB_Transaction & "','" & tUT_SaleDate & "','" & tVB_TenderCode & "',"
            tSql = tSql & "'" & tVB_TenderType & "','" & tVB_CrdCardNo & "','" & tVB_CrdApprCode & "',"
            tSql = tSql & 0 & "," & SP_FMTcCurPoint(cFAmt, True, False) & "," & SP_FMTcCurPoint(cVB_CreditRedeemAmt, True, False) & ","
            tSql = tSql & SP_FMTcCurPoint(cNet, True, False) & "," & SP_FMTcCurPoint(cVB_Change, True, False) & ",'" & IIf(cDiscMalCrdOfCrd > 0, "1", "") & "',"
            tSql = tSql & "'" & tVB_NETType & "'," & 0 & ","
            tSql = tSql & "0,"
            tSql = tSql & "'" & tVB_FTRteCode & "',"
            tSql = tSql & SP_FMTcCurPoint(cVB_FCSrcRteAmt, True, False) & ","
            tSql = tSql & SP_FMTcCurPoint(cVB_FCSrcRteFac, True, False) & ","
            tSql = tSql & SP_FMTcCurPoint(cVB_RoundChg, True, False) & ","
            tSql = tSql & "'" & tVB_CreditRedeemName & "',"
            tSql = tSql & "'" & tVB_CrdExpM & "/" & tVB_CrdExpY & "',"
            tSql = tSql & SP_FMTcCurPoint(cMalCrdOfOntop, True, False) & ","
            tSql = tSql & 0 & ","
            tSql = tSql & "'" & tVB_CrdEvnID & "',"
            tSql = tSql & "'" & tVB_EDCDetail & "',"
            tSql = tSql & vbCrLf & "'" & tVB_CreditRedeemName & "',"
            tSql = tSql & vbCrLf & "'" & tVB_CreditRedeemName & "',"
           ' tSql = tSql & vbCrLf & "'" & "1" & "'," '*KT 66-12-08 CR Bank Instant Point Redemption '*KT 67-01-29 Downgrade CR Bank Instant Point Redemption
            tSql = tSql & UT_tLastInsSql & ")"
            If SP_SQLvExecute(tSql) <> 0 Then
                tMsg = cUT.UT_STRtToken(tCS_MSG60, ";", CInt(nVB_CNCutLang)) 'tCS_MSG60
                tMsg = tMsg & "(Error No:" & nVB_CNErrNo & " Desc :" & tVB_CNErrDescript & ")"
                Call SP_MSGnShowing(tMsg, nCS_Warning, True)
                Call SP_CRTxWriteLogTerminated("TransNo:" & tVB_Running & "Tender:" & tVB_TenderCode & "Type:" & tVB_TenderType & " " & tMsg)
                cVB_Balance = cTempBal
                If cVB_AdjustMalCrdOfOntop > 0 Then
                     cVB_Balance = 0 'กลับไปที่หน้าจอ Item Entry เพื่อเริ่มทำการลดส่วนลดท้ายบิลและรับชำระใหม่
                Else
                    cVB_Balance = cTempBal
                End If
                Call SP_OBJxSetFocus(.ogdFunc)
                Call SP_DATxRsNothing(orsTemp)
                Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " INSERT RC tSql Err:" & tSql))  '*Bump 57-11-04 TK_Issue Monitor Mising Transaction ไม่มี RC
                Exit Sub
            Else
                '*Tao 59-01-14 ตรวจสอบก่อนว่า insert rc ได้หรือป่าว CommSheet TK-ISS3000-608
                tWhere = "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'" & " AND FTShdTransNo = '" & tVB_Running & "'" & " AND FNSrcSeqNo = " & nUT_SeqRC & "" & " AND FDShdTransDate = '" & tUT_SaleDate & "'" & " AND FTShdTransType = '" & tVB_Transaction & "'"
                If SP_SQLtFunction("COUNT", "FTShdTransNo", tVB_CNTblRC, tWhere) = "0" Then
                    tMsg = cUT.UT_STRtToken(tMS_CN502, ";", CInt(nVB_CNCutLang))
                    Call SP_MSGnShowing(tMsg, nCS_Warning, True)
                    Call SP_CRTxWriteLogTerminated("TransNo:" & tVB_Running & "Tender:" & tVB_TenderCode & "Type:" & tVB_TenderType & " " & "Inserted to TPSRC" & tVB_CNTerminalNum & " no error but can't Select (V_V)")
                    bComplete = False
                    cVB_Balance = cTempBal
                    If nUT_SeqRC = 1 Then
                        If Not wSub Is Nothing Then Unload wSub
                        Select Case Val(Format(tVB_TransactionSub))
                            Case tEN_TrnSaleTaxInc, tEN_TrnReturnTaxInc, tEN_TrnTotalReportTaxInc, tEN_TrnOverShortReportTaxInc, tEN_TrnClosingReportTaxInc
                                    tVB_CNMnuCurrent = "172001"
                            Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax, tEN_TrnTotalReportManualTax, tEN_TrnOverShortReportManualTax, tEN_TrnClosingReportManualTax
                                    tVB_CNMnuCurrent = "172101"
                            Case Else
                                    tVB_CNMnuCurrent = "1700"
                        End Select
                        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
                            Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
                        Else
                            wMain.W_FRMxActivate
                        End If
                        Call SP_OBJxSetFocus(wMain.otbPrompt)
                        wMain.otbPrompt.Locked = False
                        bVB_CNStartBill = True
                    Else
                        Call SP_OBJxSetFocus(.ogdFunc)
                    End If
                    Exit Sub
                End If
                '========================================
                
                Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " INSERT RC tSql sucess:" & tSql))  '*Bump 57-11-04 TK_Issue Monitor Mising Transaction ไม่มี RC
                '*KT 54-11-15 V.4.0.4 ย้ายไปอยู่หลัง Insert RC '------------------------------------------------------------------------------------------------------------
                If SP_FMTcCurPoint(cAmount, True, False) > 0 Then '*Neung 55-07-05 ML-PH4-R3-028 Can't IPV Redeem
                    nRow = .ogdTender.Aggregate(flexSTCount, .ogdTender.FixedRows, .ogdTender.ColIndex("FCSrcNet"), .ogdTender.rows - 1, .ogdTender.ColIndex("FCSrcNet")) + 1 '*Eaw 55-09-02
                     If nRow = .ogdTender.rows Then .ogdTender.rows = .ogdTender.rows + 1
                    .ogdTender.TextMatrix(nRow, .ogdTender.ColIndex("FNSrcSeqNo")) = nRow
                    .ogdTender.TextMatrix(nRow, .ogdTender.ColIndex("FTTdmType")) = tVB_CreditRedeemName
                    .ogdTender.TextMatrix(nRow, .ogdTender.ColIndex("FCSrcNet")) = cAmount
                    .ogdTender.TopRow = nRow
                    .olaDiscTotal.Caption = SP_FMTcCurPoint(SP_VALcText2Double(.olaDiscTotal.Caption), False, True)
'                    Select Case Val(Format(tVB_TransactionSub))
'                        Case tEN_TrnDeposit, tEN_TrnRedeem, tEN_TrnAddDeposit, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
'                             cVB_NetSale = cVB_NetSale
'                             cVB_NetSaleRound = cVB_NetSale + cVB_RoundRcv
'                            .olaNetSale.Caption = SP_FMTcCurPoint(SP_VALcText2Double(.olaNetSale.Caption), False, True)
'                        Case Else
'                             cVB_NetSale = cVB_NetSale
'                             cVB_NetSaleRound = cVB_NetSale + cVB_RoundRcv
'                            .olaNetSale.Caption = SP_FMTcCurPoint(SP_VALcText2Double(.olaNetSale.Caption), False, True)
'                    End Select
                    .olaBalance.Caption = SP_FMTcCurPoint(cVB_Balance, False, True)
                    .olaAmtTender.Caption = SP_FMTcCurPoint(.ogdTender.Aggregate(flexSTSum, .ogdTender.FixedRows, .ogdTender.ColIndex("FCSrcNet"), .ogdTender.rows - 1, .ogdTender.ColIndex("FCSrcNet")), False, True)
                     Call SP_OBJxSetFocus(.ogdFunc)
                End If
            End If
            cVB_Pay = cVB_Pay - cAmount 'หักยอดที่ Redeem ออก
            If bComplete Then GoTo CreditFinish
'ของเดิมมีการเก็บ T002 ปกติ Credit Card แบบ Redeem ทั้งหมด หรือ Redeem อย่างเดี่ยว เป็น 0 เสมอ
'            If cVB_Pay = 0 Then '*KT 66-12-06 CR Bank Instant Point Redemption
'                Call SP_DATxRsNothing(orsTemp)
'                Exit Sub
'            End If
        End If
        '============================
            
