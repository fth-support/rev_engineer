            '------------------------------------------------------------------------------------
            '*KT 52-03-31 PH1.8-ML-SF-013 กรณีที่สินค้าได้ราคา member price แต่เป็นสินค้า Prompt Sale นั้นต้องใส่ราคา Prompt Sale ก่อนแล้วคำนวณราคา Member Price ที่ได้
            If bVB_CNMemberPrice And cUT_RegPrice <> 0 And Not bUT_PromptSale Then  '*KT 52-03-31 ต้องเป็น Member Price และสินค้าไม่เป็น Prompt Sale เพราะ Prompt Sale จะไปคิดที่ W_KBXPromptSale อีกที่
                'If xVB_CNMemberP.ID <> "" And xVB_CNMemberP.MallCardMemberPrice = "Y" And SP_FEDtChkString(poRsSKU, "FTSkuStaMemPriceAlw") = "Y" Then
                If xVB_CNMemberP.ID <> "" And xVB_CNMemberP.MallCardMemberPrice = "Y" Then
