Public Function W_PRCbMoveDataToDeposit() As Boolean
'-------------------------------------------------------------------
'Call:
'Cmt: ทำการ Copy Transaction Deposit ไปเก็บที่ตารางอีกตารางหนึ่ง
'           เพื่อเมื่อทำการ Close Terminal ข้อมูลจะไม่หายไปด้วย
'*KT 51-10-31
'*KT 51-11-11
'*KT 52-05-30 ทำงานโดยการ Copy ข้อมูลจาก Temp Sale ไปยัง Table Deposit ในฐานข้อมูล Server แล้วค่อยให้ ServiceTransfer ส่งข้อมูลไปยัง Server อีกครั้งหนึ่ง
'---------------------------------------------------------------------
    Dim tSql$, tTable$, tWhr$
    'Dim nPdtSeq As Long
    Dim orsTemp  As ADODB.Recordset
    Dim cMiscRecv As Double
    Dim nEff As Long
On Error GoTo ErrHandle

    tSql = "STP_CNxSQLDelDepositByWhr @ptTmnNum ='" & tVB_CNTerminalNum & "',@ptRunning ='" & tVB_Running & "',@ptTransType ='" & tVB_Transaction & "',@ptTransDate ='" & tUT_SaleDate & "'"
    Call SP_SQLbExecute(tSql)
    tTable = "TPSTDepositHD"            'HD ก่อน
    tWhr = "WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblHD & "',@ptWhere = '" & tWhr & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Function
    If (orsTemp.EOF And orsTemp.BOF) Then Call SP_DATxRsNothing(orsTemp): Exit Function
    Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, 0, 0, True)
    
    
    tSql = "STP_CNxSQLDelDepositDTByWhr @ptTmnNum ='" & tVB_CNTerminalNum & "',@ptRunning ='" & tVB_Running & "',@ptTransType ='" & tVB_Transaction & "',@ptTransDate ='" & tUT_SaleDate & "'"
    Call SP_SQLbExecute(tSql)
    tTable = "TPSTDepositDT"           'DT หลัง
    tWhr = "WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblDT & "',@ptWhere = '" & tWhr & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp):   Exit Function
    'nPdtSeq = 0
    Do While Not orsTemp.EOF
        'nPdtSeq = nPdtSeq + 1            'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, 0, 0, True)        'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        orsTemp.MoveNext
    Loop
    
    tSql = "STP_CNxSQLDelDepositRCByWhr @ptTmnNum ='" & tVB_CNTerminalNum & "',@ptRunning ='" & tVB_Running & "',@ptTransType ='" & tVB_Transaction & "',@ptTransDate ='" & tUT_SaleDate & "'"
    Call SP_SQLbExecute(tSql)
    tTable = "TPSTDepositRC"           'RC หลัง
    tWhr = "WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblRC & "',@ptWhere = '" & tWhr & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Function
    'nPdtSeq = 1
    Do While Not orsTemp.EOF
        'nPdtSeq = nPdtSeq + 1            'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, 0, 0, True)        'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        orsTemp.MoveNext
    Loop
    Call SP_DATxRsNothing(orsTemp)
    

    tSql = "STP_CNxSQLDelDepositCDByWhr @ptTmnNum ='" & tVB_CNTerminalNum & "',@ptRunning ='" & tVB_Running & "',@ptTransType ='" & tVB_Transaction & "',@ptTransDate ='" & tUT_SaleDate & "'"
    Call SP_SQLbExecute(tSql)
    tTable = "TPSTDepositCD"           'CD หลัง
    tWhr = "WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblCD & "',@ptWhere = '" & tWhr & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Function
    'nPdtSeq = 1
    Do While Not orsTemp.EOF
        'nPdtSeq = nPdtSeq + 1            'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, 0, 0, True)            'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        orsTemp.MoveNext
    Loop
    Call SP_DATxRsNothing(orsTemp)
    
    Select Case Val(Format(tVB_TransactionSub))
        Case tEN_TrnAddDeposit
            '*KT 52-04-10 Deposit  เต็มจำนวน และมีเศษสตางค์ และชำระด้วย Credit Card ซึ่งจะไม่ต้องปัดเศษ ตอนทำ Redeem จะแสดงค่า Amount Due and Previous Amout Due ผิด และมีทำให้ไม่สามารถทำ IPV Redeem ได้ (see attached Redeem-S16.doc)
            'ตามเอกสาร phase1.8 UAT status on 10-04-2009
            'ถ้าไม่เกิด misc rec ที่รายการ AddDeposit ก้อไม่ต้องคำนวณหา cMiscRecv ที่นำไปหักค่า FCShdDepositBal ของเอกสาร Deposit
            '--------------------------------------------------------------------------------------------------------------
            If cVB_RoundRcv > 0 Then
                cMiscRecv = IIf(bVB_CNAlwRnd, SP_FMTcCurPoint(UT_GetnRoundDiff(cVB_DepossitAmtAddDptOrg), True, False), 0)
            Else
                cMiscRecv = 0
            End If
            '--------------------------------------------------------------------------------------------------------------
            tSql = "STP_CNxSQLUpdDepositBalByWhr @ptTmnNum = '" & tVB_TerminalNoAddDpt & "',@ptRunning = '" & tVB_TransNoAddDpt & "',@ptTransDate = '" & SP_DTEtStrSTD(dVB_TransDateAddDpt) & "' ,@pcValue = " & SP_FMTcCurPoint(cVB_AccBalAddDpt - (cVB_DepossitAmtAddDptOrg + cMiscRecv), True, False) '*KT 51-11-09 +- ค่า Misc Recv ด้วย
            nEff = 0
            Call SP_SQLvExecute(tSql, , oDB.ocnOnLine, , , nEff)
            If nEff < 1 Then
                W_PRCbMoveDataToDeposit = False
                Call SP_DATxRsNothing(orsTemp)
                Exit Function
            End If
            Call SP_SQLvExecute(tSql) 'local

            '***********************
            tSql = "UPDATE " & tVB_CNTblHD
            tSql = tSql & vbCrLf & " SET FCShdDepositBal =" & SP_FMTcCurPoint(cVB_AccBalAddDpt - (cVB_DepossitAmtAddDptOrg + cMiscRecv), True, False)
            tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_TerminalNoAddDpt & "' AND FTShdTransNo='" & tVB_TransNoAddDpt & "'"
            tSql = tSql & vbCrLf & " AND FDShdTransDate='" & SP_DTEtStrSTD(dVB_TransDateAddDpt) & "'"
            Call SP_SQLvExecute(tSql) 'local
    End Select

    bVB_CNTrnOnlineSuccess = True 'Flag ตัวบอกว่าการทำ Transaction ที่ทำงานได้เฉพาะ Online ผ่าน Success
    W_PRCbMoveDataToDeposit = True
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    W_PRCbMoveDataToDeposit = False
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Function W_PRCbMoveDataToVoucher() As Boolean
'-------------------------------------------------------------------
'Call:
'Cmt: ทำการ Copy Transaction Deposit ไปเก็บที่ตารางอีกตารางหนึ่ง
'           เพื่อเมื่อทำการ Close Terminal ข้อมูลจะไม่หายไปด้วย
'---------------------------------------------------------------------
    Dim tSql$, tTable$
    Dim nPdtSeq As Long
    Dim orsTemp  As ADODB.Recordset
On Error GoTo ErrHandle
    W_PRCbMoveDataToVoucher = False
    
    tSql = "DELETE TPSTVoucherHD"
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    Call SP_SQLbExecute(tSql)
    tTable = "TPSTVoucherHD"           'HD ก่อน
    tSql = "SELECT * FROM " & tVB_CNTblHD
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Function
    If (orsTemp.EOF And orsTemp.BOF) Then Call SP_DATxRsNothing(orsTemp): Exit Function
    Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True)
    
    
    tSql = "DELETE TPSTVoucherRC"
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    Call SP_SQLbExecute(tSql)
    tTable = "TPSTVoucherRC"           'DT หลัง
    tSql = "SELECT * FROM " & tVB_CNTblRC
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Function
    nPdtSeq = 1
    Do While Not orsTemp.EOF
        nPdtSeq = nPdtSeq + 1            'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, nPdtSeq)           'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
        orsTemp.MoveNext
    Loop
    W_PRCbMoveDataToVoucher = True
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    W_PRCbMoveDataToVoucher = False
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Function W_PRCbUpdTmpDeposit() As Boolean
'-------------------------------------------------------------------
'PH 2.0.0
'Call:
'Cmt: ทำการปรับเฟกเพื่อให้รู้ว่าใบ Ticket ที่มีการอ้างอิงการทำ Deposit ว่ามีการยกเลิก
'*KT 51-11-11
''*KT 51-05-31 Comsheet ML-SF-301
'---------------------------------------------------------------------
    Dim tSql$
    Dim bPass1 As Boolean
'    Dim bPass2 As Boolean
    Dim tTerminalNum As String
    Dim tTrnNo As String
    Dim dTranDate As Date
    Dim orsTemp As ADODB.Recordset
    Dim cDiscontop As Double
    Dim dDate  As Date
    Dim tTime As Date
    Dim cBalNew As Double
    Dim nEff As Long
On Error GoTo ErrHandle
'    bPass2 = False
'    oDB.ocnOnLine.BeginTrans 'PH 2.0.0 ติดต่อฐานข้อมูล Server เท่านั้น
'    bPass2 = True
    bPass1 = False
    ocnAll.BeginTrans
    bPass1 = True
    nVB_CNCountBegin = nVB_CNCountBegin + 1
    Select Case Val(Format(tVB_TransactionSub))
        Case tEN_TrnRedeem
            'Upd Deposit Add Deposit
            '*KT 52-11-26  PH2-ML-SF-142 HD of Deposit Missing  กรณีที่  POS/ Tran ของ Deposit เหมือนกับ POS/Tran ของ Reddem  เช่น Deposit POS 1001 Tran 1000  Deposit No. 99999 วันที่ 01/12/2008  แล้วมีการทำ Redeem  กับ Deposit ใบอื่นแต่ หมายเลข POS/Tran มาซ้ำกับ Deposit ใบแรก   Redeem Deposit Number 88888  หมายเลขเครื่อง 1001 Tran 1000 วันที่ 10/09/2009  เมื่อถึงกำหนดให้ลบ Deposit  HD ของ Deposit No. 99999 จะถูกลบด้วย
            '*KT 52-11-26 PH2-ML-SF-154  กรณี Deposit Delivery เมื่อทำการ Redeem ไม่มีการ Update record บน TPSTSalVatHD จึงทำให้ไม่สามารถทำ Confirm ได้
            '*KT 52-11-26 PH 3.0-ML-SF-033  ในกรณีที่ทำการ Deposit --> Add Deposit--> Redeem แล้ว ยังสามารถทำ Cancel Add Deposit ได้ ที่ถูกต้องจะต้องทำไม่ได้เพราะ ได้ Redeem ไปแล้ว
            tSql = "UPDATE TPSTDepositHD"
            tSql = tSql & vbCrLf & " SET FTShdStaPaid = '3'"
            tSql = tSql & vbCrLf & " ,FTShdStaPrcDoc = '1'"
            tSql = tSql & vbCrLf & " ,FTSendUp = '0'"                           '*Ao 2013/02/18   Service
            tSql = tSql & vbCrLf & " ,FTCstCardCode3 = '" & Format(tUT_SaleDate, "yyyy/MM/dd") & "'"          '*Bump 58-04-02 CommSheet TK-ISS3000-584.xls V.4.2.170
            tSql = tSql & vbCrLf & " WHERE  FTShdDepRefTmnNum='" & tVB_TerminalNoRedeem & "' AND FTShdDepReTransNo='" & tVB_TransNoRedeem & "'"
            tSql = tSql & vbCrLf & " AND  FTShdTransType IN ('" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00")) & "') AND FDShdDepReTransDate='" & SP_DTEtStrSTD(dVB_TransDateRedeem) & "'"
            nEff = 0
            If SP_SQLvExecute(tSql, , oDB.ocnOnLine, , , nEff) <> 0 Then 'Online
                If nEff < 1 Then
                     W_PRCbUpdTmpDeposit = False
    '                 If bPass2 Then oDB.ocnOnLine.RollbackTrans: bPass2 = False
                     If bPass1 Then
                        ocnAll.RollbackTrans
                        bPass1 = False
                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                     End If
                     Call SP_DATxRsNothing(orsTemp)
                     Exit Function
                End If
            End If
            Call SP_SQLvExecute(tSql) 'Offline
            
            'Upd Temp SaleHD
            tSql = "UPDATE " & tVB_CNTblHD
            tSql = tSql & vbCrLf & " SET FTShdStaPaid = '3'"
            tSql = tSql & vbCrLf & " ,FTShdStaPrcDoc = '1'"
            tSql = tSql & vbCrLf & " ,FTSendUp = '0'"                       '*Ao 2013/02/18   Service
            tSql = tSql & vbCrLf & " ,FTCstCardCode3 = '" & Format(tUT_SaleDate, "yyyy/MM/dd") & "'"          '*Bump 58-04-02 CommSheet TK-ISS3000-584.xls V.4.2.170
            tSql = tSql & vbCrLf & " WHERE  FTShdDepRefTmnNum='" & tVB_TerminalNoRedeem & "' AND FTShdDepReTransNo='" & tVB_TransNoRedeem & "'"
            tSql = tSql & vbCrLf & " AND  FTShdTransType IN ('" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00")) & "') AND FDShdDepReTransDate='" & SP_DTEtStrSTD(dVB_TransDateRedeem) & "'"
            Call SP_SQLvExecute(tSql) 'Offline
         
            'Upd  SaleHD
            tSql = "UPDATE TPSTSalHD"
            tSql = tSql & vbCrLf & " SET FTShdStaPaid = '3'"
            tSql = tSql & vbCrLf & " ,FTShdStaPrcDoc = '1'"
            tSql = tSql & vbCrLf & " ,FTSendUp = '0'"                       '*Ao 2013/02/18   Service
            tSql = tSql & vbCrLf & " ,FTCstCardCode3 = '" & Format(tUT_SaleDate, "yyyy/MM/dd") & "'"          '*Bump 58-04-02 CommSheet TK-ISS3000-584.xls
            tSql = tSql & vbCrLf & " WHERE  FTShdDepRefTmnNum='" & tVB_TerminalNoRedeem & "' AND FTShdDepReTransNo='" & tVB_TransNoRedeem & "'"
            tSql = tSql & vbCrLf & " AND  FTShdTransType IN ('" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00")) & "') AND FDShdDepReTransDate='" & SP_DTEtStrSTD(dVB_TransDateRedeem) & "'"
            Call SP_SQLvExecute(tSql, , oDB.ocnOnLine) 'Online
            Call SP_SQLvExecute(tSql) 'Offline
            
        Case tEN_TrnDepositCancel
            tSql = "UPDATE TPSTDepositHD"
            tSql = tSql & vbCrLf & " SET FTShdStaCancel = 'Y'"
            tSql = tSql & vbCrLf & " ,FTSendUp = '0'"                       '*Ao 2013/02/18   Service
            tSql = tSql & vbCrLf & " ,FTCstCardCode3 = '" & Format(tUT_SaleDate, "yyyy/MM/dd") & "'"          '*Bump 58-04-02 CommSheet TK-ISS3000-584.xls
            tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_TerminalNoDptCancel & "' AND FTShdTransNo='" & tVB_TransNoDptCancel & "'"
            tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_TransTypeDptCancel & "' AND FDShdTransDate='" & SP_DTEtStrSTD(dVB_TransDateDptCancel) & "'"
            nEff = 0
            If SP_SQLvExecute(tSql, , oDB.ocnOnLine, , , nEff) <> 0 Then 'Online
                If nEff < 1 Then
                     W_PRCbUpdTmpDeposit = False
    '                 If bPass2 Then oDB.ocnOnLine.RollbackTrans: bPass2 = False
                     If bPass1 Then
                        ocnAll.RollbackTrans
                        bPass1 = False
                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                    End If
                     Call SP_DATxRsNothing(orsTemp)
                     Exit Function
                End If
            End If
            Call SP_SQLvExecute(tSql) 'Offline

            
            '*KT 51-09-30 แก้ไขการ Deposit Cancle
            '-----------------------------------------------------------------------------------------
            tSql = "UPDATE TPSTSalHD"
            tSql = tSql & vbCrLf & " SET FTShdStaCancel = 'Y'"
            tSql = tSql & vbCrLf & " ,FTSendUp = '0'"                       '*Ao 2013/02/18   Service
            tSql = tSql & vbCrLf & " ,FTCstCardCode3 = '" & Format(tUT_SaleDate, "yyyy/MM/dd") & "'"          '*Bump 58-04-02 CommSheet TK-ISS3000-584.xls
            tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_TerminalNoDptCancel & "' AND FTShdTransNo='" & tVB_TransNoDptCancel & "'"
            tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_TransTypeDptCancel & "' AND FDShdTransDate='" & SP_DTEtStrSTD(dVB_TransDateDptCancel) & "'"
