Private Sub W_PRCxRedeemClose(ByRef pcDepositVatable As Double, ByRef pcDepositVat As Double, ByRef pcDepositUnNonVat As Double, ByRef pcDepositNonVat As Double, ByRef pcDepositAmt As Double)
    'Redeem
    '*KT 51-11-10
    'PH 2.0.0
On Error GoTo ErrHandle
    Dim orsTemp As ADODB.Recordset
    Dim tSql$
    Dim tTransType$
    tTransType = "FTShdTransType"
     tSql = "SELECT  "
     tSql = tSql & vbCrLf & "  SUM(CASE WHEN " & tTransType & "  IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "') THEN ISNULL(FCShdDepositVatable,0) ELSE 0 END) AS FCNetRdmAmt"
     tSql = tSql & vbCrLf & " ,ROUND((SUM(CASE WHEN " & tTransType & "  IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "') THEN ISNULL(FCShdDepositUnNonVat,0)  ELSE 0 END)  * 7 /107),2) AS FCVatRdmAmt"  '*ใช้แทน FCShdDepositVat เพราะค่าที่ Sum Vat จาก DT กับ ก้อน Amount * 7 /107 ไม่ Diff อยู่ประมาณ 0.01 ถึง 0.02
     tSql = tSql & vbCrLf & " ,SUM(CASE WHEN " & tTransType & "  IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "') THEN ISNULL(FCShdDepositUnNonVat,0) ELSE 0 END) AS FCSaleVatRdmAmt"
     tSql = tSql & vbCrLf & " ,SUM(CASE WHEN " & tTransType & "  IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "') THEN ISNULL(FCShdDepositNonVat,0) ELSE 0 END) AS FCSaleNTRdmAmt"
     tSql = tSql & vbCrLf & " ,SUM(CASE WHEN " & tTransType & "  IN ('" & Format(tEN_TrnDeposit, "00") & "','" & Format(tEN_TrnAddDeposit, "00") & "') THEN ISNULL(FCShdDepositAmt ,0) + ISNULL(FCShdRnd,0) ELSE 0 END) AS FCSaleTotalRdmAmt"
     tSql = tSql & vbCrLf & " FROM TPSTDepositHD"
     tSql = tSql & vbCrLf & " WHERE FTShdDepRefTmnNum='" & tVB_TerminalNoRedeem & "'"
     tSql = tSql & vbCrLf & " AND FTShdDepReTransNo='" & tVB_TransNoRedeem & "'"
     tSql = tSql & vbCrLf & " AND FDShdDepReTransDate='" & Format(dVB_TransDateRedeem, "yyyy/mm/dd") & "'"
     tSql = tSql & vbCrLf & " AND " & tTransType & " IN ("
     tSql = tSql & vbCrLf & "'" & Format(tEN_TrnDeposit, "00") & "'"
     tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnAddDeposit, "00") & "'"
     tSql = tSql & vbCrLf & ")"
     tSql = tSql & vbCrLf & " AND ISNULL(FTShdStaCancel,'N') <> 'Y'"
     tSql = tSql & vbCrLf & " AND FTShdStaDoc = '1'"
     Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) 'ต้องทำติดต่อฐานข้อมูล Server
      If Not (orsTemp.EOF Or orsTemp.BOF) Then
           pcDepositVatable = SP_FEDvChkNumeric(orsTemp, "FCNetRdmAmt")
           pcDepositVat = SP_FEDvChkNumeric(orsTemp, "FCVatRdmAmt")
           pcDepositUnNonVat = SP_FEDvChkNumeric(orsTemp, "FCSaleVatRdmAmt")
           pcDepositNonVat = SP_FEDvChkNumeric(orsTemp, "FCSaleNTRdmAmt")
           pcDepositAmt = SP_FEDvChkNumeric(orsTemp, "FCSaleTotalRdmAmt")
      Else
           pcDepositVatable = 0
           pcDepositVat = 0
           pcDepositUnNonVat = 0
           pcDepositNonVat = 0
           pcDepositAmt = 0
      End If
      Call SP_DATxRsNothing(orsTemp)
      Exit Sub
ErrHandle:
    pcDepositVatable = 0
    pcDepositVat = 0
    pcDepositUnNonVat = 0
    pcDepositNonVat = 0
    pcDepositAmt = 0
    Call SP_DATxRsNothing(orsTemp)
End Sub

Private Function W_GETcOntopDepositCancel(ptTerminalNoDptCancel$, ptTransNoDptCancel$, ptTransTypeDptCancel$, pdTransDateDptCancel As Date) As Double
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
 On Error GoTo ErrHandle
    W_GETcOntopDepositCancel = 0
    tSql = "SELECT SUM(FCScdAmt) AS FCDisc"
    tSql = tSql & vbCrLf & "  FROM         TPSTDepositCD INNER JOIN"
    tSql = tSql & vbCrLf & "                        TPSTDepositRC ON dbo.TPSTDepositCD.FTTmnNum = TPSTDepositRC.FTTmnNum AND"
    tSql = tSql & vbCrLf & "                        TPSTDepositCD.FTShdTransNo = TPSTDepositRC.FTShdTransNo AND"
    tSql = tSql & vbCrLf & "                        TPSTDepositCD.FDShdTransDate = TPSTDepositRC.FDShdTransDate AND"
    tSql = tSql & vbCrLf & "                        TPSTDepositCD.FTShdTransType = TPSTDepositRC.FTShdTransType"
    tSql = tSql & vbCrLf & " WHERE TPSTDepositRC.FTTmnNum = '" & ptTerminalNoDptCancel & "'"
    tSql = tSql & vbCrLf & " AND TPSTDepositRC.FTShdTransNo = '" & ptTransNoDptCancel & "'"
    tSql = tSql & vbCrLf & " AND TPSTDepositRC.FTShdTransType = '" & ptTransTypeDptCancel & "'"
    tSql = tSql & vbCrLf & " AND TPSTDepositRC.FDShdTransDate = '" & Format(pdTransDateDptCancel, "yyyy/mm/dd") & "'"
     tSql = tSql & vbCrLf & " AND TPSTDepositRC.FDShdTransDate = '" & Format(pdTransDateDptCancel, "yyyy/mm/dd") & "'"
     tSql = tSql & vbCrLf & " AND TPSTDepositCD.FNDctNo =15"
     tSql = tSql & vbCrLf & " AND TPSTDepositRC.FTSrcCardNo = TPSTDepositCD.FTScdCardID"
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        W_GETcOntopDepositCancel = SP_FEDvChkNumeric(orsTemp, "FCDisc")
    Else
        W_GETcOntopDepositCancel = 0
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Function

