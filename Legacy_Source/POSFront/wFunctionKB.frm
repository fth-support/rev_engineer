Private Sub W_PRCxVendor(ByVal pcNetSale As Double, ByVal pcSrcChg As Double)
'____________________________
'Call:
'Cmt:
'____________________________
    Dim bOffline As Boolean, bTranSrv As Boolean
    Dim cNet As Double
    Dim bFlagShwChg As Boolean
On Error GoTo ErrHandle
    cNet = pcNetSale
    cVB_Change = pcSrcChg
    Call W_CHKxAvgFooter
    Call W_PRCxSubRegHDEx(True)
    Call W_PrintSlipFooter
    'show change เงินทอน
    wMain.otbPrompt.Locked = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    bVB_CNStartBill = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    bVB_CNTrnOnlineSuccess = True
    bOffline = True
    If Not W_PRCxHandleTrnOnline Then
        With wMain
            .olaBarcode.Caption = ""
            .olaSKUName.Caption = ""
            .olaPrice.Caption = ""
            .olaSumQty.Caption = ""
            .olaTSubReg.Caption = ""
            .olaTSubPro.Caption = ""
            .olaTSubTotal.Caption = ""
            With .ogdForm
                .rows = 1
                .rows = nUT_GridMaxRow
            End With
            bTranSrv = False
             If Not oDB.ocnOnLine Is Nothing And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                oDB.ocnOnLine.BeginTrans
                bTranSrv = True
                nVB_CNCountBeginSrv = nVB_CNCountBeginSrv + 1
            End If
            'เงินทอน
            Select Case SP_VALnText2Double(tVB_TransactionSub)
                Case tEN_TrnReturn, tEN_TrnOtherDisbursement, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                    .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                    .olaChange.Visible = True
                Case tEN_TrnDeposit
                    bOffline = Not W_PRCbMoveDataToDeposit
                    .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                    .olaChange.Visible = True
                Case tEN_TrnRedeem
                    bOffline = Not W_PRCbUpdTmpDeposit
                    If Not bOffline Then
                        bOffline = Not W_PRCbMoveDataToDeposit
                    End If
                    .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                    .olaChange.Visible = True
                Case tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
                    bOffline = Not W_PRCbUpdTmpDeposit
                    If Not bOffline Then
                        bOffline = Not W_PRCbMoveDataToDeposit
                    End If
                    .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                    .olaChange.Visible = True
                Case tEN_TrnAddDeposit
                    bOffline = Not W_PRCbMoveDataToDeposit
                    .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                    .olaChange.Visible = True
                Case tEN_TrnVoucher
                    bOffline = Not W_PRCbMoveDataToVoucher
                    .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                    .olaChange.Visible = True
                Case tEN_TrnCancelVoucher
'                        bOffline = Not W_PRCbUpdTmpVoucher(bTranSrv)
                     bOffline = Not W_PRCbUpdTmpVoucher
                    .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                    .olaChange.Visible = True
                Case tEN_TrnVIPSale
                    bOffline = Not W_PRCbDelCreateVIP
                    .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                    .olaChange.Visible = True
                Case Else
                    bOffline = False
                    .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                    .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                    .olaChange.Visible = True
            End Select
            .Refresh '*KT 53-01-14 DoEvents
'                DoEvents '*KT 53-01-14 DoEvents
        End With
        If Not W_PRCxHandleTrnOnline(bOffline, bTranSrv) Then
            Call W_PRCxCashDrawerAct
        End If
    End If
    Call SP_UPDxSetCompleteTerminalMtn
    'เริ่ม Ticket ใหม่
     '*KT 54-09-20 V.4.0.1 กรณีที่ไม่เป็น OPOS ในการแสดงเงินทอน
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case 1, 5, 8, 9, 14, 17, 25, 26, 27, 28, 29, 30, 31, 32, 34, 35, 36
                bFlagShwChg = False
        Case Else
                If bVB_OPOSCashDrawerEnable Then
                    bFlagShwChg = False
                Else
                    bFlagShwChg = True
                End If
    End Select
     bVB_CNShwChange = bFlagShwChg
     Call UT_GenSaleNewDoc(bFlagShwChg)
     
    'Unload wSub '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnSaleTaxInc, tEN_TrnReturnTaxInc, tEN_TrnTotalReportTaxInc, tEN_TrnOverShortReportTaxInc, tEN_TrnClosingReportTaxInc
                    tVB_CNMnuCurrent = "172001"
            Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax, tEN_TrnTotalReportManualTax, tEN_TrnOverShortReportManualTax, tEN_TrnClosingReportManualTax
                    tVB_CNMnuCurrent = "172101"
            Case Else
                    tVB_CNMnuCurrent = "1700"
        End Select
    If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
        Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
    Else
        wMain.W_FRMxActivate
    End If
    Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
'        DoEvents '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero '*KT 53-01-14 DoEvents
    wMain.otbPrompt.Locked = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    bVB_CNStartBill = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    
    If bTranSrv Then
        oDB.ocnOnLine.CommitTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
   
    Exit Sub
ErrHandle:
    If bTranSrv Then
        oDB.ocnOnLine.RollbackTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
End Sub

Private Function W_PRCbCheckZeroVendor(ByVal pcNetSale As Double) As Boolean
'----------------------------------------------------------------
'Call:
'Cmt:       '*Ao 53-10-19
'-----------------------------------------------------------------
Dim tSql As String, tWhr As String
Dim orsTemp As ADODB.Recordset
Dim cNetSale As Double, cNetDutyFreeDep As Double, cSrcNet As Double, cSrcChg As Double
    
    On Error GoTo HandleErr
    
    W_PRCbCheckZeroVendor = True
    
    tWhr = " WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType=''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tWhr = tWhr & vbCrLf & " AND  FTTdmCode = ''T006''" & " AND FTVendorCnpFlag=''1''"
    tWhr = tWhr & vbCrLf & " AND ISNULL(FTSrcStaNoPay,'''') <> ''1''"
    tWhr = tWhr & vbCrLf & " ORDER BY  FNSrcSeqNo ASC"
    tSql = "STP_CNxSQLFunction @ptFunc = 'FNSrcSeqNo,FCSrcAmt,FCSrcNet,FCSrcChg' ,@ptTable = '" & tVB_CNTblRC & "',@ptWhere = '" & tWhr & "'"
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        cSrcNet = SP_FMTcCurPoint(W_SUMxValueByRS(orsTemp, "FCSrcNet"), True, False)
'        cSrcChg = SP_FMTcCurPoint(W_SUMxValueByRS(orsTemp, "FCSrcChg"), True, False)
'        tSql = "SELECT  FCSdtSaleAmt ,FCSdtDutyDeposit,FTSkuStaMallEmpCard"             'ทำการคำหา Sub Reg/Sub Pro/NetAmount ใหม่หลังจากทำส่วนลด
'        tSql = tSql & " FROM " & tVB_CNTblDTTmp '*KT 52-03-17 PH1.5-ML-SF-121 ทำการบังคับให้ Summary ใน Table Temp เลย
'        tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
'        tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
'        tSql = tSql & " AND  ISNULL(FTSdtCancelFlag,'0') <> '1'"
'        Call SP_SQLvExecute(tSql, orsTemp)
'        If Not (orsTemp.BOF and orsTemp.EOF) Then
'            cNetSale = SP_FMTcCurPoint(W_SUMxValueByRS(orsTemp, "FCSdtSaleAmt"), True, False)
''            cNetDutyFreeDep = SP_FMTcCurPoint(W_SUMxValueByRS(orsTemp, "FCSdtDutyDeposit"), True, False) '*KT 51-04-23 กรณีขายสินค้าแบบ Duty Free
'        Else
'            cNetSale = 0
''            cNetDutyFreeDep = 0
'        End If
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnDeposit, tEN_TrnAddDeposit
                cNetSale = pcNetSale
            Case Else
                cNetSale = pcNetSale
        End Select
        
        If cSrcNet >= cNetSale Then
            W_PRCbCheckZeroVendor = False
            Call W_PRCxVendor(cNetSale, cSrcChg)
        Else
            W_PRCbCheckZeroVendor = True
        End If
        
    End If
    
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
HandleErr:
    W_PRCbCheckZeroVendor = True
End Function

Public Sub W_KBCancelVendor()
'------------------------------------------------
'Call :
'Cmt:        '*Ao 53-10-13
'-------------------------------------------------
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim nRow As Integer

    On Error GoTo ErrHandle
    If bVB_CheckVendor Then
        nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
        If nRow = 0 Then
            Exit Sub
        End If
    End If
    tSql = "SELECT DISTINCT ISNULL(" & tVB_CNTblDT & ".FTSdtBarCode,'') AS FTSdtBarCode"
    'tSql = tSql & vbCrLf & ",ISNULL(" & tVB_CNTblDT & ".FTSkuAbbName,'Vendor Coupon') AS FTSkuAbbName" '*Tao 62-07-05 ของเดิม
    tSql = tSql & vbCrLf & ",ISNULL(" & tVB_CNTblDT & ".FTSkuAbbName,'Vendor Voucher') AS FTSkuAbbName" '*Tao 62-07-05 เปลี่ยนเป็น Vendor Voucher
    tSql = tSql & vbCrLf & "," & tVB_CNTblRC & ".FTSrcCardNo"
    tSql = tSql & vbCrLf & "," & tVB_CNTblRC & ".FCSrcAmt/" & tVB_CNTblRC & ".FTVendorCnpQty AS FCSrcAmtTmp"
    tSql = tSql & vbCrLf & "," & tVB_CNTblRC & ".FTVendorCnpQty," & tVB_CNTblRC & ".FCSrcAmt"
    tSql = tSql & vbCrLf & "," & tVB_CNTblRC & ".FNSrcSeqNo"
    tSql = tSql & vbCrLf & ",ISNULL(" & tVB_CNTblRC & ".FTSkuIndex,'') AS FTSkuIndex"
    tSql = tSql & vbCrLf & ",ISNULL(" & tVB_CNTblRC & ".FTVendorCnpType,'') AS FTVendorCnpType"
    tSql = tSql & vbCrLf & "FROM " & tVB_CNTblRC & " LEFT JOIN " & tVB_CNTblDT
    tSql = tSql & vbCrLf & "ON " & tVB_CNTblRC & ".FTSkuIndex = " & tVB_CNTblDT & ".FTSkuIndex"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTTmnNum = " & tVB_CNTblDT & ".FTTmnNum"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTShdTransNo = " & tVB_CNTblDT & ".FTShdTransNo"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTShdTransType = " & tVB_CNTblDT & ".FTShdTransType"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FDShdTransDate = " & tVB_CNTblDT & ".FDShdTransDate"
    tSql = tSql & vbCrLf & "WHERE " & tVB_CNTblRC & ".FTTdmCode  ='T006'"
    If bVB_CheckVendor Then
        tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTVendorCnpFlag = '1'"
    End If
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FTShdTransType = '" & tVB_Transaction & "'"
    tSql = tSql & vbCrLf & "AND " & tVB_CNTblRC & ".FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & "ORDER BY FNSrcSeqNo"
    
    Call SP_SQLvExecute(tSql, orsTemp)              '*Ao 53-10-13    DATABASE OFF
    If Not (orsTemp.EOF And orsTemp.BOF) Then
        wCNShowVendor.Show vbModal
    Else
        Call SP_MSGnShowing("tms_CN008033", nCS_Information)
    End If
    
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Private Sub W_RETxUpdateDT(ByVal poRsRet As ADODB.Recordset, ByVal pnSeq As Integer)
'------------------------------------------------
'Call :
'Cmt:
'-------------------------------------------------
    Dim tSql$
    Dim tDisChg$
    Dim cSdtDisAvg As Double
    Dim cSdtFootAvg As Double
    Dim cSdtRePackAvg As Double
    Dim cSdtVat As Double
    Dim cSdtVatable As Double
    Dim tPdtNoDis As String
    Dim nEff As Long
    
On Error GoTo ErrHandle
    'ต้อง update FTSdtDisChgTxt,FCSdtDisAvg,FCSdtFootAvg,FCSdtRePackAvg,FCSdtVat,FCSdtVatable
    tDisChg = SP_FEDvChkNumeric(poRsRet, "FTSdtDisChgTxt")
    cSdtVat = SP_FEDvChkNumeric(poRsRet, "FCSdtVat")
    cSdtVatable = SP_FEDvChkNumeric(poRsRet, "FCSdtVatable")
    '*KT 56-05-03 TK-ISS3000-169 Net Sale(EX GST) is wrong for Return refer sale
    tSql = "UPDATE  " & tVB_CNTblDT
    tSql = tSql & " SET FTSdtDisChgTxt ='" & tDisChg & "'"
    tSql = tSql & " ,FCSdtVat = " & cSdtVat
    tSql = tSql & " ,FCSdtVatable = " & cSdtVatable
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_TerminalNoRet & "' AND FTShdTransNo='" & tVB_TransNoRet & "'"
    tSql = tSql & " AND  FTShdTransType ='" & tVB_TransTypeRet & "' AND FDShdTransDate='" & Format(dVB_TransDateRet, "YYYY/MM/DD") & "'"
    tSql = tSql & " AND  FNSdtSeqNo=" & pnSeq
    Call SP_SQLvExecute(tSql, , , , , nEff)
    Exit Sub
ErrHandle:
    
End Sub

Public Sub W_CHKxAvgFooter()
'-----------------------------------------------------------
'   Call :
'   Cmt : ทำการหาค่าใหม่ของ Vat และ Vatable ตาม DT
'              รวมมูลค่า Vat และ Vatable ตาม DT  Update ที่ HD
'              รวมมูลค่า Discount ตาม DT  Update ที่ HD
'-----------------------------------------------------------

    Dim nI As Long
'    Dim nCount As Long
    Dim cTax As Double
    Dim cNet As Double
    Dim cVat As Double
    Dim cVatable As Double
    Dim cNetDpsProRate As Double
'    Dim cProRate As Double '*KT 51-10-07 V 3.0.130/V 3.0.200
    Dim cDpsVat As Double
    Dim cDpsVatable As Double
    Dim cSumDpsVat As Double 'ค่าสะสม Vat จาก DT
    Dim cSumDpsVatable As Double 'ค่าสะสม Vatable จาก DT
    Dim cSumDpsNonVat As Double
    Dim cSumDpsUnNonVat As Double
    Dim tSql$, tWhr$, tValue$
    Dim tTax$
    Dim tCancel$
    Dim orsDT As ADODB.Recordset
    Dim orsCD As ADODB.Recordset
    Dim cTmpDpsAmt As Double
    Dim cTmpDpsAmt2  As Double
    Dim cDisPromo As Double
    Dim cDisMiscPromo As Double
    Dim cQtyPromo As Double
    Dim cDiscPromoAmt  As Double
    Dim cSaleUnit  As Double
    Dim cQty As Double
    
    'Redeem
    '---------------------------------------------------------------
    Dim cPrvDepositVatable As Double
    Dim cPrvDepositVat As Double
    Dim cPrvDepositUnNonVat As Double
    Dim cPrvDepositNonVat As Double
    Dim cPrvDepositAmt As Double
    '--------------------------------------------------------------
    
    Dim cVatHD As Double
    Dim cVatableHD As Double
    
    Dim nTax As Long
    Dim bTax As Boolean
    Dim cTmpSaleAmt As Double
    Dim cTmpVatAmt As Double
    Dim cTmpVatableAmt As Double
    Dim cTmpDepSaleAmt As Double
    Dim cTmpDepVatAmt As Double 'ค่าสะสม Vat จากก้อน HD
    Dim cTmpDepVatableAmt As Double  'ค่าสะสม Vatable จากก้อน HD
    Dim nSeqNo As Long
    Dim tFilter As String
    
    Dim cMiscDisc As Double
    Dim nJ As Long
    
On Error GoTo ErrHandle
    ReDim aW_SaleVatAmt(0)    'clear array
    aW_SaleVatAmt(0).TAXCODE = ""
    aW_SaleVatAmt(0).TAXRATE = 0
    aW_SaleVatAmt(0).TAXAMT = 0
    
    ReDim aW_DepVatAmt(0)    'clear array
    aW_DepVatAmt(0).TAXCODE = ""
    aW_DepVatAmt(0).TAXRATE = 0
    aW_DepVatAmt(0).TAXAMT = 0
    
    'Cal Vat By DT
    'With wMain.ogdForm
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax
                 'none
            Case Else
                cUT_VatAmt = 0
                cUT_VatableAmt = 0
        End Select
        
        cSumDpsVat = 0
        cSumDpsVatable = 0
        cSumDpsNonVat = 0
        cSumDpsUnNonVat = 0
        '*KT 54-10-10 V.4.0.1 เก็บยอดรวมสินค้าหลังหัดส่วนลดทุกช นิดเฉพาะสินค้าป้ายน้ำเงิน,ยอดรวมสินค้าหลังหัดส่วนลดทุกชนิดเฉพาะสินค้าป้ายเหลือง
        cVB_RegTotAmtAfDisc = 0
        cVB_ProTotAmtAfDisc = 0
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnDeposit, tEN_TrnAddDeposit, tEN_TrnRedeem, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel 'กรณีไม่มีการลงใน Grid หน้า Main
                tWhr = " WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
                tWhr = tWhr & vbCrLf & " AND  FTShdTransType=''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
                tWhr = tWhr & vbCrLf & " ORDER BY FNSdtSeqNo"
                tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblDTTmp & "',@ptWhere = '" & tWhr & "'" '*KT 51-12-09 ใช้ Table Temp2
                Call SP_SQLvExecute(tSql, orsDT)
                Select Case Val(Format(tVB_TransactionSub))
                    Case tEN_TrnRedeem
                        cTmpDpsAmt = cVB_AccBalRedeem
                    Case tEN_TrnDeposit
                        cTmpDpsAmt = cVB_DepositAmt + cVB_RoundRcv '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                    Case tEN_TrnAddDeposit
                        cTmpDpsAmt = cVB_DepossitAmtAddDpt + cVB_RoundRcv '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                    Case tEN_TrnDepositCancel
                        cTmpDpsAmt = cVB_DepossitAmtDptCancel + cVB_RoundRcv '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                    Case tEN_TrnAddDepositCancel
                        cTmpDpsAmt = cVB_DepossitAmtDptCancel + cVB_RoundRcv '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                        
                End Select
                
                '*KT 52-02-19 mall card discount (sub reg,sub pro)
                tWhr = " WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
                tWhr = tWhr & vbCrLf & " AND  FTShdTransType=''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
                tWhr = tWhr & vbCrLf & " AND ISNULL(FTSdtStkCode,'''') <> ''1''" '*KT 52-11-25 Deal&Promo
                tWhr = tWhr & vbCrLf & " ORDER BY FNScdSeqNo ASC"
                tSql = "STP_CNxSQLFunction @ptFunc = ' * ' ,@ptTable = '" & tVB_CNTblCDTmp & "',@ptWhere = '" & tWhr & "'" '*KT 51-12-09 ใช้ Table Temp2
                Call SP_SQLvExecute(tSql, orsCD)

                cTmpDpsAmt2 = cTmpDpsAmt
                
                Do While Not orsDT.EOF
                    ' PRO RATE OF DEPOSIT CREATE
                    tTax = SP_FEDtChkString(orsDT, "FTTaxCode")
                    tCancel = SP_FEDtChkString(orsDT, "FTSdtCancelFlag")
                    cNet = SP_FEDvChkNumeric(orsDT, "FCSdtSaleAmt")
                    cTax = SP_FEDvChkNumeric(orsDT, "FCSdtTax")
                    nSeqNo = SP_FEDvChkNumeric(orsDT, "FNSdtSeqNo")
                    tVB_StaMemPriceAlw = SP_FEDtChkString(orsDT, "FTSdtStaRfd")
                     
                    '*KT 54-10-10 V.4.0.1 เก็บยอดรวมสินค้าหลังหัดส่วนลดทุกชนิดเฉพาะสินค้าป้ายน้ำเงิน,ยอดรวมสินค้าหลังหัดส่วนลดทุกชนิดเฉพาะสินค้าป้ายเหลือง
                    If SP_FEDtChkString(orsDT, "FTSkuStaMallEmpCard") = "Y" Then
                        cVB_RegTotAmtAfDisc = cVB_RegTotAmtAfDisc + cNet
                     Else
                        cVB_ProTotAmtAfDisc = cVB_ProTotAmtAfDisc + cNet
                     End If
                     
'ให้ Deposit Cancel/Add Deposit Cancel หา Vat/Vatble ใหม่เพราะ การทำ Deposit Cancel จะยกเลิกทั้งยวงและการทำ Add Deposit Cancel ระหว่างกลางจะยกเลิกตั้งแต่ seq จนจนรายการ Add Deposit สุดท้าย
                     If tCancel <> "1" Then '***KT 51-12-01 V 1.0.1
                        Select Case Val(Format(tVB_TransactionSub))
                            Case tEN_TrnRedeem
                                If cVB_AccBalRedeem = 0 Then
                                    cNetDpsProRate = 0
                                Else
                                     cNetDpsProRate = SP_FMTcCurPoint((cVB_AccBalRedeem * cNet) / cUT_SubTotal, True, False)
                                End If
                            Case tEN_TrnDeposit
                                If cVB_DepositAmt = 0 Then
                                    cNetDpsProRate = 0
                                Else
                                     cNetDpsProRate = SP_FMTcCurPoint(((cVB_DepositAmt + cVB_RoundRcv) * cNet) / cUT_SubTotal, True, False)  '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                                End If
                            Case tEN_TrnAddDeposit
                                If cVB_DepossitAmtAddDpt = 0 Then
                                    cNetDpsProRate = 0
                                Else
                                     cNetDpsProRate = SP_FMTcCurPoint(((cVB_DepossitAmtAddDpt + cVB_RoundRcv) * cNet) / cUT_SubTotal, True, False) '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                                End If
                            Case tEN_TrnDepositCancel
                                If cVB_DepossitAmtDptCancel = 0 Then
                                    cNetDpsProRate = 0
                                Else
                                     cNetDpsProRate = SP_FMTcCurPoint(((cVB_DepossitAmtDptCancel + cVB_RoundRcv) * cNet) / cUT_SubTotal, True, False) '*KT 51-11-09 ต้องเอา Misc Rec มา + - ออกจากยอดที่จ่ายจริงด้วย
                                End If
                            Case tEN_TrnAddDepositCancel
                                If cVB_DepossitAmtDptCancel = 0 Then
                                    cNetDpsProRate = 0
                                Else
                                     cNetDpsProRate = SP_FMTcCurPoint(((cVB_DepossitAmtDptCancel + cVB_RoundRcv) * cNet) / cUT_SubTotal, True, False)
                                End If
                        End Select
                    Else
                        cNetDpsProRate = 0
                    End If
                    
                    If cNetDpsProRate > cTmpDpsAmt2 Then cNetDpsProRate = cTmpDpsAmt2
                    
                    '***KT 51-11-26 V 1.0.1
'                    '*KT 51-10-10 V 3.0.132/V 3.0.200
'                    'ตรวจสอบ Item สุดท้ายเศษที่เหลือต้องโยนให้ Item สุดท้าย
'                    '-------------------------------------------------------------------------------------
'                    orsDT.MoveNext
'                    If orsDT.EOF Then
'                        If cSumDpsNonVat + cSumDpsUnNonVat + cNetDpsProRate <> cTmpDpsAmt Then
'                                cNetDpsProRate = cTmpDpsAmt - (cSumDpsNonVat + cSumDpsUnNonVat)
'                        End If
'                    Else
'                        If SP_FEDtChkString(orsDT, "FTTaxCode") = "00" Or SP_FEDtChkString(orsDT, "FTTaxCode") = "" Then
'                                If cSumDpsNonVat + cSumDpsUnNonVat + cNetDpsProRate <> cTmpDpsAmt Then
'                                    cNetDpsProRate = cTmpDpsAmt - (cSumDpsNonVat + cSumDpsUnNonVat)
'                                End If
'                        End If
'                    End If
'                    orsDT.MovePrevious
'                    '-----------------------------------------------------------------------------------
                    
                    If tTax <> "00" And tTax <> "" And tCancel <> "1" Then   '00 : NT By Default
                        '*KT 51-05-26 Comsheet ML-SF-291
                        'การคิด VAT ให้นำยอดก่อนลดส่วนลดใดๆๆ มาคิด VAT
                        bTax = False
                        If UBound(aW_SaleVatAmt) > 0 Then
                            For nTax = 0 To UBound(aW_SaleVatAmt) - 1
                                If aW_SaleVatAmt(nTax).TAXCODE = tTax Then
                                    bTax = True
                                    aW_SaleVatAmt(nTax).TAXAMT = CDbl(Val(Format(aW_SaleVatAmt(nTax).TAXAMT))) + cNet
                                End If
                            Next nTax
                        End If
                        If Not bTax Then
                            aW_SaleVatAmt(UBound(aW_SaleVatAmt)).TAXCODE = tTax
                            aW_SaleVatAmt(UBound(aW_SaleVatAmt)).TAXRATE = cTax
                            aW_SaleVatAmt(UBound(aW_SaleVatAmt)).TAXAMT = cNet
                            ReDim Preserve aW_SaleVatAmt(UBound(aW_SaleVatAmt) + 1)
                        End If
                    
                        Select Case Val(Format(tVB_TransactionSub))
                            Case tEN_TrnTaxExceptSale
                                cVat = 0
                                cVatable = cNet
                            Case Else
                                cVat = SP_FMTcCurPoint(cNet * (cTax / (100 + cTax)), True, False)
                                cVatable = cNet - cVat
                        End Select
                        'Total Report ส่วนของ Deposit
                        Select Case Val(Format(tVB_TransactionSub))
                            Case tEN_TrnDeposit, tEN_TrnAddDeposit, tEN_TrnRedeem, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
                                cDpsVat = SP_FMTcCurPoint(cNetDpsProRate * (cTax / (100 + cTax)), True, False)
                                cDpsVatable = cNetDpsProRate - cDpsVat
                            Case Else
                                cDpsVat = SP_FMTcCurPoint(0, True, True)
                                cDpsVatable = SP_FMTcCurPoint(0, True, True)
                        End Select
                       
                    Else
                        'กรณีที่ SKU นั้นเป็น Non Tax  ให้ Vat และ Vatable เท่ากับ 0
                        cVat = SP_FMTcCurPoint(0, True, False)
                        cVatable = SP_FMTcCurPoint(0, True, False)
                        cDpsVat = SP_FMTcCurPoint(0, True, False)
                        cDpsVatable = SP_FMTcCurPoint(0, True, False)
                    End If
                    
                    cUT_VatAmt = cUT_VatAmt + cVat
                    cUT_VatableAmt = cUT_VatableAmt + cVatable
                    cSumDpsVat = cSumDpsVat + cDpsVat
                    cSumDpsVatable = cSumDpsVatable + cDpsVatable
                    If tTax <> "00" Then
                        If cNetDpsProRate > cTmpDpsAmt2 Then
                            cSumDpsUnNonVat = cSumDpsUnNonVat + cTmpDpsAmt2
                            bTax = False
                            If UBound(aW_DepVatAmt) > 0 Then
                                For nTax = 0 To UBound(aW_DepVatAmt) - 1
                                    If aW_DepVatAmt(nTax).TAXCODE = tTax Then
                                        bTax = True
                                        aW_DepVatAmt(nTax).TAXAMT = CDbl(Val(Format(aW_DepVatAmt(nTax).TAXAMT))) + cTmpDpsAmt2
                                    End If
                                Next nTax
                            End If
                            If Not bTax Then
                                aW_DepVatAmt(UBound(aW_DepVatAmt)).TAXCODE = tTax
                                aW_DepVatAmt(UBound(aW_DepVatAmt)).TAXRATE = cTax
                                aW_DepVatAmt(UBound(aW_DepVatAmt)).TAXAMT = cNetDpsProRate
                                ReDim Preserve aW_DepVatAmt(UBound(aW_DepVatAmt) + 1)
                            End If
                        Else
                            cSumDpsUnNonVat = cSumDpsUnNonVat + cNetDpsProRate
                            bTax = False
                            If UBound(aW_DepVatAmt) > 0 Then
                                For nTax = 0 To UBound(aW_DepVatAmt) - 1
                                    If aW_DepVatAmt(nTax).TAXCODE = tTax Then
                                        bTax = True
                                        aW_DepVatAmt(nTax).TAXAMT = CDbl(Val(Format(aW_DepVatAmt(nTax).TAXAMT))) + cNetDpsProRate
                                    End If
                                Next nTax
                            End If
                            If Not bTax Then
                                aW_DepVatAmt(UBound(aW_DepVatAmt)).TAXCODE = tTax
                                aW_DepVatAmt(UBound(aW_DepVatAmt)).TAXRATE = cTax
                                aW_DepVatAmt(UBound(aW_DepVatAmt)).TAXAMT = cNetDpsProRate
                                ReDim Preserve aW_DepVatAmt(UBound(aW_DepVatAmt) + 1)
                            End If
                        End If
                    Else
                        If cNetDpsProRate > cTmpDpsAmt2 Then
                             cSumDpsNonVat = cSumDpsNonVat + cTmpDpsAmt2
                        Else
                            cSumDpsNonVat = cSumDpsNonVat + cNetDpsProRate
                        End If
                    End If

                    tValue = " SET  FCSdtVat = " & cVat
                    tValue = tValue & vbCrLf & " ,FCSdtVatable = " & cVatable
                    Select Case SP_VALnText2Double(tVB_TransactionSub)
                        Case tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
                                'non ไม่มีการ Update ยังใช้ตัวต้นฉบับ
                        Case tEN_TrnDeposit, tEN_TrnAddDeposit, tEN_TrnRedeem
                                tValue = tValue & vbCrLf & " ,FCSdtDepositVat = " & cDpsVat
                                tValue = tValue & vbCrLf & " ,FCSdtDepositVatable = " & cDpsVatable
                                tValue = tValue & vbCrLf & " ,FCSdtDepositNetProRate = " & cNetDpsProRate
                                '*KT 51-08-11 ใช้สำหรับ sale export ของ iss3000 เก็บทุก transaction ยกเว้น return
                                tValue = tValue & vbCrLf & " ,FCSdtSaleTaxAmt = " & cVat
                        Case tEN_TrnReturn, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                                tValue = tValue & vbCrLf & " ,FCSdtReturnAmt =  FCSdtSaleAmt"
                                tValue = tValue & vbCrLf & " ,FCSdtReturnQty = FCSdtQty"
                                tValue = tValue & vbCrLf & " ,FCSdtReturnTaxAmt = " & cVat
                        Case Else
                                '*KT 51-08-11 ใช้สำหรับ sale export ของ iss3000 เก็บทุก transaction ยกเว้น return
                                tValue = tValue & vbCrLf & " ,FCSdtSaleTaxAmt = " & cVat
                    End Select
                    
                    '*KT 51-09-18 เก็บค่าราคาต่อหน่วยลด Promotion , Promotion Time , Deal ไว้ที่ FCSdtSaleUnit
                    '-----------------------------------------------------------------------------------------------------------------------------------------

                    '*KT 51-12-11 Phase 2 แก้ไขเรื่อง Price Overide สินค้าที่ไม่ใช่ Prompt Sale
                    '----------------------------------------------------------------------------------------------------------------------------------------
                    If UCase(SP_FEDtChkString(orsDT, "FTSdtPriceOverideFlag")) = "Y" Then
                        cDisPromo = 0
                        cDisMiscPromo = 0
                        If Not (orsCD.BOF And orsCD.EOF) Then
                            orsCD.Filter = adFilterNone
                            tFilter = "FNSdtSeqNo =" & nSeqNo
                            orsCD.Filter = tFilter
                             If Not (orsCD.BOF And orsCD.EOF) Then
                                Do While Not orsCD.EOF
                                    Select Case SP_FEDvChkNumeric(orsCD, "FNDctNo")
                                        Case nEN_Disc01Deal, nEN_Disc02PmtTime, nEN_Disc03Pmt, nEN_Disc21MPrice
                                            'NONE
                                        Case Else
                                            cDisPromo = cDisPromo + CDbl(Val(Format(SP_FEDvChkNumeric(orsCD, "FCScdAmt"))))
                                    End Select
                                    orsCD.MoveNext
                                Loop
                                cDisPromo = CDbl(SP_FMTcCurPoint(cDisPromo, True, False))
                             End If
                            orsCD.Filter = adFilterNone
                        End If
                        cQty = CDbl(Val(Format(SP_FEDvChkNumeric(orsDT, "FCSdtQty"))))
                        cSaleUnit = CDbl(SP_FMTcCurPoint((cNet + cDisPromo) / cQty, True, False))
                        If (cSaleUnit * cQty) <> (cNet + cDisPromo) Then
                            cDisMiscPromo = cDisMiscPromo + ((cSaleUnit * cQty) - (cNet + cDisPromo))
                        End If
                        cDisMiscPromo = CDbl(SP_FMTcCurPoint(cDisMiscPromo, True, False))
                        tValue = tValue & vbCrLf & " ,FCSdtSaleUnit = ROUND((FCSdtSaleAmt+" & cDisPromo & ")/FCSdtQty,2)"
                        tValue = tValue & vbCrLf & " ,FCSdtChg= " & cDisMiscPromo
                    Else
                        cDisPromo = 0
