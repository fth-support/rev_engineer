                .olaSKUName.Caption = ""
                .olaPrice.Caption = ""
                .olaSumQty.Caption = ""
                .olaTSubReg.Caption = ""
                .olaTSubPro.Caption = ""
                .olaTSubTotal.Caption = ""
                With .ogdForm
                    .rows = 1
                    .rows = nUT_GridMaxRow
                End With
                bTranSrv = False
                 If Not oDB.ocnOnLine Is Nothing And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                    oDB.ocnOnLine.BeginTrans
                    bTranSrv = True
                    nVB_CNCountBeginSrv = nVB_CNCountBeginSrv + 1
                End If
            'เงินทอน
                Select Case Val(Format(tVB_TransactionSub))
                    Case tEN_TrnReturn, tEN_TrnOtherDisbursement, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnDeposit
                         bOffline = Not W_PRCbMoveDataToDeposit
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnRedeem
                        bOffline = Not W_PRCbUpdTmpDeposit
                        If Not bOffline Then
                            bOffline = Not W_PRCbMoveDataToDeposit
                        End If
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
                        bOffline = Not W_PRCbUpdTmpDeposit
                        If Not bOffline Then
                            bOffline = Not W_PRCbMoveDataToDeposit
                        End If
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnAddDeposit
                        bOffline = Not W_PRCbMoveDataToDeposit
                         .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnVoucher
                        bOffline = Not W_PRCbMoveDataToVoucher
                         .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case tEN_TrnCancelVoucher
'                       bOffline = Not W_PRCbUpdTmpVoucher(bTranSrv)
                         bOffline = Not W_PRCbUpdTmpVoucher
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnVIPSale
                         bOffline = Not W_PRCbDelCreateVIP
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                    Case Else
                         bOffline = False
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                End Select
                .Refresh
'                DoEvents '*KT 53-01-14 DoEvents
            End With
            If Not W_PRCxHandleTrnOnline(bOffline, bTranSrv) Then
                Call W_PRCxCashDrawerAct
            End If
        End If
        nStep = 2
        Call SP_UPDxSetCompleteTerminalMtn 'ช้าอยู่
        'เริ่ม Ticket ใหม่
         '*KT 54-09-20 V.4.0.1 กรณีที่ไม่เป็น OPOS ในการแสดงเงินทอน
        Select Case SP_VALnText2Double(tVB_TransactionSub)
            Case 1, 5, 8, 9, 14, 17, 25, 26, 27, 28, 29, 30, 31, 32, 34, 35, 36
                    bFlagShwChg = False
            Case Else
                    If bVB_OPOSCashDrawerEnable Then
                        bFlagShwChg = False
                    Else
                        bFlagShwChg = True
                    End If
        End Select
        bVB_CNShwChange = bFlagShwChg
        Call UT_GenSaleNewDoc(bFlagShwChg)
        
        'Unload wSub '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnSaleTaxInc, tEN_TrnReturnTaxInc, tEN_TrnTotalReportTaxInc, tEN_TrnOverShortReportTaxInc, tEN_TrnClosingReportTaxInc
                    tVB_CNMnuCurrent = "172001"
            Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax, tEN_TrnTotalReportManualTax, tEN_TrnOverShortReportManualTax, tEN_TrnClosingReportManualTax
                    tVB_CNMnuCurrent = "172101"
            Case Else
                    tVB_CNMnuCurrent = "1700"
        End Select
        
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
            Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
        Else
            wMain.W_FRMxActivate
        End If
        Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
'        DoEvents '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero '*KT 53-01-14 DoEvents
        wMain.otbPrompt.Locked = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        bVB_CNStartBill = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    End If
    If bTranSrv Then
        oDB.ocnOnLine.CommitTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
    Exit Sub
ErrHandle:
    If bTranSrv Then
        oDB.ocnOnLine.RollbackTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
    If nStep = 1 Then
        '*KT 52-12-01 Fix POSFront 2.0.28,2.0.29,3.0.6 ตรวจสอบว่า wSub ทำการ Unload แล้วหรือไม่ถ้ายังให้ทำการ Unload
        If Not wSub Is Nothing Then
            Unload wSub
        End If
        Call SP_UPDxSetCompleteTerminalMtn 'ช้าอยู่
        'เริ่ม Ticket ใหม่
         '*KT 54-09-20 V.4.0.1 กรณีที่ไม่เป็น OPOS ในการแสดงเงินทอน
        Select Case SP_VALnText2Double(tVB_TransactionSub)
            Case 1, 5, 8, 9, 14, 17, 25, 26, 27, 28, 29, 30, 31, 32, 34, 35, 36
                    bFlagShwChg = False
            Case Else
                    If bVB_OPOSCashDrawerEnable Then
                        bFlagShwChg = False
                    Else
                        bFlagShwChg = True
                    End If
        End Select
         bVB_CNShwChange = bFlagShwChg
         Call UT_GenSaleNewDoc(bFlagShwChg)
         
        'Unload wSub '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        Select Case Val(Format(tVB_TransactionSub))
            Case tEN_TrnSaleTaxInc, tEN_TrnReturnTaxInc, tEN_TrnTotalReportTaxInc, tEN_TrnOverShortReportTaxInc, tEN_TrnClosingReportTaxInc
                    tVB_CNMnuCurrent = "172001"
            Case tEN_TrnSaleManualTax, tEN_TrnReturnManualTax, tEN_TrnTotalReportManualTax, tEN_TrnOverShortReportManualTax, tEN_TrnClosingReportManualTax
                    tVB_CNMnuCurrent = "172101"
            Case Else
                    tVB_CNMnuCurrent = "1700"
        End Select
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
            Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
        Else
            wMain.W_FRMxActivate
        End If
        Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
'        DoEvents '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero '*KT 53-01-14 DoEvents
        wMain.otbPrompt.Locked = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
        bVB_CNStartBill = True '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
    End If
End Sub

