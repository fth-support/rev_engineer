                            If Len(Trim(poRs.Fields(i))) = 0 Then
                                 tSqlV = tSqlV & tSqlF & " = ''" & ","
                            Else
                                tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                            End If
                        End If
                    Case "D"
                        If IsNull(poRs.Fields(i).Value) Then
                            tSqlV = tSqlV & tSqlF & " = Null" & ","
                        Else
                            tSqlV = tSqlV & tSqlF & " = '" & UT_tStringDate(poRs.Fields(i).Value) & "',"                          'มี เขาเดี่ยว
                        End If
                    Case "N"
                        tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                    Case "C"
                        tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                End Select
        End Select
    Next i
    
    tSqlV = tSqlH & tSqlV & UT_tLastUpdSql
    tSql = tSqlV & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    Call SP_SQLvExecute(tSql, , , , , nEffect)         '*Ao 2010/07/27  Communication Sheet DC-ML-108 IPV
    If nEffect <= 0 Then
        Call SP_MSGnShowing("tms_CN008033", tCS_CNMsgWarn)
        Call UT_GenSaleNewDoc
        Call SP_CRTxLogPrg("wFunctionKB:W_DupTblBtwSleUpdHoldHDIPV:" & tVB_CNTerminalNum & ":" & tVB_Running & ":" & tVB_Transaction & ":" & tUT_SaleDate)
    End If
    Exit Sub
ErrHandle:
'    Call SP_MSGShowError
    Call SP_CRTxLogPrg("wFunctionKB:W_DupTblBtwSleUpdHoldHDIPV")
End Sub

Public Sub W_PRCxLogDT(ByVal poRs As ADODB.Recordset, ByVal pnType As eEN_TypeLogDT, ByVal pcQty As Double)
'----------------------------------------------------------
'   Call:   poRs as SaleDT
'   Cmt:   dup data from poRs when void
'----------------------------------------------------------
    Dim orsTemp As ADODB.Recordset
    Dim tSql$
    Dim tWhr$
    Dim nSeqNo As Long
    Dim nEffect As Long
On Error GoTo ErrHandle

    tWhr = " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    nSeqNo = SP_VALcText2Double(SP_SQLtFunction("MAX", "FNLogSeqNo", "TPSTLogDT", tWhr)) + 1
    
    tSql = "DELETE TPSTLogDT"
    tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & SP_FEDtChkString(poRs, "FTTmnNum") & "'"
    tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & SP_FEDtChkString(poRs, "FTShdTransNo") & "'"
    tSql = tSql & vbCrLf & " AND FNLogSeqNo = " & nSeqNo
    tSql = tSql & vbCrLf & " AND FDShdTransDate ='" & SP_DTEtStrSTD(SP_FEDdChkDate(poRs, "FDShdTransDate")) & "'"
    Call SP_SQLvExecute(tSql)
    
    tSql = "INSERT INTO TPSTLogDT"
    tSql = tSql & "(FTStmCode"
    tSql = tSql & ",FTTmnNum"
    tSql = tSql & ",FTShdTransNo"
    tSql = tSql & ",FNLogSeqNo"
    tSql = tSql & ",FNSdtSeqNo"
    tSql = tSql & ",FTSkuCode"
    tSql = tSql & ",FTShdTransType"
    tSql = tSql & ",FDShdTransDate"
     tSql = tSql & ",FTShdTransTime"
    tSql = tSql & ",FTSdtBarCode"
    tSql = tSql & ",FTLogType"
    tSql = tSql & ",FCLogQty"
    tSql = tSql & "," & tCS_CNLastFedIns
    tSql = tSql & " VALUES ("
    tSql = tSql & "'" & SP_FEDtChkString(poRs, "FTStmCode") & "'"
    tSql = tSql & ",'" & SP_FEDtChkString(poRs, "FTTmnNum") & "'"
    tSql = tSql & ",'" & SP_FEDtChkString(poRs, "FTShdTransNo") & "'"
    tSql = tSql & "," & nSeqNo
    tSql = tSql & "," & SP_FEDtChkString(poRs, "FNSdtSeqNo")
    tSql = tSql & ",'" & SP_FEDtChkString(poRs, "FTSkuCode") & "'"
    tSql = tSql & ",'" & SP_FEDtChkString(poRs, "FTShdTransType") & "'"
    tSql = tSql & ",'" & SP_DTEtStrSTD(SP_FEDdChkDate(poRs, "FDShdTransDate")) & "'"
    tSql = tSql & ",'" & SP_FEDtChkString(poRs, "FTShdTransTime") & "'"
    tSql = tSql & ",'" & SP_FEDtChkString(poRs, "FTSdtBarCode") & "'"
    tSql = tSql & ",'" & pnType & "'"
    tSql = tSql & "," & pcQty
    tSql = tSql & "," & UT_tLastInsSql & ")"
    Call SP_SQLvExecute(tSql, , , , , nEffect)
    If nEffect = 0 Then
        Call SP_MSGShowError
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Sub W_SwitchProgram(ByVal pMainHwnd As Long, ByVal pExePath$, ByVal ptExeCap$)
'----------------------------------------------------------
'   Call:   pMainHwnd is hadle of form main, ex. wMain.Hwnd
'              pExePath is exe file and path, ex "C:\Program Files\AdaSoft\AdaPos\AdaStoreBack.exe"
'              pExeCap is exe caption
'   Cmt:    เรียกโปรแกรมขึ้นมาแสดงถ้าเปิดอยู่แล้วจะ Active ขึ้นมา
'----------------------------------------------------------
    Dim nHwnd As Long
     
    On Error GoTo ErrFront
    
    'get handle of frmmain front
    nHwnd = FindWindow(vbNullString, ptExeCap)
    If nHwnd = 0 Then
        nHwnd = ShellEx(pMainHwnd, "open", pExePath, "", "", 10)
    Else
        ShowWindow nHwnd, 2     'SW_SHOWMINIMIZED           'ย่อก่อน=2 เพราะ ถ้าปัจจุบันเปิดแบบ max อยู่เมื่อเรียก show แล้วจะไม่ทำงาน
    End If
    ShowWindow nHwnd, 3         'SW_SHOWMAXIMIZED          'ก่อนหน้าเมื่อย่อแล้ว เมื่อเรียก show แบบ max=3 ก็จะทำงานได้

    Exit Sub
ErrFront:
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Public Sub W_PrintClosing(Optional ByVal pbSal As Boolean = False)
'*KT 51-11-01
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim tTransType As String
    Dim tTblHD As String
    Dim tTblDT As String
    Dim tTblCD As String
    Dim tTblRC As String
    Dim nRow As Long
    Dim tFed As String
    Dim tF As String
    Dim tSqlV As String
    Dim tStr As String
    Dim tSqlF As String, tRemark As String
    Dim nSeq As Long
On Error GoTo ErrHandle
    
    tTransType = IIf(bVB_TrainingMode, "FTShdTransTypeSub", "FTShdTransType")
    If pbSal Then
        tTblHD = "TPSTSalHD"
        tTblDT = "TPSTSalDT"
        tTblCD = "TPSTSalCD"
        tTblRC = "TPSTSalRC"
    Else
        tTblHD = tVB_CNTblHD
        tTblDT = tVB_CNTblDT
        tTblCD = tVB_CNTblCD
        tTblRC = tVB_CNTblRC
    End If
    
    Call SP_INSxTransHD(tTblHD, pbSal)

    tFed = "": tF = "": tStr = "": tSqlV = ""
    tFed = "FTStmCode,FTTmnNum,FTShdTransNo,FNSdtSeqNo,FTSkuCode"
    tFed = tFed & ",FTSkuAbbName,FTShdTransType,FDShdTransDate,FTSdtBarCode,FTSdtStkCode"
    tFed = tFed & ",FCSdtStkFac,FTTaxCode,FTDpcCode,FTSkuDepCode,FTSkuBrdCode"
    tFed = tFed & ",FTPunCode,FTSdtUnitName,FCSdtRegPrice,FTSdtEventPrice,FCSdtQty"
    tFed = tFed & ",FCSdtSaleTaxAmt,FCSdtReturnTaxAmt"
    tFed = tFed & ",FTSdtInstoreBar,FCSdtB4DisChg,FTSdtDisChgTxt,FCSdtDis"
    tFed = tFed & ",FCSdtChg,FCSdtSaleAmt,FCSdtVat,FCSdtVatable,FCSdtQtyAll"
    tFed = tFed & ",FTSdtStaPdt"
    tFed = tFed & ",FTSdtWeight,FTSdtConsignFlag"
    tFed = tFed & ",FTSdtCancelFlag,FCSdtTax,FCSdtSalePrice,FTShdTransTime"
    tFed = tFed & ",FTSkuAbbNameSnd,FTSkuAbbNameSrvDoc,FTSkuAbbNameSndSrvDoc"
    tFed = tFed & ",FTTaxSign,FTTaxStaSign"
    tFed = tFed & ",FCSdtSaleUnit"
    tFed = tFed & ",FCSdtQtyAllDisAvi"
    tFed = tFed & ",FCSdtAmtDisAvi"
    tFed = tFed & ",FCSdtDutyFreeAmt"
    tFed = tFed & ",FCSdtDutyFreeQty"
    tFed = tFed & ",FCSdtDutyDeposit"
    tFed = tFed & ",FCSdtWeight"
    tFed = tFed & ",FTSdtPriceOverideFlag"
    
    tSql = "SELECT  * "
    tSql = tSql & vbCrLf & "FROM TPSTClose "
    tSql = tSql & vbCrLf & "ORDER BY FNCloSeqNo ASC"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
    If Not (orsTemp.EOF Or orsTemp.BOF) Then
        tSqlF = tFed
        tSqlF = "(" & tSqlF & "," & tCS_CNLastFedIns
        tF = tFed
        tSql = "INSERT INTO " & tTblDT
'        nSeq = 0                                                   '*Ao 2013/11/26 CommSheet TK-ISS3000-430-FAPL-155_Aoo_561126
        Do While Not orsTemp.EOF
'                nSeq = nSeq + 1                            '*Ao 2013/11/26 CommSheet TK-ISS3000-430-FAPL-155_Aoo_561126
                tStr = cUT.UT_STRtToken(tF, ",", 1)
                Do While tStr <> ""
                        Select Case UCase(tStr)
                            Case UCase("FTStmCode"): tSqlV = tSqlV & "'" & tVB_CNStoreCode & "',"
                            Case UCase("FTTmnNum"): tSqlV = tSqlV & "'" & tVB_CNTerminalNum & "',"
                            Case UCase("FTShdTransNo"): tSqlV = tSqlV & "'" & tVB_Running & "',"
                            Case UCase("FTShdTransType"): tSqlV = tSqlV & "'" & Format(tVB_Transaction, "00") & "',"
                            Case UCase("FDShdTransDate"): tSqlV = tSqlV & "'" & tUT_SaleDate & "',"
                            Case UCase("FTShdTransTime"): tSqlV = tSqlV & "'" & Time$ & "',"
'                            Case UCase("FNSdtSeqNo"): tSqlV = tSqlV & nSeq & ","
                            Case UCase("FNSdtSeqNo"): tSqlV = tSqlV & SP_FEDvChkNumeric(orsTemp, "FNCloSeqNo") & ","            '*Ao 2013/11/26 CommSheet TK-ISS3000-430-FAPL-155_Aoo_561126
                            Case UCase("FTEmpCode"): tSqlV = tSqlV & "'" & tVB_CNUserCode & "',"
                            Case UCase("FTSkuAbbName"), UCase("FTSkuAbbNameSnd"), UCase("FTSkuAbbNameSrvDoc"), UCase("FTSkuAbbNameSndSrvDoc")
                                    tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTCloName") & "',"
'                            Case UCase("FCSdtSaleAmt"):  tSqlV = tSqlV & SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCCloAmt"), True, False) & ","            '*Ao 2013/09/18
                            Case UCase("FCSdtSaleAmt"):  tSqlV = tSqlV & SP_FEDvChkNumeric(orsTemp, "FCCloAmt") & ","
                            Case UCase("FTSdtConsignFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                            Case UCase("FTTaxStaSign"): tSqlV = tSqlV & "'" & "N" & "',"
                            Case UCase("FTSkuStaMallEmpCard"): tSqlV = tSqlV & "'" & "N" & "',"
                            Case UCase("FTSdtPriceOverideFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                            Case UCase("FCSdtQty"), UCase("FCSdtQtyAll")
                                If Trim(SP_FEDtChkString(orsTemp, "FTCloMode")) = Trim("1") Then
                                    tSqlV = tSqlV & "0,"
                                Else
                                    tSqlV = tSqlV & SP_FEDvChkNumeric(orsTemp, "FCCloQty") & ","
                                End If
                            Case UCase("FTSkuCode"):
'                                If SP_FEDvChkNumeric(orsTemp, "FCCloRate") <> 0 Then               '*Ao 2013/03/01
'                                    tSqlV = tSqlV & "'" & "T012" & "',"
'                                Else
'                                    tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
'                                End If
                                If SP_FEDvChkNumeric(orsTemp, "FCCloRate") <> 0 Then
                                    tSqlV = tSqlV & "'" & "T012" & "',"
                                Else
                                    If SP_FEDtChkString(orsTemp, "FTRemark") = "" Then
                                        tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                                    Else
                                        tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTRemark") & "',"
                                    End If
                                End If
                            Case UCase("FCSdtStkFac")
                                If SP_FEDvChkNumeric(orsTemp, "FCCloRate") <> 0 Then
                                    tSqlV = tSqlV & SP_FEDvChkNumeric(orsTemp, "FCCloRate") & ","
                                Else
                                    tSqlV = tSqlV & 1 & ","
                                End If
                            Case UCase("FCSdtDutyFreeAmt")
                                If Trim(SP_FEDtChkString(orsTemp, "FTCloMode")) = Trim("1") Then
                                    tSqlV = tSqlV & SP_FEDvChkNumeric(orsTemp, "FCCloQty") & ","                   '*Ao 2014/06/27    Add
                                Else
                                    tSqlV = tSqlV & 0 & ","
                                End If
                            Case UCase("FTSdtStkCode"): tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTCloMode") & "',"   '*Eaw 56-04-11
'                            Case UCase("FTSdtBarCode"): tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTRemark") & "',"   '*Ao 2013/05/31 CommSheet TK-ISS3000-208-ST 00 00 01-Ao.xls
                            Case UCase("FTSdtBarCode")
                            If Trim(SP_FEDtChkString(orsTemp, "FTRemark")) = "" Then
                                tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                            Else
                                tRemark = SP_FEDtChkString(orsTemp, "FTRemark")
                                Select Case UCase(tRemark)
                                    Case UCase("T002"), UCase("T003"), UCase("T015"), UCase("T017")
                                        If SP_FEDvChkNumeric(orsTemp, "FCCloQty") > 0 Then
                                            tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTCloCode") & "',"
                                        Else
                                             tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTRemark") & "',"
                                        End If
                                    Case UCase("T012")
                                        tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTCloCode") & "',"
                                    Case Else
                                        tSqlV = tSqlV & "'" & SP_FEDtChkString(orsTemp, "FTRemark") & "',"
                                End Select
                            End If
                            Case Else
                                Select Case UCase(Mid(tStr, 2, 1))
                                    Case "T"
                                        tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                                    Case "N", "C"
                                        tSqlV = tSqlV & 0 & ","
                                    Case "D"
                                        tSqlV = tSqlV & "NULL" & ","
                                End Select
                        End Select
                      tStr = cUT.UT_STRtToken(tF, ",", 1)
                Loop
                tSqlV = " VALUES (" & tSqlV & UT_tLastInsSql & ")"
                tSql = tSql & tSqlF & tSqlV
                Call SP_SQLvExecute(tSql)
                
                'FCSdtDutyFreeAmt
                'Start
                tSqlV = ""
                tSql = "INSERT INTO " & tTblDT
                tF = tFed
                orsTemp.MoveNext
        Loop
    End If
    Call W_SetToComplete(pbSal)
    Call SP_UPDxSetCompleteTerminalMtn(IIf(pbSal, False, True))
    tVB_CNClosingReprint = tVB_Running
    bVB_CNClosingRptSta = True '*KT 58-05-27 TK-ISS3000-587 ป้องกันการไม่พิมพ์ใบ Closing Report
    bVB_CNClosingRptAgain = False '*KT 58-05-27 TK-ISS3000-587 ป้องกันการไม่พิมพ์ใบ Closing Report
'*KT 51-08-05
    tSql = "TRUNCATE TABLE  TPSTClose"
    Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub

