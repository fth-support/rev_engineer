Private Function W_DEFbReturn() As Boolean
    '*KT 51-11-20
    W_DEFbReturn = False
    If Val(Format(tVB_TransactionSub)) = tEN_TrnReturn Or Val(Format(tVB_TransactionSub)) = tEN_TrnReturnTaxInc Or Val(Format(tVB_TransactionSub)) = tEN_TrnReturnManualTax Then        '* Ao 51-06-27 การคืนแบบไม่มีเงื่อนไข ไม่ต้องมีส่วนลดใดๆเกิดขึ้น
        If bVB_Reference = False Then
            W_DEFbReturn = True
        End If
    End If
End Function

Private Function W_DEFbChkReturn() As Boolean    '*Ao 51-07-09
'___________________________
'   Call:
'   Cmt:    Check Return
'               '*KT 54-09-13 V.4.0.1 Req3 Phase4.0(Member Point) Member Point on Other Receive อ้างอิงเอกสาร External Spec PRJ09010TheMall-R4-SE-External Spec.Member Poin for Other Receieve-00.04.00-FSBT.doc
'                IMPLEMENTATION IMPLICATIONS AND ASSUMPTION
'                5.  Other Receive ไม่มี Return หากต้องการคืน Point ของ Other Receive Apply ใช้การทำรายการ Other Disbursement แล้วทำการคีย์ Point ที่ต้องการคืน
'___________________________
Dim nRow As Integer
    W_DEFbChkReturn = False
    With wMain.ogdForm
        If Val(Format(tVB_TransactionSub)) = tEN_TrnReturn Or Val(Format(tVB_TransactionSub)) = tEN_TrnOtherDisbursement Then       '* Ao 51-06-27 การคืนแบบไม่มีเงื่อนไข ไม่ต้องมีส่วนลดใดๆเกิดขึ้น
            If bVB_Reference = False Then
                nRow = .RowSel
                If nRow = 0 Then nRow = 1
                If nRow > 0 Then
                    If Not (.TextMatrix(nRow, .ColIndex("FTSdtCancelFlag")) = "1") Then
                            wCNReturnDis.tW_ConsignmentFlag = .TextMatrix(nRow, .ColIndex("FTSdtConsignFlag"))
                            wCNReturnDis.nW_SeqNo = nRow
                            wCNReturnDis.tW_SKUCode = .TextMatrix(nRow, .ColIndex("FTSkuCode"))
                            cVB_CNRetSaleAmt = CDbl(.TextMatrix(nRow, .ColIndex("FCSdtRegPrice"))) * CDbl(.TextMatrix(nRow, .ColIndex("FCSdtQty")))
                            wCNReturnDis.Show vbModal
                            W_DEFbChkReturn = True
                    End If
                Else
                    W_DEFbChkReturn = True
                End If
            End If
        End If
    End With
End Function

Private Sub W_DEFxEditPrice(ByVal pnSeqNo As Integer)   '*Ao 51-07-09
'________________________________________
'   Call:
'   Cmt:
'________________________________________
Dim orsTemp As ADODB.Recordset
Dim tSql As String, tWhr As String
Dim bPromo As Boolean
'    tVB_Transaction = "4"
    With wMain.ogdForm
        If pnSeqNo > 0 Then
            oDisc.DISxClearAll
            oDisc.tTerminalNo = tVB_CNTerminalNum
            oDisc.dTranDate = tUT_SaleDate
            oDisc.tTransNo = tVB_Running
            oDisc.nDTSeqNo = pnSeqNo
            oDisc.C_DATxSumDT           'ไม่มีส่วนลดก็ออกจาก Sub
            oDisc.C_UPDxLabel '*KT 52-03-04
            If bW_MallANDTopALL Then
                Call W_DEFxMallCardAll
            Else
                tSql = "SELECT FCSdtQty,FCSdtSaleUnit,FCSdtSaleAmt,FTSkuStaMallEmpCard,FTSkuStaEmpCard"
                tSql = tSql & vbCrLf & " FROM " & tVB_CNTblDT
                tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                tSql = tSql & vbCrLf & " AND   FNSdtSeqNo=" & pnSeqNo
                Call SP_SQLvExecute(tSql, orsTemp)
                 If Not (orsTemp.BOF And orsTemp.EOF) Then
                    bVB_SKUisPromotion = IIf(SP_FEDtChkString(orsTemp, "FTSkuStaMallEmpCard") = "N", True, False)
                    tWhr = " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                    tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                    tWhr = tWhr & " AND  FNSdtSeqNo=" & pnSeqNo
                    tWhr = tWhr & " AND  FNDctNo IN (" & nEN_Disc01Deal & "," & nEN_Disc02PmtTime & "," & nEN_Disc03Pmt & "," & nEN_Disc21MPrice & ")"              'nEN_Disc01Deal = 1,nEN_Disc02PmtTime = 2,nEN_Disc03Pmt = 3 '*KT 52-09-07 Member + Consignment
                     tWhr = tWhr & " AND  ISNULL(FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
'                    tWhr = tWhr & " AND  FNDctNo IN (1,2,3)"              'nEN_Disc01Deal = 1,nEN_Disc02PmtTime = 2,nEN_Disc03Pmt = 3
                    bPromo = IIf(SP_FMTtNum2Shw(SP_SQLtFunction("", "FCScdAmt", tVB_CNTblCD, tWhr)) > 0, True, False)
                    If bPromo Then bVB_SKUisPromotion = bPromo
                    .TextMatrix(pnSeqNo, .ColIndex("FTPmt")) = IIf(bVB_SKUisPromotion, "*", "")
                    .TextMatrix(pnSeqNo, .ColIndex("FCSdtSaleUnit")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleUnit"), False, True)
                    .TextMatrix(pnSeqNo, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt"), False, True)
                    wMain.olaPrice.Caption = .TextMatrix(pnSeqNo, .ColIndex("FCSdtSaleUnit"))
                    Call wMain.W_SumAmount(False)
                    Call wMain.W_UPDxTransHD
                End If
            End If
        End If
    End With
    Call SP_DATxRsNothing(orsTemp)
End Sub

Private Function W_DEFbChkDiscAgain(ByVal pnSeqNo As Integer) As Boolean
'__________________________
'   Call:
'   Cmt:    การ Return ถ้าทำส่วนลดแล้ว จะไม่ให้ทำการเปลี่ยนจำนวนและ ราคา
'__________________________
Dim tSql As String
Dim orsTemp As ADODB.Recordset
Dim nEff As Long
On Error GoTo ErrHandle
    W_DEFbChkDiscAgain = False
    tSql = "SELECT * FROM " & tVB_CNTblCD
    tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND FNSdtSeqNo = " & pnSeqNo
    If SP_SQLbExecute(tSql, orsTemp, , nEff) Then
        If nEff > 0 Then
            W_DEFbChkDiscAgain = True
         End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    W_DEFbChkDiscAgain = True
    Call SP_MSGShowError
    Call SP_DATxRsNothing(orsTemp)
End Function

Private Sub W_DEFxMallCardAll()
'__________________________
'   Call:
'   Cmt:   ยกเลิก  MallCard หรือ OnTop ทั้งหมด ดึงค่าราคามาใหม่
'__________________________
Dim tSql As String, tWhr As String
Dim orsTemp As ADODB.Recordset
Dim nEff As Long
Dim nSeqNo As Integer
Dim bPromo As Boolean
On Error GoTo ErrHandle
    With wMain.ogdForm
'    If bW_MallANDTopALL Then
        bW_MallANDTopALL = False
        tSql = "SELECT FCSdtQty,FCSdtSaleUnit,FCSdtSaleAmt,FNSdtSeqNo"
        tSql = tSql & vbCrLf & " FROM " & tVB_CNTblDT
        tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
'        tSql = tSql & vbCrLf & " AND   FNSdtSeqNo=" & pnSeqNo
        tSql = tSql & vbCrLf & " ORDER BY FNSdtSeqNo"
        Call SP_SQLvExecute(tSql, orsTemp)
         If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                nSeqNo = SP_FEDvChkNumeric(orsTemp, "FNSdtSeqNo")
                bVB_SKUisPromotion = IIf(.TextMatrix(nSeqNo, .ColIndex("FTPmt")) = "*", True, False)
                tWhr = " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                tWhr = tWhr & " AND  FNSdtSeqNo=" & nSeqNo
                tWhr = tWhr & " AND  FNDctNo IN (" & nEN_Disc01Deal & "," & nEN_Disc02PmtTime & "," & nEN_Disc03Pmt & "," & nEN_Disc21MPrice & ")"                'nEN_Disc01Deal = 1,nEN_Disc02PmtTime = 2,nEN_Disc03Pmt = 3 '*KT 52-09-07 Member + Consignment
                tWhr = tWhr & " AND  ISNULL(FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
                bPromo = IIf(SP_FMTtNum2Shw(SP_SQLtFunction("", "FCScdAmt", tVB_CNTblCD, tWhr)) > 0, True, False)
                If bPromo Then bVB_SKUisPromotion = bPromo
                .TextMatrix(nSeqNo, .ColIndex("FTPmt")) = IIf(bVB_SKUisPromotion, "*", "")
                .TextMatrix(nSeqNo, .ColIndex("FCSdtSaleUnit")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleUnit"), False, True)
                .TextMatrix(nSeqNo, .ColIndex("FCSdtSaleAmt")) = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt"), False, True)
                orsTemp.MoveNext
            Loop
            wMain.olaPrice.Caption = .TextMatrix(nSeqNo, .ColIndex("FCSdtSaleUnit"))
            Call wMain.W_SumAmount
            Call wMain.W_UPDxTransHD
         End If
