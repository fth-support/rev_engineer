Public Sub W_DupTblBtwSleUpdHoldHD(ByVal poRs As ADODB.Recordset, ByVal ptTable$, Optional ByVal pnPdtSeq As Integer = 0, Optional ByVal pbPoint As Boolean = True)
'----------------------------------------------------------
'   Call:   poRs as recordset of HD or DT
'               ptTable as table name of HD or DT
'               pnSeqNo as sequence number
'               pbFrmSale as True if HD or DT from sale
'   Cmt:   dup data from poRs to ptTable
'----------------------------------------------------------
    Dim i%, tSql$, tTmp$
    Dim tSqlH$
    Dim tSqlF$, tSqlV$
    Dim tCstCode As String '*Tao 61-04-20 เก็บหมายเลขสมาชิก
    
    tSqlH = "UPDATE " & ptTable & " SET "
    For i = 0 To poRs.Fields.Count - 1
         tSqlF = poRs.Fields(i).Name
        Select Case poRs.Fields(i).Name
            Case "FTTmnNum", "FTShdTransNo", "FTShdTransType", "FDShdTransDate"
                'non
            Case "FDDateIns", "FTTimeIns", "FTWhoIns" '*KT 52-06-01 ให้การ Close ข้อมูลมาให้วันที่บันเป็นตัวปัจจุบัน(ตัวเดิม)
                'non
            Case "FDDateUpd", "FTTimeUpd", "FTWhoUpd"
                'non
            Case "FTShdStaDoc"
                'non
            Case "FTTmnCodeRecall", "FTTransNoRecall"
                'non
            Case "FTShdTransTypeSub", "FTShdTransNameAbb"
                'non
            Case "FTShdContractNo", "FTShdContractName", "FTShdContractTel", "FDShdDueDate" 'TPSTDepositHD
                'non
            Case "FNShdDocPrint"
                'non
            Case "FTShdStaPrcTmp"
                'non
            Case "FTStaSentOnOff"
                'non
            Case "FTShdStaPrcDoc" '*KT 51-11-10 ML-SB-634
                'non
            Case "FTShdStaCancel"  '*KT 51-11-10 ML-SB-634
                'non
            Case "FTLogCode" '*KT 52-01-23 IPV ข้ามเครื่องข้าม Shift
                'non
            Case "FDShdSysDate"
                tSqlV = tSqlV & tSqlF & " = '" & UT_tStringDate(SP_GETdCurrentDate) & "',"
            Case "FTShdSysTime"
                tSqlV = tSqlV & tSqlF & " = '" & Time$ & "',"
            Case "FTEmpCode" '*KT 51-10-15 V 3.0.136/V 3.0.200
                tSqlV = tSqlV & tSqlF & " = '" & tVB_CNUserCode & "',"
            'Case "FTCstCardCode", "FTCstCardType", "FNCstCardPoint", "FNCstCardLPoint", "FCCstCardAmt", "FTCstPointName" 'กรณีข้อมูลที่เป็น member point '*Tao 61-04-20 ของเดิม
            Case "FTCstCardType", "FNCstCardPoint", "FNCstCardLPoint", "FCCstCardAmt", "FTCstPointName"  'กรณีข้อมูลที่เป็น member point '*Tao 61-04-20 แยก FTCstCardCode ออกต่างหาก
                If pbPoint Then
                    Select Case Mid(poRs.Fields(i).Name, 2, 1)
                        Case "T"
                            If IsNull(poRs.Fields(i)) Then
                                tSqlV = tSqlV & tSqlF & " = Null" & ","
                            Else
                                If Len(Trim(poRs.Fields(i))) = 0 Then
                                     tSqlV = tSqlV & tSqlF & " = ''" & ","
                                Else
                                    tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                                End If
                            End If
                        Case "D"
                            If IsNull(poRs.Fields(i).Value) Then
                                tSqlV = tSqlV & tSqlF & " = Null" & ","
                            Else
                                tSqlV = tSqlV & tSqlF & " = '" & UT_tStringDate(poRs.Fields(i).Value) & "',"                          'มี เขาเดี่ยว
                            End If
                        Case "N"
                            tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                        Case "C"
                            tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                    End Select
                Else
                    'non
                End If
            Case "FTCstCardCode" '*Tao 61-04-20 Detoken ก่อน ถ้าเป็น Layaway หรือ Add Deposit
                If IsNull(poRs.Fields(i)) Then
                    tSqlV = tSqlV & tSqlF & " = Null" & ","
                Else
                    If Len(Trim(poRs.Fields(i))) = 0 Then
                         tSqlV = tSqlV & tSqlF & " = ''" & ","
                    Else
                        Select Case SP_VALnText2Double(Trim(poRs.Fields("FTShdTransType")))
                        Case tEN_TrnDeposit, tEN_TrnAddDeposit
                            If SP_PRCbDeToken(Trim(poRs.Fields(i)), tCstCode) Then
                                Call SP_CRTxLogMallCardExtend("W_DupTblBtwSleUpdHoldHD:tRefDeToken:" & Trim(poRs.Fields(i)) & ",Value:" & tCstCode)
                                'สำเร็จ
                                If Trim(tCstCode) <> "" Then
                                    tVB_MemPointIDTmp = tCstCode
                                    tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(tCstCode) & "',"         'มี เขาเดี่ยว
                                Else
                                    tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                                End If
                            Else
                                'ไม่สำเร็จ
                                Call SP_CRTxLogMallCardExtend("W_DupTblBtwSleUpdHoldHD:tRefDeToken:" & Trim(poRs.Fields(i)) & ",Value:" & tCstCode)
                                tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                            End If
                        Case Else
                            tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                        End Select
                    End If
                End If
            Case Else                           'อื่นๆ
              ' If poRs.Fields(i).Name = "FCShdVATRate" Then Stop
                Select Case Mid(poRs.Fields(i).Name, 2, 1)
                    Case "T"
                        If IsNull(poRs.Fields(i)) Then
                            tSqlV = tSqlV & tSqlF & " = Null" & ","
                        Else
                            If Len(Trim(poRs.Fields(i))) = 0 Then
                                 tSqlV = tSqlV & tSqlF & " = ''" & ","
                            Else
                                tSqlV = tSqlV & tSqlF & " = '" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"         'มี เขาเดี่ยว
                            End If
                        End If
                    Case "D"
                        If IsNull(poRs.Fields(i).Value) Then
                            tSqlV = tSqlV & tSqlF & " = Null" & ","
                        Else
                            tSqlV = tSqlV & tSqlF & " = '" & UT_tStringDate(poRs.Fields(i).Value) & "',"                          'มี เขาเดี่ยว
                        End If
                    Case "N"
                        tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                    Case "C"
                        tSqlV = tSqlV & tSqlF & " = " & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name)), True, False) & ","            'ไม่มี เขาเดี่ยว
                End Select
        End Select
    Next i
    
    tSqlV = tSqlH & tSqlV & UT_tLastUpdSql
    tSql = tSqlV & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    Call SP_SQLvExecute(tSql)
End Sub

