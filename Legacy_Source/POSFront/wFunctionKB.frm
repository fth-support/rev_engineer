                    End If
                    If W_PRCbCheckZeroVendor(cVB_NetSale) Then                   '*Ao 53-10-20
                        wSub.Show vbModal
                    End If
                Else
                    bVB_CNTrnDiscEx = True
                    bVB_CNReSumAmount = True
                   '*KT 53-01-14 DoEvents
                    wMain.W_SumAmount
                    bVB_CNReSumAmount = False
                End If
        End Select
     Else    'level ไม่ผ่าน
            Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub

