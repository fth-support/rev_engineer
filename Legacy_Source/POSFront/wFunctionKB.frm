        tSql = tSql & vbCrLf & "COUNT(HD.FTShdTransNo) AS FCCount,  SUM(RC.FCSrcNet) AS FCSrcNet,RC.FTSrcAbb,RC.FTTdmCode,SUM (RC.FCSrcRteAmt) AS FCSrcRteAmt"  '*Eaw 56-04-09 CommSheet TK-ISS3000-106 00.00.03.xlsx
        tSql = tSql & vbCrLf & ",RC.FCSrcRteFac"               '*Ao 2014/06/27
        tSql = tSql & vbCrLf & " FROM  " & ptTblHD & " HD INNER JOIN"
        tSql = tSql & vbCrLf & ptTblRC & " RC ON HD.FTTmnNum = RC.FTTmnNum AND"
        tSql = tSql & vbCrLf & " HD.FTShdTransNo = RC.FTShdTransNo And HD.FDShdTransDate = RC.FDShdTransDate"
        tSql = tSql & vbCrLf & " WHERE  " & "HD.FTTmnNum='" & tVB_CNTerminalNum & "'"
