         'แสดงข้อมูลที่หน้าจอ  wCNSubPay

         '*AO51-03-19
'         nRow = .ogdTender.Aggregate(flexSTMax, .ogdTender.FixedRows, .ogdTender.ColIndex("FTTdmType"), .ogdTender.rows - 1, .ogdTender.ColIndex("FTTdmType")) + 1
