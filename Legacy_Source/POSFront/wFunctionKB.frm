Public Sub W_KBLockKB()
'----------------------------------------------------------
'   Call:
'
'   Cmt:    lock all keyborad function (for user braking)
'----------------------------------------------------------
    Dim bAccept As Boolean
    
    bAccept = W_CheckLevelPass("W_KBLockKB")
    
    If bAccept Then     'if level is ok
        'process
        If Not bUT_FuncLockKB Then
            bUT_FuncLockKB = True
            wMain.otbPrompt.Text = "Locked"
            Call SaveSetting("AdaPosMall", "POSFront", "SentSale", "1")
            'Call SP_PRCxStartServiceSQL
        Else
            bUT_FuncLockKB = False
            wMain.otbPrompt.Text = vbNullString
        End If
    Else    'level ไม่ผ่าน
       Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
End Sub


Public Sub W_KBHoldBill()
'----------------------------------------------------------
'   Call:
'   Cmt:    hoding current bill to temporary (Suspend)
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim nPdtSeq As Integer           ' ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
    Dim nRow As Long
    Dim tTable$
On Error GoTo ErrHandle
'    If bVB_TrainingMode Then
'        Call SP_MSGnShowing("tms_CN005061", nCS_Information)
'        Call SP_DATxRsNothing(orsTemp)
'        Exit Sub
'    End If
    '_________________________________
    '*Ao 51-07-08
    If W_DEFbReturn Then    'การคืนแบบไม่มีเงื่อนไข ใช้ HoldBill ไม่ได้
        Exit Sub
    End If
    '_________________________________
    bAccept = W_CheckLevelPass("W_KBHoldBill")
    If Not bAccept Then     'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
