        tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVDutyFreeSale, "00") & "'"
        tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVOtherReceive, "00") & "'"
        tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVReturn, "00") & "'"
    End If
    tSql = tSql & vbCrLf & ")"
    tSql = tSql & vbCrLf & " AND FCShdRnd <> 0"
    If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND FTShdTransType  = '" & tEN_TrnTraining & "'"
    tSql = tSql & vbCrLf & " GROUP BY " & ptTransType '& ",FTShdStaCancel"
    
    Call SP_SQLvExecute(tSql, orsTemp)
    Do While Not orsTemp.EOF
'        If SP_FEDtChkString(orsTemp, "FTShdStaCancel") <> "Y" Then
            cQty = cQty + SP_FEDvChkNumeric(orsTemp, "FCNum")
            cAmt = cAmt + SP_FEDvChkNumeric(orsTemp, "FCShdRnd")
