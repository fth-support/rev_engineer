                End If
                '*Eaw 56-09-07 CommSheet TK-ISS3000-257-TR.xls Update Display หลังจาก Update ค่า FCSdtSaleAmt
                If bVB_OPOSLineDisplayEnable Then
                    Select Case nVB_TypeDiscLineItem
                        Case nEN_LnDis3NewPrice
                            tPrint = wMain.ogdForm.TextMatrix(nRow, wMain.ogdForm.ColIndex("FTSkuAbbName"))
                            tPrint = tPrint & ";" & wMain.ogdForm.TextMatrix(nRow, wMain.ogdForm.ColIndex("FCSdtSaleAmt"))
                            Call SP_PrnPollDisplay(tPrint)
                    End Select
                End If
                wMain.olaPrice = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSdtSaleAmt"), False, True)  '*Eaw 56-07-01CommSheet TK-ISS3000-252-TR.xls
                wMain.W_ClearValAfterInsTSDT
                wMain.W_SumAmount
                wMain.otbPrompt.Locked = False
            Else
                Call SP_MSGnShowing("tms_CN005107", nCS_Information)
            End If
        End With
    Else
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrDB:
    Call SP_DATxRsNothing(orsTemp)
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub


