                End If
                tPrint = tPrint & Trim(SP_FMTcCurPoint(cVB_Balance, False, True))
                Call SP_PrnPollDisplay(tPrint)
            End If
        End If
        '*KT 54-08-03 V.4.0.1 Req.2 Phase4.0(Member Point) Member Point Based on Tender เก็บมูลค่า Tender รวมที่อนุญาตให้ได้รับ Point
        'If aVB_TenderMnu(nVB_CurTenderSeqNo).StaPoint Then
