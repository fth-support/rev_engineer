'* 56-05-29 Bump copy W_PrintSignOut จาก SVN  Pae แก้ CommSheet TK-ISS3000-191-ST 00 00 01.xls
Public Sub W_PrintSignOut(Optional ByVal pbSal As Boolean = False, Optional ByVal pbBlank As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False)
'----------------------------------------------------------
'   Call:
'   Cmt:  Print Clossing Report
'   *KT 51-10-29
'   *KT 51-10-30
'   *KT 51-11-18 3.0.164
'----------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim nEff As Long
    Dim tFed$, tF$, tStr$, tSqlV$, tSqlF$
    Dim nI As Long
    Dim nSeq  As Long
    Dim cQty As Double
    Dim cAmt  As Double
    Dim tName As String
    Dim tTaxSign As String
    Dim tWhr$
    Dim cVatAmt As Double
    Dim cTotalSaleAmt As Double
    Dim cDisNoPro As Double
    Dim cDisLn As Double
    Dim tTransType As String
    Dim tTblHD As String
    Dim tTblDT As String
    Dim tTblCD As String
    Dim tTblRC As String
    Dim tCloRunning As String
    Dim tFUpd As String
    Dim tVUpd As String
    Dim cTmpValue As Double
    Dim tTmpVat$
    Dim cTaxExceptAmt As Double
    Dim nTmp As Long '*KT 51-10-27
On Error GoTo ErrHandle '*KT 53-01-05 3.0.32

    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_PrintSignOut[1]")
    tTransType = IIf(bVB_TrainingMode, "FTShdTransTypeSub", "FTShdTransType")
    
    tSql = "TRUNCATE TABLE TPSTClose"              '*Ao 2014/01/15 CommSheet TK-ISS3000-452-FAPL-174    ให้ลบข้อมูลก่อนทำการเก็บข้อมูล
    Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)
    
    If pbSal Then
        tTblHD = "TPSTSalHD"
        tTblDT = "TPSTSalDT"
        tTblCD = "TPSTSalCD"
        tTblRC = "TPSTSalRC"
    Else
        tTblHD = tVB_CNTblHD
        tTblDT = tVB_CNTblDT
        tTblCD = tVB_CNTblCD
        tTblRC = tVB_CNTblRC
    End If

    If pbCloseTmn Then
        tFed = "": tF = "": tStr = "": tSqlV = ""
        tFed = "FNCloSeqNo,FTCloCode,FTCloName,FTCloGrp,FCCloQty,FCCloAmt,FTCloMode"
        tCloRunning = CStr(Val(Format(SP_SQLtFunction("MAX", "FTCloGrp", "TPSTClose", "", oDB.ocnOffLine))))
        If tCloRunning = "" Or tCloRunning = "0" Then tCloRunning = "1"
    Else
        tFed = "": tF = "": tStr = "": tSqlV = ""
        tFed = "FTStmCode,FTTmnNum,FTShdTransNo,FNSdtSeqNo,FTSkuCode"
        tFed = tFed & ",FTSkuAbbName,FTShdTransType,FDShdTransDate,FTSdtBarCode,FTSdtStkCode"
        tFed = tFed & ",FCSdtStkFac,FTTaxCode,FTDpcCode,FTSkuDepCode,FTSkuBrdCode"
        tFed = tFed & ",FTPunCode,FTSdtUnitName,FCSdtRegPrice,FTSdtEventPrice,FCSdtQty"
        tFed = tFed & ",FCSdtSaleTaxAmt,FCSdtReturnTaxAmt"
        tFed = tFed & ",FTSdtInstoreBar,FCSdtB4DisChg,FTSdtDisChgTxt,FCSdtDis"
        tFed = tFed & ",FCSdtChg,FCSdtSaleAmt,FCSdtVat,FCSdtVatable,FCSdtQtyAll"
        tFed = tFed & ",FTSdtStaPdt"
        tFed = tFed & ",FTSdtWeight,FTSdtConsignFlag"
        tFed = tFed & ",FTSdtCancelFlag,FCSdtTax,FCSdtSalePrice,FTShdTransTime"
        tFed = tFed & ",FTSkuAbbNameSnd,FTSkuAbbNameSrvDoc,FTSkuAbbNameSndSrvDoc"
        tFed = tFed & ",FTTaxSign,FTTaxStaSign"
        tFed = tFed & ",FCSdtSaleUnit"
        tFed = tFed & ",FCSdtQtyAllDisAvi"
        tFed = tFed & ",FCSdtAmtDisAvi"
        tFed = tFed & ",FCSdtDutyFreeAmt"
        tFed = tFed & ",FCSdtDutyFreeQty"
        tFed = tFed & ",FCSdtDutyDeposit"
        tFed = tFed & ",FCSdtWeight"
        tFed = tFed & ",FTSdtPriceOverideFlag"
        tCloRunning = ""
    End If
    If Not pbBlank Then

        If Not pbCloseTmn Then Call SP_INSxTransHD(tTblHD, pbSal)
        
        cW_TolalSaleAmt = 0
        'NatSaleAmt(Vat)
        Dim cVatHD As Double
        cVatHD = 0
        nSeq = 0
        Call W_AddxCloseNatSaleVat(nSeq, pbSal, pbCloseTmn, tCloRunning, cVatHD)
        'Vat Amount
        Call W_AddxCloseVatAmt(nSeq, pbSal, pbCloseTmn, tCloRunning, cVatHD)
        'SaleAmt(Vat)/SaleAmt(NT)/SaleAmt(NZ)
        cW_TolalSaleAmt = 0             '*Ao 2013/03/08   TK
        Call W_AddxCloseSaleAmt(nSeq, pbSal, pbCloseTmn, tCloRunning)
       'Total Sale Amt/Return
        Call W_AddxCloseTotal(nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Deposit
        Call W_AddxCloseDeposit(nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Deposit
        'Call W_AddxCloseRedeem(nSeq, pbSal, pbCloseTmn) 'Online
        Call W_AddxCloseRedeemEx(nSeq, pbSal, pbCloseTmn, tCloRunning) 'Offline
        nSeq = nSeq + 1                 '*Ao 2013/03/01
         '.......................................................................................................................................................................................................................................

        'TotRoundDiffIn
        Call W_AddxCloseDiffIn(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'TotRoundDiffOut
        Call W_AddxCloseDiffOut(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'DepRoundDiffIn
        
        Call W_AddxCloseDepDiffIn(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'DepRoundDiffOut
        Call W_AddxCloseDepDiffOut(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Rounding
'        Call W_AddxDataPrintClosingOther(cW_CloseDiffInQty - cW_CloseDiffOutQty + cW_CloseDepDiffOutQty - cW_CloseDepDiffInQty, "Rounding", SP_FMTcCurPoint(cW_CloseDiffIn - cW_CloseDiffOut + cW_CloseDepDiffOut - cW_CloseDepDiffIn, True, False), nSeq, pbSal, pbCloseTmn, tCloRunning)
        '*Ao 2013/08/14
'        Call W_AddxDataPrintClosingOther((cW_CloseDiffInQty - cW_CloseDiffOutQty) + (cW_CloseDepDiffInQty - cW_CloseDepDiffOutQty), "Rounding", SP_FMTcCurPoint((cW_CloseDiffIn - cW_CloseDiffOut) + (cW_CloseDepDiffIn - cW_CloseDepDiffOut), True, False), nSeq, pbSal, pbCloseTmn, tCloRunning)
        Call W_AddxDataPrintClosingOther((cW_CloseDiffInQty + cW_CloseDiffOutQty) + (cW_CloseDepDiffInQty + cW_CloseDepDiffOutQty), "Rounding", SP_FMTcCurPoint((cW_CloseDiffIn - cW_CloseDiffOut) + (cW_CloseDepDiffIn - cW_CloseDepDiffOut), True, False), nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        'cW_ACCTABLTY
        Call W_AddxDataPrintClosingOther(0, "ACCTABLTY", SP_FMTcCurPoint(cW_ACCTABLTY, True, False), nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep2
        nSeq = nSeq + 1
        Call W_AddxDataPrintClosingTenderBlank("FTSep2", nSeq, pbSal, pbCloseTmn, tCloRunning)
         '.......................................................................................................................................................................................................................................
         
        'ItemMdseIn
        nSeq = nSeq + 1 '*KT 51-10-28
        'ยอดเงินรายรับที่หักส่วนลดและต้องถอด vat แล้วไม่รวมการนำเงินเข้าแก๊ะ
        Call W_AddxCloseMdseIn(tTblHD, tTblDT, tTblCD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'ยอดเงินรายจ่ายที่หักส่วนลดและต้องถอด vat แล้วไม่รวมการนำเงินออกแก๊ะ
        'ItemMdseOut
        Call W_AddxCloseMdseOut(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep3
        Call W_AddxDataPrintClosingTenderBlank("FTSep3", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        '.......................................................................................................................................................................................................................................

        'OtherReceive IN
        Call W_AddxOtherReceiveIn(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'OtherReceive Out
        Call W_AddxOtherReceiveOut(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'OtherDisburse IN
        Call W_AddxOtherDisburseIn(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'OtherDisburse Out
        Call W_AddxOtherDisburseOut(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep4
        Call W_AddxDataPrintClosingTenderBlank("FTSep4", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
       '.......................................................................................................................................................................................................................................

        'Voucher IN
        Call W_AddxVoucherIn(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Voucher Cancel
        Call W_AddxVoucherCancel(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep5
        Call W_AddxDataPrintClosingTenderBlank("FTSep5", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        '.......................................................................................................................................................................................................................................

        'Duty Free Sale In
        Call W_AddxDutyIn(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Duty Free Deposit
        Call W_AddxDutyDeposit(tTblHD, tTblDT, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep6
        Call W_AddxDataPrintClosingTenderBlank("FTSep6", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        '.......................................................................................................................................................................................................................................

        'Deposit money
        Call W_AddxCloseDepositMny(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Pickup money
        Call W_AddxClosePicup(tTblHD, tTblRC, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep7
        Call W_AddxDataPrintClosingTenderBlank("FTSep7", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        '.......................................................................................................................................................................................................................................

        'Tender
        Call W_AddxCloseTender(tTblHD, tTblRC, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)

        'Sep9
        Call W_AddxDataPrintClosingTenderBlank("FTSep8", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        '.......................................................................................................................................................................................................................................

        'start bank
        Call W_AddxCloseStartBank(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        'Sep10
        Call W_AddxDataPrintClosingTenderBlank("FTSep9", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
        '.......................................................................................................................................................................................................................................

        'Discount
        Call W_AddxCloseDiscount(tTblHD, tTblCD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)

        'Sep12
        Call W_AddxDataPrintClosingTenderBlank("FTSep10", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
         '.......................................................................................................................................................................................................................................

        'Nosale
        Call W_AddxCloseNoSale(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        
        'CV Issue,CV Cancel,CV pickup
        Call W_AddxCloseCV(tTblHD, tTblRC, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        
        'Sep13
        Call W_AddxDataPrintClosingTenderBlank("FTSep11", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1
         '.......................................................................................................................................................................................................................................
        
        'Suspended
        Call W_AddxCloseSuspend(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)

        'Total IPV In
        Call W_AddxCloseIPVIn(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        
        'Total IPV Out
        Call W_AddxCloseIPVOut(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)

        'DepositCancel/Add Deposit Cancel
        'Call W_AddxCloseDpsCancel(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        
        'VOID
        Call W_AddxCloseVoid(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        
        'OFF-LINE
        Call W_AddxCloseOffline(tTblHD, tTransType, nSeq, pbSal, pbCloseTmn, tCloRunning)
        
        'Sep14
        Call W_AddxDataPrintClosingTenderBlank("FTSep12", nSeq, pbSal, pbCloseTmn, tCloRunning)
        nSeq = nSeq + 1

        'If pbCloseTmn Then Call W_PRCxSortSeqNoClose '*KT 51-10-28
        'If pbCloseTmn Then Call W_PRCxNewRecalVat '*KT 51-10-28
    End If

    Call SP_DATxRsNothing(orsTemp)
    If Not pbCloseTmn Then
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_PrintSignOut[2]")
        Call W_SetToComplete(pbSal)
        Call SP_UPDxSetCompleteTerminalMtn(IIf(pbSal, False, True))
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_PrintSignOut[3]")
    End If

    '*KT 51-09-19 ให้ทำการ Copy ข้อมูลที่เป็น Sign Out
    '---------------------------------------------------------------------

    '---------------------------------------------------------------------
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_PrintSignOut[4]")
    Exit Sub
ErrHandle:
     Call SP_DATxRsNothing(orsTemp)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_PrintSignOut[5]")
