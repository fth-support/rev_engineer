                    tSql = tSql & vbCrLf & "AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                    tSql = tSql & vbCrLf & "AND  FNSdtSeqNo = " & .TextMatrix(nRow, .ColIndex("FNSdtSeqNo"))
                    tSql = tSql & vbCrLf & "AND  FCLineOver > 0"
                    Call SP_SQLvExecute(tSql, orsTemp)
                    If (orsTemp.BOF And orsTemp.EOF) Then
                        Call SP_DATxRsNothing(orsTemp)
                        Exit Sub
                    Else
                    
                     End If
                End If
                
'*KT 51-06-03 ใส่เครื่องหมาย * หน้าสินค้าที่ไม่ยอมให้ทำ Double Policy กับ Mall Card
'*KT 51-08-01
'*KT 52-02-19 PH2-ML-SF-102 โปรแกรมไม่แสดง *  ในกรณีที่ สินค้ามีส่วนลดแล้วไม่สามารถใช้ Mall Card ได้  (EX  Set Double Discount Line Dis - > Mall Card = NO) แต่เมื่อ Cancel สินค้านั้น จะมี * ขึ้นมา
