                            cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCQty"), True, False)
                        End If
                    End If
                Else
                '*BG 56-09-11  Comsheet-343  V 4.0.64
'                    cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSrcNet"), True, False)  '*KT 51-10-28 V 3.0.144/V 3.0.200
                    If UCase(tTender) = UCase("T018") Then
                        cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSrcNet") + SP_FEDvChkNumeric(orsTemp, "FCSrcChg"), True, False)
                        If cAmt = 0 Then   '*Eaw 56-09-12 CommSheet TK-ISS3000-351-UAT-FAPL-119.xls
                            If SP_FEDvChkNumeric(orsTemp, "FCQty") <> 0 Then
                                cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCQty"), True, False)
                            End If
                        End If
                    Else
                        cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSrcNet"), True, False)  '*KT 51-10-28 V 3.0.144/V 3.0.200
                        If cAmt = 0 Then   '*Eaw 56-09-12 CommSheet TK-ISS3000-351-UAT-FAPL-119.xls
                            If SP_FEDvChkNumeric(orsTemp, "FCQty") <> 0 Then
                                cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCQty"), True, False)
                            End If
                        End If
                    End If
                    '****
                End If
    '            cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSrcNet"), True, False)  '*KT 51-10-28 V 3.0.144/V 3.0.200
                If cAmt <> 0 Then '*KT 51-10-27 V 3.0.143/V 3.0.200
                    If UCase(tTender) = UCase("T012") Then
                            If pbCloseTmn Then                      '*Ao 2013/03/01   PK
                                ptCloRunning = pnSeq
                            End If
                            '* 56-05-29 Comment 2 บรรทัด Bump copy  จาก SVN  Pae แก้ CommSheet TK-ISS3000-191-ST 00 00 01.xls
                            'Call W_AddxDataPrintClosingOther(0, "FTSep8", SP_FMTcCurPoint(0, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tTender)
                            'pnSeq = pnSeq + 1
                            tSql = wFunctionKB.W_GETtCloseTenderCurSQL(ptTblHD, ptTblRC, ptTransType, pbCloseTmn)
                            'Call SP_SQLvExecute(tSql, orsFor) '*Thirapong 64-03-18 Performance tuning 'CommSheet TTK-ISS3000-784 TK ISSUE - Missing data on Closing Report
                            Call SP_SQLvExecute(tSql, orsFor, IIf(False, oDB.ocnOnLine, oDB.ocnOffLine), , , , , IIf(False, True, False))
                            If Not (orsFor.BOF And orsFor.EOF) Then
                                Do While Not orsFor.EOF
                                    cQty = 0
                                    cAmt = SP_FEDvChkNumeric(orsFor, "FCSrcRteAmt")
                                    tName = SP_FEDtChkString(orsFor, "FTRteCode")
                                    If pbCloseTmn Then                      '*Ao 2013/03/01   PK
                                        ptCloRunning = pnSeq
                                    End If
                                    Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tName, tTender, SP_FEDvChkNumeric(orsFor, "FCSrcRteFac"))
                                    pnSeq = pnSeq + 1
                                    orsFor.MoveNext
                                Loop
                            End If
                            If pbCloseTmn Then                      '*Ao 2013/03/01   PK
                                ptCloRunning = pnSeq
                            End If
                            '* 56-05-29 Comment 2 บรรทัด Bump copy  จาก SVN  Pae แก้ CommSheet TK-ISS3000-191-ST 00 00 01.xls
                            'Call W_AddxDataPrintClosingOther(0, "FTSep9", SP_FMTcCurPoint(0, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tTender)
                            'pnSeq = pnSeq + 1
                    ElseIf UCase(tTender) = UCase("T002") Or UCase(tTender) = UCase("T003") Or UCase(tTender) = UCase("T017") Or UCase(tTender) = UCase("T015") Then    '*BG 56-07-10 เพิ่ม NETS T015
                            If pbCloseTmn Then                      '*Ao 2013/03/01   PK
                                ptCloRunning = pnSeq
                            End If
                            cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSrcNet"), True, False)     '*Ao 2014/07/31   CommSheet TK-ISS3000-460-00 00 03   V4.1.129
                            Call W_AddxDataPrintClosingOther(0, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tName, tTender)
                            pnSeq = pnSeq + 1
                            tSql = wFunctionKB.W_GETtCloseTenderCreditCardSQL(ptTblHD, ptTblRC, ptTransType, pbCloseTmn, tTender)
                            
                            'Call SP_SQLvExecute(tSql, orsFor) '*Thirapong 64-03-18 Performance tuning 'CommSheet TTK-ISS3000-784 TK ISSUE - Missing data on Closing Report
                            Call SP_SQLvExecute(tSql, orsFor, IIf(False, oDB.ocnOnLine, oDB.ocnOffLine), , , , , IIf(False, True, False))
                            
                            If Not (orsFor.BOF And orsFor.EOF) Then
                                Do While Not orsFor.EOF
                                    cQty = SP_FEDvChkNumeric(orsFor, "FCQty")
                                    cAmt = SP_FEDvChkNumeric(orsFor, "FCSrcNet")
                                    tName = SP_FEDtChkString(orsFor, "FTSrcRetDocRef")
                                    '*BG 56-07-10  Comsheet-208
                                    If UCase(tTender) = UCase("T015") Then
                                        tName = Right(tName, Len(tName) - 2)
                                    End If
                                    '****
                                    If pbCloseTmn Then                      '*Ao 2013/03/01   PK
                                        ptCloRunning = pnSeq
                                    End If
                                    Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tName, tTender)
                                    pnSeq = pnSeq + 1
                                    orsFor.MoveNext
                                Loop
                            End If
                    ElseIf UCase(tTender) = UCase("T018") Then  '*Eaw 56-06-25 เพิ่มเคส T018 เข้ามา
                        cAmt = SP_FEDvChkNumeric(orsTemp, "FCSrcNet")   '*BG 56-09-11  Comsheet-343         V.4.0.64
                        cAmtChgCV = SP_FEDvChkNumeric(orsTemp, "FCSrcChg")
                        cAmt = cAmt - cAmtChgCV
'                        cQty = SP_FEDvChkNumeric(orsTemp, "FCQty") '*Eaw 56-09-12 CommSheet TK-ISS3000-351-UAT-FAPL-119.xls
                        cQty = W_GETnCVQty(ptTblRC)  '*BG 56-10-22 CommSheet TK-ISS3000-FAPL-141.xlsx
                        Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tName, tTender)
                        pnSeq = pnSeq + 1
                    Else
'                        Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tTender)
                        Select Case UCase(tTender)
                            Case UCase("T001")   '*Eaw 56-09-12 CommSheet TK-ISS3000-351-UAT-FAPL-119.xls
                                cAmt = SP_FMTcCurPoint(CDbl(SP_FEDvChkNumeric(orsTemp, "FCSrcNet")) - cAmtChgAll, True, False)
                                cQty = SP_FEDvChkNumeric(orsTemp, "FCQty")
                            Case UCase("T013"), UCase("T016")               'Cash Card,Flash Pay
                                cQty = SP_FEDvChkNumeric(orsTemp, "FCQty")
                                cAmt = SP_FEDvChkNumeric(orsTemp, "FCSrcNet") '*Eaw 56-09-12 CommSheet TK-ISS3000-351-UAT-FAPL-119.xls
                            Case Else   '*Eaw 56-09-12 CommSheet TK-ISS3000-351-UAT-FAPL-119.xls เพิ่มเคส T008และเคสอื่นๆที่ไม่ใช่ข้างบน
                                cAmt = SP_FEDvChkNumeric(orsTemp, "FCSrcNet")
                                cQty = SP_FEDvChkNumeric(orsTemp, "FCQty")
                        End Select
                        Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning, tName, tTender)   '*Ao 2013/05/30 CommSheet TK-ISS3000-208-ST 00 00 01-Ao.xls
                        pnSeq = pnSeq + 1
                    End If
                End If
                orsTemp.MoveNext
            Loop
'            Call W_UPDxCloseTender(pbCloseTmn, pbSal) '*Eaw 56-08-06
        End If
        Call SP_DATxRsNothing(orsTemp)
        Call SP_DATxRsNothing(orsFor)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseTender[2]")
        Exit Sub
ErrHandle:
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_AddxCloseTender[3]")
End Sub

Public Sub W_AddxCloseStartBank(ByVal ptTblHD As String, ByVal ptTransType As String, ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
'-------------------------------------------------------------------------
'Call:
'Cmt: ทำการหายอด Start Bank ในการออก Total Report กับ Closing Report
' *KT 51-10-30
'-------------------------------------------------------------------------
        'Start Bank
        Dim cQty As Double
        Dim cAmt As Double
        Dim tName As String
        Dim tSql As String
        Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseStartBank[1]")
        cQty = 0: cAmt = 0
        tName = "Start Bank"
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & ptTblHD & ".FCShdGrand AS FCShdGrand"  '*KT 51-10-27 V 3.0.142/V 3.0.200
        tSql = tSql & vbCrLf & " FROM " & ptTblHD
        tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND ISNULL(" & ptTblHD & ".FTShdStaCancel,'N') <> 'Y'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdStaDoc = '1'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FCShdGrand>0" '*KT 51-10-27 V 3.0.142/V 3.0.200
'        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTLogCode  = '" & tUT_LoginCode & "'" '*KT 52-01-16 ต้องมี Logcode เป้นเงื่อนไขด้วย        '*Ao 2013/08/23 TK
'        If Not pbSal Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTEmpCode  = '" & tVB_CNUserCode & "'"
'         If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTEmpCode  = '" & tVB_CNUserCode & "'" '*KT 51-10-28       '*Ao 2013/08/23 TK
        tSql = tSql & vbCrLf & " AND " & ptTblHD & "." & ptTransType & " IN ("
        tSql = tSql & vbCrLf & "'" & Format(tEN_TrnStartBank, "00") & "'"
        tSql = tSql & vbCrLf & ")"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdTransType  = '" & tEN_TrnTraining & "'"
        Call SP_SQLvExecute(tSql, orsTemp)
        Do While Not orsTemp.EOF
            cQty = cQty + 1
            cAmt = cAmt + SP_FEDvChkNumeric(orsTemp, "FCShdGrand")
            orsTemp.MoveNext
        Loop
        If cQty > 0 Then
            Call W_AddxDataPrintClosingOther(0, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning)
            pnSeq = pnSeq + 1
        End If
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseStartBank[2]")
        Exit Sub
ErrHandle:
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_AddxCloseStartBank[3]")
End Sub

