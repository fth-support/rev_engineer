                            bOffline = Not W_PRCbMoveDataToDeposit
                        End If
                        .olaPrice.Caption = SP_FMTcCurPoint(cNet, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005027")
                        .olaChange.Visible = True
                    Case tEN_TrnAddDeposit
                        bOffline = Not W_PRCbMoveDataToDeposit
                        .olaPrice.Caption = SP_FMTcCurPoint(cVB_Change, False, True)
                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
