                .ogdTender.TextMatrix(nRow, .ogdTender.ColIndex("FCSrcNet")) = cAmount
                .ogdTender.TopRow = nRow
                .olaBalance.Caption = SP_FMTcCurPoint(cVB_Balance, False, True)
                .olaAmtTender.Caption = SP_FMTcCurPoint(.ogdTender.Aggregate(flexSTSum, .ogdTender.FixedRows, .ogdTender.ColIndex("FCSrcNet"), .ogdTender.rows - 1, .ogdTender.ColIndex("FCSrcNet")), False, True)
                Call SP_OBJxSetFocus(.ogdFunc)
        '        DoEvents '*KT 53-01-14 DoEvents
            End If
'------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        End If

         'save HD
        If Not bComplete Then
            tSql = "UPDATE " & tVB_CNTblHD
            tSql = tSql & " SET FCShdChn=" & SP_FMTcCurPoint(cVB_Change, , False)         'เงินทอน
            tSql = tSql & ",FCShdRndMnyChg = " & SP_FMTcCurPoint(cVB_RoundChg, , False)         'ยอดปัดเศษเงินทอน
