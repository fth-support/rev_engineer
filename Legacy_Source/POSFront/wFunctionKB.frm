    End If
    
    tVB_CNMnuCurrent = "1802"
    If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
'         DoEvents '*KT 53-01-14 DoEvents
         If tVB_CNUserAlwC = "" Then
            Call SP_DATxRsNothing(orsTemp)
             Exit Sub
         End If
     End If
     
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnSale, tEN_TrnTaxExceptSale, tEN_TrnDutyFreeSale
            'non
        Case Else
            Call SP_MSGnShowing("tms_CN005061", nCS_Information)
            Call SP_DATxRsNothing(orsTemp)
            Exit Sub
    End Select
    
    'level ok, process
    nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
    If nRow < 1 Then
        Call SP_MSGnShowing("tms_CN005104", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub         'if no item in grid, nothing to do
    End If

    'refund can not hold bill
    If SP_VALnText2Double(tVB_Transaction) = tEN_TrnReturn Then     'สถานะเอกสาร 3 : ขายปกติ 4 : คืน
        Call SP_MSGnShowing("tms_CN005115", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub         'if no item in grid, nothing to do
    End If

   If tVB_Transaction <> tEN_TrnCreateVIP Then
        If SP_MSGnShowing("tms_CN005116", nCS_OkCancelDefaultButton1) = vbCancel Then  '*KT 53-01-14 DoEvents nCS_OkCancel--> nCS_OkCancelDefaultButton1
            Call SP_DATxRsNothing(orsTemp)
            Exit Sub        'ต้องการพัก bill ?
        End If
    End If
    
    If bVB_CNUserOveride Then Call SP_UPDxOverideEmp '*KT 51-08-25 เก็บข้อมูล User ที่ทำการ Overide
    '____________________________________________________
    '*Ao 2010/11/05
    'delete RC
