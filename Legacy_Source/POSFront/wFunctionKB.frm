            'non
        Case Else
            tVB_Transaction = aVB_TransMode(28).ID
            tVB_TransactionSub = tVB_Transaction
            tVB_TransName = aVB_TransMode(28).Name
            tVB_TransNameABB = aVB_NameAbb(tEN_AbbSuspended - 1).UsrLangPri & ";" & aVB_NameAbb(tEN_AbbSuspended - 1).UsrLangSec
            tVB_CNTypePrinter = aVB_TransMode(28).PrintType
    End Select
    wFunctionKB.W_SetToComplete
    '*KT 52-08-14 ทำการ Copy ข้อมูลไปไว้ที่ตาราง  Hold
    tTable = "TPSTHoldHD"            'HD ก่อน
    tSql = "SELECT * FROM " & tVB_CNTblHD
