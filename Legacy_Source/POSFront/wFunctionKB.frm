'Cmt: ทำการ Recal ค่า VAT Amount ของ Closing Report
'          *KT 52-10-21 เปลี่ยนจากการใช้ oDB.ocnOffLine.BeginTrans มาเป็นการส่ง SQL BeginTrans ไปแทน
'          *KT 53-02-06 เปลี่ยนจากการใช้ SQL BeginTrans มาเป็น oDB.ocnOffLine.BeginTrans แทน
'--------------------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim orsTax As ADODB.Recordset
    Dim cSaleAmt As Double
    Dim cTolSaleAmt As Double
    Dim cTolDpsAmt As Double
    Dim cTolRedeemAmt As Double
    Dim cTax  As Double
    Dim cTaxAmt  As Double
    Dim cDpsTaxAmt As Double
    Dim cRedeemTaxAmt As Double
    Dim cTolTaxAmt  As Double
    Dim cTolDpsTaxAmt As Double
    Dim cTolRedeemTaxAmt As Double
    Dim bPass As Boolean
On Error GoTo ErrHandle
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_PRCxNewRecalVat[1]")
    bPass = False
    
    cTolSaleAmt = 0
    cTolDpsAmt = 0
    cTolRedeemAmt = 0
    
    cTolTaxAmt = 0
    cTolDpsTaxAmt = 0
    cTolRedeemTaxAmt = 0
    
'    tSql = "BEGIN TRANSACTION T1"
'    oDB.ocnOffLine.Execute tSql
    ocnAll.BeginTrans
    bPass = True
    nVB_CNCountBegin = nVB_CNCountBegin + 1
    tSql = "SELECT FTCloCode,FCCloAmt "
    tSql = tSql & vbCrLf & " FROM TPSTClose WITH (TABLOCKX,XLOCK)"
    tSql = tSql & vbCrLf & " ORDER BY FNCloSeqNo"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
            tSql = "SELECT FTTaxCode,FTTaxDesc ,FCTaxRate "
            tSql = tSql & vbCrLf & " FROM TCNMTaxMtn "
            tSql = tSql & vbCrLf & " WHERE  FTTaxCode <>  '00' "
            tSql = tSql & vbCrLf & " ORDER BY FTTaxCode"
            Call SP_SQLvExecute(tSql, orsTax, oDB.ocnOnLine, , , , , True, True) 'read master
             If Not (orsTax.BOF And orsTax.EOF) Then
                    'Sale Amount
                    Do While Not orsTax.EOF
                        orsTemp.Filter = "FTCloCode = 'Sale(" & SP_FEDtChkString(orsTax, "FTTaxDesc") & ")'"
                        If Not (orsTemp.BOF And orsTemp.EOF) Then
                            cSaleAmt = 0
                            Do While Not orsTemp.EOF
                                cSaleAmt = cSaleAmt + SP_FEDvChkNumeric(orsTemp, "FCCloAmt")
                                cTolSaleAmt = cTolSaleAmt + cSaleAmt
                                orsTemp.MoveNext
                            Loop
                            cTax = SP_FEDvChkNumeric(orsTax, "FCTaxRate")
                            cTaxAmt = SP_FMTcCurPoint(SP_VALcText2Double(cSaleAmt * cTax / (100 + cTax)), True, False)
                            cTolTaxAmt = cTolTaxAmt + cTaxAmt
                        End If
                        orsTemp.Filter = adFilterNone
                        orsTax.MoveNext
                    Loop
                    
                    'Deposit/Redeem
                    orsTax.MoveFirst
                    orsTax.Filter = "FTTaxCode = '01'"
                    If Not (orsTax.BOF And orsTax.EOF) Then
                        cTax = SP_FEDvChkNumeric(orsTax, "FCTaxRate")
                    Else
                        cTax = 7
                    End If
                    'Deposit
                    orsTemp.Filter = "FTCloCode = 'DepositAmt(VAT)'"
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                        cSaleAmt = 0
                        Do While Not orsTemp.EOF
                            cSaleAmt = cSaleAmt + SP_FEDvChkNumeric(orsTemp, "FCCloAmt")
                            cTolDpsAmt = cTolDpsAmt + cSaleAmt
                            orsTemp.MoveNext
                        Loop
                        cDpsTaxAmt = SP_FMTcCurPoint(SP_VALcText2Double(cSaleAmt * cTax / (100 + cTax)), True, False)
                        cTolDpsTaxAmt = cTolDpsTaxAmt + cDpsTaxAmt
                    End If
                    orsTemp.Filter = adFilterNone
                    orsTax.Filter = adFilterNone
                    
                    'Redeem
                    orsTemp.Filter = "FTCloCode = 'RedeemAmt(VAT)'"
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                        cSaleAmt = 0
                        Do While Not orsTemp.EOF
                            cSaleAmt = cSaleAmt + SP_FEDvChkNumeric(orsTemp, "FCCloAmt")
                            cTolRedeemAmt = cTolRedeemAmt + cSaleAmt
                            orsTemp.MoveNext
                        Loop
                        cRedeemTaxAmt = SP_FMTcCurPoint(SP_VALcText2Double(cSaleAmt * cTax / (100 + cTax)), True, False)
                        cTolRedeemTaxAmt = cTolRedeemTaxAmt + cRedeemTaxAmt
                    End If
                    orsTemp.Filter = adFilterNone
                    orsTax.Filter = adFilterNone
                    
                '    oDB.ocnOffLine.BeginTrans
                '    bPass = True
                    'VAT Amount
                    tSql = "UPDATE TPSTClose SET FCCloAmt = " & cTolTaxAmt
                    tSql = tSql & "WHERE FTCloCode = 'GST'"
                    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
                    'NetSaleAmt(VAT)
                    tSql = "UPDATE TPSTClose SET FCCloAmt = " & SP_FMTcCurPoint(SP_VALcText2Double(cTolSaleAmt - cTolTaxAmt), True, False)
                    tSql = tSql & "WHERE FTCloCode = 'Sale(VAT)'"
                    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
                    'VAT Amount(Dps)
                    tSql = "UPDATE TPSTClose SET FCCloAmt = " & cTolDpsTaxAmt
                    tSql = tSql & "WHERE FTCloCode = 'VAT Amount(Dps)'"
                    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
                    'NetDepositAmt(VAT)
                    tSql = "UPDATE TPSTClose SET FCCloAmt = " & SP_FMTcCurPoint(SP_VALcText2Double(cTolDpsAmt - cTolDpsTaxAmt), True, False)
                    tSql = tSql & "WHERE FTCloCode = 'NetDepositAmt(VAT)'"
                    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
                    'VAT Amount(Re)
                    tSql = "UPDATE TPSTClose SET FCCloAmt = " & cTolRedeemTaxAmt
                    tSql = tSql & "WHERE FTCloCode = 'VAT Amount(Re)'"
                    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
                    'NetRedeemAmt(VAT)
                    tSql = "UPDATE TPSTClose SET FCCloAmt = " & SP_FMTcCurPoint(SP_VALcText2Double(cTolRedeemAmt - cTolRedeemTaxAmt), True, False)
                    tSql = tSql & "WHERE FTCloCode = 'NetRedeemAmt(VAT)'"
                    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
                    
            End If
    End If

'    If bPass Then oDB.ocnOffLine.CommitTrans
     If bPass Then
'            tSql = "COMMIT TRANSACTION T1"
'            oDB.ocnOffLine.Execute tSql
            ocnAll.CommitTrans
            bPass = False
            nVB_CNCountBegin = nVB_CNCountBegin - 1
     End If
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTax)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_PRCxNewRecalVat[2]")
    Exit Sub
ErrHandle:
   ' If bPass Then oDB.ocnOffLine.RollbackTrans
    If bPass Then
'            tSql = "ROLLBACK TRANSACTION T1"
'            oDB.ocnOffLine.Execute tSql
            ocnAll.RollbackTrans
            bPass = False
            nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTax)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_PRCxNewRecalVat[3]")
End Sub

Private Sub W_AddxCloseNatSaleVat(ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "", Optional ByRef pcVatHD As Double = 0)
'------------------------------------------------------------------
'Call:
'Cmt:
' *KT 51-10-29
' *KT 51-10-30
' *KT 51-10-31
'*KT 51-12-11 Phase 2 ข้อ 18,19
'IPV ข้ามเครื่อง ไม่ตัดยอด Sale ทั้งเครื่อง Original และเครื่องไปทำ IPV และขอให้ตัดยอดขาย ของเครื่องนั้น และ Cashier คนที่ทำ **ตัดเครื่องที่ทำ IPV
'IPV ข้าม Shift ไม่ตัดยอด ในส่วนของ "SALE" บน Closing Report และ Total Report
'------------------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim orsTemp2 As ADODB.Recordset
    Dim nEff As Long
    Dim tFed$, tF$, tStr$, tSqlV$, tSqlF$, tSql2$
    Dim nI As Long
    Dim cQty As Double
    Dim cAmt  As Double
    Dim tTaxSign As String
    Dim tWhr$
    Dim cVatAmt As Double
    Dim tTransType As String
    Dim tTblHD As String
    Dim tTblDT As String
    Dim tTblCD As String
    Dim tTblRC As String
    Dim tFUpd As String
    Dim tVUpd As String
    Dim cTmpValue As Double
    Dim cTmpVatableDiff As Double
    Dim cTmpVatDiff As Double
    Dim cTmpVatable As Double
    Dim cTmpVat As Double
On Error GoTo ErrHandle
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseNatSaleVat[1]")
    tTransType = IIf(bVB_TrainingMode, "FTShdTransTypeSub", "FTShdTransType")
    If pbSal Then
        tTblHD = "TPSTSalHD"
        tTblDT = "TPSTSalDT"
        tTblCD = "TPSTSalCD"
        tTblRC = "TPSTSalRC"
    Else
        tTblHD = tVB_CNTblHD
        tTblDT = tVB_CNTblDT
        tTblCD = tVB_CNTblCD
        tTblRC = tVB_CNTblRC
    End If

    If pbCloseTmn Then
        tFed = "": tF = "": tStr = "": tSqlV = ""
        tFed = "FNCloSeqNo,FTCloCode,FTCloName,FTCloGrp,FCCloQty,FCCloAmt,FTCloMode"
    Else
        tFed = "": tF = "": tStr = "": tSqlV = ""
        tFed = "FTStmCode,FTTmnNum,FTShdTransNo,FNSdtSeqNo,FTSkuCode"
        tFed = tFed & ",FTSkuAbbName,FTShdTransType,FDShdTransDate,FTSdtBarCode,FTSdtStkCode"
        tFed = tFed & ",FCSdtStkFac,FTTaxCode,FTDpcCode,FTSkuDepCode,FTSkuBrdCode"
        tFed = tFed & ",FTPunCode,FTSdtUnitName,FCSdtRegPrice,FTSdtEventPrice,FCSdtQty"
        tFed = tFed & ",FCSdtSaleTaxAmt,FCSdtReturnTaxAmt"
        tFed = tFed & ",FTSdtInstoreBar,FCSdtB4DisChg,FTSdtDisChgTxt,FCSdtDis"
        tFed = tFed & ",FCSdtChg,FCSdtSaleAmt,FCSdtVat,FCSdtVatable,FCSdtQtyAll"
        tFed = tFed & ",FTSdtStaPdt"
        tFed = tFed & ",FTSdtWeight,FTSdtConsignFlag"
        tFed = tFed & ",FTSdtCancelFlag,FCSdtTax,FCSdtSalePrice,FTShdTransTime"
        tFed = tFed & ",FTSkuAbbNameSnd,FTSkuAbbNameSrvDoc,FTSkuAbbNameSndSrvDoc"
        tFed = tFed & ",FTTaxSign,FTTaxStaSign"
        tFed = tFed & ",FCSdtSaleUnit"
        tFed = tFed & ",FCSdtQtyAllDisAvi"
        tFed = tFed & ",FCSdtAmtDisAvi"
        tFed = tFed & ",FCSdtDutyFreeAmt"
        tFed = tFed & ",FCSdtDutyFreeQty"
        tFed = tFed & ",FCSdtDutyDeposit"
        tFed = tFed & ",FCSdtWeight"
        tFed = tFed & ",FTSdtPriceOverideFlag"
    End If
    
     tSql = "SELECT  "
     'NetSaleAmt (Vat)
     If bVB_ReEntryMode Then
        Select Case tVB_CNMnuCurrent
            Case "172003", "172005"
                tSql = tSql & vbCrLf & "  ROUND(SUM(CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "'"
                tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'"
            Case "172103", "172105"
               tSql = tSql & vbCrLf & "  ROUND(SUM(CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnSaleManualTax, "00") & "'"
                tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnManualTax, "00") & "'"
            Case Else
                'none
        End Select
     Else
         tSql = tSql & vbCrLf & "  ROUND(SUM(CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnSale, "00") & "'"
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnVIPSale, "00") & "'"
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnDutyFreeSale, "00") & "'" '*KT 51-10-21 V 3.0.140/V 3.0.200 เพิ่มรายการ Duty Free Sale
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnRedeem, "00") & "'" '*KT 51-10-22 V 3.0.140/V 3.0.200 เปลี่ยน  Deposit เป็น Redeem
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturn, "00") & "'"
        'IPV
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPV, "00") & "'"
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVVIPService, "00") & "'"
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVDutyFreeSale, "00") & "'"
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVRedeem, "00") & "'"
         tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVReturn, "00") & "'"
     End If
     tSql = tSql & vbCrLf & ")                              THEN "
     tSql = tSql & vbCrLf & "                                           CASE WHEN  " & tTblDT & ".FTTaxCode = '00' "
     tSql = tSql & vbCrLf & "                                                       THEN "
     tSql = tSql & vbCrLf & "                                                                    0 "
     tSql = tSql & vbCrLf & "                                                        ELSE "
     If bVB_ReEntryMode Then
        Select Case tVB_CNMnuCurrent
            Case "172003", "172005"
                tSql = tSql & vbCrLf & "                                                                    CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnReturnTaxInc, "00") & "')"
            Case "172103", "172105"
                tSql = tSql & vbCrLf & "                                                                    CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnReturnManualTax, "00") & "')"
            Case Else
                'none
        End Select
     Else
        tSql = tSql & vbCrLf & "                                                                    CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnReturn, "00") & "'"
        tSql = tSql & vbCrLf & "                                                                                                                                                                           ,'" & Format(tEN_TrnIPV, "00") & "'"
        tSql = tSql & vbCrLf & "                                                                                                                                                                           ,'" & Format(tEN_TrnIPVVIPService, "00") & "'"
        tSql = tSql & vbCrLf & "                                                                                                                                                                           ,'" & Format(tEN_TrnIPVDutyFreeSale, "00") & "'"
        tSql = tSql & vbCrLf & "                                                                                                                                                                           ,'" & Format(tEN_TrnIPVRedeem, "00") & "')"
    End If
     tSql = tSql & vbCrLf & "                                                                                  THEN -1 * "
    '*KT 51-09-20 ไม่ต้องคำนวณให้ใช้ FCSdtVatable
    '*KT 52-03-27 กรณีที่ FCSdtSaleUnit * FCSdtQty แล้วต้อง - FCSdtChg เพราะค่า FCSdtChg คือค่าที่เป็นเศษเหลือจากการทำการหาค่า FCSdtSaleUnit ตอนเข้า Function W_CHKxAvgFooter
    'เช่นรายการ SKU 001 จำนวน 3 ชิ้น   ได้ Deal ส่วนลด 1000 บาท FCSdtSaleUnit เก็บราคาสินค้าหลังหักเฉพาะ Deal,Promo Time,Promo เมื่อนำ 100 / 3 =33.33 เหลือเศษ 0.01 ซึ่ง 0.01 ต้องเก็บใน FCSdtChg
    'เพื่อนำมาออก Closing Report แบบ Before
    '----------------------------------------------------------------------------
    If bVB_CNAlwBeOrAftDisc Then
            'คิดคำนวณกรณีก่อนลดส่วนลด
         If tVB_CNDiscPrcAftDisc = "0" Then
             tSql = tSql & vbCrLf & "                                                                                       CASE WHEN " & tTblDT & ".FCSdtTax > 0 " '*KT 54-06-14 V.4.0.0 Req.12 Tax Except Sale (Closing Report/Total Report ใน NetSaleAmt(VAT) ไม่รวม Vat 0%
             tSql = tSql & vbCrLf & "                                                                                            THEN"
             tSql = tSql & vbCrLf & "                                                                                                       (((" & tTblDT & ".FCSdtSaleUnit * " & tTblDT & ".FCSdtQty) - " & tTblDT & ".FCSdtChg) - (((" & tTblDT & ".FCSdtSaleUnit * " & tTblDT & ".FCSdtQty) - " & tTblDT & ".FCSdtChg) * " & tTblDT & ".FCSdtTax /(100+" & tTblDT & ".FCSdtTax)))"
             tSql = tSql & vbCrLf & "                                                                                            ELSE"
             tSql = tSql & vbCrLf & "                                                                                                       0"
             tSql = tSql & vbCrLf & "                                                                                             END"
             tSql = tSql & vbCrLf & "                                                                           ELSE"
             tSql = tSql & vbCrLf & "                                                                                        CASE WHEN " & tTblDT & ".FCSdtTax > 0 " '*KT 54-06-14 V.4.0.0 Req.12 Tax Except Sale (Closing Report/Total Report ใน NetSaleAmt(VAT) ไม่รวม Vat 0%
             tSql = tSql & vbCrLf & "                                                                                            THEN"
             tSql = tSql & vbCrLf & "                                                                                                      ((" & tTblDT & ".FCSdtSaleUnit * " & tTblDT & ".FCSdtQty) - " & tTblDT & ".FCSdtChg) - (((" & tTblDT & ".FCSdtSaleUnit * " & tTblDT & ".FCSdtQty) - " & tTblDT & ".FCSdtChg) * " & tTblDT & ".FCSdtTax /(100+" & tTblDT & ".FCSdtTax))"
              tSql = tSql & vbCrLf & "                                                                                            ELSE"
             tSql = tSql & vbCrLf & "                                                                                                       0"
             tSql = tSql & vbCrLf & "                                                                                             END"
             tSql = tSql & vbCrLf & "                                                                           END "
             tSql = tSql & vbCrLf & "                                                END "
         Else
             'คิดคำนวณกรณีหลังลดส่วนลด
             tSql = tSql & vbCrLf & "                                                                                       CASE WHEN " & tTblDT & ".FCSdtTax > 0 " '*KT 54-06-14 V.4.0.0 Req.12 Tax Except Sale (Closing Report/Total Report ใน NetSaleAmt(VAT) ไม่รวม Vat 0%
             tSql = tSql & vbCrLf & "                                                                                            THEN"
             tSql = tSql & vbCrLf & "                                                                                                       FCSdtVatable "
             tSql = tSql & vbCrLf & "                                                                                             ELSE"
             tSql = tSql & vbCrLf & "                                                                                                       0"
             tSql = tSql & vbCrLf & "                                                                                             END"
             tSql = tSql & vbCrLf & "                                                                           ELSE"
             tSql = tSql & vbCrLf & "                                                                                       CASE WHEN " & tTblDT & ".FCSdtTax > 0 " '*KT 54-06-14 V.4.0.0 Req.12 Tax Except Sale (Closing Report/Total Report ใน NetSaleAmt(VAT) ไม่รวม Vat 0%
             tSql = tSql & vbCrLf & "                                                                                            THEN"
             tSql = tSql & vbCrLf & "                                                                                                       FCSdtVatable "
             tSql = tSql & vbCrLf & "                                                                                             ELSE"
             tSql = tSql & vbCrLf & "                                                                                                       0"
             tSql = tSql & vbCrLf & "                                                                                             END"
             tSql = tSql & vbCrLf & "                                                                           END "
             tSql = tSql & vbCrLf & "                                                END "
         End If
    Else
        tSql = tSql & vbCrLf & "                                                                                       CASE WHEN " & tTblDT & ".FCSdtTax > 0 " '*KT 54-06-14 V.4.0.0 Req.12 Tax Except Sale (Closing Report/Total Report ใน NetSaleAmt(VAT) ไม่รวม Vat 0%
        tSql = tSql & vbCrLf & "                                                                                            THEN"
        tSql = tSql & vbCrLf & "                                                                                                       FCSdtVatable "
        tSql = tSql & vbCrLf & "                                                                                             ELSE"
        tSql = tSql & vbCrLf & "                                                                                                       0"
        tSql = tSql & vbCrLf & "                                                                                             END"
        tSql = tSql & vbCrLf & "                                                                           ELSE"
        tSql = tSql & vbCrLf & "                                                                                       CASE WHEN " & tTblDT & ".FCSdtTax > 0 " '*KT 54-06-14 V.4.0.0 Req.12 Tax Except Sale (Closing Report/Total Report ใน NetSaleAmt(VAT) ไม่รวม Vat 0%
        tSql = tSql & vbCrLf & "                                                                                            THEN"
        tSql = tSql & vbCrLf & "                                                                                                       FCSdtVatable "
        tSql = tSql & vbCrLf & "                                                                                             ELSE"
        tSql = tSql & vbCrLf & "                                                                                                       0"
        tSql = tSql & vbCrLf & "                                                                                             END"
        tSql = tSql & vbCrLf & "                                                                           END "
        tSql = tSql & vbCrLf & "                                               END "
    End If
    '----------------------------------------------------------------------------
     tSql = tSql & vbCrLf & "                            ELSE "
     tSql = tSql & vbCrLf & "                                        0 "
     tSql = tSql & vbCrLf & "                            END"
     tSql = tSql & vbCrLf & "),2) AS FCNetSaleVatAmt"

     'TotalTaxExceptSale
     tSql = tSql & vbCrLf & " ,ROUND(SUM(CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnTaxExceptSale, "00") & "','" & Format(tEN_TrnIPVTaxExceptSale, "00") & "'"
     tSql = tSql & vbCrLf & ")                                            THEN CASE WHEN  " & tTblDT & ".FTTaxCode = '00' "
     tSql = tSql & vbCrLf & "                                                                      THEN "
     tSql = tSql & vbCrLf & "                                                                                 0 "
     tSql = tSql & vbCrLf & "                                                                      ELSE "
     '*KT 51-09-20 ไม่ต้องคำนวณให้ใช้ FCSdtVatable
    '----------------------------------------------------------------------------
     tSql = tSql & vbCrLf & "                                                                                CASE WHEN " & tTblHD & "." & tTransType & " IN ('" & Format(tEN_TrnIPVTaxExceptSale, "00") & "')"
     tSql = tSql & vbCrLf & "                                                                                       THEN -1 * "
     If bVB_CNAlwBeOrAftDisc Then
