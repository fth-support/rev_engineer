'* 56-05-29 Bump copy W_AddxCloseMdseIn จาก SVN  Pae แก้ CommSheet TK-ISS3000-191-ST 00 00 01.xls
Public Sub W_AddxCloseMdseIn(ByVal ptTblHD As String, ByVal ptTblDT As String, ByVal ptTblCD As String, ByVal ptTransType As String, ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
'-------------------------------------------------------------------------
'Call:
'Cmt: ทำการหายอด ItemMdseIn ในการออก Total Report กับ Closing Report
'           กรณีที่ทำ Deposit Create และ Add Deposit แต่ยังไม่ Redeem ยังไม่ต้อง Summary ItemMdseIn
'           ส่วน Qty ให้นับเฉพาะที่ Redeem
' *KT 51-10-30
'*KT 51-12-22 Phase 2 ข้อ 18,19
'IPV ข้ามเครื่อง ไม่ตัดยอด Sale ทั้งเครื่อง Original และเครื่องไปทำ IPV และขอให้ตัดยอดขาย ของเครื่องนั้น และ Cashier คนที่ทำ **ตัดเครื่องที่ทำ IPV
'IPV ข้าม Shift ไม่ตัดยอด ในส่วนของ "SALE" บน Closing Report และ Total Report
'-------------------------------------------------------------------------
        'ItemMdseIn
        Dim cQty As Double
        Dim cAmt As Double
        Dim tName As String
        Dim tSql As String
        Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseMdseIn[1]")
        cQty = 0:  cAmt = 0
        tName = "ItemMdseIn"
        
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & " SUM(CASE WHEN " & ptTblHD & "." & ptTransType & " IN ("
        If bVB_ReEntryMode Then
            Select Case tVB_CNMnuCurrent
                Case "172003", "172005"
                    tSql = tSql & vbCrLf & "'" & Format(0, "00") & "')"
                Case "172103", "172105"
                    tSql = tSql & vbCrLf & "'" & Format(0, "00") & "')"
                Case Else
                    'none
            End Select
         Else
            tSql = tSql & vbCrLf & "'" & Format(tEN_TrnIPV, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVVIPService, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVTaxExceptSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVDutyFreeSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVRedeem, "00") & "')"
        End If
        tSql = tSql & vbCrLf & " THEN (-1) *"
        tSql = tSql & vbCrLf & "            FCSdtQty"
        tSql = tSql & vbCrLf & " ELSE"
        tSql = tSql & vbCrLf & "            FCSdtQty"
        tSql = tSql & vbCrLf & " END"
        tSql = tSql & vbCrLf & " ) AS FCNum"
        tSql = tSql & vbCrLf & "FROM   " & ptTblHD & " INNER JOIN"
        tSql = tSql & vbCrLf & ptTblDT & " ON " & ptTblHD & ".FTTmnNum = " & ptTblDT & ".FTTmnNum AND"
        tSql = tSql & vbCrLf & ptTblHD & ".FTShdTransNo = " & ptTblDT & ".FTShdTransNo And " & ptTblHD & ".FDShdTransDate = " & ptTblDT & ".FDShdTransDate"
        tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FDShdTransDate='" & tUT_SaleDate & "'"
'        tSql = tSql & vbCrLf & " AND ISNULL(" & ptTblHD & ".FTShdStaCancel,'N') <> 'Y'" '*KT 51-12-22 Phase 2 ข้อ 18,19
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdStaDoc = '1'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdStaPrcDoc = '1'" 'กรณีที่ใบ Deposit ทำการ Redeem แล้วถึงนำมารวมกับ SQL นี้
'        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTLogCode  = '" & tUT_LoginCode & "'" '*KT 52-01-16 ต้องมี Logcode เป้นเงื่อนไขด้วย                '*Ao 2013/08/23 TK
        'If Not pbSal Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTEmpCode  = '" & tVB_CNUserCode & "'" '*KT 51-10-28
'        If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND FTEmpCode  = '" & tVB_CNUserCode & "'" '*KT 51-10-28                                            '*Ao 2013/08/23 TK
        tSql = tSql & vbCrLf & " AND " & ptTblHD & "." & ptTransType & " IN ("
        If bVB_ReEntryMode Then
            Select Case tVB_CNMnuCurrent
                Case "172003", "172005"
                    tSql = tSql & vbCrLf & "'" & Format(tEN_TrnSaleTaxInc, "00") & "'"
                Case "172103", "172105"
                    tSql = tSql & vbCrLf & "'" & Format(tEN_TrnSaleManualTax, "00") & "'"
                Case Else
                    'none
            End Select
        Else
            tSql = tSql & vbCrLf & "'" & Format(tEN_TrnSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnRedeem, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnVIPSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnTaxExceptSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnDutyFreeSale, "00") & "'"
            '*KT 51-12-22 Phase 2
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPV, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVVIPService, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVTaxExceptSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVDutyFreeSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnIPVRedeem, "00") & "'"
        End If
        tSql = tSql & vbCrLf & ")"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdTransType  = '" & tEN_TrnTraining & "'"
        tSql = tSql & vbCrLf & " AND ISNULL(" & ptTblDT & ".FTSdtCancelFlag,'0') <> '1'"
        Call SP_SQLvExecute(tSql, orsTemp)
        Do While Not orsTemp.EOF
            cQty = cQty + SP_FEDvChkNumeric(orsTemp, "FCNum")
            orsTemp.MoveNext
        Loop
        
        tSql = "SELECT  "
'       *KT 51-09-20 ML-SF-303
        If bVB_ReEntryMode Then
            Select Case tVB_CNMnuCurrent
                Case "172003", "172005"
                        tSql = tSql & vbCrLf & " SUM(CASE WHEN " & ptTransType & " IN ("
                        tSql = tSql & vbCrLf & "'" & Format(0, "00") & "')"
                        tSql = tSql & vbCrLf & " THEN "
                        tSql = tSql & vbCrLf & "        ISNULL(" & ptTblHD & ".FCShdDepositAmt,0) "
                        tSql = tSql & vbCrLf & "  ELSE "
                        tSql = tSql & vbCrLf & "        CASE WHEN " & ptTransType & " IN ("
                        tSql = tSql & vbCrLf & "     '" & Format(0, "00") & "')"
                        tSql = tSql & vbCrLf & "        THEN (-1) *"
                        tSql = tSql & vbCrLf & "                ISNULL(" & ptTblHD & ".FCShdGrand,0) "
                        tSql = tSql & vbCrLf & "        ELSE"
                        tSql = tSql & vbCrLf & "                ISNULL(" & ptTblHD & ".FCShdGrand,0) "
                        tSql = tSql & vbCrLf & "        END"
                        tSql = tSql & vbCrLf & " END) - "
                        tSql = tSql & vbCrLf & " SUM(CASE WHEN " & ptTransType & " IN ("
                        tSql = tSql & vbCrLf & "'" & Format(0, "00") & "')"
                        tSql = tSql & vbCrLf & " THEN "
                        tSql = tSql & vbCrLf & "        ISNULL(" & ptTblHD & ".FCShdDepositVat,0) "
                        tSql = tSql & vbCrLf & "  ELSE "
                        tSql = tSql & vbCrLf & "        CASE WHEN " & ptTransType & " IN ("
                        tSql = tSql & vbCrLf & "     '" & Format(0, "00") & "')"
                        tSql = tSql & vbCrLf & "        THEN (-1) *"
                        tSql = tSql & vbCrLf & "                ISNULL(" & ptTblHD & ".FCShdVat,0) "
                        tSql = tSql & vbCrLf & "        ELSE"
