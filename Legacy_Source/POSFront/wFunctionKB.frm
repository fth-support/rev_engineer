Public Sub W_DupTblBtwSleNHold(ByVal poRs As ADODB.Recordset, ByVal ptTable$, ByVal pnSeqNo As Long, ByVal pbFrmSale As Boolean, Optional ByVal pnPdtSeq As Integer = 0, Optional ByVal pnSeqNoCD As Long = 0, Optional ByVal pbMoveLocal As Boolean = False, Optional ByVal pbCpyDeal As Boolean = False, Optional ByVal pnDateTime As Long = 0, Optional ByVal pnSeqNoActCD As Long = 0, Optional pbClrDealPromo As Boolean = False)
'----------------------------------------------------------
'   Call:   poRs as recordset of HD or DT
'               ptTable as table name of HD or DT
'               pnSeqNo as sequence number
'               pbFrmSale as True if HD or DT from sale
'               pbDateTime 0 : ไม่ Update FDDateIns/FTTimeIns/FTWhoIns/FDDateUpd/FTTimeUpd/FTWhoUpd  1 : ไม่ Update  FDDateIns/FTTimeIns/FTWhoIns Update FDDateUpd/FTTimeUpd/FTWhoUpd  2 : Update  FDDateIns/FTTimeIns/FTWhoIns /FDDateUpd/FTTimeUpd/FTWhoUpd
'               pbClrDealPromo : เป็นตัวแปรที่บ่งบอกว่าต้องการ Claer ค่า FTSdtStkCode ในตาราง CD ให้ค่าเป้นค่าว่างหรือไม่ True : Claer False : ไม่ Claer
'   Cmt:   dup data from poRs to ptTable
'----------------------------------------------------------
    Dim i%, tSql$, tTmp$
    Dim tSqlH$, tSqlT$
    Dim tSqlF$, tSqlV$
        
    tSqlH = "INSERT INTO " & ptTable & " ("
    tSqlT = " VALUES ("
    For i = 0 To poRs.Fields.Count - 1
        tSqlF = tSqlF & poRs.Fields(i).Name & ","
        Select Case poRs.Fields(i).Name
            Case "FTTmnNum"
                If pbFrmSale Then
                    tSqlV = tSqlV & "'" & UT_tChkFieldString(poRs, poRs.Fields(i).Name) & "',"
                Else
                    tSqlV = tSqlV & "'" & tVB_CNTerminalNum & "',"
                End If
                
            Case "FTShdTransNo"
                If pbFrmSale Then
                    tSqlV = tSqlV & "'" & UT_tChkFieldString(poRs, poRs.Fields(i).Name) & "',"
                Else
                    tSqlV = tSqlV & "'" & tVB_Running & "',"
                End If
                
            Case "FTShdTransType"
                If pbFrmSale Then
                    tSqlV = tSqlV & "'" & UT_tChkFieldString(poRs, poRs.Fields(i).Name) & "',"
                Else
                    tSqlV = tSqlV & "'" & tVB_Transaction & "',"
                End If
                
            Case "FDShdTransDate"
                If pbFrmSale Then
                    If IsNull(poRs.Fields(i).Value) Then
                         tSqlV = tSqlV & "Null" & ","
                     Else
                         tSqlV = tSqlV & "'" & UT_tStringDate(poRs.Fields(i).Value) & "',"
                     End If
                Else
                    tSqlV = tSqlV & "'" & tUT_SaleDate & "',"
                End If
            
