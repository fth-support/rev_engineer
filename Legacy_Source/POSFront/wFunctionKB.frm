Public Function W_PRCbFindRow(ByVal ptBarcode$) As Boolean
'-------------------------------------------------------------
'Call:
'Cmt: หา row ใน grid ตาม barcode ที่ scan เข้ามา(negative scan) จากล่าสุดไปที่เริ่มต้นการ scan ขายสินค้า
'*KT 51-12-12 Phase 2 ข้อ 22 + ต้องมีการแก้ ISS3000 ทำการ Trim ช่องว่างซ้ายขวาใน Barcode/SKU Code
'--------------------------------------------------------------
    Dim nLRow As Long
    Dim nI As Long
    Dim bFound As Boolean
On Error GoTo ErrHandle
    bFound = False
    W_PRCbFindRow = False
    With wMain.ogdForm
        .Enabled = True
        .HighLight = flexHighlightAlways
        nLRow = .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))
        nI = nLRow
        Do While nI >= 1 And nI <= nLRow
             If .TextMatrix(nI, .ColIndex("FTSdtCancelFlag")) <> "1" Then
                If Trim(.TextMatrix(nI, .ColIndex("FTSdtBarCode"))) = ptBarcode Then bFound = True: Exit Do
             End If
            nI = nI - 1
        Loop
        If bFound Then
            .Enabled = True
            .HighLight = flexHighlightAlways
            .Select nI, 1
            .SetFocus
            W_PRCbFindRow = True
        Else
            .HighLight = flexHighlightNever
            .Editable = flexEDNone
            .Enabled = False
        End If
    End With
    Exit Function
ErrHandle:
    W_PRCbFindRow = False
End Function

Public Sub W_PRCxRetBillVIPSale()
'----------------------------------------------------------
'   Call:
'   Cmt:    retrive bill from holding
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim orsTemp As ADODB.Recordset
    Dim tSql$
    Dim tWhr$
    Dim nSeqNo As Long
    Dim nRow As Long
    
    'level ok, process
    nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
    If nRow > 1 Then        'If nRow > 1 Then
        Call SP_MSGnShowing("tms_CN005109", nCS_Warning)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub     'กำลังทำรายการอื่นอยู่ทำไม่ได้
    End If
    
    'refund can not hold bill
    If tVB_Transaction <> 10 Then     'สถานะเอกสาร 3 : ขายปกติ 4 : คืน
        Call SP_MSGnShowing("tms_CN005126", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub         'if no item in grid, nothing to do
    End If
    
    'find last insert DT
    tWhr = "WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType =''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tWhr = tWhr & vbCrLf & " ORDER BY FNSdtSeqNo"
    tSql = "STP_CNxSQLFunction @ptFunc = '*' ,@ptTable = '" & tVB_CNTblDT & "',@ptWhere = '" & tWhr & "'"
    
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub
    
    'insert into grid     อาจจะไม่ถูกนัก ถ้าแยกเอา promotion แยก table ออกมาต่างหาก, หรือไม่ต้อง return table promotion ด้วย
    nRow = 0
    Do While Not orsTemp.EOF
        With wMain.ogdForm
            If nRow + 1 >= .rows Then
                .rows = .rows + 1
                .TopRow = nRow + 1
            End If
            nSeqNo = SP_FEDvChkNumeric(orsTemp, "FNSdtSeqNo")
            tWhr = " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
            tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
            tWhr = tWhr & " AND  FNSdtSeqNo=" & nSeqNo
            tWhr = tWhr & " AND  FNDctNo IN (1,2,3,21)" '*KT 52-09-07 Member + Consignment
            tWhr = tWhr & " AND  ISNULL(FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
            bVB_SKUisPromotion = IIf(SP_FMTtNum2Shw(SP_SQLtFunction("", "FCScdAmt", tVB_CNTblCD, tWhr)) > 0, True, False)
            'อ้างอิง Comm.Sheet  ML-SF-083 (Mall Card Flag = No)  ต้องมีเครื่องหมาย * อยู่หน้า Barcode
            If Not bVB_SKUisPromotion Then
                    bVB_SKUisPromotion = IIf(SP_FEDtChkString(orsTemp, "FTSkuStaMallEmpCard") = "Y", False, True)     '*KT 51-03-27 Comsheet ML-SF-083
            End If
    
             '*KT 55-08-17 Takashimaya PRJ10001TK-External Specification SKU-00.01.00.doc
            tVB_CNSkuStaAlw = SP_FEDtChkString(orsTemp, "FTSdtStaPdt")
            tVB_SKUSymbol = ""
             '*Eaw 55-12-06  เปลี่ยนเป็นใช้เครื่องหมาย *สำหรับ Alw Member Card ,# สำหรับ Alw Emp Card
            If Mid(tVB_CNSkuStaAlw, 20, 1) = "0" Then tVB_SKUSymbol = "#"       'ไม่ให้ส่วนลดEmp card
            If Mid(tVB_CNSkuStaAlw, 9, 1) = "0" Then tVB_SKUSymbol = "*"       'ไม่ให้ส่วนลดMember card
            If Mid(tVB_CNSkuStaAlw, 20, 1) = "0" And Mid(tVB_CNSkuStaAlw, 9, 1) = "0" Then tVB_SKUSymbol = "*" 'ไม่ให้ส่วนลด Mall+Emp
