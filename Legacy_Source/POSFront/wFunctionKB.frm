                             tSql = "UPDATE TPSTClose SET FNCloSeqNo =" & pnSeq & " WHERE " & tFUpd & " AND FNCloSeqNo < " & pnSeq: Call SP_SQLvExecute(tSql, , oDB.ocnOffLine)  '*KT 51-10-21 V 3.0.140/V 3.0.200 '*KT 51-10-28 V 3.0.144/V 3.0.200
                          End If
                 End If
                 tSqlV = ""
                 tSql = "INSERT INTO TPSTClose"
                 tF = tFed
             Next nI
         Else
             For nI = 0 To orsTemp.Fields.Count - 1
                 pnSeq = pnSeq + 1
                 Do While tStr <> ""
                         Select Case UCase(tStr)
                             Case UCase("FTStmCode"): tSqlV = tSqlV & "'" & tVB_CNStoreCode & "',"
                             Case UCase("FTTmnNum"): tSqlV = tSqlV & "'" & tVB_CNTerminalNum & "',"
                             Case UCase("FTShdTransNo"): tSqlV = tSqlV & "'" & tVB_Running & "',"
                             Case UCase("FTShdTransType"): tSqlV = tSqlV & "'" & Format(tVB_Transaction, "00") & "',"
                             Case UCase("FDShdTransDate"): tSqlV = tSqlV & "'" & tUT_SaleDate & "',"
                             Case UCase("FTShdTransTime"): tSqlV = tSqlV & "'" & Time$ & "',"
                             Case UCase("FNSdtSeqNo"): tSqlV = tSqlV & pnSeq & ","
                             Case UCase("FTEmpCode"): tSqlV = tSqlV & "'" & tVB_CNUserCode & "',"
                             Case UCase("FTSkuAbbName"), UCase("FTSkuAbbNameSnd"), UCase("FTSkuAbbNameSrvDoc"), UCase("FTSkuAbbNameSndSrvDoc")
                                 Select Case UCase(orsTemp.Fields(nI).Name)
                                     Case UCase("FCLayawayPickup")
                                         tSqlV = tSqlV & "'" & "" & "',"
                                     Case UCase("FTSep1")
                                         tSqlV = tSqlV & "'" & "" & "',"
                                 End Select
                             Case UCase("FCSdtSaleAmt"): tSqlV = tSqlV & 0 & ","
                             Case UCase("FTSdtConsignFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                             Case UCase("FTTaxStaSign"): tSqlV = tSqlV & "'" & "N" & "',"
                             Case UCase("FTSkuStaMallEmpCard"): tSqlV = tSqlV & "'" & "N" & "',"
                             Case UCase("FTSkuStaEmpCard"): tSqlV = tSqlV & "'" & "N" & "',"
                             Case UCase("FTSdtPriceOverideFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                             Case UCase("FCSdtQty"), UCase("FCSdtQtyAll"): tSqlV = tSqlV & 0 & ","
                             Case Else
                                 Select Case UCase(Mid(tStr, 2, 1))
                                     Case "T"
                                         tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                                     Case "N", "C"
                                         tSqlV = tSqlV & 0 & ","
                                     Case "D"
                                         tSqlV = tSqlV & "NULL" & ","
                                 End Select
                         End Select
                       tStr = cUT.UT_STRtToken(tF, ",", 1)
                 Loop
                 tSqlV = " VALUES (" & tSqlV & UT_tLastInsSql & ")"
                 tSql = tSql & tSqlF & tSqlV
                 Call SP_SQLvExecute(tSql)
                 tSqlV = ""
                 tSql = "INSERT INTO " & tTblDT
                 tF = tFed
             Next nI
         End If
     End If
    Call SP_DATxRsNothing(orsTemp)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseRedeemEx[2]")
    Exit Sub
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_AddxCloseRedeemEx[3]")
End Sub


Private Sub W_AddxCloseDiffIn(ByVal ptTblHD$, ByVal ptTransType$, ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
