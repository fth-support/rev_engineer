On Error GoTo ErrHandle
    bComplete = False
    bAccept = W_CheckLevelPass("W_KBRcvWalletPay")

    If Not bAccept Then         'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If

    With wSub
        '*KT 52-08-19 เกิด Offline ขณะทำรายการ tEN_TrnIPV, tEN_TrnIPVDutyFreeSale, tEN_TrnIPVRedeem, tEN_TrnIPVReturn, tEN_TrnIPVTaxExceptSale, tEN_TrnIPVVIPService, tEN_TrnIPVOtherReceive, tEN_TrnIPVOtherDisbursement
        'tEN_TrnDeposit, tEN_TrnRedeem, tEN_TrnAddDeposit, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel
        'tEN_TrnVoucher, tEN_TrnCancelVoucher
        If bVB_TicketNotSuccess Then
            Unload wSub
            'เริ่ม Ticket ใหม่
            Call UT_GenSaleNewDoc
            'Unload wSub '*KT 51-09-16 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
            tVB_CNMnuCurrent = "1700"
            If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
                Call wMain.otbPrompt_KeyDown(vbKeyEscape, 0)
            Else
                wMain.W_FRMxActivate
            End If
            Call SP_OBJxSetFocus(wMain.otbPrompt) '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
'            DoEvents '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero '*KT 53-01-14 DoEvents
            wMain.otbPrompt.Locked = False '*KT 51-09-17 แก้ไขเรื่องการยิงสินค้าขึ้น Zero
