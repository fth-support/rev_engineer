                cVB_SaleLineItemAmt = .ValueMatrix(nRow, .ColIndex("FCSdtSaleUnit"))
                tStaMemPriceAlw = .TextMatrix(nRow, .ColIndex("FTSdtStaRfd"))
                tVB_CNSKUFlagPrv = .TextMatrix(nRow, .ColIndex("FTSdtStaPreview")) '*KT 53-11-01 Preview Day
                
                '*KT 52-02-17 member price เอกสาร Mail วันที่  17/02/2009
                'คำถาม ในกรณีที่ป้อน SKU ที่ได้ราคา Member, ถ้ามี Discount อื่นๆ เช่น Coop.Disc จะลดได้อีกหรือไม่?
