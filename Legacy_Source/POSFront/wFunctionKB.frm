Private Sub W_PRCxSetPoint()
'--------------------------------------------------------
'   Call
'   Cmt '*Ao 2014/12/12    CommSheet TK-ISS3000-569
'--------------------------------------------------------
Dim bChk As Boolean

Dim tSql As String
Dim tSaveID  As String, tSaveName As String, tSavePoint As String, tMemID As String
Dim tExpDate As String, tName As String, tTmp As String
Dim tPointBefore As String, tBonusPoints As String, tTotalBonus As String
Dim nPoint As Long, nBalance As Long
Dim orsMem As ADODB.Recordset
Dim orsTemp As ADODB.Recordset
Dim tCardNo As String ''*Bmp 61-02-15 Token
Dim tTokenCardNo As String
        
On Error GoTo ErrHandle

    If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
        bChk = True
    Else
        bChk = False
    End If
    
    tSaveID = ""
    tSaveName = ""
    tSavePoint = ""
    
    tSql = "SELECT SUM(FCSpoPoint) AS FCSpoPoint,MIN(CONVERT(INT,FTSpoID)) AS FTSpoID,FTSpoMemID,FDDateIns"
    tSql = tSql & vbCrLf & "FROM TPSTSalePoint WITH(NOLOCK)"
    tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransNo= '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate= '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & "GROUP BY FTSpoMemID,FDDateIns"
    tSql = tSql & vbCrLf & "ORDER BY FTSpoID"
    Call SP_SQLvExecute(tSql, orsTemp)
    If (orsTemp.BOF And orsTemp.EOF) Then Exit Sub
    orsTemp.MoveFirst
    
    Do While Not orsTemp.EOF
    
        tMemID = SP_FEDtChkString(orsTemp, "FTSpoMemID")
        nPoint = SP_FEDvChkNumeric(orsTemp, "FCSpoPoint")
        tExpDate = SP_DTEtStrSTD(SP_FEDdChkDate(orsTemp, "FDDateIns"))
        '*Bmp 61-02-15 Token, update 61-04-11-Issue 7. Card # on Slip print should be actual value(masked) = OK /การพิมพ์ถูกแล้ว
        tCardNo = tMemID
'        If SP_CHKbWebservice Then
            tTokenCardNo = ""
            If SP_PRCbToken("W_PRCxSetPoint", tCardNo, tTokenCardNo) Then
                If tTokenCardNo <> "" Then
                    tCardNo = tTokenCardNo
                Else
                    bChk = False
                End If
                Call SP_CRTxLogMallCardExtend(" W_PRCxSetPoint(SP_PRCbToken): " & "[Tokenized Card No:" & tTokenCardNo & "]")
            Else
                bChk = False
            End If
'        Else
'            bChk = False    '*Bmp 61-04-12 08.30 เพิ่มการเช็ค Web service ว่าใช้งานได้หรือไม่ POSFront[5.1804.8].exe
'        End If
        '===================================
        If bChk Then
            tSql = "SELECT TOP 1 * FROM TCNMMallCard WITH(NOLOCK)"
            'tSql = tSql & vbCrLf & "WHERE FTMcdCode = '" & tMemID & "'"
            tSql = tSql & vbCrLf & "WHERE FTMcdCode = '" & tCardNo & "'" '*Bmp 61-02-15 Token
            tSql = tSql & vbCrLf & "AND FDMcdExpDate = '" & tExpDate & "'"
            tSql = tSql & vbCrLf & "ORDER BY FDMcdExpDate DESC"                             'อาจจะมีมากกว่า 1 Record
            If SP_SQLvExecute(tSql, orsMem, ocnMember, , , , True) = 0 Then
                If Not (orsMem.BOF And orsMem.EOF) Then
                    tName = SP_FEDtChkString(orsMem, "FTMcdName") & " " & SP_FEDtChkString(orsMem, "FTMcdSurName")
                    nBalance = SP_FEDvChkNumeric(orsMem, "FCBalance")
                    tExpDate = Format(Month(CDate(tExpDate)), "00") & "/" & Right(Format(Year(CDate(tExpDate)), "0000"), 2)
                    
                    Select Case Val(Format(tVB_Transaction))
                        Case tEN_TrnReturn, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                            tPointBefore = nBalance + nPoint
                            tBonusPoints = (-1) * nPoint
                            tTotalBonus = nBalance
                        Case Else
                            tPointBefore = nBalance - nPoint
                            tBonusPoints = nPoint
                            tTotalBonus = nBalance
                    End Select
                    tTmp = oTransPrn.W_CHKtChangeCardID(tMemID, "0")
                    
                    tSaveID = tSaveID & tTmp & "," & tExpDate & ";"
                    tSaveName = tSaveName & tName & ";"
                    tSavePoint = tSavePoint & tPointBefore & "," & tBonusPoints & "," & tTotalBonus & ";"
                End If
            Else
                tExpDate = Format(Month(CDate(tExpDate)), "00") & "/" & Right(Format(Year(CDate(tExpDate)), "0000"), 2)
                tName = "New Member"
                nBalance = 0
                Select Case Val(Format(tVB_Transaction))
                    Case tEN_TrnReturn, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                        tPointBefore = nBalance
                        'tBonusPoints = (-1) * nPoint '*Tao 61-07-19 ของเดิม
                        'tBonusPoints = nBalance '*Tao 61-07-19 TK-ISS3000-683 ถ้าติดต่อ Member Server ไม่ได้ ไม่ต้องเอาไปลบ ให้แสดงเป็นเลข 0
                        tBonusPoints = (-1) * nPoint '*Tao 61-08-09 TK-ISS3000-691 ถ้าติดต่อ Member Server ไม่ได้ ให้เอาไปลบ (กลับไปเป็นเหมือนเดิม)
                        'tTotalBonus = nBalance '*Tao 61-08-09 ของเดิม
                        tTotalBonus = (-1) * nPoint   '*Tao 61-08-09 TK-ISS3000-691 ถ้าติดต่อ Member Server ไม่ได้ ให้เอาไปลบ
                    Case Else
                        tPointBefore = nBalance
                        tBonusPoints = nPoint
                        tTotalBonus = nPoint
                End Select
                tTmp = oTransPrn.W_CHKtChangeCardID(tMemID, "0")
                tSaveID = tSaveID & tTmp & "," & tExpDate & ";"
                tSaveName = tSaveName & tName & ";"
                tSavePoint = tSavePoint & tPointBefore & "," & tBonusPoints & "," & tTotalBonus & ";"
            End If
        Else
            tExpDate = Format(Month(CDate(tExpDate)), "00") & "/" & Right(Format(Year(CDate(tExpDate)), "0000"), 2)
            tName = "New Member"
            nBalance = 0
            Select Case Val(Format(tVB_Transaction))
                Case tEN_TrnReturn, tEN_TrnDepositCancel, tEN_TrnAddDepositCancel, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
                    tPointBefore = nBalance
                    'tBonusPoints = (-1) * nPoint '*Tao 61-07-19 ของเดิม
                    'tBonusPoints = nBalance '*Tao 61-07-19 TK-ISS3000-683 ถ้าติดต่อ Member Server ไม่ได้ ไม่ต้องเอาไปลบ ให้แสดงเป็นเลข 0
                    tBonusPoints = (-1) * nPoint '*Tao 61-08-09 TK-ISS3000-691 ถ้าติดต่อ Member Server ไม่ได้ ให้เอาไปลบ (กลับไปเป็นเหมือนเดิม)
                    'tTotalBonus = nBalance '*Tao 61-08-09 ของเดิม
                    tTotalBonus = (-1) * nPoint   '*Tao 61-08-09 TK-ISS3000-691 ถ้าติดต่อ Member Server ไม่ได้ ให้เอาไปลบ
                Case Else
                    tPointBefore = nBalance
                    tBonusPoints = nPoint
                    tTotalBonus = nPoint
            End Select
            tTmp = oTransPrn.W_CHKtChangeCardID(tMemID, "0")
            tSaveID = tSaveID & tTmp & "," & tExpDate & ";"
            tSaveName = tSaveName & tName & ";"
            tSavePoint = tSavePoint & tPointBefore & "," & tBonusPoints & "," & tTotalBonus & ";"
        End If
        orsTemp.MoveNext
    Loop
    
    tSql = "UPDATE TPSTSalHD WITH(ROWLOCK)"
    tSql = tSql & vbCrLf & "SET FTCstPointName = '" & Left(tSaveID, 45) & "'"
    If Len(tSaveID) > 45 Then
        tSql = tSql & vbCrLf & ",FTShdDocRefMin = '" & Right(tSaveID, Len(tSaveID) - 45) & "'"
    Else
        tSql = tSql & vbCrLf & ",FTShdDocRefMin = '' "
    End If
    tSql = tSql & vbCrLf & ",FTCstPointName2 = '" & tSaveName & "'"
    tSql = tSql & vbCrLf & ",FTCstPointName3 = '" & tSavePoint & "'"
    tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate = '" & tUT_SaleDate & "'"
    Call SP_SQLvExecute(tSql)
    tSql = "UPDATE " & tVB_CNTblHD & " WITH(ROWLOCK)"
    tSql = tSql & vbCrLf & "SET FTCstPointName = '" & Left(tSaveID, 45) & "'"
    If Len(tSaveID) > 45 Then
        tSql = tSql & vbCrLf & ",FTShdDocRefMin = '" & Right(tSaveID, Len(tSaveID) - 45) & "'"
    Else
        tSql = tSql & vbCrLf & ",FTShdDocRefMin = '' "
    End If
    tSql = tSql & vbCrLf & ",FTCstPointName2 = '" & tSaveName & "'"
    tSql = tSql & vbCrLf & ",FTCstPointName3 = '" & tSavePoint & "'"
    tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & "AND FTShdTransNo = '" & tVB_Running & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate = '" & tUT_SaleDate & "'"
    Call SP_SQLvExecute(tSql)
    
    Exit Sub
ErrHandle:

End Sub
 
Private Function W_GETnCVQty(ByVal ptTblRC As String) As Integer
'-----------------------------------------------------------
'   Parameter :
'   Cmt :  หาจำนวณของการทอนด้วย CV
'   EXP :
'    select FCSrcAmt,FCSrcNet,FCSrcChg
'    ,* from  TPSRC00070
'    where FTTdmCode='T018'
'   File Refer :
'   Developer : BUNG
'   Date Create : 22/10/2013 :  13:12:33
'-----------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As New ADODB.Recordset
    Dim cQty As Double
    Dim cAmtCV As Double
    On Error GoTo ErrHandle
        W_GETnCVQty = 0
        tSql = "SELECT FCSrcAmt,FCSrcNet,FCSrcChg"
        tSql = tSql & vbCrLf & "FROM " & ptTblRC
        tSql = tSql & vbCrLf & "WHERE FTTdmCode = 'T018'"
        Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While (Not orsTemp.EOF)
                cQty = cQty + 1
                cAmtCV = SP_FEDvChkNumeric(orsTemp, "FCSrcChg")
                If cAmtCV > 0 Then
                    cQty = cQty + 1
                End If
                orsTemp.MoveNext
            Loop
        End If
        W_GETnCVQty = cQty
    Exit Function
ErrHandle:
    W_GETnCVQty = 0
End Function

Private Function W_GETbSalemanList() As Boolean
'______________________________________
'   Call:
'   Cmt: ตรวจสอบว่ามี Saleman ID list หรือไม่'*Eaw 56-09-06 CommSheet TK-ISS3000-240
'______________________________________
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    tSql = "SELECT FNSdtSeqNo, FTSdtSpnCode,FTSdtBarCode,FTSkuAbbName"
    tSql = tSql & "  FROM " & tVB_CNTblDT
    tSql = tSql & "  WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & "  AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & "  AND FTShdTransType='" & tVB_Transaction & "'"
    tSql = tSql & "  AND FDShdTransDate ='" & tUT_SaleDate & "'"
    tSql = tSql & "  AND FTSdtSpnCode <> ''"
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOffLine)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        W_GETbSalemanList = True
    Else
        W_GETbSalemanList = False
    End If
    Exit Function
ErrHandle:
    W_GETbSalemanList = False
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

