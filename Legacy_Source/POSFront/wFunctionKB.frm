        Exit Sub
ErrHandle:
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_AddxCloseIPVIn[3]")
End Sub

