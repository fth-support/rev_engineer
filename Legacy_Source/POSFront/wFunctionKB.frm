Private Sub W_DupTblBtwSleNHoldHD(ByVal poRs As ADODB.Recordset, ByVal ptTable$, ByVal pnSeqNo As Long, ByVal pbFrmSale As Boolean, Optional ByVal pnPdtSeq As Integer = 0) '*Tee 49-12-25 RQ0611-021 ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
