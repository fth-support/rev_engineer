    tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & " AND FDShdTransDate='" & tUT_SaleDate & "'"
'    tSql = tSql & vbCrLf & " AND ISNULL(FTShdStaCancel,'N') <> 'Y'"
    tSql = tSql & vbCrLf & " AND FTShdStaDoc = '1'"
'    tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTLogCode  = '" & tUT_LoginCode & "'" '*KT 52-01-16 ต้องมี Logcode เป้นเงื่อนไขด้วย                '*Ao 2013/08/23 TK
    'If Not pbSal Then tSql = tSql & vbCrLf & " AND FTEmpCode  = '" & tVB_CNUserCode & "'" '*KT 51-10-28
'    If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND FTEmpCode  = '" & tVB_CNUserCode & "'" '*KT 51-10-28                                        '*Ao 2013/08/23 TK
    tSql = tSql & vbCrLf & " AND " & ptTransType & " IN ("
    tSql = tSql & vbCrLf & "'" & Format(tEN_TrnDepositCancel, "00") & "'"
    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnAddDepositCancel, "00") & "'"
'    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnAddDeposit, "00") & "'" '*Eaw 56-07-29 CommSheet TK-ISS3000-287 TR-FAPL-067-00.00.03 NG.xlsx ไม่นับรวม AddDeposit ใน Rounding
    tSql = tSql & vbCrLf & ")"
    tSql = tSql & vbCrLf & " AND FCShdRnd <> 0"
