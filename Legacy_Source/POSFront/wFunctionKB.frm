    Dim tTmpVat As String
    Dim cTmpTax As Double
On Error GoTo ErrHandle
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseVatAmt[1]")
    cTmpValue = 0
    cW_GSTVat = 0 '*Eaw 56-08-28
    tTransType = IIf(bVB_TrainingMode, "FTShdTransTypeSub", "FTShdTransType")
