     W_GETbRoundBnkNote = False
    tSql = "SELECT * FROM TCNMBanknote"
    tSql = tSql & vbCrLf & "WHERE  FTBnkStaAlw='Y' AND FTBnkStaRound='Y'"
     If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then
