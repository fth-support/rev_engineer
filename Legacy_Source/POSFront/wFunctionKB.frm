                .olaBarcode.Caption = ""
                .olaSKUName.Caption = ""
                .olaPrice.Caption = ""
                .olaSumQty.Caption = ""
                .olaTSubReg.Caption = ""
                .olaTSubPro.Caption = ""
                .olaTSubTotal.Caption = ""
                With .ogdForm
                    .rows = 1
