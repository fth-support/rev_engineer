Public Sub W_AddxCloseNoSale(ByVal ptTblHD As String, ByVal ptTransType As String, ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
'-------------------------------------------------------------------------
'Call:
'Cmt: ทำการหายอด No Sale ในการออก Total Report กับ Closing Report
' *KT 51-10-30
' *KT 51-11-08
'-------------------------------------------------------------------------
        'No Sale
        Dim cQty As Double
        Dim cAmt As Double
        Dim tName As String
        Dim tSql As String
        Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseNoSale[1]")
        cQty = 0
        cAmt = 0
        tName = "Drawer Open"
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & " COUNT(" & ptTblHD & ".FTShdTransNo) AS FCNum"
        tSql = tSql & vbCrLf & " ,SUM(ISNULL(FCShdGrand,0) + ISNULL(FCShdRnd,0)) AS FCShdGrand"
        tSql = tSql & vbCrLf & " FROM " & ptTblHD
        tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND ISNULL(FTShdStaCancel,'N') <> 'Y'"
        tSql = tSql & vbCrLf & " AND FTShdStaDoc = '1'"
'        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTLogCode  = '" & tUT_LoginCode & "'" '*KT 52-01-16 ต้องมี Logcode เป้นเงื่อนไขด้วย        '*Ao 2013/08/23 TK
'        If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND FTEmpCode  = '" & tVB_CNUserCode & "'"                                                                  '*Ao 2013/08/23 TK
        tSql = tSql & vbCrLf & " AND " & ptTransType & " IN ('" & Format(tEN_TrnNoSale, "00") & "'"
        tSql = tSql & vbCrLf & ")"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND FTShdTransType  = '" & tEN_TrnTraining & "'"
        Call SP_SQLbExecute(tSql, orsTemp)
        Do While Not orsTemp.EOF
            cQty = cQty + SP_FEDvChkNumeric(orsTemp, "FCNum")
            cAmt = cAmt + SP_FEDvChkNumeric(orsTemp, "FCShdGrand")
            orsTemp.MoveNext
        Loop
        If cQty > 0 Then
            Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning)
            pnSeq = pnSeq + 1
        End If
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseNoSale[2]")
        Exit Sub
ErrHandle:
        Call SP_DATxRsNothing(orsTemp)
