Public Sub W_FindTaxDetail(ByVal ptTaxCode$)
'----------------------------------------------------------
'   Call:
'   Cmt:  finding the tax
'----------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    
    tSql = "STP_CNxGetDataTax @ptTaxCode = '" & ptTaxCode & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            If bVB_ChkRetGST7 = True Then '*Amorn 65-07-11 ถ้า bVB_ChkRetGST7 = True ให้
                '*KT 66-08-09 TTK-ISS3000-829 GST Rate for old Layaway transactions 2024
                Select Case ptTaxCode
                    Case "00"
                        cVB_SKUTaxRate = SP_FEDvChkNumeric(orsTemp, "FCTaxRate")
                    Case "01"
                        cVB_SKUTaxRate = cVB_OldGstRate
                    Case Else
                        cVB_SKUTaxRate = SP_FEDvChkNumeric(orsTemp, "FCTaxRate")
                End Select
            Else
                cVB_SKUTaxRate = SP_FEDvChkNumeric(orsTemp, "FCTaxRate")
            End If
            tVB_SKUTaxStaSign = SP_FEDtChkString(orsTemp, "FTTaxStaSign")
            tVB_SKUTaxSign = SP_FEDtChkString(orsTemp, "FTTaxSign")
        Else
            cVB_SKUTaxRate = 0
            tVB_SKUTaxStaSign = ""
            tVB_SKUTaxSign = ""
        End If
    Else
        cVB_SKUTaxRate = 0
        tVB_SKUTaxStaSign = ""
        tVB_SKUTaxSign = ""
    End If
    Call SP_DATxRsNothing(orsTemp)
End Sub

