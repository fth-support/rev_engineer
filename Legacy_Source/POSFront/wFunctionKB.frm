        End If
    
        cTempBal = cVB_Balance '*KT 54-11-15 V.4.0.4

'         nUT_SeqRC = .ogdTender.Aggregate(flexSTCount, 1, .ogdTender.ColIndex("FCSrcNet"), .ogdTender.rows - 1, .ogdTender.ColIndex("FCSrcNet")) + 1                            'เพิ่มลำดับ sequence ของ RC
         nUT_SeqRC = W_FNDnFindSeqRC(tVB_CNTblRC)                '*Ao 53-10-16    แก้ไข New Vendor ทำให้หาค่า Seq จาก Gird ไม่ได้ ต้องหาใน Database
         
         cFAmt = cVB_Balance
        'เงินทอน
         '*Eaw 56-04-29   CommSheet TK-ISS3000-105-FSBT Answer.xlsx ไม่ต้อง Rounding ก่อนเข้า Tender นี้
'        '*Ao 2012/04/02 Communication Sheet ML-PRV-080 สามารถชำระเศษสตางค์ได้
''        If cVB_Pay < CDbl(SP_FMTcCurPoint(cVB_Balance, True, False)) Then  'เงินรับ น้อยกว่า เงินที่จะต้องจ่าย(ยังค้างชำระอยู่)
'        If cVB_Pay < CDbl(SP_FMTcCurPoint(cVB_Balance - cVB_RoundRcv, True, False)) Then 'เงินรับ น้อยกว่า เงินที่จะต้องจ่าย(ยังค้างชำระอยู่)
'            cNet = cVB_Pay
''            cVB_Balance = SP_FMTcCurPoint(cVB_Balance - cVB_Pay, True, False)
'            cVB_Balance = SP_FMTcCurPoint(cVB_Balance - cVB_RoundRcv - cVB_Pay, True, False)
'            '*Ao 2012/04/02 Communication Sheet ML-PRV-080 สามารถชำระเศษสตางค์ได้
''            cVB_RoundRcv = IIf(bVB_CNAlwRnd, SP_FMTcCurPoint(UT_GetnRoundDiff(cVB_Balance), True, False), 0)    '*Eaw 56-01-04
'            cVB_Balance = SP_FMTcCurPoint(cVB_Balance + cVB_RoundRcv, True, False)
'            cVB_Change = 0
        If cVB_Pay < CDbl(SP_FMTcCurPoint(cVB_Balance, True, False)) Then
                cNet = cVB_Pay
                cVB_Balance = SP_FMTcCurPoint(cVB_Balance - cVB_Pay, True, False)
                cVB_Change = 0
'            If W_GETbRoundBnkNote(cVB_Balance) Then
'                cVB_RoundChgRC = SP_FMTcCurPoint(IIf(bVB_CNAlwRnd, SP_FMTcCurPoint(UT_GetnRoundDiff(cVB_Balance), True, True), 0), True, False)
'                cVB_Balance = 0
'                bComplete = True
'            End If
'            '------------------------------------------------------------------------------------
        Else
            cNet = cVB_Balance
            If aVB_TenderMnu(nVB_CurTenderSeqNo).StaChange Then
                cVB_Change = SP_FMTcCurPoint(cVB_Pay - cVB_Balance, True, False)
