                        .olaChange.Caption = SP_INItGetLang("ALL", "tcs_CN005028")
                        .olaChange.Visible = True
                End Select
                .Refresh
'                DoEvents '*KT 53-01-14 DoEvents
            End With
            If Not W_PRCxHandleTrnOnline(bOffline, bTranSrv) Then
                Call W_PRCxCashDrawerAct
            End If
        End If
        Call SP_UPDxSetCompleteTerminalMtn
        'เริ่ม Ticket ใหม่
