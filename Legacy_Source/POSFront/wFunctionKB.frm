                cQty = SP_FEDvChkNumeric(orsTemp, "FCNum")
                '---------------------------------------------------------------------------
                nFNDctNo = SP_FEDvChkNumeric(orsTemp, "FNDctNo")
                For nLoop = 0 To UBound(aDisIN)
                    If aDisIN(nLoop).FNDctNo = nFNDctNo Then
