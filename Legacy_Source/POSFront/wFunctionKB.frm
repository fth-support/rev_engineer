Public Function W_PRCbDelCreateVIP() As Boolean
'---------------------------------------------
'Call:
'Cmt: delete data transaction create sale vip
'-------------------------------------------
    Dim tSql$
On Error GoTo ErrHandle
     W_PRCbDelCreateVIP = False
   'delete TPSTHoldDT
    '*KT 52-04-10 ทำ VIP Create แล้วทำ VIP Service แต่ไม่แสดงรายการใดๆ (ต้องมา Copy Database แล้วเรียก VIP Service โดยใส่ Customer Id.:11111) ตามเอกสาร phase1.8 UAT status on 08-04-2009
    'delete TPSTHoldCD
    tSql = "DELETE  TPSTHoldCD"
    tSql = tSql & vbCrLf & "FROM  TPSTHoldHD INNER JOIN"
    tSql = tSql & vbCrLf & "TPSTHoldCD ON TPSTHoldHD.FTTmnNum = TPSTHoldHD.FTTmnNum "
    tSql = tSql & vbCrLf & "AND TPSTHoldHD.FTShdTransNo = TPSTHoldCD.FTShdTransNo"
    tSql = tSql & vbCrLf & "AND TPSTHoldHD.FTShdTransType = TPSTHoldCD.FTShdTransType "
    tSql = tSql & vbCrLf & "AND TPSTHoldHD.FDShdTransDate = TPSTHoldCD.FDShdTransDate"
    tSql = tSql & vbCrLf & " WHERE  TPSTHoldCD.FTShdTransType='" & Format(tEN_TrnCreateVIP, "00") & "'"
    tSql = tSql & vbCrLf & " AND TPSTHoldCD.FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND  TPSTHoldHD.FTCstVIPCode='" & tVB_CstID & "'"
    If SP_SQLvExecute(tSql, , oDB.ocnOnLine) = 0 Then 'PH 2.0.0 connect database server
        Call SP_SQLvExecute(tSql)
    Else
        W_PRCbDelCreateVIP = False
        Exit Function
    End If
    
    'delete TPSTHoldDT
    tSql = "DELETE  TPSTHoldDT"
    tSql = tSql & vbCrLf & "FROM  TPSTHoldHD INNER JOIN"
    tSql = tSql & vbCrLf & "TPSTHoldDT ON TPSTHoldHD.FTTmnNum = TPSTHoldDT.FTTmnNum "
    tSql = tSql & vbCrLf & "AND TPSTHoldHD.FTShdTransNo = TPSTHoldDT.FTShdTransNo"
    tSql = tSql & vbCrLf & "AND TPSTHoldHD.FTShdTransType = TPSTHoldDT.FTShdTransType"
    tSql = tSql & vbCrLf & "AND TPSTHoldHD.FDShdTransDate = TPSTHoldDT.FDShdTransDate"
    tSql = tSql & vbCrLf & " WHERE  TPSTHoldDT.FTShdTransType='" & Format(tEN_TrnCreateVIP, "00") & "'"
    tSql = tSql & vbCrLf & "AND TPSTHoldDT.FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND  TPSTHoldHD.FTCstVIPCode='" & tVB_CstID & "'"
    If SP_SQLvExecute(tSql, , oDB.ocnOnLine) = 0 Then 'PH 2.0.0 connect database server
        Call SP_SQLvExecute(tSql)
    Else
        W_PRCbDelCreateVIP = False
        Exit Function
    End If
    
    'delete TPSTHoldHD
    '*Eaw 56-02-19
'---------------------------------------------------------------------------------
    tSql = "UPDATE TPSTHoldHD SET"
    tSql = tSql & vbCrLf & "FTShdStaPaid ='3' ,FTSendUp='0'"
    tSql = tSql & vbCrLf & " WHERE  FTShdTransType='" & Format(tEN_TrnCreateVIP, "00") & "'"
    tSql = tSql & vbCrLf & "AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND  FTCstVIPCode='" & tVB_CstID & "'"
    If SP_SQLvExecute(tSql, , oDB.ocnOnLine) = 0 Then
        tSql = "STP_CNxSQLDelHoldHDByWhr @ptTransType ='" & Format(tEN_TrnCreateVIP, "00") & "',@ptTransDate = '" & tUT_SaleDate & "',@ptCstID ='" & tVB_CstID & "'"
        Call SP_SQLvExecute(tSql)
    Else
        W_PRCbDelCreateVIP = False
        Exit Function
    End If

'    tSql = "STP_CNxSQLDelHoldHDByWhr @ptTransType ='" & Format(tEN_TrnCreateVIP, "00") & "',@ptTransDate = '" & tUT_SaleDate & "',@ptCstID ='" & tVB_CstID & "'"
'    If SP_SQLvExecute(tSql, , oDB.ocnOnLine) = 0 Then 'PH 2.0.0 connect database server
'        Call SP_SQLvExecute(tSql)
'    Else
'        W_PRCbDelCreateVIP = False
'        Exit Function
'    End If
'------------------------------------------------------------------------------------
    W_PRCbDelCreateVIP = True
    Exit Function
