            '*KT 51-03-27 Comsheet ML-SF-141
            '-------------------------------------------------------
            If .ogdForm.TextMatrix(nSeqNo, .ogdForm.ColIndex("FTSdtCancelFlag")) = "1" Then
                Call SP_MSGnShowing("tms_CN005104", nCS_Information)
                Call SP_DATxRsNothing(orsSKU)
                Call SP_DATxRsNothing(orsTemp)
                Call SP_DATxRsNothing(orsCD)
                If bVB_CNTrStaRegPreviewDay Then
                   Call SP_INIxSwitchModePreviewDay(True)
                Else
                   Call SP_INIxSwitchModePreviewDay(False)
                End If
                Exit Sub
            End If
            '---------------------------------------------------------
            tSql = "SELECT TOP 1 * "
            tSql = tSql & " FROM " & tVB_CNTblDT
            tSql = tSql & " WHERE  FTSkuCode='" & tSKUCode & "'"
            If tWeight = "" Then  'สินค้าปกติ
                tSql = tSql & " AND  FTSdtBarCode='" & tBarC & "'"
           Else 'สินค้าน้ำหนัก
                tSql = tSql & " AND  FTSdtInstoreBar='" & tBarC & "'"
            End If
            tSql = tSql & " AND  FNSdtSeqNo =" & nSeqNo
            tSql = tSql & " AND  FTTmnNum ='" & tVB_CNTerminalNum & "'"
            tSql = tSql & " AND  FTShdTransNo ='" & tVB_Running & "'"
            tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "'"
            tSql = tSql & " AND  FDShdTransDate='" & tUT_SaleDate & "'"
            Call SP_SQLvExecute(tSql, orsSKU)
            If Not (orsSKU.BOF And orsSKU.EOF) Then
                    'Copy DB
                    For nI = 0 To orsSKU.Fields.Count - 1
                        tFed = orsSKU.Fields(nI).Name
                        tSqlF = tSqlF & tFed & ","
                        Select Case UCase(tFed)
                            Case UCase("FNSdtSeqNo"), UCase("FNSdtStaRef")
                                        tSqlV = tSqlV & SP_FEDvChkNumeric(orsSKU, tFed) + 1 & ","
                            Case UCase("FTSkuIndex")
                                        tSqlV = tSqlV & "'" & SP_VALnText2Double(SP_FEDtChkString(orsSKU, tFed)) + 1 & "'" & ","
                            Case Else
                                    Select Case UCase(Mid(tFed, 2, 1))
                                        Case "T"
                                            tSqlV = tSqlV & "'" & SP_STRtSiggleCode(SP_FEDtChkString(orsSKU, tFed)) & "'" & ","
                                        Case "D"
                                            If IsNull(orsSKU.Fields(tFed)) Then
                                                tSqlV = tSqlV & "NULL" & ","
                                            Else
                                                tSqlV = tSqlV & SP_DTEtStrSTD(SP_FEDdChkDate(orsSKU, tFed), True) & ","
                                            End If
                                        Case "N"
                                            tSqlV = tSqlV & SP_FEDvChkNumeric(orsSKU, tFed) & ","
                                        Case "C"
                                             tSqlV = tSqlV & SP_FEDvChkNumeric(orsSKU, tFed) & ","
                                    End Select
                         End Select
                    Next nI
                    
                    If CDbl(Val(Format(SP_FEDvChkNumeric(orsSKU, "FCSdtSaleAmt")))) + cUT_SubTotal > cCS_CNMaxSale Then
                        Call SP_MSGnShowing("tms_CN005170", nCS_Warning)
                        Call SP_DATxRsNothing(orsSKU)
                        Call SP_DATxRsNothing(orsTemp)
                        Call SP_DATxRsNothing(orsCD)
                        If bVB_CNTrStaRegPreviewDay Then
                           Call SP_INIxSwitchModePreviewDay(True)
                        Else
                           Call SP_INIxSwitchModePreviewDay(False)
                        End If
                        Exit Sub
                    End If
                    '*KT 53-11-01 Preview Day
                    If bVB_CNTrStaRegPreviewDay Then
                       If SP_FEDtChkString(orsSKU, "FTSdtStaPreview") = "Y" And SP_FEDtChkString(orsSKU, "FTSdtStaNotAlwPrv") <> "Y" Then
                            Call SP_INIxSwitchModePreviewDay(True)
                       Else
                            Call SP_INIxSwitchModePreviewDay(False)
                       End If
                    Else
                       Call SP_INIxSwitchModePreviewDay(False)
                    End If

                    'ตรวจสอบ Limit จำนวนสินค้าที่ซื้อจาก Max Qty ของ Member Price
                    'กรณีสินค้านั้นเป็นสินค้า Member Price แล้วเกินจำนวน Max Qty ของทั้งบิลจะไม่ยอมให้ขาย
                    cQtyDiff = CDbl(CLng(SP_FEDvChkNumeric(orsSKU, "FCSdtQty"))) '*KT 52-04-17 ให้เปลียนจาก .ValueMatrix มาใช้  .EditText กรรีต้องการค่าใน Cell เมื่อมีการการทำงานใน AfterEdit
                    bCHKPromo = False
                    If bVB_CNMemberPrice Then
                        If xVB_CNMemberP.ID <> "" And xVB_CNMemberP.MallCardMemberPrice = "Y" And SP_FEDtChkString(orsSKU, "FTSdtStaRfd") = "Y" Then
                            tSql = "SELECT FNPmpMemMaxQty"
                            tSql = tSql & vbCrLf & "FROM " & tVB_CNTblMBPrice
                            tSql = tSql & vbCrLf & "WHERE FTSkuCode = '" & tSKUCode & "'"
                            tSql = tSql & vbCrLf & "AND FDPmpMemEndDate >= '" & SP_DTEtStrSTD(SP_GETdChkDateDisc) & "'" '*KT 52-06-04 ตรวจสอบวันที่หมดอายุตามที่กำหนดใน parameter
                            tSql = tSql & vbCrLf & "AND ISNULL(FTPmpStaDiscType,'0') <> '0'"
                            If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                                If Not (orsTemp.BOF And orsTemp.EOF) Then
                                    cMemPriceMaxQty = SP_FEDvChkNumeric(orsTemp, "FNPmpMemMaxQty")
                                Else
                                     cMemPriceMaxQty = 0
                                End If
                            Else
                                cMemPriceMaxQty = 0
                            End If
                           
                            If Not (cMemPriceMaxQty = 0) Then            '*Ao 10/01/11   แก้ไขถ้าไม่จัดสินค้า MemberPrice มาให้ไม่ต้องเช็ค
                                If Not wFunctionKB.W_PRCbMaxQtyMemberPriceBySKU(tSKUCode, cQtyDiff, cMemPriceMaxQty, 0) Then
                '                    Call SP_MSGnShowing("tms_CN005071", nCS_Error)
                                     MsgBox "Max Qty Member Price", vbCritical
                                    Call SP_DATxRsNothing(orsSKU)
                                    Call SP_DATxRsNothing(orsTemp)
                                    Call SP_DATxRsNothing(orsCD)
                                    If bVB_CNTrStaRegPreviewDay Then
                                       Call SP_INIxSwitchModePreviewDay(True)
                                    Else
                                       Call SP_INIxSwitchModePreviewDay(False)
                                    End If
                                     Exit Sub
                                End If
                            Else
                                bCHKPromo = True        '*Ao 10/01/11   แก้ไขถ้าไม่จัดสินค้า MemberPrice มาให้ไม่ต้องเช็ค
                            End If
                        Else
                            bCHKPromo = True
                        End If
                    Else
                        bCHKPromo = True
                    End If
                    
                    'ตรวจสอบ Limit จำนวนสินค้าที่ซื้อจาก Max Qty ของ Promotion
                    'กรณีสินค้านั้นเป็นสินค้า Promotion แล้วเกินจำนวน Max Qty ของทั้งบิลจะไม่ยอมให้ขาย
                    If bCHKPromo Then
                        If Not wFunctionKB.W_PRCbMaxQtyPmtTimeSaleBySKU(tSKUCode, cQtyDiff) Then
                            Call SP_MSGnShowing("tms_CN005071", nCS_Error)
                            Call SP_DATxRsNothing(orsSKU)
                            Call SP_DATxRsNothing(orsTemp)
                            Call SP_DATxRsNothing(orsCD)
                            If bVB_CNTrStaRegPreviewDay Then
                               Call SP_INIxSwitchModePreviewDay(True)
                            Else
                               Call SP_INIxSwitchModePreviewDay(False)
                            End If
                            Exit Sub
                        End If
                    End If
                    
                    'ตรวจสอบ Limit จำนวนสินค้าที่ซื้อจาก Max Qty ของ Promotion
                    'กรณีสินค้านั้นเป็นสินค้า Promotion แล้วเกินจำนวน Max Qty ของทั้งบิลจะไม่ยอมให้ขาย
                    If bCHKPromo Then
                        If Not wFunctionKB.W_PRCbMaxQtyPromotionBySKU(tSKUCode, cQtyDiff) Then
                                Call SP_MSGnShowing("tms_CN005070", nCS_Error)
                                Call SP_DATxRsNothing(orsSKU)
                                Call SP_DATxRsNothing(orsTemp)
                                Call SP_DATxRsNothing(orsCD)
                                If bVB_CNTrStaRegPreviewDay Then
                                   Call SP_INIxSwitchModePreviewDay(True)
                                Else
                                   Call SP_INIxSwitchModePreviewDay(False)
                                End If
                                Exit Sub
                        End If
                    End If
                    
                    tSqlF = Left(tSqlF, Len(tSqlF) - 1)
                    tSqlV = Left(tSqlV, Len(tSqlV) - 1)
                    tSql = "INSERT INTO " & tVB_CNTblDT & "(" & tSqlF & ") VALUES (" & tSqlV & ")"
                    Call SP_SQLbExecute(tSql)
                    
                    'CD
                    '--------------------------------------------------------------------------------------------------------------------------------------------------
                    '*KT 51-12-11 Phase 2 ข้อ 13 Communication Sheet PH2-ML-SF-024 Wrong amount when press Repeat Key.xls
                    nSeqNoCD = 0
                    tSql = "SELECT  * "
                    tSql = tSql & " FROM " & tVB_CNTblCD
                    tSql = tSql & " WHERE  FTSkuCode='" & tSKUCode & "'"
                    tSql = tSql & " AND  FNSdtSeqNo =" & nSeqNo
                    tSql = tSql & " AND  FTTmnNum ='" & tVB_CNTerminalNum & "'"
                    tSql = tSql & " AND  FTShdTransNo ='" & tVB_Running & "'"
                    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "'"
                    tSql = tSql & " AND  FDShdTransDate='" & tUT_SaleDate & "'"
                    tSql = tSql & " AND  FNDctNo IN (1,2,3,4,5,6,21,22)" '*KT 52-09-07 Member + Consignment
                    Call SP_SQLvExecute(tSql, orsCD)
                    If Not (orsCD.BOF And orsCD.EOF) Then
                        tWhr = " WHERE  FTTmnNum ='" & tVB_CNTerminalNum & "'"
                        tWhr = tWhr & " AND  FTShdTransNo ='" & tVB_Running & "'"
                        tWhr = tWhr & " AND  FTShdTransType='" & tVB_Transaction & "'"
                        tWhr = tWhr & " AND  FDShdTransDate='" & tUT_SaleDate & "'"
                        nSeqNoCD = SP_VALnText2Double(Val(Format(SP_SQLtFunction("MAX", "FNScdSeqNo", tVB_CNTblCD, tWhr))))
                       Do While Not orsCD.EOF
                            'Copy DB
                            nSeqNoCD = nSeqNoCD + 1
                            tSql = "": tSqlV = "": tSqlF = "": tFed = ""
                            For nI = 0 To orsCD.Fields.Count - 1
                                tFed = orsCD.Fields(nI).Name
                                tSqlF = tSqlF & tFed & ","
                                Select Case UCase(tFed)
                                    Case UCase("FNSdtSeqNo"), UCase("FNSdtStaRef")
                                             tSqlV = tSqlV & SP_FEDvChkNumeric(orsSKU, tFed) + 1 & ","
                                    Case UCase("FNScdSeqNo"), UCase("FNScdActSeqNo")
                                             tSqlV = tSqlV & nSeqNoCD & ","
                                    Case Else
                                            Select Case UCase(Mid(tFed, 2, 1))
                                                Case "T"
                                                    tSqlV = tSqlV & "'" & SP_STRtSiggleCode(SP_FEDtChkString(orsCD, tFed)) & "'" & ","
                                                Case "D"
                                                    If IsNull(orsCD.Fields(tFed)) Then
                                                        tSqlV = tSqlV & "NULL" & ","
                                                    Else
                                                        tSqlV = tSqlV & SP_DTEtStrSTD(SP_FEDdChkDate(orsCD, tFed), True) & ","
                                                    End If
                                                Case "N"
                                                    tSqlV = tSqlV & SP_FEDvChkNumeric(orsCD, tFed) & ","
                                                Case "C"
                                                     tSqlV = tSqlV & SP_FEDvChkNumeric(orsCD, tFed) & ","
                                            End Select
                                 End Select
                            Next nI
                            
                            tSqlF = Left(tSqlF, Len(tSqlF) - 1)
                            tSqlV = Left(tSqlV, Len(tSqlV) - 1)
                            tSql = "INSERT INTO " & tVB_CNTblCD & "(" & tSqlF & ") VALUES (" & tSqlV & ")"
                            Call SP_SQLbExecute(tSql)
                            orsCD.MoveNext
                        Loop
                    End If
                    
                    '--------------------------------------------------------------------------------------------------------------------------------------------------
                    
                    'Copy Grid
                    With .ogdForm
                        If .rows = nSeqNo + 1 Then .rows = .rows + 1          '*AO51-03-20  Comm. Sheet SF-105
                        If .rows - 1 >= nUT_GridMaxRow Then                    '*Ao 51-06-18   Comm. Sheet ML-SF- 353
                            .TopRow = .rows - (nUT_GridMaxRow - 1) '.TopRow + 1
                        End If
                        For nI = 0 To .Cols - 1
                            If UCase(.ColKey(nI)) = UCase("FNSdtSeqNo") Then
                                .TextMatrix(nSeqNo + 1, nI) = CLng(Val(Format(.TextMatrix(nSeqNo, nI)))) + 1
                            Else
                                .TextMatrix(nSeqNo + 1, nI) = .TextMatrix(nSeqNo, nI)
                            End If
                        Next nI
                    End With
                    'Show Total
                    Call wMain.W_SumAmount
                    Call wMain.W_UPDxTransHD
                     nVB_CNScollItem = nSeqNo + 1 '*KT 51-12-24 Phase 2 ต้องการให้หลังจากใช้คำสั่ง Copy Sale แล้วทำ Function ที่เกี่ยวกับ Items ให้ Default ที่รายการ Item สุดท้าย
            End If
        End With
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
    Call SP_DATxRsNothing(orsSKU)
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsCD)
    If bVB_CNTrStaRegPreviewDay Then
       Call SP_INIxSwitchModePreviewDay(True)
    Else
       Call SP_INIxSwitchModePreviewDay(False)
    End If
    Exit Sub
ErrHandle:
    tSql = "DELETE " & tVB_CNTblDT
    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND   FNSdtSeqNo=" & nSeqNo + 1
    Call SP_SQLvExecute(tSql)
    tSql = "DELETE " & tVB_CNTblCD
    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND   FNSdtSeqNo=" & nSeqNo + 1
    Call SP_SQLvExecute(tSql)
    wMain.ogdForm.RemoveItem nSeqNo + 1
    If (nSeqNo + 1) <= nUT_GridMaxRow Then wMain.ogdForm.rows = nUT_GridMaxRow
    Call wMain.W_ClearValAfterInsTSDT
    Call wMain.W_SumAmount
    Call wMain.W_UPDxTransHD
    cUT_Qty = 1
    wMain.olaRef.Caption = ""
    nVB_CNScollItem = nSeqNo
    
    Call SP_DATxRsNothing(orsSKU)
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsCD)
    Exit Sub
End Sub


Public Sub W_KBCopySale()
'----------------------------------------------------------
'   Call:
'   Cmt:    '*KT 50-12-29 การทำ Copy Sale เป็นการขายดดยอ้างใบ Ticket ที่เคยก่อนหน้านี้มาแล้วโดยการ Key Terminal No กับ Transaction No
'   Req :   การเรียกข้อมูลสินค้าที่จบบิลไปแล้วมาทำการขายใหม่ - เพื่อให้พนักงานเก็บเงิน สามารถเรียกข้อมูลสินค้าที่ได้จบการขายไปแล้วกอนหน้านั้นมาทำการขายใหม่ ในกรณีที่มีการผิดพลาดในการ
'                ให้ส่วนลดหรือการชำระ
'*KT 51-11-04
'*KT 51-11-05 Copy Sale
'*KT 53-11-02 Preview Day
'----------------------------------------------------------
    Dim tSql$, tWh$, tTable$
    Dim tWhr$
    Dim nSeqNo As Long
    Dim orsTemp As ADODB.Recordset
    Dim orsSKU As ADODB.Recordset
    Dim tPLU  As String
    Dim bAccept As Boolean
    Dim nRow As Long
    Dim tWhCD As String
    Dim nSeqNoCD As Integer
    Dim orsCD As ADODB.Recordset
    Dim cDiscBHome As Double
    Dim cRegPrice  As Double
    Dim cSalPrice  As Double
    Dim tPrint As String
    Dim cSKUTaxRate As Double
    Dim tMemberPrice As String
    Dim cMemPriceAmt As Double
    Dim cB4DiscChg As Double
    Dim tMemberPriceAlw As String
    Dim tMemberPriceEvent As String '*KT 52-09-08 Member Price + Consignment
    Dim tMarkNonTax As String   '*Eaw 56-06-24 CommSheet TK-ISS3000-232-ST 00.00.01_eaw.xlsx
    Dim tCardNo As String '*Bmp 61-02-15 Token
    Dim tTokenCardNo As String
    '_______________________
    '*Ao 51-07-08
    If W_DEFbReturn Then    'การคืนแบบไม่มีเงื่อนไข ใช้ CopySale ไม่ได้
        Call SP_DATxRsNothing(orsTemp)
        Call SP_DATxRsNothing(orsCD)
        Exit Sub
    End If
    '_______________________
    
    '*KT 51-08-20 ใช้ Copy Sale กับหน้าจอ Item Emptryc ที่เป็น Transaction Sale เท่านั้น
    '---------------------------------------
    Select Case Val(Format(tVB_Transaction))
        Case tEN_TrnSale, tEN_TrnTaxExceptSale
            'non
        Case Else
            Call SP_MSGnShowing("tms_CN005107", nCS_Information)
            Call SP_DATxRsNothing(orsTemp)
            Call SP_DATxRsNothing(orsCD)
            Exit Sub
    End Select
    '---------------------------------------
    
    bAccept = W_CheckLevelPass("W_KBCopySale")
    If bAccept Then     'if level is ok
    
        tVB_CNMnuCurrent = "1806"
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
'             DoEvents  '*KT 53-01-14 DoEvents
             If tVB_CNUserAlwC = "" Then
                Call SP_DATxRsNothing(orsTemp)
                Call SP_DATxRsNothing(orsCD)
                 Exit Sub
             End If
         End If
         
        With wMain
            nRow = .ogdForm.Aggregate(flexSTMax, .ogdForm.FixedRows, .ogdForm.ColIndex("FNSdtSeqNo"), .ogdForm.rows - 1, .ogdForm.ColIndex("FNSdtSeqNo"))
            If nRow > 0 Then            'If nRow > 1 Then    '*Ao 2014/06/21
                Call SP_MSGnShowing("tms_CN005109", nCS_Warning)
                Call SP_OBJxSetFocus(wMain.otbPrompt)
                Call SP_DATxRsNothing(orsTemp)
                Call SP_DATxRsNothing(orsCD)
                Exit Sub                'if no item in grid, nothing to do
            End If
            wCNCopySale.Show vbModal
            If bVB_CpySale Then
                tWh = " WHERE  FTTmnNum='" & tVB_TerminalCpySale & "' AND FTShdTransNo='" & tVB_TransNoCpySale & "'"
                tWh = tWh & " AND  FTShdTransType='" & tVB_TransTypeCpySale & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                tTable = tVB_CNTblHD
                '*KT 51-08-14 Communication Sheet ML-SF-461 VIP sale can't copy transaction.xls
                tSql = "SELECT * FROM TPSTSalHD" & tWh
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub 'PH 2.0.0 ติดต่อฐานข้อมูล server
                If (orsTemp.BOF And orsTemp.EOF) Then Call SP_DATxRsNothing(orsTemp): Exit Sub
                Call W_DupTblBtwSleUpdHoldHD(orsTemp, tTable, , False)
                tMemberPrice = SP_FEDtChkString(orsTemp, "FTMemberPriceID")
                
                tVB_CstID = UT_tChkFieldString(orsTemp, "FTCstCode")
                tVB_SalemanID = UT_tChkFieldString(orsTemp, "FTSpnCode")
                
                '*KT 53-11-02 Preview Day
                '-------------------------INITIAL-----------------------------------------------------------------------
                Call SP_INIxSwitchModePreviewDay(False)
                Call SP_INIxClearVarPrv
                tVB_CNPreDayIDReg = SP_FEDtChkString(orsTemp, "FTPrvCardID")
                If tVB_CNPreDayIDReg <> "" Then
                    'อยู่ในช่วง Preview Day
                    If SP_CHKbPeriodPreDay Then
                        nVB_RegPreType = SP_FEDtChkString(orsTemp, "FTPrvCardType")
                        bVB_CNTrStaRegPreviewDay = True
                        Call SP_INIxSwitchModePreviewDay(True)
                        wMain.olaTransName.Caption = "Preview/" & tVB_TransName
                        Select Case nVB_RegPreType
                            Case 1 'Credit Card
                                Call SP_PRCxFindCrdByAccNum(tVB_CNPreDayIDReg)                  '*Ao 2011/01/20      CommSheet ML-UAT-PRV-030-After Recall preview transaction, price is not preview.xls
                                Call SP_GETxRecDataCrdPrv
                            Case 2 'Member Card
                                Call SP_PRCxFindMallCardRangByID(tVB_CNPreDayIDReg)         '*Ao 2011/01/20         หาค่าเก็บไว้ก่อน
                                Call SP_GETxRecDataMallPrv
                            Case 3 'None Card
                                Call SP_PRCxFindNonCardRangByID(tVB_CNPreDayIDReg)          '*Ao 2011/01/20
                                Call SP_GETxRecDataMallPrv
                        End Select
                        If Not SP_UPDbPreviewDayHD Then 'บันทึกข้อมูล Preview Day ลงตาราง HD
                            Call SP_MSGnShowing("tms_CN005221", nCS_Warning)
                            Call SP_INIxSwitchModePreviewDay(False)
                            Call SP_INIxClearVarPrv
                            wMain.olaTransName.Caption = tVB_TransName
                        End If
                    End If
                End If
                '-------------------------END INITIAL---------------------------------------------------------------------
                
                'ก่อนการ Insert data to dt ให้ทำการลบ dt ก่อนเพื่อความแน่ใจ
                tSql = "DELETE " & tVB_CNTblDT
                tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                Call SP_SQLbExecute(tSql)
                
                'insert to DT
                tWhCD = tWh
                tWh = tWh & " AND NOT(FTSdtCancelFlag='1') "                '*AO 51-04-01   Comm.Sheet  ML-SF-174     ไม่เอา Item ที่ยกเลิก
                '*KT 51-08-14 Communication Sheet ML-SF-461 VIP sale can't copy transaction.xls
                tSql = "SELECT * FROM TPSTSalDT" & tWh
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub 'PH 2.0.0 ติดต่อฐานข้อมูล server
                nSeqNo = 1
                nSeqNoCD = 1
                If Not (orsTemp.BOF And orsTemp.EOF) Then orsTemp.MoveFirst
                Do While Not orsTemp.EOF
                     'CD
                     '*KT 51-08-14 Communication Sheet ML-SF-461 VIP sale can't copy transaction.xls
                     tSql = "SELECT * FROM TPSTSalCD" & tWhCD                   '*Ao 51-04-21     แก้ให้บันทึก CD ด้วย
                     tSql = tSql & " AND FNSdtSeqNo= " & SP_FEDvChkNumeric(orsTemp, "FNSdtSeqNo")
                     tSql = tSql & " AND FTSkuCode='" & SP_FEDtChkString(orsTemp, "FTSkuCode") & "'"
                     '*KT 51-08-01 ML-SF-406
                     '------------------------------------------------------------------------
