'Public Function W_PRCbUpdTmpVoucher(ByRef pTran As Boolean) As Boolean
Public Function W_PRCbUpdTmpVoucher() As Boolean
'-------------------------------------------------------------------
'Call:
'Cmt: ทำการปรับเฟกเพื่อให้รู้ว่าใบ Ticket ที่มีการอ้างอิงการทำ Voucher  ว่ามีการยกเลิก
'---------------------------------------------------------------------
    Dim tSql$
    Dim bPass1 As Boolean
'    Dim bPass2 As Boolean
    Dim nEff As Long
    
On Error GoTo ErrHandle
    bPass1 = False
    ocnAll.BeginTrans
    bPass1 = True
    nVB_CNCountBegin = nVB_CNCountBegin + 1
'    bPass2 = False
'    If Not oDB.ocnOnLine Is Nothing And oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
'        If Not pTran Then
'            oDB.ocnOnLine.BeginTrans
'            pTran = True
'        End If
'    End If
'    bPass2 = pTran
    Select Case Val(Format(tVB_TransactionSub))
        Case tEN_TrnCancelVoucher
             tSql = "UPDATE TPSTVoucherHD"
            tSql = tSql & " SET FTShdStaCancel = 'Y'"
            tSql = tSql & " WHERE  FTTmnNum='" & tVB_CancelTmnNumRef & "' AND FTShdTransNo='" & tVB_CancelTransNoRef & "'"
            tSql = tSql & " AND  FTShdTransType='" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnVoucher, "00")) & "' AND FDShdTransDate='" & SP_DTEtStrSTD(dVB_CancelTransDateRef) & "'"
            nEff = 0
            If SP_SQLvExecute(tSql, , oDB.ocnOnLine, , , nEff) <> 0 Then 'PH 2.0.0 ติดต่อฐานข้อมูล server
                 'เกิด offline ขึ้น
                 If nEff < 1 Then
                     W_PRCbUpdTmpVoucher = False
'                     If bPass2 Then oDB.ocnOnLine.RollbackTrans: bPass2 = False: pTran = False
                     If bPass1 Then
                        ocnAll.RollbackTrans
                        bPass1 = False
                        nVB_CNCountBegin = nVB_CNCountBegin - 1
                     End If
                     Exit Function
                 End If
            End If
            Call SP_SQLvExecute(tSql)
            
            tSql = "UPDATE TPSTSalHD"
            tSql = tSql & " SET FTShdStaCancel = 'Y'"
            tSql = tSql & " WHERE  FTTmnNum='" & tVB_CancelTmnNumRef & "' AND FTShdTransNo='" & tVB_CancelTransNoRef & "'"
            tSql = tSql & " AND  FTShdTransType='" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnVoucher, "00")) & "' AND FDShdTransDate='" & SP_DTEtStrSTD(dVB_CancelTransDateRef) & "'"
            Call SP_SQLvExecute(tSql, , oDB.ocnOnLine)
            Call SP_SQLvExecute(tSql)
            
            tSql = "UPDATE " & tVB_CNTblHD
            tSql = tSql & " SET FTShdStaCancel = 'Y'"
            tSql = tSql & " WHERE  FTTmnNum='" & tVB_CancelTmnNumRef & "' AND FTShdTransNo='" & tVB_CancelTransNoRef & "'"
            tSql = tSql & " AND  FTShdTransType='" & IIf(bVB_TrainingMode, Format(tEN_TrnTraining, "00"), Format(tEN_TrnVoucher, "00")) & "' AND FDShdTransDate='" & SP_DTEtStrSTD(dVB_CancelTransDateRef) & "'"
            Call SP_SQLvExecute(tSql)
    End Select
'    If bPass2 Then oDB.ocnOnLine.CommitTrans: pTran = False
    If bPass1 Then
        ocnAll.CommitTrans
        bPass1 = False
        nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    W_PRCbUpdTmpVoucher = True
    Exit Function
ErrHandle:
    W_PRCbUpdTmpVoucher = False
'    If bPass2 Then oDB.ocnOnLine.RollbackTrans: pTran = False
    If bPass1 Then
