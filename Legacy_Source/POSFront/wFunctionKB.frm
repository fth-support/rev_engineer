Private Function W_GETcDiscAftAddDeposit(ByVal ptTmnNo$, ByVal ptTrnNo$, ByVal pdTrnDate As Date) As Double
'__________________________
'   Call:
'   Cmt:   Summary ส่วนลดที่เป็นประเภทท้ายบิลของ Deposit และ Add Deposit
'__________________________
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    W_GETcDiscAftAddDeposit = 0
    tSql = "SELECT     SUM(TPSTDepositCD.FCScdAmt) AS FCSUM"
    tSql = tSql & vbCrLf & "FROM TPSTDepositHD INNER JOIN"
    tSql = tSql & vbCrLf & "TPSTDepositCD ON  TPSTDepositHD.FTTmnNum = TPSTDepositCD.FTTmnNum AND"
    tSql = tSql & vbCrLf & "TPSTDepositHD.FTShdTransNo = TPSTDepositCD.FTShdTransNo And TPSTDepositHD.FDShdTransDate = TPSTDepositCD.FDShdTransDate"
    tSql = tSql & vbCrLf & "WHERE TPSTDepositCD.FNDctNo IN (" & nEN_Disc07AutoTran
    tSql = tSql & vbCrLf & "," & nEN_Disc08MallCpn
    tSql = tSql & vbCrLf & "," & nEN_Disc09CoopCpn
    tSql = tSql & vbCrLf & "," & nEN_Disc10CoopBrand
    tSql = tSql & vbCrLf & "," & nEN_Disc11MallCrd
    tSql = tSql & vbCrLf & "," & nEN_Disc12EmpCrd
    tSql = tSql & vbCrLf & "," & nEN_Disc13TranDisc
    tSql = tSql & vbCrLf & "," & nEN_Disc14TranMDown
    tSql = tSql & vbCrLf & "," & nEN_Disc15Ontop
    tSql = tSql & vbCrLf & "," & nEN_Disc16FreeGift
    tSql = tSql & vbCrLf & "," & nEN_Disc20Special
    tSql = tSql & vbCrLf & "," & nEN_Disc23TranMDown1  '*KT 54-07-01 V.4.0.0 Req.18 Add 5 Types of TransMarkdow
    tSql = tSql & vbCrLf & "," & nEN_Disc24TranMDown2
    tSql = tSql & vbCrLf & "," & nEN_Disc25TranMDown3
    tSql = tSql & vbCrLf & "," & nEN_Disc26TranMDown4
    tSql = tSql & vbCrLf & "," & nEN_Disc27TranMDown5
    tSql = tSql & vbCrLf & ")"
    tSql = tSql & vbCrLf & "AND  (TPSTDepositHD.FTShdTransNo = '" & ptTrnNo & "') AND (TPSTDepositCD.FTTmnNum = '" & ptTmnNo & "') AND"
    tSql = tSql & vbCrLf & "(TPSTDepositHD.FDShdTransDate = '" & Format(pdTrnDate, "yyyy/mm/dd") & "')"
    tSql = tSql & vbCrLf & "AND ISNULL(FTShdStaCancel,'N') <> 'Y'"
    tSql = tSql & vbCrLf & "AND  ISNULL(TPSTDepositCD.FTSdtStkCode,'') <> '1'" '*KT 52-11-25 Deal&Promo
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) 'ติดต่อฐานข้อมูล server เท่านั้น
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        W_GETcDiscAftAddDeposit = SP_FEDvChkNumeric(orsTemp, "FCSUM")
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    Call SP_DATxRsNothing(orsTemp)
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Function

Private Function W_GETtTaxDesc(ByVal ptTaxCode$) As String
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHadle
    tSql = "SELECT FTTaxDesc "
    tSql = tSql & vbCrLf & "FROM TCNMTaxMtn"
    tSql = tSql & vbCrLf & "WHERE FTTaxCode ='" & ptTaxCode & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then  'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            Select Case ptTaxCode
                Case "01"
                    W_GETtTaxDesc = "Taxable"
                Case Else
                    W_GETtTaxDesc = SP_FEDtChkString(orsTemp, "FTTaxDesc")
            End Select
        Else
            W_GETtTaxDesc = ""
        End If
    Else
        W_GETtTaxDesc = ""
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHadle:
    W_GETtTaxDesc = ""
    Call SP_DATxRsNothing(orsTemp)
End Function


Private Function W_GETcSumAmtForTaxExcept(ByVal ptTblHD$, ptTblDT$, pbSal As Boolean, ptTransType$, Optional ByVal pbCloseTmn As Boolean = False) As Double
'---------------------------------------------------------------------------------------------------
'Call:
'Cmt: *KT 51-09-2008 เก็บมูลค่ารวมของ Tax except sale
''*KT 51-10-28
'--------------------------------------------------------------------------------------------------
        Dim orsTemp As ADODB.Recordset
        Dim tSql$
On Error GoTo ErrHandle
        tSql = ""
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & " ROUND(SUM("
       '*KT 51-09-20 ML-SF-552 ต้องยอดที่หักเฉพาะ Deal,Promo,Promo Time
       '---------------------------------------------------------------------
        If bVB_CNAlwBeOrAftDisc Then
               'คิดคำนวณกรณีก่อนลดส่วนลด
            If tVB_CNDiscPrcAftDisc = "0" Then
                tSql = tSql & vbCrLf & "CASE WHEN " & ptTblDT & ".FTTaxCode = '00' "
                tSql = tSql & vbCrLf & "             THEN "
                tSql = tSql & vbCrLf & "                  " & ptTblDT & ".FCSdtSaleUnit  * " & ptTblDT & ".FCSdtQty "
                tSql = tSql & vbCrLf & "              ELSE "
                tSql = tSql & vbCrLf & "                     ((" & ptTblDT & ".FCSdtSaleUnit * " & ptTblDT & ".FCSdtQty)  - ((" & ptTblDT & ".FCSdtSaleUnit * " & ptTblDT & ".FCSdtQty) * " & ptTblDT & ".FCSdtTax /(100+" & ptTblDT & ".FCSdtTax))) "
                tSql = tSql & vbCrLf & "              END"
                tSql = tSql & vbCrLf & "),2) AS FCSaleVatAmt"
            Else
                'คิดคำนวณกรณีหลังลดส่วนลด
                tSql = tSql & vbCrLf & "CASE WHEN " & ptTblDT & ".FTTaxCode = '00' "
                tSql = tSql & vbCrLf & "             THEN "
                tSql = tSql & vbCrLf & "                  " & ptTblDT & ".FCSdtSaleAmt"
                tSql = tSql & vbCrLf & "              ELSE "
                tSql = tSql & vbCrLf & "                     ((" & ptTblDT & ".FCSdtSaleAmt)  - ((" & ptTblDT & ".FCSdtSaleAmt) * " & ptTblDT & ".FCSdtTax /(100+" & ptTblDT & ".FCSdtTax))) "
                tSql = tSql & vbCrLf & "              END"
                tSql = tSql & vbCrLf & "),2) AS FCSaleVatAmt"
            End If
        Else
                'คิดคำนวณกรณีหลังลดส่วนลด
                tSql = tSql & vbCrLf & "CASE WHEN " & ptTblDT & ".FTTaxCode = '00' "
                tSql = tSql & vbCrLf & "             THEN "
                tSql = tSql & vbCrLf & "                  " & ptTblDT & ".FCSdtSaleAmt"
                tSql = tSql & vbCrLf & "              ELSE "
                tSql = tSql & vbCrLf & "                     ((" & ptTblDT & ".FCSdtSaleAmt)  - ((" & ptTblDT & ".FCSdtSaleAmt) * " & ptTblDT & ".FCSdtTax /(100+" & ptTblDT & ".FCSdtTax))) "
                tSql = tSql & vbCrLf & "              END"
                tSql = tSql & vbCrLf & "),2)  AS FCSaleVatAmt"
        End If
        '------------------------------------------------------------------------
        tSql = tSql & vbCrLf & " FROM  " & ptTblHD & " INNER JOIN"
        tSql = tSql & vbCrLf & "" & ptTblDT & " ON " & ptTblHD & ".FTTmnNum = " & ptTblDT & ".FTTmnNum AND"
        tSql = tSql & vbCrLf & "" & ptTblHD & ".FTShdTransNo = " & ptTblDT & ".FTShdTransNo And " & ptTblHD & ".FDShdTransDate = " & ptTblDT & ".FDShdTransDate"
        tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND ISNULL(" & ptTblHD & ".FTShdStaCancel,'N') <> 'Y'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdStaDoc = '1'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdStaPrcDoc = '1'" 'กรณีที่ใบ Deposit ทำการ Redeem แล้วถึงนำมารวมกับ SQL นี้
'        If Not pbSal Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTEmpCode  = '" & tVB_CNUserCode & "'"
        If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTEmpCode  = '" & tVB_CNUserCode & "'" '*KT 51-10-28
        tSql = tSql & vbCrLf & " AND " & ptTblHD & "." & ptTransType & " IN ('" & Format(tEN_TrnTaxExceptSale, "00") & "'"
        tSql = tSql & vbCrLf & ")"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdTransType  = '" & tEN_TrnTraining & "'"
        tSql = tSql & vbCrLf & " AND ISNULL(" & ptTblDT & ".FTSdtCancelFlag,'0') <> '1'" 'ไม่นับรายการ Items ที่ Cancel
        Call SP_SQLvExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            W_GETcSumAmtForTaxExcept = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCSaleVatAmt"), True, False)
        Else
            W_GETcSumAmtForTaxExcept = 0
        End If
        Call SP_DATxRsNothing(orsTemp)
        Exit Function
ErrHandle:
       W_GETcSumAmtForTaxExcept = 0
       Call SP_DATxRsNothing(orsTemp)
End Function


