                wCNTDisc.Show vbModal
'                If cVB_DiscLineItem = 0 Then Call SP_DATxRsNothing(orsTemp):   Exit Sub                '*Ao 2013/03/18  TK
                If cVB_DiscLineItem = 0 Then
                    Call SP_DATxRsNothing(orsTemp)
                    tSql = "SELECT * FROM " & tVB_CNTblDT
