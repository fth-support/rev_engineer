On Error GoTo ErrHandle
   Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseSaleAmt[1]")
    tTransType = IIf(bVB_TrainingMode, "FTShdTransTypeSub", "FTShdTransType")
