Public Function W_PRCxUpdCouponSta()
'----------------------------------------------------------------------------
'call:
'cmt: Update status ของ coupon ให้เป็น 4 เมื่อถูกใช้งานแล้ว '*Eaw 56-05-08 CommSheet TK-ISS3000-179-ST 00 00 01.xls
  '---------------------------------------------------------------------------
On Error GoTo ErrHandle
Dim tSql As String
    
    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " tVB_Transaction:" & tVB_Transaction) & "wFunctionKB-W_PRCxUpdCouponSta:FTCVStatusCode = '4'" & ",FTCVNum='" & tVB_CouponNo & "'") '*Bump 63-02-18 Log-ComSheet719,756
    
    tSql = "UPDATE TPSTCV  WITH(ROWLOCK)  SET FTCVStatusCode = '4'"
'    tSql = tSql & vbCrLf & ",FTCVCashierID =  '" & tVB_CNUserCode & "'"
    tSql = tSql & vbCrLf & ",FDCVPickupdate =  '" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & ",FTSendUp =  '0'"
    tSql = tSql & vbCrLf & ",FCCVBalAmt =  0"
    tSql = tSql & vbCrLf & ",FDDateUpd = '" & UT_tStringDate(Date) & "' "
    tSql = tSql & vbCrLf & ",FTTimeUpd = '" & Format(Time, "HH:MM:SS") & "' "
    tSql = tSql & vbCrLf & ",FTWhoUpd = '" & tVB_CNUserName & "' "
'    tSql = tSql & vbCrLf & ",FTPOSNo = '" & tVB_CNTerminalNum & "' "
'    tSql = tSql & vbCrLf & ",FTTransNo = '" & tVB_Running & "' "
'    tSql = tSql & vbCrLf & ",FTTransType = '" & tVB_Transaction & "' "       '*Ao 2014/10/20   eCoupon  V 4.2.152
    tSql = tSql & vbCrLf & " WHERE FTCVFlag = '1' AND FTCVNum='" & tVB_CouponNo & "'"
    '*FTCVFlag = '1' คือ Coupon
    '*FTCVFlag = '0' คือ Credit Voucher
    Call SP_SQLvExecute(tSql, , oDB.ocnOnLine, , , , , True, True)
    Exit Function
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxLogMallCardExtend(("Date:" & Date & " Time:" & Time$ & " tVB_Transaction:" & tVB_Transaction) & "wFunctionKB-W_PRCxUpdCouponSta:FTCVStatusCode = '4'" & ",Err='" & Err.Number & ",ErrDesc:" * Err.Description & "'") '*Bump 63-02-18 Log-ComSheet719,756
