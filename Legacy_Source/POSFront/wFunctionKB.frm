    tSql = tSql & vbCrLf & " AND " & ptTransType & " IN ("
    If bVB_ReEntryMode Then
        Select Case tVB_CNMnuCurrent
            Case "172003", "172005"
                 tSql = tSql & vbCrLf & "'" & Format(tEN_TrnSaleTaxInc, "00") & "'"                         '*Ao 2013/08/14 CommSheet TK-ISS3000-312-313 -UAT-FAPL-089.xlsx
'                 tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'"
            Case "172103", "172105"
