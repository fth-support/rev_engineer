                    tWhe = tWhe & "," & nEN_Disc23TranMDown1  '*KT 54-07-01 V.4.0.0 Req.18 Add 5 Types of TransMarkdow
                    tWhe = tWhe & "," & nEN_Disc24TranMDown2
                    tWhe = tWhe & "," & nEN_Disc25TranMDown3
