'        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, nPdtSeq) '*KT 51-12-15 Phase 2 ข้อ 27 Communication Sheet PH2-ML-SF-028 Sale amount incorrect when Recall Transaction.xls
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True)
        orsTemp.MoveNext
    Loop
    
    tTable = "TPSTHoldCD"
    tSql = "SELECT * FROM " & tVB_CNTblCD
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub
    nPdtSeq = 0
    Do While Not orsTemp.EOF
'        nPdtSeq = nPdtSeq + 1            'ทำให้ return แล้ว ต้องไม่มีรายการยกเลิก
'        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, nPdtSeq) '*KT 51-12-15 Phase 2 ข้อ 27 Communication Sheet PH2-ML-SF-028 Sale amount incorrect when Recall Transaction.xls
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True)
        orsTemp.MoveNext
    Loop
    '______________________________________________________________
    '*Ao 2010/11/05
    tTable = "TPSTHoldRC"
    tSql = "SELECT * FROM " & tVB_CNTblRC
    tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
    tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub
    Do While Not orsTemp.EOF
'        nPdtSeq = nPdtSeq + 1
'        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True, nPdtSeq) '*KT 51-12-15 Phase 2 ข้อ 27 Communication Sheet PH2-ML-SF-028 Sale amount incorrect when Recall Transaction.xls
        Call W_DupTblBtwSleNHold(orsTemp, tTable, 1, True)
        orsTemp.MoveNext
    Loop
    '______________________________________________________________
    
    
'*KT 51-10-24 V 3.0.141/V 3.0.200
'-----------------------------------------------------------
     Call SP_UPDxSetCompleteTerminalMtn
'------------------------------------------------------------
    tVB_Transaction = aVB_TransMode(2).ID
    tVB_TransactionSub = tVB_Transaction
    tVB_TransName = aVB_TransMode(2).Name
    tVB_TransNameABB = aVB_NameAbb(tEN_AbbSale - 1).UsrLangPri & ";" & aVB_NameAbb(tEN_AbbSale - 1).UsrLangSec
