        '   '1'  คือ CV ที่ Issue
        '   '2'  คือ CV ที่ Pickup แล้วมี Re-Issue
        '-------------------------------------------------------------
'        tSql = "SELECT  "
'        tSql = tSql & vbCrLf & "  SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'')='2'  OR ISNULL(" & ptTblHD & ".FTCVNum,'')='1' THEN 1 ELSE 0 END ) AS FCNum"
''        tSql = tSql & vbCrLf & " ,SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'')='2'  OR ISNULL(" & ptTblHD & ".FTCVNum,'')='1'  THEN  ISNULL(FCShdGrand,0) + ISNULL(FCShdRnd,0) ELSE 0 END) AS FCShdGrand"
'        tSql = tSql & vbCrLf & " ,SUM((CASE WHEN ISNULL(FTCVNUM,'') = '1' THEN FCShdGrand ELSE (CASE WHEN ISNULL(FTCVNUM,'') = '2'   THEN FCShdChn END)END)) AS FCShdGrand"  '*Eaw 56-06-24  CommSheet TK-ISS3000-FAPL-031.xls
'        tSql = tSql & vbCrLf & " ,SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'')='3' THEN 1 ELSE 0 END ) AS FCNum2"
'        tSql = tSql & vbCrLf & " ,SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'')='3' THEN  ISNULL(FCShdGrand,0) + ISNULL(FCShdRnd,0) ELSE 0 END) AS FCShdGrand2"
'       ' tSql = tSql & vbCrLf & " ,SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'')='0' OR ISNULL(" & ptTblHD & ".FTCVNum,'')='2'  THEN 1 ELSE 0 END ) AS FCNum3"
'       ' tSql = tSql & vbCrLf & " ,SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'')='0' OR ISNULL(" & ptTblHD & ".FTCVNum,'')='2'  THEN  ISNULL(FCShdGrand,0) + ISNULL(FCShdRnd,0) ELSE 0 END) AS FCShdGrand3"
'        tSql = tSql & vbCrLf & " FROM " & ptTblHD
'        tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
'        tSql = tSql & vbCrLf & " AND FDShdTransDate='" & tUT_SaleDate & "'"
'       ' tSql = tSql & vbCrLf & " AND ISNULL(FTShdStaCancel,'N') <> 'Y'"
'        tSql = tSql & vbCrLf & " AND FTShdStaDoc = '1'"
''        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTLogCode  = '" & tUT_LoginCode & "'" '*KT 52-01-16 ต้องมี Logcode เป้นเงื่อนไขด้วย        '*Ao 2013/08/23 TK
''        If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND FTEmpCode  = '" & tVB_CNUserCode & "'"                                                              '*Ao 2013/08/23 TK
'        'tSql = tSql & vbCrLf & " AND " & ptTransType & " IN ('" & Format(tEN_TrnNoSale, "00") & "'"
'        'tSql = tSql & vbCrLf & ")"
'        If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND FTShdTransType  = '" & tEN_TrnTraining & "'"
        '-------------------------------------------------
        '*Ao 2013/09/10
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & "SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'') = '1' OR ISNULL(" & ptTblHD & ".FTCVNum,'') = '2' THEN 1 ELSE 0 END ) AS FCNum"
        tSql = tSql & vbCrLf & "FROM " & ptTblHD
        tSql = tSql & vbCrLf & "WHERE " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdStaDoc = '1'"
        tSql = tSql & vbCrLf & "AND (ISNULL(" & ptTblHD & ".FTCVNum,'') = '1' OR ISNULL(" & ptTblHD & ".FTCVNum,'') = '2')"
        If bVB_ReEntryMode Then
            Select Case tVB_CNMnuCurrent
                Case "172003", "172005"
                    tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdTransType IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "'"
                    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'"
                Case "172103", "172105"
                    tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdTransType IN ('" & Format(tEN_TrnSaleManualTax, "00") & "'"
                    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnManualTax, "00") & "'"
            End Select
        Else
            tSql = tSql & vbCrLf & "AND NOT (" & ptTblHD & "." & ptTransType & " IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnSaleManualTax, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnManualTax, "00") & "')"
        End If
        tSql = tSql & vbCrLf & ")"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdTransType  = '" & tEN_TrnTraining & "'"
        cQty = 0
        Call SP_SQLbExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                cQty = cQty + SP_FEDvChkNumeric(orsTemp, "FCNum")
                orsTemp.MoveNext
            Loop
        End If
        Call SP_DATxRsClose(orsTemp)
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & "SUM(CASE WHEN ISNULL(" & ptTblHD & ".FTCVNum,'') = '1'"
        tSql = tSql & vbCrLf & "THEN " & ptTblRC & ".FCSrcNet ELSE " & ptTblRC & ".FCSrcChg END) AS FCIssue"
        tSql = tSql & vbCrLf & "FROM " & ptTblHD & " INNER JOIN"
        tSql = tSql & vbCrLf & ptTblRC & " ON " & ptTblHD & ".FTTmnNum = " & ptTblRC & ".FTTmnNum AND " & ptTblHD & ".FTShdTransNo = " & ptTblRC & ".FTShdTransNo AND"
        tSql = tSql & vbCrLf & ptTblHD & ".FTShdTransType = " & ptTblRC & ".FTShdTransType AND " & ptTblHD & ".FDShdTransDate = " & ptTblRC & ".FDShdTransDate"
        tSql = tSql & vbCrLf & "WHERE " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdStaDoc = '1'"
        tSql = tSql & vbCrLf & "AND (ISNULL(" & ptTblHD & ".FTCVNum,'') = '1' OR ISNULL(" & ptTblHD & ".FTCVNum,'') = '2')"
        If bVB_ReEntryMode Then
            Select Case tVB_CNMnuCurrent
                Case "172003", "172005"
                    tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdTransType IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "'"
                    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'"
                Case "172103", "172105"
                    tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdTransType IN ('" & Format(tEN_TrnSaleManualTax, "00") & "'"
                    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnManualTax, "00") & "'"
            End Select
        Else
            tSql = tSql & vbCrLf & "AND NOT (" & ptTblHD & "." & ptTransType & " IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnSaleManualTax, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnManualTax, "00") & "')"
        End If
        tSql = tSql & vbCrLf & ")"
        tSql = tSql & vbCrLf & "AND " & ptTblRC & ".FTTdmCode = 'T018'"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & "AND " & ptTblHD & ".FTShdTransType  = '" & tEN_TrnTraining & "'"
        cAmt = 0
        '----------------------------------------------------------------------------
        Call SP_SQLbExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            orsTemp.MoveFirst
            Do While Not orsTemp.EOF
                cAmt = cAmt + SP_FEDvChkNumeric(orsTemp, "FCIssue")
                orsTemp.MoveNext
            Loop
        End If
        cQty2 = 0                       '*Ao 2013/09/10   ไม่มี CV Cancel
        cAmt2 = 0
        'TK-ISS3000-127 Close report summary CV wrong
        Call SP_DATxRsClose(orsTemp)
        tSql = "SELECT  "
        tSql = tSql & vbCrLf & "  COUNT(" & ptTblRC & ".FTTdmCode)  AS FCNum"
'        tSql = tSql & vbCrLf & " ,SUM(" & ptTblRC & ".FCSrcNet) AS FCShdGrand"
        tSql = tSql & vbCrLf & " ,SUM(" & ptTblRC & ".FCSrcAmt) AS FCShdGrand"  '*Eaw 56-06-24 ใบที่ Pickup ให้มองที่บอดของ CV ไม่ใช่ยอดที่จ่าย CommSheet TK-ISS3000-FAPL-031.xls
        tSql = tSql & vbCrLf & " FROM  " & ptTblHD & " INNER JOIN"
        tSql = tSql & vbCrLf & "              " & ptTblRC & " ON " & ptTblHD & ".FTTmnNum = " & ptTblRC & ".FTTmnNum AND " & ptTblHD & ".FTShdTransNo = " & ptTblRC & ".FTShdTransNo AND"
        tSql = tSql & vbCrLf & "              " & ptTblHD & ".FTShdTransType = " & ptTblRC & ".FTShdTransType AND " & ptTblHD & ".FDShdTransDate = " & ptTblRC & ".FDShdTransDate"
        tSql = tSql & vbCrLf & " WHERE  " & ptTblHD & ".FTTmnNum='" & tVB_CNTerminalNum & "'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdStaDoc = '1'"
'        tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTLogCode  = '" & tUT_LoginCode & "'" '*KT 52-01-16 ต้องมี Logcode เป้นเงื่อนไขด้วย        '*Ao 2013/08/23 TK
'        If Not pbCloseTmn Then tSql = tSql & vbCrLf & " AND FTEmpCode  = '" & tVB_CNUserCode & "'"                                                              '*Ao 2013/08/23 TK
        tSql = tSql & vbCrLf & " AND " & ptTblRC & ".FTTdmCode='T018'"
        If bVB_ReEntryMode Then
            Select Case tVB_CNMnuCurrent
                Case "172003", "172005"
                    tSql = tSql & vbCrLf & "  AND " & ptTblHD & ".FTShdTransType IN ('" & Format(tEN_TrnSaleTaxInc, "00") & "'"
    '                    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnTaxInc, "00") & "'" '*Eaw 56-07-24 มอง pickup เมื่อจ่าย(sale)เท่านั้น CommSheet TK-ISS3000-282-TR.xls
                Case "172103", "172105"
                   tSql = tSql & vbCrLf & "  AND " & ptTblHD & ".FTShdTransType IN ('" & Format(tEN_TrnSaleManualTax, "00") & "'"
    '                    tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnReturnManualTax, "00") & "'" '*Eaw 56-07-24 มอง pickup เมื่อจ่าย(sale)เท่านั้น CommSheet TK-ISS3000-282-TR.xls
                Case Else
                    'none
            End Select
        Else
            tSql = tSql & vbCrLf & " AND " & ptTblHD & "." & ptTransType & " IN ('" & Format(tEN_TrnSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnDeposit, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnRedeem, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnVIPSale, "00") & "'"
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnDutyFreeSale, "00") & "'" '*KT 51-10-21 V 3.0.140/V 3.0.200 เพิ่มรายการ Duty Free Sale
            tSql = tSql & vbCrLf & ",'" & Format(tEN_TrnAddDeposit, "00") & "'"
        End If
        tSql = tSql & vbCrLf & ")"
        If bVB_TrainingMode Then tSql = tSql & vbCrLf & " AND " & ptTblHD & ".FTShdTransType  = '" & tEN_TrnTraining & "'"
        Call SP_SQLbExecute(tSql, orsTemp)
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            cQty3 = cQty3 + SP_FEDvChkNumeric(orsTemp, "FCNum")
            cAmt3 = cAmt3 + SP_FEDvChkNumeric(orsTemp, "FCShdGrand")
        End If
        
        If cQty > 0 Then
            Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning)
            pnSeq = pnSeq + 1
        End If
        If cQty2 > 0 Then
            Call W_AddxDataPrintClosingOther(cQty2, tName2, SP_FMTcCurPoint(cAmt2, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning)
            pnSeq = pnSeq + 1
        End If
        If cQty3 > 0 Then
            Call W_AddxDataPrintClosingOther(cQty3, tName3, SP_FMTcCurPoint(cAmt3, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning)
            pnSeq = pnSeq + 1
        End If
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxCloseCV[2]")
        Exit Sub
ErrHandle:
        Call SP_DATxRsNothing(orsTemp)
        Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_AddxCloseCV[3]")
End Sub


Public Sub W_AddxCloseIPVIn(ByVal ptTblHD As String, ByVal ptTransType As String, ByRef pnSeq As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
