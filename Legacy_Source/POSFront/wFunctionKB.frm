Public Function W_FNDnFindSeqRC(ByVal ptTableRC As String) As Integer
'----------------------------------------------------------
'   Call:
'   Cmt:
'----------------------------------------------------------
Dim tWhe As String
Dim nSeqRC As Integer

    tWhe = "WHERE   FTTmnNum = '" & tVB_CNTerminalNum & "'"                 '*Ao 53-10-16    แก้ไข New Vendor ทำให้หาค่า Seq จาก Gird ไม่ได้ ต้องหาใน Database
    tWhe = tWhe & " AND FTShdTransNo = '" & tVB_Running & "'"
    tWhe = tWhe & " AND FTShdTransType = '" & tVB_Transaction & "'"
    tWhe = tWhe & " AND FDShdTransDate = '" & tUT_SaleDate & "'"

    nSeqRC = SP_VALnText2Double(SP_SQLtFunction("MAX", "FNSrcSeqNo", ptTableRC, tWhe))
    W_FNDnFindSeqRC = nSeqRC + 1
End Function

Public Sub W_KBRefund()
'----------------------------------------------------------
'   Call:
'   Cmt:   return  product
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim nKey As Integer
    Dim tSql As String
    Dim nRow As Long
    Dim nSeqNoCD As Long
    Dim orsTemp As ADODB.Recordset
    '*Eaw 56-03-04
    Dim nSeqNoDT As Long
    Dim nSeqNoDTRet As Long
    Dim tSKUBar As String
    Dim tMarkNonTax As String
    Dim tCstCode As String '*Tao 61-12-27 MenberID Original
    
On Error GoTo ErrDB
    bAccept = W_CheckLevelPass("W_KBRefund")

    If bAccept Then     'if level is ok
        With wMain.oScanner
             If bVB_OPOSScannerEnable Then
                 If .DeviceEnabled Then
                     .DeviceEnabled = False
                     .Release
                     .Close
                 End If
             End If
         End With
        'process
        wCNRefSaleNo.Show vbModal
        If Not bVB_Return Then Exit Sub
        Select Case tVB_TransTypeRet
            Case tEN_TrnClose, tEN_TrnStartBank, tEN_TrnReturn, tEN_TrnSuspended 'กรณีที่ป้อน TerminalNo กับ TransactionNo ผิดประเภท
                Call SP_MSGnShowing("tms_CN005117", nCS_Warning)
                bVB_Return = False
                Exit Sub
        End Select
        'ถ้าข้อมูลใน grid มีอยู่ ไม่สามารถทำงานได้
        nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
        If nRow > 0 Then        'If nRow > 1 Then
            Call SP_MSGnShowing("tms_CN005109", nCS_Warning)
            Exit Sub
        End If
        nKey = SP_MSGnShowing("tms_CN005118", tCS_CNMsgYesNoDefYes)     'คุณต้องการคืนสินค้า โดยอ้างถึงเลขที่ใบเสร็จอย่างย่อหรือไม่
        Select Case nKey
            Case vbNo      'cancel
                bVB_Return = False
                Exit Sub
            Case vbYes             'refer to bill no/อ้างถึงเลขที่ใบเสร็จอย่างย่อ
                wCNSelectReturnItem.Show vbModal
                 If Not bVB_Return Then Exit Sub
                 
                '*Tao 61-12-27 Detoken MemberID
                If tVB_MemPointID <> "" Then
                    Screen.MousePointer = vbHourglass
                    If SP_PRCbDeToken(tVB_MemPointID, tCstCode, True) Then
                        'DeToken Success
                        tVB_MemPointID = tCstCode
                        tSql = "UPDATE " & tVB_CNTblHD
                        tSql = tSql & vbCrLf & "SET FTCstCardCode = '" & tVB_MemPointID & "'"
                        tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "'"
                        tSql = tSql & vbCrLf & "AND FTShdTransNo = '" & tVB_Running & "'"
                        tSql = tSql & vbCrLf & "AND FTShdTransType = '" & tVB_Transaction & "'"
                        tSql = tSql & vbCrLf & "AND FDShdTransDate = '" & tUT_SaleDate & "'"
                        If SP_SQLvExecute(tSql) <> 0 Then
                            bVB_Return = False
                            Screen.MousePointer = vbDefault
                            Exit Sub
                        End If
                    Else
                        'DeToken Fail
                        Screen.MousePointer = vbDefault
                        Call SP_MSGnShowing("tms_CN005258", nCS_Warning) 'DeToken Fail. Not allow Return
                        bVB_Return = False
                        Exit Sub
                    End If
                    Screen.MousePointer = vbDefault
                End If
                '==============================
                
                Call wMain.W_ClearValAfterInsTSDT
                nSeqNoCD = 1
                nSeqNoDTRet = 1   '* Eaw 56-03-07
                Do While Not orsRet.EOF
                    tUT_TextPrompt = oSKU.GETSKUBarcode(SP_FEDtChkString(orsRet, "FTSdtInstoreBar"))
                   Call W_AddRefund2Grid(orsRet, nSeqNoCD)  '*KT 52-01-23 Communication Sheet PH2-ML-SF-068 Return refer sale wrong.xls
                    '__________________________________________________________________________________
                    '*Ao 2012/11/26  Return & Return Refer Sale ให้เข้าหน้า Discount เหมือนขาย
'                    tVB_InStoreBar = SP_FEDtChkString(orsRet, "FTSdtInstoreBar")
'                    cVB_CNRegPrice = SP_FEDtChkString(orsRet, "FCSdtRegPrice")
'                    tMarkNonTax = SP_FEDtChkString(orsRet, "FTSdtStaPrcstk")   '*Eaw 56-03-13  '*Eaw 56-03-13 TK-ISS3000-090
'                    If tVB_InStoreBar = "" Then
'                        wMain.otbPrompt.Text = SP_FEDtChkString(orsRet, "FTSdtBarCode")                     '*Ao 2013/03/21  CommSheet TK-ISS3000-117 00.00.01.xlsx
'                        tSKUBar = SP_FEDtChkString(orsRet, "FTSdtBarCode")   '*Eaw 56-03-04
'                    Else
'                        wMain.otbPrompt.Text = tVB_InStoreBar
'                        tSKUBar = tVB_InStoreBar '* Eaw 56-03-04
'                    End If
'                    Call W_KBXEnter
'                    nSeqNoDT = SP_FEDvChkNumeric(orsRet, "FNSdtSeqNo")    '*Eaw 56-03-04
'                    Call W_GetxItemDiscount(tSKUBar, nSeqNoDT, nSeqNoDTRet) '*Eaw 56-03-04
'                    '*Eaw 56-03-13  '*Eaw 56-03-13 TK-ISS3000-090
'                    If tMarkNonTax = "1" Then
'                        Call W_KBMarkNonTax
'                    End If
'                    nSeqNoDTRet = nSeqNoDTRet + 1  '*Eaw 56-03-07
                    '__________________________________________________________________________________
                    orsRet.MoveNext
                Loop
'                bVB_Reference = False       '*Ao 2012/11/26  Return & Return Refer Sale ให้เข้าหน้า Discount เหมือนขาย
                '________________________________________
                '*Ao 2010/11/06  Vendor Item
                nSeqNoCD = 1
                tSql = "SELECT * FROM TPSTSalRC"
                tSql = tSql & vbCrLf & "WHERE  FTTmnNum='" & tVB_TerminalNoRet & "' AND FTShdTransNo='" & tVB_TransNoRet & "'"
                tSql = tSql & vbCrLf & "AND  FTShdTransType='" & tVB_TransTypeRet & "' AND FDShdTransDate='" & Format(dVB_TransDateRet, "YYYY/MM/DD") & "'"
                tSql = tSql & vbCrLf & " AND  (FTSkuIndex IN (" & nVB_SeqRC & "))"
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) = 0 Then
                    Do While Not orsTemp.EOF
                        Call W_DupTblBtwSleNHold(orsTemp, tVB_CNTblRC, nSeqNoCD, False, nSeqNoCD)
                        nSeqNoCD = nSeqNoCD + 1
                        orsTemp.MoveNext
                    Loop
                End If
                
                '________________________________________
                
        End Select
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        bVB_Return = False
    End If
    Exit Sub
ErrDB:
    Screen.MousePointer = vbDefault
    bVB_Return = False
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

