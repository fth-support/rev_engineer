Public Sub W_GETxMemberPrice(ByVal ptSKUCode$, ByRef ptMemberPriceAlw$, ByRef pcMemberPrice As Double, ByRef ptEventMemberPrice As String, ByRef pnQtyMax As Long, ByRef ptMemberPriceType As String, ByRef pcMemberPriceAmt As Double, ByRef pcMemberPriceAmtDis As Double)
'--------------------------------------------------------------------------
'Ret:
'Cmt:   '*KT 52-02-18 member price
'--------------------------------------------------------------------------
    Dim cSumTmp As Double
    Dim orsTemp As ADODB.Recordset
    Dim tSql As String
    Dim cMemAmt As Double
    Dim cSalePrice As Double
    Dim tDiscType As String
    
On Error GoTo ErrHandle
    ptMemberPriceAlw = "N"
    pcMemberPrice = 0
    ptEventMemberPrice = ""
    pnQtyMax = 0
    '*KT 53-11-01 Preview Day
'    If bVB_CNTrStaRegPreviewDay And tVB_CNSKUFlagNotAlwPrvUse = "N" And tVB_CNSKUFlagPrv = "N" Then
'        tVB_CNTblMBPrice = "TCNMMemberPrice"
'    End If
    
'    tSql = "SELECT FTSkuCode,FTEvnCode,FCPmpMemAmt,FTPmpStaDiscType,FNPmpMemMaxQty"
'    tSql = tSql & vbCrLf & ",FTPmpStaPreview,FDPmpPreStartDate"
'    tSql = tSql & vbCrLf & "FROM " & tVB_CNTblMBPrice
'    tSql = tSql & vbCrLf & "WHERE FTSkuCode = '" & ptSKUCode & "'"
'    tSql = tSql & vbCrLf & "AND FDPmpMemEndDate >= '" & SP_DTEtStrSTD(SP_GETdChkDateDisc) & "'"  '*KT 52-06-04 ตรวจสอบวันที่หมดอายุตามที่กำหนดใน parameter
'    tSql = tSql & vbCrLf & "AND ISNULL(FTPmpStaDiscType,'0') <> '0'"
'*KT 53-11-03 ปรับปรุง Performance
    If bVB_CNModePreviewDay And tVB_CNSKUFlagNotAlwPrvUse = "N" Then
        tSql = "STP_CNxGETDataMemberPricePreDay @ptSKUCode ='" & ptSKUCode & "',@pdDate='" & SP_DTEtStrSTD(SP_GETdChkDateDisc) & "'"
    Else
        tSql = "STP_CNxGETDataMemberPrice @ptSKUCode ='" & ptSKUCode & "',@pdDate='" & SP_DTEtStrSTD(SP_GETdChkDateDisc) & "'"
    End If
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then  'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            ptMemberPriceAlw = "Y"
            cMemAmt = SP_VALcText2Double(SP_FEDvChkNumeric(orsTemp, "FCPmpMemAmt"))
            tDiscType = SP_FEDtChkString(orsTemp, "FTPmpStaDiscType")
            '*KT 53-11-01 Preview Day
            If bVB_CNModePreviewDay And tVB_CNSKUFlagNotAlwPrvUse = "N" Then
                tVB_CNSKUFlagAlwPrvUseMBPri = SP_FEDtChkString(orsTemp, "FTPmpStaPreview")
            Else
                tVB_CNSKUFlagAlwPrvUseMBPri = "N"
            End If
            Select Case tDiscType
                Case "1"
                    pcMemberPrice = SP_FMTcCurPoint(cUT_SalePrice - (cUT_SalePrice * cMemAmt / 100), True, False) '%off
                    pcMemberPriceAmtDis = (cUT_SalePrice * cMemAmt / 100)
                Case "2"
                    pcMemberPrice = SP_FMTcCurPoint(cUT_SalePrice - cMemAmt, True, False) 'amount off
                    pcMemberPriceAmtDis = cMemAmt
                Case "3"
                    pcMemberPrice = SP_FMTcCurPoint(cMemAmt, True, False) 'new price
                    pcMemberPriceAmtDis = cUT_SalePrice - cMemAmt
                Case Else 'No promotion PH2-ML-SF-147 Merber Price ถ้าเปลี่ยน Promotion Price เป็น No Promotion แต่ วัน End Date ยัง Active อยู่ เมื่อทำการขาย Sale Amount จะเป็น 0.00 ที่ถูกต้องจะต้องขายราคาปรกติ
                    ptMemberPriceAlw = "N"
                    pcMemberPrice = 0
                    ptEventMemberPrice = ""
                    pnQtyMax = 0
                    ptMemberPriceType = ""
                    pcMemberPriceAmt = 0
                    pcMemberPriceAmtDis = 0
                    Call SP_DATxRsNothing(orsTemp)
                    Exit Sub
            End Select
            If pcMemberPrice < 0 Then pcMemberPrice = 0
            pcMemberPriceAmt = cMemAmt
            ptMemberPriceType = tDiscType
            ptEventMemberPrice = SP_FEDtChkString(orsTemp, "FTEvnCode")
            pnQtyMax = SP_FEDvChkNumeric(orsTemp, "FNPmpMemMaxQty")
        End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    ptMemberPriceAlw = "N"
    pcMemberPrice = 0
    ptEventMemberPrice = ""
    pnQtyMax = 0
    ptMemberPriceType = ""
    pcMemberPriceAmt = 0
    pcMemberPriceAmtDis = 0
    Call SP_DATxRsNothing(orsTemp)
End Sub

Public Function W_CHKnDDPMallCard(ByVal pnENDisc As Integer) As Integer
'CREATE BY            #   Kitti                            LAST MODIFIED BY           # Kitti
'CREATE DATE      #  Not Define                               LAST MODIFIED DATE     # 52-12-11
'DESCRIPTION       #
'ARGUMENT LIST #
'
'RETURN VALUE  #
'-----------------------------------------------------------------------------------------------------------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
On Error GoTo Err_Handler
    tSql = "SELECT PO.FNDdpNo1,PO.FNDdpNo2 ,PO.FTDdpStaPolicy"
    tSql = tSql & vbCrLf & " FROM TCNMDoubleDiscPolicy PO "
    tSql = tSql & vbCrLf & "  WHERE PO.FNDdpNo1 = " & pnENDisc
    tSql = tSql & vbCrLf & "  AND PO.FNDdpNo2 = " & nEN_Disc11MallCrd
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
        If Not (orsTemp.BOF And orsTemp.EOF) Then
                orsTemp.Filter = "FTDdpStaPolicy = 'N'"
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    W_CHKnDDPMallCard = 0 'มีตัวที่เป็น N ไม่ให้ผ่าน
                Else
                    orsTemp.Filter = "FTDdpStaPolicy = 'B'"
                    If Not (orsTemp.BOF And orsTemp.EOF) Then 'มีตัวที่เป็น B
                        W_CHKnDDPMallCard = 2
                    Else
                        W_CHKnDDPMallCard = 1
                    End If
                End If
        Else
            W_CHKnDDPMallCard = 1
        End If
    Else
        W_CHKnDDPMallCard = 0
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
Err_Handler:
    W_CHKnDDPMallCard = 0
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Function

Public Sub W_PRCxGETPmtCpnBar()
'-----------------------------------------------------------------------------------------------------------------------------------------------------------
'CREATE BY            #   Kitti                            LAST MODIFIED BY           # Kitti
'CREATE DATE      #   54-07-22                            LAST MODIFIED DATE     # 54-07-22
'DESCRIPTION       #   คำนวณการได้ Promotion Coupon(Req.6 Ph.4.0(Member Point))
'                                            '*KT 54-10-06 V.4.0.1Req.6 Phase4.0(Member Point) Promotion Coupon ขอทำการแก้ไขตาม  DCR_5410001
'ARGUMENT LIST #
'RETURN VALUE  #
'-----------------------------------------------------------------------------------------------------------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
    Dim orsTier  As ADODB.Recordset
    'Dim oSKU As New cSKU
    Dim tReg As String
    Dim tPro As String
    Dim tBarCof As String
    Dim tSubTotal As String
    Dim cSubTotal As Double
    Dim cSubTotalAll As Double
    Dim aCpn() As PmtCpn
    Dim cAmt As Double
    Dim bStep As Boolean
'    Dim nIndex As Long
'    Dim cTemp1 As Double
'    Dim cTemp2 As Double
    Dim nI As Long
    Dim nCount As Long
    Dim tCalTypa As String  'N: วนจนครบทุกรอบในการหา Promotion Coupon Y : วนรอบเดียว
    Dim nLoop As Long 'จำนวนเท่า กรณีที่ tCalTypa = 'Y'
    Dim tID As String
    Dim tSqlF As String
    Dim tSqlV As String
    Dim bNext As Boolean
    Dim cBalance As Double
    Dim cRegBal As Double
    Dim cProBal As Double
    Dim cMin As Double
    Dim cMax As Double
On Error GoTo Err_Handler
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnSale, tEN_TrnDeposit, tEN_TrnVIPSale, tEN_TrnTaxExceptSale, tEN_TrnDutyFreeSale
            'หายอด SUBTOTAL-ALL,SUBTOTAL
            Select Case Val(Format(tVB_TransactionSub))
                Case tEN_TrnDeposit
                    cSubTotal = (cVB_Total - cVB_TotalDiscAft) 'SUBTOTAL
                Case Else
                    cSubTotal = cVB_NetSale 'SUBTOTAL
            End Select
            cSubTotalAll = cUT_SubReg + cUT_SubPro 'SUBTOTAL-ALL
            
            'หายอดรวมมูลค่าสินค้าป้ายเหลือง,น้ำเงิน หลังหักส่วนลด
'            tSql = "SELECT SUM(CASE WHEN ISNULL(FTSkuStaMallEmpCard,'N') = 'Y' THEN  ISNULL(FCSdtSaleAmt,0) ELSE 0 END) AS FCReg"
'            tSql = tSql & vbCrLf & ", SUM(CASE WHEN ISNULL(FTSkuStaMallEmpCard,'N') <> 'Y' THEN  ISNULL(FCSdtSaleAmt,0)  ELSE 0 END) AS FCPro"
'            tSql = tSql & vbCrLf & "FROM " & tVB_CNTblDT
'            tSql = tSql & vbCrLf & "WHERE FTTmnNum = '" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
'            tSql = tSql & vbCrLf & " AND FDShdTransDate='" & tUT_SaleDate & "'"
'            tSql = tSql & vbCrLf & "AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
'            If SP_SQLvExecute(tSql, orsTemp) = 0 Then
'                 If Not (orsTemp.BOF And orsTemp.EOF) Then
'                        cRegBal = SP_FEDvChkNumeric(orsTemp, "FCReg")
'                        cProBal = SP_FEDvChkNumeric(orsTemp, "FCPro")
'                        cBalance = cRegBal + cProBal
'                 End If
'            End If
'            Call SP_DATxRsClose(orsTemp)
            cRegBal = cVB_RegTotAmtAfDisc 'ยอดรวมสินค้าหลังหัดส่วนลดทุกชนิดเฉพาะสินค้าป้ายน้ำเงิน
            cProBal = cVB_ProTotAmtAfDisc 'ยอดรวมสินค้าหลังหัดส่วนลดทุกชนิดเฉพาะสินค้าป้ายเหลือง
            cBalance = cVB_RegTotAmtAfDisc + cVB_ProTotAmtAfDisc
                     
            tSql = "SELECT TOP 1 FTPcnID,ISNULL(FTPcnStaReg,'N') AS FTPcnStaReg,ISNULL(FTPcnStaPro,'N') AS FTPcnStaPro,ISNULL(FTPcnStaSubTotal,'N') AS FTPcnStaSubTotal"
            tSql = tSql & vbCrLf & ",FTBafCode,ISNULL(FTPcnStaCalType,'N') AS FTPcnStaCalType"
            tSql = tSql & vbCrLf & ",ISNULL(FCPcnMin,0) AS FCPcnMin,ISNULL(FCPcnMax,0) AS FCPcnMax"
            tSql = tSql & vbCrLf & "FROM TCNMPmtCpnJN"
            tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE ISNULL(FTPcnStaAct,'N') = 'Y'"
            tSql = tSql & vbCrLf & "ORDER BY FTPcnID "
            If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , True, True) = 0 Then
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                     tID = SP_FEDtChkString(orsTemp, "FTPcnID")
                    cMin = SP_FEDvChkNumeric(orsTemp, "FCPcnMin")
                    cMax = SP_FEDvChkNumeric(orsTemp, "FCPcnMax")
                    tSubTotal = SP_FEDtChkString(orsTemp, "FTPcnStaSubTotal")
                    tReg = SP_FEDtChkString(orsTemp, "FTPcnStaReg")
                    tPro = SP_FEDtChkString(orsTemp, "FTPcnStaPro")
                    tBarCof = SP_FEDtChkString(orsTemp, "FTBafCode")
                    tCalTypa = SP_FEDtChkString(orsTemp, "FTPcnStaCalType")
                    
                    bNext = False
                    
                    'ตรวจสอบตาราง Tier
                    tSql = "SELECT "
                    tSql = tSql & vbCrLf & "FNPcnSeq,FCPcnAmt,FCPcnVal,FNPcnQty"
                    tSql = tSql & vbCrLf & "FROM TCNMPmtCpnJNTier"
                    tSql = tSql & vbCrLf & "WITH(NOLOCK) WHERE FTPcnID = '" & tID & "'"
                    tSql = tSql & vbCrLf & "ORDER BY FNPcnSeq DESC"
                    If SP_SQLvExecute(tSql, orsTier, oDB.ocnOnLine, , , , True, True) = 0 Then
                         If Not (orsTier.BOF And orsTier.EOF) Then
                            bNext = True
                        End If
                    End If
                    
                    'ตรวจสอบ Min ตาม  Calculate from SUBTOTAL-ALL
                    If tSubTotal = "Y" Then 'check sub total all
                        If cSubTotalAll >= cMin Then
                            bNext = True
                        Else
                            bNext = False
                        End If
                    Else
                        If cSubTotal >= cMin Then
                            bNext = True
                        Else
                            bNext = False
                        End If
                    End If
                    
                    'ตรวจสอบเงื่อน Reg,Pro
                    If bNext Then
                       If tReg = "Y" And tPro = "Y" Then
                            cBalance = cRegBal + cProBal
                        ElseIf tReg = "Y" And tPro = "N" Then
                            cBalance = cRegBal
                       ElseIf tReg = "N" And tPro = "Y" Then
                            cBalance = cProBal
                       End If
                    End If
                    
                    'ตรวจสอบ Max  กับยอดที่นำมาหาคูปอง ถ้ายอดมากกว่าก้อนดังกล่าวให้ใช้ยอด Max แทน
                     If bNext Then
                         If cBalance > cMax Then
                               cBalance = cMax
                        End If
                     End If
                                        
                    'ตรวจสอบว่าผ่านเงื่อนหรือไม่ ถ้าไม่ให้ออกจาก Procedure นี้
                    If Not bNext Then
                        Call SP_DATxRsNothing(orsTemp)
                        Call SP_DATxRsNothing(orsTier)
                        tSql = "DELETE  TPSTSalPmtCpn WITH(ROWLOCK) "
                        tSql = tSql & vbCrLf & " WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
                        tSql = tSql & vbCrLf & " AND FTShdTransNo='" & tVB_Running & "'"
                        tSql = tSql & vbCrLf & " AND FTShdTransType='" & tVB_Transaction & "'"
                        tSql = tSql & vbCrLf & " AND FDShdTransDate ='" & tUT_SaleDate & "'"
                        Call SP_SQLvExecute(tSql)
                        Exit Sub
                    End If
                    
                    ReDim aCpn(0)
                    nI = 0
                    aCpn(nI).Amt = 0
                    aCpn(nI).Val = 0
                    aCpn(nI).Qty = 0
                    aCpn(nI).ID = ""
                
                    Do While Not orsTier.EOF
                        bStep = False
                        cAmt = SP_FEDvChkNumeric(orsTier, "FCPcnAmt")
                        If tReg <> "N" Or tPro <> "N" Then
                            'Step 1
                            '-----------------------------------------------------------------------------------------------------------------------
                            If cBalance >= cAmt Then
                                bStep = True
                            Else
                                bStep = False
                            End If
                            '-----------------------------------------------------------------------------------------------------------------------
                            'Step 2
                            '-----------------------------------------------------------------------------------------------------------------------
                            If bStep Then
                                ReDim Preserve aCpn(nI) As PmtCpn
                                aCpn(nI).Amt = cAmt
                                aCpn(nI).Val = SP_FEDvChkNumeric(orsTier, "FCPcnVal")
                                If tCalTypa = "Y" Then
                                    aCpn(nI).Qty = SP_FEDvChkNumeric(orsTier, "FNPcnQty")
                                    aCpn(nI).ID = tBarCof
                                    Exit Do
                                Else
                                    If tReg = "Y" And tPro = "Y" Then
                                         nLoop = (cBalance \ cAmt) 'จำนวนเท่า
                                     ElseIf tReg = "Y" And tPro = "N" Then
                                         nLoop = (cRegBal \ cAmt) 'จำนวนเท่า
                                    ElseIf tReg = "N" And tPro = "Y" Then
                                         nLoop = (cProBal \ cAmt) 'จำนวนเท่า
                                    End If
                                    aCpn(nI).Qty = CLng(SP_FEDvChkNumeric(orsTier, "FNPcnQty")) * nLoop
                                End If
                                aCpn(nI).ID = tBarCof
                                nI = nI + 1
                                If tReg = "Y" And tPro = "Y" Then
                                    cBalance = cBalance - (cAmt * nLoop)
                                ElseIf tReg = "Y" And tPro = "N" Then
                                    cRegBal = cRegBal - (cAmt * nLoop)
                               ElseIf tReg = "N" And tPro = "Y" Then
                                    cProBal = cProBal - (cAmt * nLoop)
                               End If
                            End If
                            '-----------------------------------------------------------------------------------------------------------------------
                        End If
                        orsTier.MoveNext
                    Loop
                    
                    tSql = "DELETE  TPSTSalPmtCpn WITH(ROWLOCK) "
                    tSql = tSql & vbCrLf & " WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
                    tSql = tSql & vbCrLf & " AND FTShdTransNo='" & tVB_Running & "'"
                    tSql = tSql & vbCrLf & " AND FTShdTransType='" & tVB_Transaction & "'"
                    tSql = tSql & vbCrLf & " AND FDShdTransDate ='" & tUT_SaleDate & "'"
                    If SP_SQLvExecute(tSql) = 0 Then
                        tSqlF = "(FTTmnNum,FTShdTransNo,FTShdTransType,FDShdTransDate,FTShdPmtCpnID"
                        tSqlF = tSqlF & vbCrLf & ",FNPcnSeqNo,FCPcnAmt,FNShdPmtCpnQty,FCShdPmtCpnVal,FTStaSentOnOff"
                        tSqlF = tSqlF & vbCrLf & ",FTBafCode,FTPcnID"
                        tSqlF = tSqlF & "," & tCS_CNLastFedIns
                        If UBound(aCpn) >= 0 And aCpn(0).ID <> "" Then
                            nCount = 0
                            For nI = 0 To UBound(aCpn)
                                If CLng(aCpn(nI).Qty) > 0 Then
                                    tSqlV = "('" & tVB_CNTerminalNum & "'"
                                    tSqlV = tSqlV & ",'" & tVB_Running & "'"
                                    tSqlV = tSqlV & ",'" & tVB_Transaction & "'"
                                    tSqlV = tSqlV & ",'" & tUT_SaleDate & "'"
                                    tSqlV = tSqlV & ",'" & oSKU.GETPmtCpnBarcodeID(aCpn(nI).ID, "", aCpn(nI).Val) & "'"
                                    tSqlV = tSqlV & "," & nCount
                                    tSqlV = tSqlV & "," & CDbl(aCpn(nI).Amt)
                                    tSqlV = tSqlV & "," & CLng(aCpn(nI).Qty)
                                    tSqlV = tSqlV & "," & CDbl(aCpn(nI).Val)
                                    tSqlV = tSqlV & ",'0'"
                                    tSqlV = tSqlV & ",'" & aCpn(nI).ID & "'"
                                    tSqlV = tSqlV & ",'" & tID & "'"
                                    tSqlV = tSqlV & "," & cUT.UT_SQLtLastIns(tVB_CNUserName)
                                    tSql = "INSERT INTO TPSTSalPmtCpn" & tSqlF & " VALUES " & tSqlV
                                    Call SP_SQLvExecute(tSql)
                                    nCount = nCount + 1
                                 End If
                            Next nI
                        End If
                    End If

                    '-----------------------------------------------------------------------------------------------------------------------
                Else
                    tSql = "DELETE  TPSTSalPmtCpn WITH(ROWLOCK) "
                    tSql = tSql & vbCrLf & " WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
                    tSql = tSql & vbCrLf & " AND FTShdTransNo='" & tVB_Running & "'"
                    tSql = tSql & vbCrLf & " AND FTShdTransType='" & tVB_Transaction & "'"
                    tSql = tSql & vbCrLf & " AND FDShdTransDate ='" & tUT_SaleDate & "'"
                    Call SP_SQLvExecute(tSql)
                End If
            Else
                tSql = "DELETE  TPSTSalPmtCpn WITH(ROWLOCK) "
                tSql = tSql & vbCrLf & " WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransNo='" & tVB_Running & "'"
                tSql = tSql & vbCrLf & " AND FTShdTransType='" & tVB_Transaction & "'"
                tSql = tSql & vbCrLf & " AND FDShdTransDate ='" & tUT_SaleDate & "'"
                Call SP_SQLvExecute(tSql)
            End If
        Case Else
            tSql = "DELETE  TPSTSalPmtCpn WITH(ROWLOCK) "
            tSql = tSql & vbCrLf & " WHERE FTTmnNum='" & tVB_CNTerminalNum & "'"
            tSql = tSql & vbCrLf & " AND FTShdTransNo='" & tVB_Running & "'"
            tSql = tSql & vbCrLf & " AND FTShdTransType='" & tVB_Transaction & "'"
            tSql = tSql & vbCrLf & " AND FDShdTransDate ='" & tUT_SaleDate & "'"
            Call SP_SQLvExecute(tSql)
    End Select
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTier)
    Exit Sub
Err_Handler:
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsTier)
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Public Sub W_DupTblBtwSleNHoldPoint(ByVal poRs As ADODB.Recordset, ByVal ptTable$, ByVal pnSeqNo As Long, ByVal pbFrmSale As Boolean, Optional ByVal pnPdtSeq As Integer = 0, Optional ByVal pnSeqNoCD As Long = 0, Optional ByVal pbMoveLocal As Boolean = False, Optional ByVal pbCpyDeal As Boolean = False, Optional ByVal pnDateTime As Long = 0, Optional ByVal pnSeqNoActCD As Long = 0, Optional pbClrDealPromo As Boolean = False)
'----------------------------------------------------------
'   Call:   poRs as recordset of HD or DT
'               ptTable as table name of HD or DT
'               pnSeqNo as sequence number
'               pbFrmSale as True if HD or DT from sale
'               pbDateTime 0 : ไม่ Update FDDateIns/FTTimeIns/FTWhoIns/FDDateUpd/FTTimeUpd/FTWhoUpd  1 : ไม่ Update  FDDateIns/FTTimeIns/FTWhoIns Update FDDateUpd/FTTimeUpd/FTWhoUpd  2 : Update  FDDateIns/FTTimeIns/FTWhoIns /FDDateUpd/FTTimeUpd/FTWhoUpd
'               pbClrDealPromo : เป็นตัวแปรที่บ่งบอกว่าต้องการ Claer ค่า FTSdtStkCode ในตาราง CD ให้ค่าเป้นค่าว่างหรือไม่ True : Claer False : ไม่ Claer
'   Cmt:   dup data from poRs to ptTable
'----------------------------------------------------------
    Dim i%, tSql$, tTmp$
    Dim tSqlH$, tSqlT$
    Dim tSqlF$, tSqlV$
        
    tSqlH = "INSERT INTO " & ptTable & " ("
    tSqlT = " VALUES ("
    For i = 0 To poRs.Fields.Count - 1
        tSqlF = tSqlF & poRs.Fields(i).Name & ","
        Select Case poRs.Fields(i).Name
            Case "FTTmnNum"
                If pbFrmSale Then
                    tSqlV = tSqlV & "'" & UT_tChkFieldString(poRs, poRs.Fields(i).Name) & "',"
                Else
                    tSqlV = tSqlV & "'" & tVB_CNTerminalNum & "',"
                End If
                
            Case "FTShdTransNo"
                If pbFrmSale Then
                    tSqlV = tSqlV & "'" & UT_tChkFieldString(poRs, poRs.Fields(i).Name) & "',"
                Else
                    tSqlV = tSqlV & "'" & tVB_Running & "',"
                End If
                
            Case "FTShdTransType"
                If pbFrmSale Then
                    tSqlV = tSqlV & "'" & UT_tChkFieldString(poRs, poRs.Fields(i).Name) & "',"
                Else
                    tSqlV = tSqlV & "'" & tVB_Transaction & "',"
                End If
                
            Case "FDShdTransDate"
                If pbFrmSale Then
                    If IsNull(poRs.Fields(i).Value) Then
                         tSqlV = tSqlV & "Null" & ","
                     Else
                         tSqlV = tSqlV & "'" & UT_tStringDate(poRs.Fields(i).Value) & "',"
                     End If
                Else
                    tSqlV = tSqlV & "'" & tUT_SaleDate & "',"
                End If
            
                Case "FTShdTransTime"
                    If pbFrmSale Then
                        tSqlV = tSqlV & "'" & Format(Time$, "HH:MM") & "',"
                    Else
                        tSqlV = tSqlV & "'" & Format(Time$, "HH:MM") & "',"
                    End If
                    
                Case "FTSpoID"
                    If IsNull(poRs.Fields(i)) Then
                        tSqlV = tSqlV & "''" & ","
                    Else
                        If Len(Trim(poRs.Fields(i))) = 0 Then
                           tSqlV = tSqlV & "''" & ","
                        Else
                            tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                        End If
                    End If
                    
                Case "FTStaSentOnOff"
                    If IsNull(poRs.Fields(i)) Then
                        tSqlV = tSqlV & "''" & ","
                    Else
                        If Len(Trim(poRs.Fields(i))) = 0 Then
                           tSqlV = tSqlV & "''" & ","
                        Else
                            tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                        End If
                    End If
                                   
            Case "FDDateIns", "FTTimeIns", "FTWhoIns", "FDDateUpd", "FTTimeUpd", "FTWhoUpd"
                Select Case pnDateTime
                    Case 0
                        Select Case Mid(poRs.Fields(i).Name, 2, 1)
                            Case "T"
                                If IsNull(poRs.Fields(i)) Then
                                    tSqlV = tSqlV & "Null" & ","
                                Else
                                    If Len(Trim(poRs.Fields(i))) = 0 Then
                                        tSqlV = tSqlV & "Null" & ","
                                    Else
                                        tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                                    End If
                                End If
                                
                            Case "D"
                                If IsNull(poRs.Fields(i).Value) Then
                                    tSqlV = tSqlV & "Null" & ","
                                Else
                                    tSqlV = tSqlV & "'" & UT_tStringDate(poRs.Fields(i).Value) & "',"                         'มี เขาเดี่ยว
                                End If
                                
                            Case "N"
                               tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                            Case "C"
                                tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                        End Select
                    Case 1
                        Select Case poRs.Fields(i).Name
                            Case "FDDateIns"
                                If IsNull(poRs.Fields(i).Value) Then
                                    tSqlV = tSqlV & "Null" & ","
                                Else
                                    tSqlV = tSqlV & "'" & UT_tStringDate(poRs.Fields(i).Value) & "',"                         'มี เขาเดี่ยว
                                End If
                            Case "FTTimeIns", "FTWhoIns"
                                If IsNull(poRs.Fields(i)) Then
                                    tSqlV = tSqlV & "Null" & ","
                                Else
                                    If Len(Trim(poRs.Fields(i))) = 0 Then
                                        tSqlV = tSqlV & "Null" & ","
                                    Else
                                        tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                                    End If
                                End If
                            Case "FDDateUpd"
                                 tSqlV = tSqlV & "'" & UT_tStringDate(Date) & "',"
                            Case "FTTimeUpd"
                                 tSqlV = tSqlV & "'" & Time$ & "',"
                            Case "FTWhoUpd"
                                 tSqlV = tSqlV & "'" & tVB_CNUserName & "',"
                        End Select
                    Case 2
                        Select Case poRs.Fields(i).Name
                            Case "FDDateIns"
                                tSqlV = tSqlV & "'" & UT_tStringDate(Date) & "',"
                            Case "FTTimeIns"
                                tSqlV = tSqlV & "'" & Time$ & "',"
                            Case "FTWhoIns"
                                tSqlV = tSqlV & "'" & tVB_CNUserName & "',"
                            Case "FDDateUpd"
                                 tSqlV = tSqlV & "'" & UT_tStringDate(Date) & "',"
                            Case "FTTimeUpd"
                                 tSqlV = tSqlV & "'" & Time$ & "',"
                            Case "FTWhoUpd"
                                 tSqlV = tSqlV & "'" & tVB_CNUserName & "',"
                        End Select
                End Select
            'Case "FCSdtMemberPrice"
                
            Case Else                           'อื่นๆ
                Select Case Mid(poRs.Fields(i).Name, 2, 1)
                    Case "T"
                        If IsNull(poRs.Fields(i)) Then
                            tSqlV = tSqlV & "Null" & ","
                        Else
                            If Len(Trim(poRs.Fields(i))) = 0 Then
                                tSqlV = tSqlV & "''" & ","
                            Else
                                tSqlV = tSqlV & "'" & SP_STRtSiggleCode(UT_tChkFieldString(poRs, poRs.Fields(i).Name)) & "',"        'มี เขาเดี่ยว
                            End If
                        End If
                        
                    Case "D"
                        If IsNull(poRs.Fields(i).Value) Then
                            tSqlV = tSqlV & "Null" & ","
                        Else
                            tSqlV = tSqlV & "'" & UT_tStringDate(poRs.Fields(i).Value) & "',"                         'มี เขาเดี่ยว
                        End If
                        
                    Case "N"
                       tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALnText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                    Case "C"
                        tSqlV = tSqlV & SP_FMTcCurPoint(SP_VALcText2Double(UT_vChkFieldNumeric(poRs, poRs.Fields(i).Name))) & ","              'ไม่มี เขาเดี่ยว
                    
                End Select
        End Select
        If i = poRs.Fields.Count - 1 Then
            tSqlF = Left(tSqlF, Len(tSqlF) - 1)
            tSqlV = Left(tSqlV, Len(tSqlV) - 1)
        End If
    Next i
    tSql = tSqlH & tSqlF & ")" & tSqlT & tSqlV & ")"
    Call SP_SQLvExecute(tSql, , oDB.ocnOnLine)
End Sub

Private Function W_CHKbChkDigit(ByVal ptInStoreBar As String) As Boolean
'------------------------------------------------
'Call :
'Cmt:   '*Aoo 2012/10/26    Check Digi Bar
'-------------------------------------------------
Dim nI As Integer
Dim tTmp As String, tDigit As String
Dim bChk As Boolean
Dim cSum As Double

On Error GoTo ErrHandle
    bChk = False
    tTmp = ptInStoreBar
    cSum = 0
    For nI = 1 To Len(ptInStoreBar) - 1
        tDigit = Left(tTmp, 1)
        tTmp = Right(tTmp, Len(tTmp) - 1)
        If nI Mod 2 = 0 Then
            tDigit = (CInt(tDigit) * 3)
            cSum = cSum + CInt(Right(tDigit, 1))
        Else
            tDigit = CInt(tDigit) * 1
            cSum = cSum + CInt(Right(tDigit, 1))
        End If
    Next nI
    
    cSum = 100 - cSum
    tDigit = CStr(cSum)
    
    If Right(ptInStoreBar, 1) = Right(tDigit, 1) Then
        bChk = False
    Else
        bChk = True
    End If
    
    W_CHKbChkDigit = bChk
    Exit Function
ErrHandle:
    W_CHKbChkDigit = False
End Function
Private Function W_CHKb2LineBarcode(ByVal ptBarcode As String) As Boolean
'________________________________________
'   Call:
'   Cmt:  '*Eaw 56-02-04 2Line Barcode
'________________________________________
Dim tSql As String
Dim nEff As Long
Dim nMatchStr As String
Dim tBarType As String
Dim tName As String
Dim nLocate As Long
Dim nSize As Long
Dim nDec As Long
Dim cPrice As Double
Dim tCheckDigit As String '*Bump 56-03-02 TK-ISS3000-004 เช็ค Digits ของ 2Line Barcode
'ถ้า tCheckDigit = '1' คือ ต้อง Check Digits สูตร Mod10 เหมือนบัตร Member Card
'ถ้า tCheckDigit = '2' คือไม่ต้อง Check Digits
Dim orsTemp As ADODB.Recordset
Dim orsSKU As ADODB.Recordset
On Error GoTo ErrHandle
    W_CHKb2LineBarcode = False
    tSql = "SELECT  * FROM  TCNMSkuBarCon WHERE  FTBafCodeType = '5'"
    tSql = tSql & " AND left(FNBafMatchStr,1) = left('" & ptBarcode & "',1)"
    tSql = tSql & " AND FNBafItemSize = len('" & ptBarcode & "')"
'    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)    '*Eaw 56-02-12
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master   '*Eaw 56-02-12
    If Not (orsTemp.BOF And orsTemp.EOF) Then
            nLocate = SP_FEDvChkNumeric(orsTemp, "FNBafPLULocate")
            nSize = SP_FEDvChkNumeric(orsTemp, "FNBafPLUSize")
            tCheckDigit = SP_FEDtChkString(orsTemp, "FTBafStaChkDigit") '*Bump 56-03-02 TK-ISS3000-004 เช็ค Digits ของ 2Line Barcode
            If tCheckDigit = "1" Then
                If W_CHKbChkDigit(ptBarcode) Then
                    Call SP_MSGnShowing("tms_CN014039", nCS_Warning)
                    wMain.otbPrompt.Text = ""
                    W_CHKb2LineBarcode = False
                    Exit Function
                End If
            End If
            tVB_2LineCode = Mid(ptBarcode, nLocate, nSize)
 '*Eaw 56-03-05
'            wMain.otcForm1(21).Visible = True
'            wMain.opbWeight.Visible = True
'            wMain.olaForm(4).Caption = "Please scan barcode price"  '*Eaw 56-03-02 TK-ISS3000-084
'            wMain.olaForm(3).Visible = False
'            wMain.olaForm(7).Visible = False
'            wMain.olaForm(7).Caption = SP_FMTcCurPoint(0)
'-------------------------------------------------------------------------------------------------
            tSql = "SELECT SK.FTSkuCode,SK.FTSkuAbbThai,SK.FTSkuAbbEng,SB.FTPbcbarcode FROM TCNMSKU SK INNER JOIN TCNMSKUBarcode SB"
            tSql = tSql & " ON SK.FTSkuCode = SB.FTSkuCode"
            tSql = tSql & " WHERE SB.FTPbcbarcode ='" & tVB_2LineCode & "'"
        '    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)    '*Eaw 56-02-12
            Call SP_SQLvExecute(tSql, orsSKU, oDB.ocnOnLine, , , , , True, True) 'read master  '*Eaw 56-02-12
            If Not (orsSKU.BOF And orsSKU.EOF) Then
                wMain.olaForm(5).Caption = SP_FEDtChkString(orsSKU, "FTPbcbarcode")
                If tVB_CNPrnSKUName = "1" Then
                    wMain.olaForm(6).Caption = SP_FEDtChkString(orsSKU, "FTSkuAbbThai")
                Else
                    wMain.olaForm(6).Caption = SP_FEDtChkString(orsSKU, "FTSkuAbbEng")
                End If
'                wMain.olaForm(6).Caption = SP_FEDtChkString(orsSKU, "FTSkuAbbThai")
                '*Eaw 56-03-05
                wMain.otcForm1(21).Visible = True
                wMain.opbWeight.Visible = True
                wMain.olaForm(4).Caption = "Please scan barcode price"  '*Eaw 56-03-02 TK-ISS3000-084
                wMain.olaForm(3).Visible = False
                wMain.olaForm(7).Visible = False
                wMain.olaForm(7).Caption = SP_FMTcCurPoint(0)
                '------------------------------------------------------------------------------------
                wMain.otbPrompt.Text = ""
                W_CHKb2LineBarcode = True
                If cVB_2LinePrice = 0 Then
                    wMain.olaForm(8).Visible = False  '*Eaw 56-03-02 TK-ISS3000-084
                End If
            Else
                tVB_2LineCode = ""
            End If
        Exit Function
    Else
         If tVB_2LineCode = "" Then
                wMain.olaForm(5).Caption = ""
                wMain.olaForm(6).Caption = ""
         End If
    End If
    'ptBarcode = "3000000021309"
    tSql = "SELECT  * FROM  TCNMSkuBarCon WHERE  FTBafCodeType = '6'"
    tSql = tSql & "AND left(FNBafMatchStr,1) = left('" & ptBarcode & "',1)"
    tSql = tSql & "AND FNBafItemSize = len('" & ptBarcode & "')"
'    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine)    '*Eaw 56-02-12
    Call SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) 'read master   '*Eaw 56-02-12
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        nLocate = SP_FEDvChkNumeric(orsTemp, "FNBafPriceLocate")
        nSize = SP_FEDvChkNumeric(orsTemp, "FNBafPriceSize")
        tCheckDigit = SP_FEDtChkString(orsTemp, "FTBafStaChkDigit") '*Bump 56-03-02 TK-ISS3000-004 เช็ค Digits ของ 2Line Barcode
        If tCheckDigit = "1" Then
                If W_CHKbChkDigit(ptBarcode) Then
                    Call SP_MSGnShowing("tms_CN014039", nCS_Warning)
                    wMain.otbPrompt.Text = ""
                    W_CHKb2LineBarcode = False
                    Exit Function
                End If
        End If
        tName = Mid(ptBarcode, nLocate, nSize)
        nDec = Val(Format(orsTemp("FNBafPriceDec")))
        cPrice = Val(Format(Mid(ptBarcode, Val(Format(orsTemp("FNBafPriceLocate"))), Val(Format(orsTemp("FNBafPriceSize")))))) / (10 ^ Val(Format(orsTemp("FNBafPriceDec"))))
        wMain.otcForm1(21).Visible = True
        wMain.opbWeight.Visible = True
        wMain.olaForm(3).Visible = False
        wMain.olaForm(7).Visible = False
'        wMain.olaForm(7).Caption = SP_FMTcCurPoint(0)
        cVB_2LinePrice = cPrice
        wMain.olaForm(4).Caption = "Sub Total : "  '*Eaw 56-03-02 TK-ISS3000-084
        wMain.olaForm(8).Visible = True  '*Eaw 56-03-02 TK-ISS3000-084
        wMain.olaForm(8).Caption = SP_FMTcCurPoint(cPrice)
        wMain.otbPrompt.Text = ""
        W_CHKb2LineBarcode = True
    End If
    Exit Function
ErrHandle:
    Call SP_MSGShowError
    W_CHKb2LineBarcode = False
End Function


Private Function W_PRCxClearData(ByVal ptTenderCode As String)
