        bVB_CNStaMain = True

        'กรณี Excep Sale ต้องถอด Vat
        Call SP_CALxExceptSale(wMain.ogdForm, nCurRow, cUT_SalePrice)
      
        Select Case Val(Format(tVB_TransactionSub))
            '*Ao 2012/11/26  Return & Return Refer Sale ให้เข้าหน้า Discount เหมือนขาย
'            Case tEN_TrnReturn, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax, tEN_TrnReturnCashControl '*KT 51-06-07 Comsheet ML-SF-327
'            Case tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax  '*KT 51-06-07 Comsheet ML-SF-327
            Case tEN_TrnReturnManualTax   '*Eaw 56-06-04  CommSheet TK-ISS3000-214-ST 00 00 01.xls
                'none
            Case tEN_TrnSaleManualTax
                'none
            Case Else
            
                  tVB_StaMemPricePromoAlw = False '*KT 52-02-16 member price
                  
                '1 Deal ไว้ตอนกด Total
                
                '2 ตรวจสอบ Promotion Time Sale (bVB_SKUisChkPromoTime ได้ค่ามาจาก W_PRCbMaxQtyPmtTimeSaleBySKU)
                If bVB_SKUisChkPromoTime Then W_PRCxPmtTimeSaleDisc (nCurRow)

                '3  ตรวจสอบ Promotion (bVB_SKUisChkPromo ได้ค่ามาจาก W_PRCbMaxQtyPromotionBySKU)
