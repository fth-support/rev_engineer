                            tSql = tSql & vbCrLf & ",FCSdtBSubPro=0"
                            tSql = tSql & vbCrLf & ",FCSdtBluePrice=FCSdtSaleAmt"
                            tSql = tSql & vbCrLf & ",FCSdtYellowPrice=0"
                            tSql = tSql & vbCrLf & ",FCSdtCostEX=0" '*KT 51-10-21 V 3.0.140/V 3.0.200
                            tSql = tSql & vbCrLf & ",FTSkuStaMallEmpCard ='Y'" '*KT 51-10-21 V 3.0.140/V 3.0.200
                            tSql = tSql & vbCrLf & ",FCSdtDis =  " & SP_FMTcCurPoint(cDiscBHome, True, False)  '*KT 51-11-05 Copy Sale
                            tSql = tSql & vbCrLf & ",FCSdtSaleUnit =  " & SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")), True, False) '*KT 51-11-05 Copy Sale ''*KT 51-12-16 V 1.0.3 Phase 2 ข้อ 16  Communication Sheet PH2-ML-SF-003 Coop. Dis is not shown on Screen when Copy Sale.xls
                            tSql = tSql & vbCrLf & ",FCSdtSalePrice =  " & SP_FMTcCurPoint(.ValueMatrix(nRow + 1, .ColIndex("FCSdtSaleUnit")), True, False) '*KT 51-11-05 Copy Sale ''*KT 51-12-16 V 1.0.3 Phase 2 ข้อ 16  Communication Sheet PH2-ML-SF-003 Coop. Dis is not shown on Screen when Copy Sale.xls
                            tSql = tSql & vbCrLf & ",FTSdtStaPdt =  '" & tVB_CNSkuStaAlw & "'"
                            tSql = tSql & vbCrLf & ",FTSdtConsignFlag =  '" & tVB_SKUConsignFlag & "'"
                            tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                            tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                            If .TextMatrix(nRow + 1, .ColIndex("FTSdtWeight")) = "" Then
                                 tSql = tSql & vbCrLf & " AND  FTSdtBarCode='" & .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode")) & "' AND FNSdtSeqNo=" & .TextMatrix(nRow + 1, .ColIndex("FNSdtSeqNo"))
                            Else
                                 tSql = tSql & vbCrLf & " AND  FTSdtInstoreBar='" & .TextMatrix(nRow + 1, .ColIndex("FTSdtBarCode")) & "' AND FNSdtSeqNo=" & .TextMatrix(nRow + 1, .ColIndex("FNSdtSeqNo"))
                            End If
                            Call SP_SQLvExecute(tSql)
                        End If
                    End With
                    nRow = nRow + 1
                    orsTemp.MoveNext
                Loop
                      
                'show poll
                '*KT 51-08-01 ML-SF-406
                '------------------------------------------------------------------------
                
                '*KT 51-11-06 ReCal
                '-----------------------------------------------------------------
                tSql = "SELECT FCScdAmt "
                tSql = tSql & " FROM " & tVB_CNTblCD
                tSql = tSql & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
                tSql = tSql & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
                Call SP_SQLvExecute(tSql, orsTemp)
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    oDisc.nENDiscType = nEN_Disc01Deal 'เริ่ม Recal ส่วนลดจาก Deal
                    oDisc.dTranDate = tUT_SaleDate
                    oDisc.tTerminalNo = tVB_CNTerminalNum
                    oDisc.tTransNo = tVB_Running
                    oDisc.DISbClearDiscDT       '*KT 51-09-19 Clear DT ก่อนทำ
                    oDisc.DISxPrcRecal
                    'Show grid dt again
                    ''*KT 51-12-16 V 1.0.3 Phase 2 ข้อ 16  Communication Sheet PH2-ML-SF-003 Coop. Dis is not shown on Screen when Copy Sale.xls
                    '-------------------------------------------------------------------------
                    Call W_AddProduct2GridAgain
                    With wMain.ogdForm
                        ' If wMain.olaChange.Visible Then wMain.olaChange.Visible = False '*KT 54-09-20 V.4.0.1 กรณีที่ไม่เป็น OPOS ในการแสดงเงินทอน
                        wMain.olaSKUName.Caption = .TextMatrix(nRow, .ColIndex("FTSkuAbbName"))
                        wMain.olaBarcode.Caption = .TextMatrix(nRow, .ColIndex("FTSdtBarCode"))
                        wMain.olaPrice.Caption = SP_FMTcCurPoint(.TextMatrix(nRow, .ColIndex("FCSdtSaleAmt")), False)
                    End With
                    '--------------------------------------------------------------------------
                End If
                '------------------------------------------------------------
                If bVB_OPOSLineDisplayEnable Then
'                    tPrint = wMain.ogdForm.TextMatrix(.ogdForm.rows - 1, .ogdForm.ColIndex("FTSdtBarCode")) & ";" & .ogdForm.TextMatrix(.ogdForm.rows - 1, .ogdForm.ColIndex("FCSdtSaleAmt"))
                    tPrint = wMain.ogdForm.TextMatrix(.ogdForm.rows - 1, .ogdForm.ColIndex("FTSkuAbbName")) & ";" & .ogdForm.TextMatrix(.ogdForm.rows - 1, .ogdForm.ColIndex("FCSdtSaleAmt")) '*Eaw 56-07-01CommSheet TK-ISS3000-252-TR.xls แก้ให้แสดง Display เป็น SKU Name
                    Call SP_PrnPollDisplay(tPrint)
                End If
                Call wMain.W_ClearValAfterInsTSDT
                Call wMain.W_SumAmount(False)
                Call wMain.W_UPDxTransHD
                '------------------------------------------------------------------------
                cUT_Qty = 1
                wMain.olaRef.Caption = ""
                wMain.otbPrompt.Text = vbNullString
                Call SP_OBJxSetFocus(wMain.otbPrompt)
                nVB_CNScollItem = nRow '*KT 51-12-24 Phase 2 ต้องการให้หลังจากใช้คำสั่ง Copy Sale แล้วทำ Function ที่เกี่ยวกับ Items ให้ Default ที่รายการ Item สุดท้าย
            End If
        End With
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
    Call SP_DATxRsNothing(orsTemp)
    Call SP_DATxRsNothing(orsCD)
    Call SP_DATxRsNothing(orsSKU)
End Sub

Public Sub W_KBQtyChange()
'----------------------------------------------------------
'   Call:
'   Cmt:    '*KT 50-12-29 การเปลี่ยนจำนวน
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim i As Integer
    Dim bVoid As Boolean
    Dim nRow As Long
    '_____________________________
    On Error GoTo ErrHandle
    Call wMain.W_ClearValAfterInsTSDT               '*Ao 2011/03/31  CommSheet ML-PRV-054-SF Wrong qty on last item.xls
    If Val(Format(tVB_TransactionSub)) = tEN_TrnReturn Or Val(Format(tVB_TransactionSub)) = tEN_TrnReturnTaxInc Or Val(Format(tVB_TransactionSub)) = tEN_TrnReturnManualTax Then        '* Ao 51-06-27 การคืนแบบไม่มีเงื่อนไข ไม่ต้องมีส่วนลดใดๆเกิดขึ้น
        If bVB_Reference = False Then
            If bMainFunc Then  'เรียกคำสั่ง CallByName จากหน้าจอ main
                nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
            Else
                nRow = wMain.ogdForm.Row
            End If
            If W_DEFbChkDiscAgain(nRow) Then
                Exit Sub
            End If
        End If
    End If
    '_____________________________
    'ใส่ชื่อ ฟังก์ชัน แทน XXX ข้างล่าง
    bAccept = W_CheckLevelPass("W_KBQtyChange")
    If bAccept Then     'if level is ok
    
         tVB_CNMnuCurrent = "1807"
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
'             DoEvents '*KT 53-01-14 DoEvents
             If tVB_CNUserAlwC = "" Then
                 Exit Sub
             End If
         End If
         
        'process ทำทุกรายการ คล้าย Void
        With wMain.ogdForm
'            nRow = .Row             '*AO51-03-20            Comm.Sheet   ML-SF-102      Code เก่าทำให้ ไม่สามารถ Browse จาก Function ได้ '*KT 51-05-12 Comsheet ML-SF-269
            If bMainFunc Then  'เรียกคำสั่ง CallByName จากหน้าจอ main
                nRow = .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))
            Else
                'nRow = .Row
                'nRow = nVB_CNScollItem
                nRow = IIf(nVB_CNScollItem > 0, nVB_CNScollItem, .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))) '*Tao 60-05-03 ถ้าไม่ได้กำหนด ให้เอาล่างสุด
            End If
            If nRow < 1 Then
                Call SP_MSGnShowing("tms_CN005104", nCS_Information)
                .Enabled = False
                Call SP_OBJxSetFocus(wMain.otbPrompt)
                Exit Sub                'if no item in grid, nothing to do
            End If
            
            '*KT 51-03-26 Comm.Sheet   ML-SF-142
            If Trim(.TextMatrix(nRow, .ColIndex("FTSdtCancelFlag"))) = "1" Then bVoid = True
            If bVoid Then
                Call SP_MSGnShowing("tms_CN005161", nCS_Information)
                Exit Sub
            End If
            '*AO 51-03-28 Comm.Sheet   ML-SF-166
            If Trim(.TextMatrix(nRow, .ColIndex("FNSdtQty"))) = "" Then bVoid = True     'Row not Item
            If bVoid Then
                Exit Sub
            End If
 '----------------------------------------------------
 
            wMain.otbPrompt.Text = ""       ' ป้องกันกรณี Key ตัวเลขแล้วเลือกรายการโดยเข้าใจว่าเลือกลดรายการ
            bVB_FKeyQtyChange = True
            .Enabled = True
             wMain.otbPrompt.Locked = True
             wMain.nW_GridEnter = 0
             wMain.bW_GridEnter = False
            .HighLight = flexHighlightAlways
            .Select nRow, 1        'move highlight to first row
            .Col = .ColIndex("FNSdtQty")
             DoEvents 'ห้ามเอาออกไม่นั้นจะทำให้ Grid ไม่มีการ Select Row
            .EditCell

        End With
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
    Exit Sub
ErrHandle:
    Call wMain.W_ClearValAfterInsTSDT               '*Ao 2011/03/31  CommSheet ML-PRV-054-SF Wrong qty on last item.xls
End Sub

Public Sub W_KBPriceOverride()
'----------------------------------------------------------
'   Call:
'   Cmt:    '*KT 50-12-29 การเปลี่ยนราคา
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim nI As Integer
    Dim bVoid As Boolean
    Dim nRow As Long
On Error GoTo ErrHandle

    'ใส่ชื่อ ฟังก์ชัน แทน XXX ข้างล่าง
    '_____________________________
    If Val(Format(tVB_TransactionSub)) = tEN_TrnReturn Or Val(Format(tVB_TransactionSub)) = tEN_TrnReturnTaxInc Or Val(Format(tVB_TransactionSub)) = tEN_TrnReturnManualTax Then       '* Ao 51-06-27 การคืนแบบไม่มีเงื่อนไข ไม่ต้องมีส่วนลดใดๆเกิดขึ้น
        If bVB_Reference = False Then
            nRow = wMain.ogdForm.Row
            If nRow = 0 Then nRow = 1
            If W_DEFbChkDiscAgain(nRow) Then
                Exit Sub
            End If
        End If
    End If
    '_____________________________
    bAccept = W_CheckLevelPass("W_KBPriceOverride")
    If bAccept Then     'if level is ok
        'process ทำทุกรายการ คล้าย Void
        If Not bVB_PriceOveride Then
            Select Case SP_VALnText2Double(tVB_TransactionSub)
                Case tEN_TrnSale, tEN_TrnVIPSale, tEN_TrnTaxExceptSale, tEN_TrnIPVVIPService, tEN_TrnDeposit
                    tVB_CNMnuCurrent = "1808"
                    
'Comsheet ML-SF-118
                    If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
'                        DoEvents '*KT 53-01-14 DoEvents
                        If tVB_CNUserAlwC = "" Then
                            Exit Sub
                        End If
                    End If
'                    DoEvents '*KT 53-01-14 DoEvents
'-----------------------------------------------

                Case Else
                    Call SP_MSGnShowing("tms_CN005107", nCS_Information)
                    Exit Sub
            End Select
            bVB_PriceOveride = True
            wMain.ostForm.Panels(2).Text = "Price Overide"
'            DoEvents '*KT 53-01-14 DoEvents
        End If
        With wMain.ogdForm
            'Comsheet ML- SF- 403
'===================================================================================
            If bMainFunc Then  'เรียกคำสั่ง CallByName จากหน้าจอ main
                nRow = .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))
            Else
                'nRow = .Row
                'nRow = nVB_CNScollItem '*KT 51-10-09 V 3.0.131/V 3.0.200
                nRow = IIf(nVB_CNScollItem > 0, nVB_CNScollItem, .Aggregate(flexSTMax, .FixedRows, .ColIndex("FNSdtSeqNo"), .rows - 1, .ColIndex("FNSdtSeqNo"))) '*Tao 60-05-03 ถ้าไม่ได้กำหนด ให้เอาล่างสุด
            End If
            If nRow < 1 Then
                Call SP_MSGnShowing("tms_CN005104", nCS_Information)
                .Enabled = False
                wMain.otbPrompt.Text = vbNullString
                wMain.otbPrompt.Locked = False
                Call SP_OBJxSetFocus(wMain.otbPrompt)
                Exit Sub                'if no item in grid, nothing to do
            End If
'=====================================================================================
            '*KT 51-03-26 Comm.Sheet   ML-SF-142
            If Trim(.TextMatrix(nRow, .ColIndex("FTSdtCancelFlag"))) = "1" Then bVoid = True
            If bVoid Then
                Call SP_MSGnShowing("tms_CN005161", nCS_Information)
                Exit Sub
            End If
            
            '*KT 51-12-24 Phase 2 กรณีที่ Item นั้นได้ส่วนลดใด จะไม่สามารถทำ Price Override
            '*KT 52-06-12 PH 2.0 ML-SF-027 Price Override ไม่สามารถใช้กับสินค้า Promotion ได้ (ให้สามารถทำ Price Overide กรณีที่ได้ส่วนลด Deal , PromotionTime,Promotion)
            If W_GETbHaveDisc(tVB_CNTerminalNum, tVB_Running, tUT_SaleDate, nRow) Then
                Call SP_MSGnShowing("tms_CN005107", nCS_Information)
                Exit Sub
            End If
 '----------------------------------------------------
            wMain.otbPrompt.Text = ""       ' ป้องกันกรณี Key ตัวเลขแล้วเลือกรายการโดยเข้าใจว่าเลือกลดรายการ
            bVB_PriceOveride = True
            .Enabled = True
             wMain.otbPrompt.Locked = True
             wMain.tW_KeyPress = ""
             wMain.nW_GridEnter = 0 '*KT 52-11-26 PH 3.0-ML-SF-034  กด Price Override เป็นเศษสตางค์  เครื่องมีข้อความเตื่อน แต่เมื่อกด Enter แล้วใส่จำนวนเงินใหม่ เมื่อพิมพ์ Receipt จะพิมพ์ค่าที่ป้อนผิด
             wMain.bW_ChkDecimals = True '*KT 52-11-26 PH 3.0-ML-SF-034  กด Price Override เป็นเศษสตางค์  เครื่องมีข้อความเตื่อน แต่เมื่อกด Enter แล้วใส่จำนวนเงินใหม่ เมื่อพิมพ์ Receipt จะพิมพ์ค่าที่ป้อนผิด
            .HighLight = flexHighlightAlways
            .Select nRow, 1        'move highlight to first row
            .Col = .ColIndex("FCSdtSaleUnit")
             DoEvents 'ห้ามเอาออกไม่นั้นจะทำให้ Grid ไม่มีการ Select Row '*KT 51-10-09 V 3.0.131/V 3.0.200
            .EditCell
        End With
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        If bVB_PriceOveride Then
            wMain.ostForm.Panels(2).Text = "Ready..."
            bVB_PriceOveride = False
            wMain.otbPrompt.Text = vbNullString
            wMain.otbPrompt.Locked = False
            Call SP_OBJxSetFocus(wMain.otbPrompt)
        End If
    End If
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    If bVB_PriceOveride Then
        wMain.ostForm.Panels(2).Text = "Ready..."
        bVB_PriceOveride = False
        wMain.otbPrompt.Text = vbNullString
        wMain.otbPrompt.Locked = False
        Call SP_OBJxSetFocus(wMain.otbPrompt)
    End If
End Sub

Private Function W_GETbHaveDisc(ByVal ptTmnNum$, ByVal ptTrnNo$, ByVal ptTrnDate$, ByVal pnSeqNo As Long)
'----------------------------------------------------------
'   Call:
'   Cmt:    ตรวจสอบรายการสินค้าที่ขายมีส่วนลดอื่นที่ยอมให้ทำ Price Overide
'*Ao 52-02-12  PH2-ML-SF079  PriceOveride กับสินค้า Deal & Free Item,Promotion Timesale,Promotion สถานะปัจจุบัน Pending
'*KT 52-06-12 PH 2.0 ML-SF-027 Price Override ไม่สามารถใช้กับสินค้า Promotion ได้ (ให้สามารถทำ Price Overide กรณีที่ได้ส่วนลด Deal , PromotionTime,Promotion)
'----------------------------------------------------------
    Dim tSql As String
    Dim orsTemp As ADODB.Recordset
On Error GoTo ErrHandle
    W_GETbHaveDisc = False
    tSql = "SELECT FTShdTransNo FROM " & tVB_CNTblCD
    tSql = tSql & vbCrLf & " WHERE FTTmnNum = '" & ptTmnNum & "'"
    tSql = tSql & vbCrLf & " AND FTShdTransNo = '" & ptTrnNo & "'"
    tSql = tSql & vbCrLf & " AND FDShdTransDate = '" & ptTrnDate & "'"
    tSql = tSql & vbCrLf & " AND FNSdtSeqNo = " & pnSeqNo
    tSql = tSql & vbCrLf & " AND NOT(FNDctNo IN ('1','2','3','21'))"     '*Ao 2010/12/16  Price Override
    Call SP_SQLvExecute(tSql, orsTemp)
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        W_GETbHaveDisc = True
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    W_GETbHaveDisc = False
    Call SP_DATxRsNothing(orsTemp)
End Function

