Public Sub W_KBCancelNagativeScan()
'----------------------------------------------------------
'   Call:
'   Cmt:    cancel items
'   Step:
'   1 ตรอบสอบสิทธิการใช้งาน
'   2 หา row ของ Item ที่จะทำการ Cancel
'   3 ขึ้นข้อความการยืนยันการ Cancel
'   4 ใส่ข้อมูลลงตาราง grid
'   5 ทำการ insert ข้อมูล cancel ลง DT
'   6 update item ที่ถูก cancel
'----------------------------------------------------------
    Dim orsTemp As ADODB.Recordset
    Dim bAccept As Boolean

    
    bAccept = W_CheckLevelPass("W_KBCancelNagativeScan")

    If bAccept Then        'ทำงานเฉพาะใน if- then
    
        tVB_CNMnuCurrent = "1801"
        If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
'             DoEvents '*KT 53-01-14 DoEvents
             If tVB_CNUserAlwC = "" Then
                 Exit Sub
             End If
         End If
        If wMain.ogdForm.rows < 2 Then
            Call SP_MSGnShowing("tms_CN005104", nCS_Information)
            Exit Sub         'if no item in grid, nothing to do
        End If
        With wMain
             bVB_NagativeScan = True
            wMain.ostForm.Panels(2).Text = "Nagative Scan"
            .otbPrompt.Text = vbNullString
            .otbPrompt.SetFocus
       End With
    Else    'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
    End If
    Call SP_DATxRsNothing(orsTemp)
End Sub

