Public Sub W_PRCxMemberPrice(ByVal pnSeqNo As Long, ByVal ptSKUCode As String, Optional ByVal pcMBQty As Double = 0, Optional ByVal pnScdSeqNo As Long = 0, Optional ByVal pbFrmDeal As Boolean = False)
'-----------------------------------------------------------------------------------------------------------------------------------------------------------
'Call:
'Cmt: ทำการปรับปรุงราคาสินค้าว่าเป็นราคา member price ไม่ใช่ราคาปกติ
'*KT 52-02-16 member price
'-----------------------------------------------------------------------------------------------------------------------------------------------------------
    Dim tSql As String
    Dim nEffect As Long
    Dim tWhr As String
    Dim cQty As Double
    Dim bPass As Boolean
    Dim nRow As Long
On Error GoTo Err_Handler
    bPass = False
    If bVB_CNMemberPrice Then
        If xVB_CNMemberP.ID <> "" And xVB_CNMemberP.MallCardMemberPrice = "Y" And tVB_StaMemPriceAlw = "Y" And Not tVB_StaMemPricePromoAlw Then
            ocnAll.BeginTrans
            bPass = True
            nVB_CNCountBegin = nVB_CNCountBegin + 1
            cQty = 0
            tWhr = " WHERE " & tVB_CNWheBill
            tWhr = tWhr & vbCrLf & " AND FTSkuCode = '" & ptSKUCode & "'"
            tWhr = tWhr & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
            tWhr = tWhr & vbCrLf & " AND FTSdtStaRfd = 'Y'"
'            tWhr = tWhr & vbCrLf & " AND FCSdtMemberPrice = FCSdtB4DisChg"
            tWhr = tWhr & vbCrLf & " AND ISNULL(FTSdtEventMemPrice,'') <> ''" '*KT 52-09-08 Member Price + Consignment
            If cQty < 1 Then
                cQty = CDbl(Val(Format(SP_SQLtFunction("SUM", "FCSdtQty", tVB_CNTblDT, tWhr)))) '*KT 52-09-23 ปรับให้การทำงานเร็วขึ้น
            Else
                cQty = pcMBQty
            End If
            If cQty <= CDbl(nVB_CNMemPriceMaxQty) Then
                bVB_SKUisPromotion = True
                tSql = "UPDATE " & tVB_CNTblDT & " SET "
                Select Case Val(Format(tVB_TransactionSub))
                    Case tEN_TrnDutyFreeSale
'                        tSql = tSql & vbCrLf & " FCSdtB4DisChg = ROUND(FCSdtMemberPrice,2)" '*KT 52-09-08 Member Price + Consignment
                        tSql = tSql & vbCrLf & " FCSdtSalePrice = ROUND(FCSdtMemberPrice,2)"
                        tSql = tSql & vbCrLf & " ,FCSdtSaleUnit = ROUND(FCSdtMemberPrice,2)"
                        tSql = tSql & vbCrLf & " ,FCSdtSaleAmt = ROUND((FCSdtMemberPrice) * FCSdtQty,2) "
                        tSql = tSql & vbCrLf & " ,FCSdtQtyAllDisAvi = ROUND(FCSdtQty,2)"
'                        tSql = tSql & vbCrLf & " ,FCSdtAmtDisAvi =0" '*KT 52-12-09 กรณีที่สินค้าเป็น Member Price + Consignment และเป็น Double Policy กับ Mall Card ต้องเป็นสินค้าป้ายน้ำเงิน
                    Case tEN_TrnTaxExceptSale
'                        tSql = tSql & vbCrLf & " FCSdtB4DisChg = ROUND(FCSdtMemberPrice,2)" '*KT 52-09-08 Member Price + Consignment
                        tSql = tSql & vbCrLf & " FCSdtSalePrice = ROUND(FCSdtMemberPrice * 100 / (100 + FCSdtTax),2)"
                        tSql = tSql & vbCrLf & " ,FCSdtSaleUnit = ROUND(FCSdtMemberPrice * 100 / (100 + FCSdtTax),2)"
                        tSql = tSql & vbCrLf & " ,FCSdtSaleAmt = ROUND((FCSdtMemberPrice * 100 / (100 + FCSdtTax)) * FCSdtQty,2) "
                        tSql = tSql & vbCrLf & " ,FCSdtQtyAllDisAvi = ROUND(FCSdtQty,2)"
'                         tSql = tSql & vbCrLf & " ,FCSdtAmtDisAvi =0" '*KT 52-12-09 กรณีที่สินค้าเป็น Member Price + Consignment และเป็น Double Policy กับ Mall Card ต้องเป็นสินค้าป้ายน้ำเงิน
                    Case Else
'                        tSql = tSql & vbCrLf & " FCSdtB4DisChg = ROUND(FCSdtMemberPrice,2)" '*KT 52-09-08 Member Price + Consignment
                        tSql = tSql & vbCrLf & " FCSdtSalePrice = ROUND(FCSdtMemberPrice,2)"
                        tSql = tSql & vbCrLf & " ,FCSdtSaleUnit = ROUND(FCSdtMemberPrice,2)"
                        tSql = tSql & vbCrLf & " ,FCSdtSaleAmt = ROUND((FCSdtMemberPrice) * FCSdtQty,2) "
                        tSql = tSql & vbCrLf & " ,FCSdtQtyAllDisAvi = ROUND(FCSdtQty,2)"
'                         tSql = tSql & vbCrLf & " ,FCSdtAmtDisAvi =0" '*KT 52-12-09 กรณีที่สินค้าเป็น Member Price + Consignment และเป็น Double Policy กับ Mall Card ต้องเป็นสินค้าป้ายน้ำเงิน
                End Select
                tSql = tSql & vbCrLf & " ,FCSdtDis = 0"
                '*KT 52-09-08 Member Price + Consignment
                '*KT 52-02-09 Communication Sheet PH3-ML-SD-043 RF unit price wrong (Mprice+Promo)
'                If tVB_SKUConsignFlag = "N" Then
'                    tSql = tSql & vbCrLf & " ,FTSkuStaMallEmpCard = 'N'"
'                Else
'                    bVB_SKUisPromotion = False '*KT 52-12-09 กรณีที่สินค้าเป็น Member Price + Consignment และเป็น Double Policy กับ Mall Card ต้องเป็นสินค้าป้ายน้ำเงิน
'                End If
                Select Case W_CHKnDDPMallCard(IIf(UCase(tVB_SKUConsignFlag) = "Y", nEN_Disc22MDisc, nEN_Disc21MPrice))
                    Case 0
                        tSql = tSql & vbCrLf & " ,FTSkuStaMallEmpCard = 'N'"
                        bVB_SKUisPromotion = True
                    Case 1
                        tSql = tSql & vbCrLf & " ,FTSkuStaMallEmpCard = 'Y'"
                        bVB_SKUisPromotion = False
                    Case 2
                        tSql = tSql & vbCrLf & " ,FTSkuStaMallEmpCard = 'Y'"
                        bVB_SKUisPromotion = False
                    Case Else
                        tSql = tSql & vbCrLf & " ,FTSkuStaMallEmpCard = 'N'"
                         bVB_SKUisPromotion = True
                End Select
                tSql = tSql & vbCrLf & " ,FTSdtStaRfd = 'Y'"
                If bVB_SKUisPromotion Then
                        Select Case Val(Format(tVB_TransactionSub))
                            Case tEN_TrnTaxExceptSale
                                tSql = tSql & vbCrLf & " ,FCSdtBSubPro = ROUND((FCSdtMemberPrice * 100 / (100 + FCSdtTax)) * FCSdtQty,2) "
                                tSql = tSql & vbCrLf & " ,FCSdtYellowPrice= ROUND((FCSdtMemberPrice * 100 / (100 + FCSdtTax)) * FCSdtQty,2) "
                                tSql = tSql & vbCrLf & " ,FCSdtBSubReg = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtBluePrice = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubPro = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubReg = 0"
                            Case Else
                                tSql = tSql & vbCrLf & " ,FCSdtBSubPro = ROUND((FCSdtMemberPrice) * FCSdtQty,2)"
                                tSql = tSql & vbCrLf & " ,FCSdtYellowPrice= ROUND((FCSdtMemberPrice) * FCSdtQty,2)"
                                tSql = tSql & vbCrLf & " ,FCSdtBSubReg = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtBluePrice = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubPro = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubReg = 0"
                        End Select
                Else
                        Select Case Val(Format(tVB_TransactionSub))
                            Case tEN_TrnTaxExceptSale
                                tSql = tSql & vbCrLf & " ,FCSdtBSubPro = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtYellowPrice= 0"
                                tSql = tSql & vbCrLf & " ,FCSdtBSubReg = ROUND((FCSdtMemberPrice) * FCSdtQty,2)"
                                tSql = tSql & vbCrLf & " ,FCSdtBluePrice = ROUND((FCSdtMemberPrice) * FCSdtQty,2)"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubPro = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubReg = 0"
                            Case Else
                                 tSql = tSql & vbCrLf & " ,FCSdtBSubPro = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtYellowPrice= 0"
                                tSql = tSql & vbCrLf & " ,FCSdtBSubReg = ROUND((FCSdtMemberPrice * 100 / (100 + FCSdtTax)) * FCSdtQty,2) "
                                tSql = tSql & vbCrLf & " ,FCSdtBluePrice = ROUND((FCSdtMemberPrice * 100 / (100 + FCSdtTax)) * FCSdtQty,2) "
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubPro = 0"
                                tSql = tSql & vbCrLf & " ,FCSdtDiscSubReg = 0"
                        End Select
                End If
                tSql = tSql & vbCrLf & " WHERE " & tVB_CNWheBill
                tSql = tSql & vbCrLf & " AND FNSdtSeqNo =" & pnSeqNo
                tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
                nEffect = 0
                Call SP_SQLvExecute(tSql, , , , , nEffect)
                If nEffect > 0 Then
                    '*KT 52-09-07 MemberPrice + Consignment
                    oDisc.DISxClearAll
                    '------------------------------------------------------------------------------------
                    If pnScdSeqNo > 0 Then
                         oDisc.bRecalByItem = True
                         oDisc.nScdSeqNo = pnScdSeqNo
                    Else
                        oDisc.bRecalByItem = False
                        oDisc.nScdSeqNo = pnScdSeqNo
                    End If
                    oDisc.dTranDate = tUT_SaleDate
                    oDisc.tTerminalNo = tVB_CNTerminalNum
                    oDisc.tTransNo = tVB_Running
                    oDisc.nDTSeqNo = pnSeqNo
                    If UCase(tVB_SKUConsignFlag) = "Y" Then
                        oDisc.nENDiscType = nEN_Disc22MDisc
                    Else
                        oDisc.nENDiscType = nEN_Disc21MPrice
                    End If
                    Select Case oDisc.C_CHKnDDPDeal(oDisc.nDTSeqNo)  'Check Double Policy
                        Case 0 'ไม่อนุญาต
                            'คิดเฉพาะส่วนที่เหลือ
                            oDisc.bPromoAftDeal = True
                        Case 1 'อนุญาต
                            oDisc.bPromoAftDeal = False
                        Case 2 'หาผลที่ดีที่สุด
                            'รอดำเนินการ
                            oDisc.bPromoAftDeal = False
                        Case Else
                            oDisc.bPromoAftDeal = False
                    End Select
                    oDisc.tEventID = tVB_CNEventMemPrice
                    oDisc.cDiscValue = cVB_CNMemPriceAmt
                    Select Case tVB_CNMemPriceType
                        Case "1" '% Off
                            oDisc.nENLnDisType = nEN_LnDis1Per
                            oDisc.cDiscPer = cVB_CNMemPriceAmt
                        Case "2" 'Amount Off
                            oDisc.nENLnDisType = nEN_LnDis2Amt
                            oDisc.cDiscAmt = cVB_CNMemPriceAmt
                        Case "3" 'New Price
                            oDisc.nENLnDisType = nEN_LnDis3NewPrice
                            oDisc.cDiscNew = cVB_CNMemPriceAmt
                        Case "4" 'No Promotion
                            Call SP_DISxShwDisc2Grid(pnSeqNo, wMain.ogdForm)
                            If bPass Then
                                ocnAll.RollbackTrans
                                bPass = False
                                nVB_CNCountBegin = nVB_CNCountBegin - 1
                            End If
                            Exit Sub
                        Case Else
                            Call SP_DISxShwDisc2Grid(pnSeqNo, wMain.ogdForm)
                            If bPass Then
                                ocnAll.RollbackTrans
                                bPass = False
                                nVB_CNCountBegin = nVB_CNCountBegin - 1
                            End If
                            Exit Sub
                    End Select
                    oDisc.cDiscPerOrg = oDisc.cDiscPer
                    oDisc.cDiscAmtOrg = oDisc.cDiscAmt
                    oDisc.cDiscNewOrg = oDisc.cDiscNew
                    oDisc.nActSeqNo = pnSeqNo
                    oDisc.tCardID = xVB_CNMemberP.ID
                    oDisc.tCardType = xVB_CNMemberP.MallCardType
                    oDisc.dCardExpDate = xVB_CNMemberP.MallCardExpire
                    Call oDisc.C_DATxInsertDiscCD(cVB_CNMemPriceAmtDis, pnSeqNo, tVB_CNEventMemPrice, cUT_Qty, cUT_RegPrice * cUT_Qty, cUT_Qty)
                    Call oDisc.C_DATxSumDT(eEN_VerifyDiscType.nEN_Type1ByItem) '*KT 52-09-23 Analyse code
                    Call oDisc.C_UPDxLabel '*KT 52-12-09 กรณีที่สินค้าเป็น Member Price + Consignment และเป็น Double Policy กับ Mall Card ต้องเป็นสินค้าป้ายน้ำเงิน
                    '----------------------------------------------------------------------------------
                    If pnScdSeqNo = 0 And pbFrmDeal = False Then Call SP_DISxShwDisc2Grid(pnSeqNo, wMain.ogdForm) 'ไม่ต้องแสดงใหม่
                End If
            End If
        End If
    End If
    If bPass Then
        ocnAll.CommitTrans
        bPass = False
        nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    Exit Sub
Err_Handler:
    If bPass Then
        ocnAll.RollbackTrans
        bPass = False
        nVB_CNCountBegin = nVB_CNCountBegin - 1
    End If
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

Public Function W_DEFcSUMChangeAll(ByVal porsTemp As ADODB.Recordset, ByVal ptTemp As String) As Double
'--------------------------------------------------------------------------
'Call:
'Cmt:   '*Ao 52-02-17
'--------------------------------------------------------------------------
    Dim cSumTmp As Double
