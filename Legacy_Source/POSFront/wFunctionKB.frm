        End If
        If bTranSrv Then
            oDB.ocnOnLine.CommitTrans
            bTranSrv = False
            nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
        End If
    End If
    Exit Sub
ErrHandle:
    If bTranSrv Then
        oDB.ocnOnLine.RollbackTrans
        bTranSrv = False
        nVB_CNCountBeginSrv = nVB_CNCountBeginSrv - 1
    End If
End Sub

