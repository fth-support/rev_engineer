'                    cVB_DiscLineItem = oDisc.cLastDiscount
'                    Call W_AddProduct2GridAgain
'                End If
'                cDiscAmt = SP_FEDvChkNumeric(orsTemp, "FCScdDiscNew")
'                If cDiscAmt <> 0 Then
'                    nVB_TypeDiscLineItem = nEN_LnDis3NewPrice
'                    oDisc.bRecalByItem = False
