                    nVB_CNMemPriceMaxQty = 0
                    tVB_CNMemPriceType = ""
                    cVB_CNMemPriceAmt = 0
                    cVB_CNMemPriceAmtDis = 0
                End If
            Else
               tVB_StaMemPriceAlw = "N"
