        End Select
    Else
        tSql = tSql & vbCrLf & " ,SUM(CASE WHEN  FTShdTransType IN ('" & Format(tEN_TrnIPV, "00") & "','" & Format(tEN_TrnIPVRedeem, "00") & "','" & Format(tEN_TrnIPVVIPService, "00") & "','" & Format(tEN_TrnIPVTaxExceptSale, "00") & "','" & Format(tEN_TrnIPVDutyFreeSale, "00") & "','" & Format(tEN_TrnIPVOtherReceive, "00") & "')"
