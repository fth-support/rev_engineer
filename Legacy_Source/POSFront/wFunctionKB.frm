    'insert to TSCDXXX
    tTable = tVB_CNTblCD
    tSql = "STP_CNxSQLSelHoldCDByWhr @ptTmnNum ='" & tVB_TerminalRecall & "',@ptRunning ='" & tVB_TransNoRecall & "',@ptTransType ='" & tVB_TransTypeRecall & "',@ptTransDate ='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub  'PH 2.0.0 ติดต่อฐานข้อมูล server ตลอด
    Do While Not orsTemp.EOF
        Call W_DupTblBtwSleNHold(orsTemp, tTable, nSeqNo, False, , , , , 2)
