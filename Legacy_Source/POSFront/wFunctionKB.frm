Public Sub W_AddxDataPrintClosingTenderBlank(ByVal ptSep As String, ByRef pnSeqNo As Long, Optional ByVal pbSal As Boolean = False, Optional ByVal pbCloseTmn As Boolean = False, Optional ByVal ptCloRunning As String = "")
'--------------------------------------
'Cmt:
'Call: Insert tender to DT(Print Closing Report)
'--------------------------------------
    Dim tFed$, tStr$, tF$
    Dim tSql$, tSqlF$, tSqlV$
    Dim tTblDT As String
    Dim tFUpd As String
    Dim tVUpd As String
    
   Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxDataPrintClosingTenderBlank[1]")
    tFed = "": tStr = "": tF = ""
    tSql = "": tSqlF = "": tSqlV = ""
    If pbSal Then
        tTblDT = "TPSTSalDT"
    Else
         tTblDT = tVB_CNTblDT
    End If
On Error GoTo ErrHandle
    If pbCloseTmn Then
        tFed = "FNCloSeqNo,FTCloCode,FTCloName,FTCloGrp,FCCloQty,FCCloAmt,FTCloMode"
    Else
        tFed = "FTStmCode,FTTmnNum,FTShdTransNo,FNSdtSeqNo,FTSkuCode"
        tFed = tFed & ",FTSkuAbbName,FTShdTransType,FDShdTransDate,FTSdtBarCode,FTSdtStkCode"
        tFed = tFed & ",FCSdtStkFac,FTTaxCode,FTDpcCode,FTSkuDepCode,FTSkuBrdCode"
        tFed = tFed & ",FTPunCode,FTSdtUnitName,FCSdtRegPrice,FTSdtEventPrice,FCSdtQty"
        tFed = tFed & ",FCSdtSaleTaxAmt,FCSdtReturnTaxAmt"
        tFed = tFed & ",FTSdtInstoreBar,FCSdtB4DisChg,FTSdtDisChgTxt,FCSdtDis"
        tFed = tFed & ",FCSdtChg,FCSdtSaleAmt,FCSdtVat,FCSdtVatable,FCSdtQtyAll"
        tFed = tFed & ",FTSdtStaPdt"
        tFed = tFed & ",FTSdtWeight,FTSdtConsignFlag"
        tFed = tFed & ",FTSdtCancelFlag,FCSdtTax,FCSdtSalePrice,FTShdTransTime"
        tFed = tFed & ",FTSkuAbbNameSnd,FTSkuAbbNameSrvDoc,FTSkuAbbNameSndSrvDoc"
        tFed = tFed & ",FTTaxSign,FTTaxStaSign"
        tFed = tFed & ",FCSdtSaleUnit"
        tFed = tFed & ",FCSdtQtyAllDisAvi"
        tFed = tFed & ",FCSdtAmtDisAvi"
        tFed = tFed & ",FCSdtDutyFreeAmt"
        tFed = tFed & ",FCSdtDutyFreeQty"
        tFed = tFed & ",FCSdtDutyDeposit"
        tFed = tFed & ",FCSdtWeight"
        tFed = tFed & ",FTSdtPriceOverideFlag"
    End If
    tSqlF = tFed
    tSqlF = "(" & tSqlF & "," & tCS_CNLastFedIns
    tF = tFed
    If pbCloseTmn Then
        tSql = "INSERT INTO TPSTClose"
    Else
         tSql = "INSERT INTO " & tTblDT
    End If
    tStr = cUT.UT_STRtToken(tF, ",", 1)
    
    Do While tStr <> ""
        If pbCloseTmn Then
            Select Case UCase(tStr)
                Case UCase("FNCloSeqNo"): tSqlV = tSqlV & pnSeqNo & ","
                Case UCase("FTCloGrp"): tSqlV = tSqlV & "'" & ptCloRunning & "',"
                Case UCase("FTCloCode")
                        tSqlV = tSqlV & "'" & ptSep & "',"
                        tFUpd = "FTCloCode = '" & ptSep & "'"
                Case UCase("FTCloName")
                        tSqlV = tSqlV & "'" & "" & "',"
                Case UCase("FCCloQty"): tSqlV = tSqlV & 0 & ","
                Case UCase("FCCloAmt")
                        tSqlV = tSqlV & 0 & ","
                        tVUpd = ""
                Case Else
                    Select Case UCase(Mid(tStr, 2, 1))
                        Case "T"
                            tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                        Case "N", "C"
                            tSqlV = tSqlV & 0 & ","
                        Case "D"
                            tSqlV = tSqlV & "NULL" & ","
                    End Select
            End Select
            tStr = cUT.UT_STRtToken(tF, ",", 1)
        Else
            Select Case UCase(tStr)
                Case UCase("FTStmCode"): tSqlV = tSqlV & "'" & tVB_CNStoreCode & "',"
                Case UCase("FTTmnNum"): tSqlV = tSqlV & "'" & tVB_CNTerminalNum & "',"
                Case UCase("FTShdTransNo"): tSqlV = tSqlV & "'" & tVB_Running & "',"
                Case UCase("FTShdTransType"): tSqlV = tSqlV & "'" & Format(tVB_Transaction, "00") & "',"
                Case UCase("FDShdTransDate"): tSqlV = tSqlV & "'" & tUT_SaleDate & "',"
                Case UCase("FTShdTransTime"): tSqlV = tSqlV & "'" & Time$ & "',"
                Case UCase("FNSdtSeqNo"): tSqlV = tSqlV & pnSeqNo & ","
                Case UCase("FTEmpCode"): tSqlV = tSqlV & "'" & tVB_CNUserCode & "',"
                Case UCase("FTSkuAbbName"), UCase("FTSkuAbbNameSnd"), UCase("FTSkuAbbNameSrvDoc"), UCase("FTSkuAbbNameSndSrvDoc")
                        tSqlV = tSqlV & "'" & "" & "',"
                Case UCase("FCSdtSaleAmt"): tSqlV = tSqlV & 0 & ","
                Case UCase("FTSdtConsignFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FTTaxStaSign"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FTSkuStaMallEmpCard"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FTSdtPriceOverideFlag"): tSqlV = tSqlV & "'" & "N" & "',"
                Case UCase("FCSdtQty"), UCase("FCSdtQtyAll"): tSqlV = tSqlV & 0 & ","
                Case Else
                    Select Case UCase(Mid(tStr, 2, 1))
                        Case "T"
                            tSqlV = tSqlV & "'" & tCS_CNBlank & "',"
                        Case "N", "C"
                            tSqlV = tSqlV & 0 & ","
                        Case "D"
                            tSqlV = tSqlV & "NULL" & ","
                    End Select
            End Select
            tStr = cUT.UT_STRtToken(tF, ",", 1)
        End If
    Loop
    tSqlV = " VALUES (" & tSqlV & UT_tLastInsSql & ")"
    tSql = tSql & tSqlF & tSqlV
   If pbCloseTmn Then
        If SP_SQLvExecute(tSql, , oDB.ocnOffLine) = -2147217873 Then
                '*KT 51-10-27 V 3.0.143/V 3.0.200
                '---------------------------------------------------------
'                If tFUpd <> "" Then
'                    If tVUpd <> "" Then
'                         tSql = "UPDATE TPSTClose SET " & tVUpd & " WHERE " & tFUpd: Call SP_SQLvExecuteOff(tSql, , oDB.ocnOffLine)  '*KT 51-10-21 V 3.0.140/V 3.0.200 '*KT 51-10-28 V 3.0.144/V 3.0.200
'                         tSql = "UPDATE TPSTClose SET FNCloSeqNo =" & pnSeqNo & " WHERE " & tFUpd & " AND FNCloSeqNo < " & pnSeqNo: Call SP_SQLvExecuteOff(tSql, , oDB.ocnOffLine)  '*KT 51-10-21 V 3.0.140/V 3.0.200 '*KT 51-10-28 V 3.0.144/V 3.0.200
'                    Else
'                         tSql = "UPDATE TPSTClose SET FNCloSeqNo =" & pnSeqNo & " WHERE " & tFUpd & " AND FNCloSeqNo < " & pnSeqNo: Call SP_SQLvExecuteOff(tSql, , oDB.ocnOffLine)  '*KT 51-10-21 V 3.0.140/V 3.0.200 '*KT 51-10-28 V 3.0.144/V 3.0.200
'                    End If
'                End If
                '---------------------------------------------------------
        End If
    Else
        Call SP_SQLvExecute(tSql)
    End If
    Call SP_CRTxWriteLogTerminated("ErrorNumber:0" & " ErrorDesc:" & " Form:" & "wFunctionKB" & " Events:W_AddxDataPrintClosingTenderBlank[2]")
    Exit Sub
ErrHandle:
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_CRTxWriteLogTerminated("ErrorNumber:" & Err.Number & " ErrorDesc:" & Err.Description & " Form:" & "wFunctionKB" & " Events:W_AddxDataPrintClosingTenderBlank[3]")
End Sub

Public Sub W_RePrintSignOut(Optional ByVal pbSal As Boolean = False)
'----------------------------------------------------------
'   Call: pbSal = true กรณีที่ Exit Terminal  แล้วเปิด POSFront อีกครั้ง ต้องการทำ Reprint Closing Report ตัวเก่า  pbSal = False ปกติ
'   Cmt:  Print Clossing Report
'            *KT 53-01-07 แก้ไขการ Reprint Clossing Report กรณีเกิดเหตุการณ์ดังนี้ Print Closing --->>> Open Terminal(หน้าจอ Login กด Esc) --->>> Re-Print Closing
'----------------------------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim tTblHD As String
    Dim tTmnNum As String '*Eaw 56-06-28
    Dim tSaleDate As String '*Eaw 56-07-04 CommSheet TK-ISS3000-245-TR.xls
On Error GoTo ErrHandle
    If pbSal Then
        tTblHD = "TPSTSalHD"
    Else
        tTblHD = tVB_CNTblHD
    End If
    Select Case Val(Format(tVB_TransactionSub))  '*Eaw 56-06-28
        Case tEN_TrnClosingReportManualTax, tEN_TrnClosingReportTaxInc
'            Select Case Val(Format(tVB_TransactionSub)) '*Eaw 56-07-04 CommSheet TK-ISS3000-245-TR.xls
'                Case tEN_TrnClosingReportManualTax
'                    tTmnNum = tVB_CNVirTerminalNum
'                    tSaleDate = tVB_CNReEntryDate
'                Case Else
'                    tTmnNum = tVB_CNTerminalNum
'                    tSaleDate = tVB_CNReEntryDate
'            End Select
            '*Eaw 56-09-30 Re-Entry ให้ใช้ PhysicalPos ทั้ง 2 Mode
            tTmnNum = tVB_CNTerminalNum
            tSaleDate = tVB_CNReEntryDate
        Case Else
            tTmnNum = tVB_CNTerminalNum
            tSaleDate = tUT_SaleDate '*Eaw 56-07-04 CommSheet TK-ISS3000-245-TR.xls
    End Select
    
    Call SP_ChkxClosingMissing '*Tao 61-09-10 หาเลขที่ Closing
    
    tSql = "SELECT FTTmnNum,FTShdTransNo,FDShdTransDate,FTShdTransType FROM " & tTblHD
'    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "'"
    tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tTmnNum & "'"   '*Eaw 56-06-28
    tSql = tSql & vbCrLf & " AND  FTShdTransNo='" & tVB_CNClosingReprint & "'"
'    tSql = tSql & vbCrLf & " AND FDShdTransDate='" & tUT_SaleDate & "'"
    tSql = tSql & vbCrLf & " AND FDShdTransDate='" & tSaleDate & "'" '*Eaw 56-07-04 CommSheet TK-ISS3000-245-TR.xls
    If tVB_CNMnuCurrent <> "160603" Then
        tSql = tSql & vbCrLf & " AND FTShdTransType = '" & Format(tEN_TrnPrintClose, "00") & "'"
    Else
        tSql = tSql & vbCrLf & " AND FTShdTransType IN ('" & Format(tEN_TrnClosingReportTaxInc, "00") & "','" & Format(tEN_TrnClosingReportManualTax, "00") & "')"
    End If
    'tSql = tSql & vbCrLf & " AND FTEmpCode = '" & tVB_CNUserCode & "'" '*KT 51-11-06 ไม่ใช้ Emp code มาเป็นเงื่อนไขการ Reprint Closing Report
    tSql = tSql & vbCrLf & " ORDER BY FTShdTransNo DESC"
    If SP_SQLvExecute(tSql, orsTemp) = 0 Then
        If Not (orsTemp.BOF And orsTemp.EOF) Then
            oTransPrn.PrintEJ = False 'Comsheet ML- SF- 399
            oTransPrn.RePrint = True
            oTransPrn.RePrintNormal = True
            oTransPrn.RePrintCV1 = False
            oTransPrn.RePrintCV2 = False
            oTransPrn.TypePriner = tVB_CNTypePrinter
            oTransPrn.PhysicalTmnNum = tVB_CNPhysicalTerminalNum
'            Call oTransPrn.OpenTransaction(Val(SP_FEDtChkString(orsTemp, "FTShdTransType")), SP_FEDdChkDate(orsTemp, "FDShdTransDate"), tVB_CNTerminalNum, SP_FEDtChkString(orsTemp, "FTShdTransNo"), IIf(pbSal, False, True), tVB_TransNameABB)
            Call oTransPrn.OpenTransaction(Val(SP_FEDtChkString(orsTemp, "FTShdTransType")), SP_FEDdChkDate(orsTemp, "FDShdTransDate"), tTmnNum, SP_FEDtChkString(orsTemp, "FTShdTransNo"), IIf(pbSal, False, True), tVB_TransNameABB)  '*Eaw 56-06-28
            oTransPrn.PrintOut
            oTransPrn.PrintEJ = True 'Comsheet ML- SF- 399
            oTransPrn.RePrint = False
            oTransPrn.RePrintNormal = False
            bVB_CNClosingRptAgain = False
        Else
            If oDB.SQLbAvailableServer(oDB.OffServerName, oDB.OnComIP) Then
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine) = 0 Then
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                        oTransPrn.PrintEJ = False 'Comsheet ML- SF- 399
                        oTransPrn.RePrint = True
                        oTransPrn.RePrintNormal = True
                        oTransPrn.RePrintCV1 = False
                        oTransPrn.RePrintCV2 = False
                        oTransPrn.TypePriner = tVB_CNTypePrinter
                        oTransPrn.PhysicalTmnNum = tVB_CNPhysicalTerminalNum
'                        Call oTransPrn.OpenTransaction(Val(SP_FEDtChkString(orsTemp, "FTShdTransType")), SP_FEDdChkDate(orsTemp, "FDShdTransDate"), tVB_CNTerminalNum, SP_FEDtChkString(orsTemp, "FTShdTransNo"), IIf(pbSal, False, True), tVB_TransNameABB, True)
                        Call oTransPrn.OpenTransaction(Val(SP_FEDtChkString(orsTemp, "FTShdTransType")), SP_FEDdChkDate(orsTemp, "FDShdTransDate"), tVB_CNTerminalNum, SP_FEDtChkString(orsTemp, "FTShdTransNo"), IIf(pbSal, False, True), tVB_TransNameABB, True)  '*Eaw 56-06-28
                        oTransPrn.PrintOut
                        oTransPrn.PrintEJ = True 'Comsheet ML- SF- 399
                        oTransPrn.RePrint = False
                        oTransPrn.RePrintNormal = False
                        bVB_CNClosingRptAgain = False
                    Else
                        Call SP_MSGnShowing("tms_CN008026", nCS_Error)
                    End If
                Else
                    Call SP_MSGnShowing("tms_CN008026", nCS_Error)
                End If
            Else
                Call SP_MSGnShowing("tms_CN008026", nCS_Error)
            End If
        End If
    Else
        Call SP_MSGnShowing("tms_CN008026", nCS_Error)
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Sub
ErrHandle:
    oTransPrn.PrintEJ = True 'Comsheet ML- SF- 399
    Call SP_MSGxShowError(Err.Number, Err.Description)
    Call SP_DATxRsNothing(orsTemp)
End Sub

