    tSql = "SELECT  "
    tSql = tSql & vbCrLf & " COUNT(FTShdTransNo) AS FCNum"
    tSql = tSql & vbCrLf & " ,SUM(FCShdRnd) AS FCShdRnd"
'    tSql = tSql & vbCrLf & " ,FTShdTransType"                      '*Ao 2014/04/28     ***************
    tSql = tSql & vbCrLf & " ," & ptTransType
    tSql = tSql & vbCrLf & " ,FTShdStaCancel"
