'Cmt: ตรวจสอบ Limitการขายสินค้าที่อาจเป็นโปรโมชั่น
'--------------------------------------
    Dim tSql$
    Dim orsTemp As ADODB.Recordset
    Dim cMaxQty As Double
    Dim tCurDate$
On Error GoTo ErrHandle
    tCurDate = SP_DTEtStrSTD(SP_GETdChkDateDisc) '*KT 52-06-04 ตรวจสอบวันที่หมดอายุตามที่กำหนดใน parameter
     W_PRCbMaxQtyPromotionBySKU = True
     bVB_SKUisChkPromo = False
    If bVB_CNModePreviewDay And tVB_CNSKUFlagNotAlwPrvUse = "N" Then
        tSql = "STP_CNxGetMaxQtyPromoPre @ptTransDate='" & tCurDate & "',@ptSKUCode='" & ptSKUCode & "'"
    Else
        tSql = "STP_CNxGetMaxQtyPromo @ptTransDate='" & tCurDate & "',@ptSKUCode='" & ptSKUCode & "'"
    End If
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) <> 0 Then 'read master
        Call SP_DATxRsNothing(orsTemp)
        Exit Function
    End If
    If Not (orsTemp.BOF And orsTemp.EOF) Then
        bVB_SKUisPromotion = True
        bVB_SKUisChkPromo = True
        cMaxQty = SP_FEDvChkNumeric(orsTemp, "FNPpmSkuMaxQty")
        '*KT 53-11-01 Preview Day
        If bVB_CNModePreviewDay And tVB_CNSKUFlagNotAlwPrvUse = "N" Then
            tVB_CNSKUFlagAlwPrvUsePromo = SP_FEDtChkString(orsTemp, "FTPpmStaPreview")
        Else
           tVB_CNSKUFlagAlwPrvUsePromo = "N"
        End If
        tSql = " SELECT CASE WHEN SUM(FCSdtQtyAll)IS NULL THEN 0 ELSE SUM(FCSdtQtyAll) END AS FCSumQty FROM " & tVB_CNTblDT
        tSql = tSql & vbCrLf & " WHERE  FTTmnNum='" & tVB_CNTerminalNum & "' AND FTShdTransNo='" & tVB_Running & "'"
        tSql = tSql & vbCrLf & " AND  FTShdTransType='" & tVB_Transaction & "' AND FDShdTransDate='" & tUT_SaleDate & "'"
        tSql = tSql & vbCrLf & " AND  FTSkuCode='" & ptSKUCode & "'"
        tSql = tSql & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
        '*KT 52-04-08 Max Qty Member Price
        If bVB_CNMemberPrice Then
            If xVB_CNMemberP.ID <> "" And xVB_CNMemberP.MallCardMemberPrice = "Y" Then
                 tSql = tSql & vbCrLf & " AND  NOT (FTSdtStaRfd = 'Y' AND ISNULL(FTSdtEventMemPrice,'') <> '')" '*KT 52-09-08 Member Price + Consignment
            End If
        End If
        Call SP_SQLvExecute(tSql, orsTemp)
         If Not (orsTemp.BOF And orsTemp.EOF) Then
            If (SP_FEDvChkNumeric(orsTemp, "FCSumQty") + pcQty) > cMaxQty Then W_PRCbMaxQtyPromotionBySKU = False
         End If
    End If
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    W_PRCbMaxQtyPromotionBySKU = True
    Call SP_DATxRsNothing(orsTemp)
End Function

