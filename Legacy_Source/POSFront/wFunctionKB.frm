        Call SP_CRTxLogCashBalEvent("wFunctionKB", "W_KBRcvWalletPay[1]", "WalletPay Tender", cVB_Balance)
        cFAmt = cVB_Balance
        'เงินทอน
        If CDbl(cVB_Pay) < CDbl(SP_FMTcCurPoint(cVB_Balance, True, True)) Then    'เงินรับ น้อยกว่า เงินที่จะต้องจ่าย(ยังค้างชำระอยู่)
