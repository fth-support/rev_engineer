Private Sub W_CHKxTenderAllowPoint(ByVal pcNet As Double, Optional ByVal ptTenderCode As String)
'______________________________________
'   Call:
'   Cmt: '*Ao 2012/08/01
'______________________________________
Dim cTemp As Double
Dim tSql As String
Dim orsTemp As ADODB.Recordset
    On Error GoTo Err_Handler
    
    Select Case SP_VALnText2Double(tVB_TransactionSub)
        Case tEN_TrnReturn, tEN_TrnOtherDisbursement, tEN_TrnReturnTaxInc, tEN_TrnReturnManualTax
            Select Case UCase(ptTenderCode)
                Case UCase("T002"), UCase("T003"), UCase("T017")
                    If UCase(tVB_CrdStaBPReturn) = UCase("Y") Then
                        cVB_CNTenderAmtAlwPoint = cVB_CNTenderAmtAlwPoint + pcNet
                    End If
                Case Else
                    If aVB_TenderMnu(nVB_CurTenderSeqNo).StaBPReturn Then
                        cVB_CNTenderAmtAlwPoint = cVB_CNTenderAmtAlwPoint + pcNet
                    End If
            End Select
            
        Case Else
                Select Case UCase(ptTenderCode)
                    Case UCase("T002"), UCase("T003"), UCase("T017")
                        If UCase(tVB_CrdStaBPSale) = UCase("Y") Then
                            cVB_CNTenderAmtAlwPoint = cVB_CNTenderAmtAlwPoint + pcNet
                        End If
                    Case Else
                        If aVB_TenderMnu(nVB_CurTenderSeqNo).StaPoint Then
                            cVB_CNTenderAmtAlwPoint = cVB_CNTenderAmtAlwPoint + pcNet
                        End If
                End Select
    End Select
    
    Call SP_DATxRsNothing(orsTemp)
Exit Sub
Err_Handler:
    cVB_CNTenderAmtAlwPoint = 0
    Call SP_MSGxShowError(Err.Number, Err.Description)
End Sub

