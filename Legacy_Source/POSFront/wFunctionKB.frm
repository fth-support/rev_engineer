                Select Case SP_CHKnDDPMallCard(.TextMatrix(nRow, .ColIndex("FNSdtSeqNo")), nEN_Disc05LnDisc, tVB_Running, tVB_CNTerminalNum, tUT_SaleDate)
                    Case 0 'Not Allow
