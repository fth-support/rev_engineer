                '--------------------------------------------------------------------------------
                cAmt = SP_FMTcCurPoint(SP_FEDvChkNumeric(orsTemp, "FCScdAmt"), True, False)
                 If cAmt <> 0 Then '*KT 51-10-27 V 3.0.143/V 3.0.200
                    Call W_AddxDataPrintClosingOther(cQty, tName, SP_FMTcCurPoint(cAmt, True, False), pnSeq, pbSal, pbCloseTmn, ptCloRunning)
                    pnSeq = pnSeq + 1
                End If
                
                'Out
                cQty = SP_FEDvChkNumeric(orsTemp, "FCNumOut")
