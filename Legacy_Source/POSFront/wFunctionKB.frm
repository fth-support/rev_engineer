Public Function W_PRCbMaxQtyMemberPriceBySKU(ByVal ptSKUCode$, ByVal pcQty As Double, ByVal pcMaxQtyMemberPrice As Double, Optional ByRef pcQtyMemberPrice As Double = 0) As Boolean
'---------------------------------------
'Ret: True : ผ่าน False ไม่ผ่าน
'Cmt: ตรวจสอบ Limitการขายสินค้าที่อาจเป็น Member Price
'*KT 52-04-08 Max Qty Member Price
'*KT 52-09-08 Member Price + Consignment
'--------------------------------------
    Dim tSql$
    Dim tWhr$
    Dim orsTemp As ADODB.Recordset
    Dim cQty As Double
On Error GoTo ErrHandle
    W_PRCbMaxQtyMemberPriceBySKU = False
    tWhr = " WHERE " & tVB_CNWheBill
    tWhr = tWhr & vbCrLf & " AND FTSkuCode = '" & ptSKUCode & "'"
    tWhr = tWhr & vbCrLf & " AND ISNULL(FTSdtCancelFlag,'0') <> '1'"
    tWhr = tWhr & vbCrLf & " AND FTSdtStaRfd = 'Y'"
    tWhr = tWhr & vbCrLf & " AND ISNULL(FTSdtEventMemPrice,'') <> ''"
    cQty = CDbl(Val(Format(SP_SQLtFunction("SUM", "FCSdtQty", tVB_CNTblDT, tWhr))))
    pcQtyMemberPrice = cQty + pcQty
    If pcQtyMemberPrice > CDbl(pcMaxQtyMemberPrice) Then
         W_PRCbMaxQtyMemberPriceBySKU = False
    Else
         W_PRCbMaxQtyMemberPriceBySKU = True
    End If
    
    Call SP_DATxRsNothing(orsTemp)
    Exit Function
ErrHandle:
    W_PRCbMaxQtyMemberPriceBySKU = False
    Call SP_DATxRsNothing(orsTemp)
End Function

