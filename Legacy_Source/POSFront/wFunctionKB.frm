Public Sub W_KBRetBill()
'----------------------------------------------------------
'   Call:
'   Cmt:    retrive bill from holding (Recall)
'----------------------------------------------------------
    Dim bAccept As Boolean
    Dim orsTemp As ADODB.Recordset
    Dim tSql$, tWh$, tTable$
    Dim tWhr$
    Dim nSeqNo As Long
    Dim nRow As Long
On Error GoTo ErrHandle
    If bVB_TrainingMode Then
        Call SP_MSGnShowing("tms_CN005060", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If
    '_________________________________
    '*Ao 51-07-08
    If W_DEFbReturn Then    'การคืนแบบไม่มีเงื่อนไข ใช้ RetBill ไม่ได้
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If
    '_________________________________
    bAccept = W_CheckLevelPass("W_KBRetBill")
    If Not bAccept Then     'level ไม่ผ่าน
        Call SP_MSGnShowing("tms_CN005107", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub
    End If
    
    tVB_CNMnuCurrent = "1803"
    If Not SP_USRbMnuAccept(nEN_Usr2AthRead, tVB_CNMnuCurrent) Then
'         DoEvents '*KT 53-01-14 DoEvents
         If tVB_CNUserAlwC = "" Then
            Call SP_DATxRsNothing(orsTemp)
             Exit Sub
         End If
     End If

    
    'level ok, process
    nRow = wMain.ogdForm.Aggregate(flexSTMax, wMain.ogdForm.FixedRows, wMain.ogdForm.ColIndex("FNSdtSeqNo"), wMain.ogdForm.rows - 1, wMain.ogdForm.ColIndex("FNSdtSeqNo"))
    If nRow > 0 Then '*KT 53-01-14 DoEvents  If nRow > 1 Then >>>> If nRow > 0 Then
        Call SP_MSGnShowing("tms_CN005109", nCS_Warning)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub     'กำลังทำรายการอื่นอยู่ทำไม่ได้
    End If
    
    'refund can not hold bill
    If SP_VALnText2Double(tVB_Transaction) = tEN_TrnReturn Then     'สถานะเอกสาร 3 : ขายปกติ 4 : คืน
        Call SP_MSGnShowing("tms_CN005115", nCS_Information)
        Call SP_DATxRsNothing(orsTemp)
        Exit Sub         'if no item in grid, nothing to do
    End If
    
    'เรียกฟอร์ม Brows
    Call W_BrowsHoldHD               'get tUT_BrwRet  เช่น 1;0107001000001;...
    
    If Not bVB_Recall Then Call SP_DATxRsNothing(orsTemp): Exit Sub
    
    tTable = tVB_CNTblHD
    tSql = "STP_CNxSQLSelHoldHDByWhr @ptTmnNum ='" & tVB_TerminalRecall & "',@ptRunning ='" & tVB_TransNoRecall & "',@ptTransType ='" & tVB_TransTypeRecall & "',@ptTransDate ='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub  'PH 2.0.0 ติดต่อฐานข้อมูล server ตลอด
    If (orsTemp.BOF And orsTemp.EOF) Then Call SP_DATxRsNothing(orsTemp): Exit Sub
    Call W_DupTblBtwSleUpdHoldHD(orsTemp, tTable)
    
    tVB_CstID = UT_tChkFieldString(orsTemp, "FTCstCode")
    tVB_SalemanID = UT_tChkFieldString(orsTemp, "FTSpnCode")
    xVB_CNMemberP.ID = SP_FEDtChkString(orsTemp, "FTMemberPriceID")
    '*Ao 2011/01/20      CommSheet ML-UAT-PRV-030-After Recall preview transaction, price is not preview.xls
    bVB_CNTrStaRegPreviewDay = False
    Call SP_INIxSwitchModePreviewDay(False)
    Call SP_INIxClearVarPrv
    tVB_CNPreDayIDReg = SP_FEDtChkString(orsTemp, "FTPrvCardID")
    If tVB_CNPreDayIDReg <> "" Then
        'อยู่ในช่วง Preview Day
        If SP_CHKbPeriodPreDay Then
            If SP_FEDtChkString(orsTemp, "FTPrvCardType") = "" Then
                nVB_RegPreType = 0
            Else
                nVB_RegPreType = SP_FEDtChkString(orsTemp, "FTPrvCardType")
            End If
            bVB_CNTrStaRegPreviewDay = True
            Call SP_INIxSwitchModePreviewDay(True)
            wMain.olaTransName.Caption = "Preview/" & tVB_TransName
            Select Case nVB_RegPreType
                Case 1 'Credit Card
                    Call SP_PRCxFindCrdByAccNum(tVB_CNPreDayIDReg)
                    Call SP_GETxRecDataCrdPrv
                Case 2 'Member Card
                    Call SP_PRCxFindMallCardRangByID(tVB_CNPreDayIDReg)
                    Call SP_GETxRecDataMallPrv
                Case 3 'None Card
                    Call SP_PRCxFindNonCardRangByID(tVB_CNPreDayIDReg)
                    Call SP_GETxRecDataMallPrv
            End Select
        End If
    End If
    '_____________________________________________________________________
    '*KT 52-08-14 member price
    '-------------------------------------------------------------------------------------------------------
    If xVB_CNMemberP.ID <> "" Then
        bVB_CNMemberPrice = True
        tSql = "SELECT Top 1 FTMcdName,FTMcdSurName,FTMcdCode,FTMcdTel,FDMcdExpDate,FTMcdSta  "
        tSql = tSql & vbCrLf & " FROM TCNMMallCard"
        tSql = tSql & vbCrLf & " WHERE FTMcdCode='" & xVB_CNMemberP.ID & "'"
        If SP_SQLvExecute(tSql, orsTemp, ocnMember, , , , True) = 0 Then
            If Not (orsTemp.BOF And orsTemp.EOF) Then
                xVB_CNMemberP.FName = SP_FEDtChkString(orsTemp, "FTMcdName")
                xVB_CNMemberP.LName = SP_FEDtChkString(orsTemp, "FTMcdSurName")
                xVB_CNMemberP.Tel = SP_FEDtChkString(orsTemp, "FTMcdTel")
                xVB_CNMemberP.Expire = Date
                xVB_CNMemberP.Status = SP_FEDtChkString(orsTemp, "FTMcdSta")
                tSql = "STP_PRCxFindMallCardByIDEx @ptAccNum= '" & xVB_CNMemberP.ID & "'"
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                        xVB_CNMemberP.MallCardType = SP_FEDtChkString(orsTemp, "FTMcdCardType")
                        xVB_CNMemberP.MallCardExpire = SP_FEDdChkDate(orsTemp, "FDMcdEndDate")
                        xVB_CNMemberP.MallCardMemberPrice = SP_FEDtChkString(orsTemp, "FTMcdAlwPrice")
                        xVB_CNMemberP.MallCardMemberPoint = SP_FEDtChkString(orsTemp, "FTMcdAlwPoint")
                    End If
                End If
                 wMain.ostForm.Panels(2).Text = "Mem:" & xVB_CNMemberP.ID
            Else
                xVB_CNMemberP.FName = "New Member"
                xVB_CNMemberP.LName = ""
                xVB_CNMemberP.Tel = ""
                xVB_CNMemberP.Expire = Date
                xVB_CNMemberP.Status = ""
                tSql = "STP_PRCxFindMallCardByIDEx @ptAccNum= '" & xVB_CNMemberP.ID & "'"
                If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                    If Not (orsTemp.BOF And orsTemp.EOF) Then
                        xVB_CNMemberP.MallCardType = SP_FEDtChkString(orsTemp, "FTMcdCardType")
                        xVB_CNMemberP.MallCardExpire = SP_FEDdChkDate(orsTemp, "FDMcdEndDate")
                        xVB_CNMemberP.MallCardMemberPrice = SP_FEDtChkString(orsTemp, "FTMcdAlwPrice")
                        xVB_CNMemberP.MallCardMemberPoint = SP_FEDtChkString(orsTemp, "FTMcdAlwPoint")
                    End If
                End If
                 wMain.ostForm.Panels(2).Text = "Mem:" & xVB_CNMemberP.ID
            End If
        Else
            xVB_CNMemberP.FName = "New Member"
            xVB_CNMemberP.LName = ""
            xVB_CNMemberP.Tel = ""
            xVB_CNMemberP.Expire = Date
            xVB_CNMemberP.Status = ""
            tSql = "STP_PRCxFindMallCardByIDEx @ptAccNum= '" & xVB_CNMemberP.ID & "'"
            If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True, True) = 0 Then 'read master
                If Not (orsTemp.BOF And orsTemp.EOF) Then
                    xVB_CNMemberP.MallCardType = SP_FEDtChkString(orsTemp, "FTMcdCardType")
                    xVB_CNMemberP.MallCardExpire = SP_FEDdChkDate(orsTemp, "FDMcdEndDate")
                    xVB_CNMemberP.MallCardMemberPrice = SP_FEDtChkString(orsTemp, "FTMcdAlwPrice")
                    xVB_CNMemberP.MallCardMemberPoint = SP_FEDtChkString(orsTemp, "FTMcdAlwPoint")
                End If
            End If
             wMain.ostForm.Panels(2).Text = "Mem:" & xVB_CNMemberP.ID
        End If
    Else
        bVB_CNMemberPrice = False
        xVB_CNMemberP.ID = ""
        xVB_CNMemberP.FName = ""
        xVB_CNMemberP.LName = ""
        xVB_CNMemberP.Tel = ""
        xVB_CNMemberP.Expire = Date
        xVB_CNMemberP.Status = ""
        xVB_CNMemberP.MallCardType = ""
        xVB_CNMemberP.MallCardExpire = Date
        xVB_CNMemberP.MallCardMemberPrice = "1"
        wMain.ostForm.Panels(2).Text = "Ready..."
    End If
    '-------------------------------------------------------------------------------------------------------------

    'ก่อนการ Insert data to dt ให้ทำการลบ dt ก่อนเพื่อความแน่ใจ
    tWhr = " WHERE  FTTmnNum=''" & tVB_CNTerminalNum & "'' AND FTShdTransNo=''" & tVB_Running & "''"
    tWhr = tWhr & vbCrLf & " AND  FTShdTransType=''" & tVB_Transaction & "'' AND FDShdTransDate=''" & tUT_SaleDate & "''"
    tSql = "STP_CNxSQLFunctionDel @ptTable = '" & tVB_CNTblDT & "',@ptWhere = '" & tWhr & "'"
    Call SP_SQLbExecute(tSql)
    
    'insert to TSDTXXX
    tTable = tVB_CNTblDT
    tSql = "STP_CNxSQLSelHoldDTByWhr @ptTmnNum ='" & tVB_TerminalRecall & "',@ptRunning ='" & tVB_TransNoRecall & "',@ptTransType ='" & tVB_TransTypeRecall & "',@ptTransDate ='" & tUT_SaleDate & "'"
    If SP_SQLvExecute(tSql, orsTemp, oDB.ocnOnLine, , , , , True) <> 0 Then Call SP_DATxRsNothing(orsTemp): Exit Sub  'PH 2.0.0 ติดต่อฐานข้อมูล server ตลอด
    Do While Not orsTemp.EOF
        Call W_DupTblBtwSleNHold(orsTemp, tTable, nSeqNo, False, , , , , 2)
        orsTemp.MoveNext
