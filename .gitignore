# Visual Basic 6.0 (VB6)

# ไฟล์ที่ได้จากการ Compile (Build artifacts)
*.exe
*.dll
*.ocx
*.obj
*.exp
*.lib
*.pdb

# ไฟล์ Temporary และ Log
*.tmp
*.log

# ไฟล์สถานะของ IDE (ไม่จำเป็นต้องแชร์)
*.vbw

# ไฟล์อื่นๆ
*.scc
*.user

# Database backups — POSSDB.bak (1.2GB) ไม่ขึ้น git, ใช้ schema/table-detail แทน
*.bak
legacy_source/POSSDB.bak

# DB data exports (real transaction data + PII) — keep LOCAL, never push to public repo
db_export/
legacy_source/pos_export/
# Crystal report files (may embed saved customer data) — keep LOCAL until verified
legacy_source/Reports/
# Internal user manual (large binary; knowledge captured in POS_Transaction_Model.md)
legacy_source/*.docx

# Python
__pycache__/
*.pyc
